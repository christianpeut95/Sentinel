@page
@model Surveillance_MVP.Pages.Cases.DeleteModel
@using Surveillance_MVP.Models

@{
    ViewData["Title"] = "Delete Case";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Cases</a></li>
        <li class="breadcrumb-item"><a asp-page="./Details" asp-route-id="@Model.Case.Id">@Model.Case.FriendlyId</a></li>
        <li class="breadcrumb-item active" aria-current="page">Delete</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="text-danger"><i class="bi bi-trash me-2"></i>Delete Case @Model.Case.FriendlyId</h2>
</div>

<div class="alert alert-danger" role="alert">
    <h5 class="alert-heading">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>Warning: This action cannot be undone!
    </h5>
    <p>Are you sure you want to delete this case? This will permanently remove all case data from the system.</p>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Case Details</h5>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Case ID</dt>
            <dd class="col-sm-8"><strong>@Model.Case.FriendlyId</strong></dd>

            <dt class="col-sm-4">Patient</dt>
            <dd class="col-sm-8">
                @if (Model.Case.Patient != null)
                {
                    @Model.Case.Patient.GivenName @Model.Case.Patient.FamilyName
                }
                else
                {
                    <span class="text-muted">Unknown</span>
                }
            </dd>

            <dt class="col-sm-4">Date of Onset</dt>
            <dd class="col-sm-8">@(Model.Case.DateOfOnset?.ToString("dd MMMM yyyy") ?? "-")</dd>

            <dt class="col-sm-4">Date of Notification</dt>
            <dd class="col-sm-8">@(Model.Case.DateOfNotification?.ToString("dd MMMM yyyy") ?? "-")</dd>

            <dt class="col-sm-4">Confirmation Status</dt>
            <dd class="col-sm-8">@(Model.Case.ConfirmationStatus?.Name ?? "-")</dd>
        </dl>
    </div>
</div>

<form method="post" class="mt-3">
    <input type="hidden" asp-for="Case.Id" />
    <div class="d-flex justify-content-between">
        <a asp-page="./Details" asp-route-id="@Model.Case.Id" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Cancel
        </a>
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>Delete Case
        </button>
    </div>
</form>
