@page
@model Surveillance_MVP.Pages.Cases.SearchModel
@using Surveillance_MVP.Models

@{
    ViewData["Title"] = "Search Cases";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<style>
    .search-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 1rem 1.5rem;
        border-radius: 8px;
        margin-bottom: 1rem;
    }
    
    .search-form {
        background: white;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1rem;
    }
    
    .search-form .form-label {
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 0.25rem;
    }
    
    .search-form .form-control, .search-form .form-select {
        font-size: 0.9rem;
        padding: 0.375rem 0.75rem;
    }
    
    .search-form .row {
        row-gap: 0.75rem;
    }
    
    .table-compact {
        font-size: 0.9rem;
    }
    
    .table-compact th, .table-compact td {
        padding: 0.5rem;
        vertical-align: middle;
    }
</style>

<nav aria-label="breadcrumb" class="mb-2">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Cases</a></li>
        <li class="breadcrumb-item active" aria-current="page">Search</li>
    </ol>
</nav>

<div class="search-header">
    <div class="d-flex justify-content-between align-items-center">
        <h3 class="mb-0"><i class="bi bi-search me-2"></i>Search Cases</h3>
        <a asp-page="./Index" class="btn btn-light btn-sm">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<!-- Search Form -->
<div class="search-form">
    <form method="get">
        <div class="row">
            <div class="col-md-3">
                <label asp-for="CaseId" class="form-label">Case ID</label>
                <input asp-for="CaseId" class="form-control form-control-sm" placeholder="C-2024-00001" />
            </div>
            <div class="col-md-3">
                <label asp-for="PatientName" class="form-label">Patient Name</label>
                <input asp-for="PatientName" class="form-control form-control-sm" placeholder="First Last" />
            </div>
            <div class="col-md-3">
                <label asp-for="DiseaseId" class="form-label">Disease</label>
                <select asp-for="DiseaseId" class="form-select form-select-sm disease-select" asp-items="Model.Diseases">
                    <option value="">-- All --</option>
                </select>
            </div>
            <div class="col-md-3">
                <label asp-for="ConfirmationStatusId" class="form-label">Status</label>
                <select asp-for="ConfirmationStatusId" class="form-select form-select-sm" asp-items="Model.ConfirmationStatuses">
                    <option value="">-- All --</option>
                </select>
            </div>
        </div>

        <div class="row mt-2">
            <div class="col-md-3">
                <label asp-for="OnsetDateFrom" class="form-label">Onset From</label>
                <input asp-for="OnsetDateFrom" class="form-control form-control-sm" type="date" />
            </div>
            <div class="col-md-3">
                <label asp-for="OnsetDateTo" class="form-label">Onset To</label>
                <input asp-for="OnsetDateTo" class="form-control form-control-sm" type="date" />
            </div>
            <div class="col-md-3">
                <label asp-for="NotificationDateFrom" class="form-label">Notified From</label>
                <input asp-for="NotificationDateFrom" class="form-control form-control-sm" type="date" />
            </div>
            <div class="col-md-3">
                <label asp-for="NotificationDateTo" class="form-label">Notified To</label>
                <input asp-for="NotificationDateTo" class="form-control form-control-sm" type="date" />
            </div>
        </div>

        <!-- Collapsible Additional Filters -->
        <div class="mt-2">
            <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#moreFilters">
                <i class="bi bi-plus-circle me-1"></i>More Filters
            </button>
        </div>

        <div class="collapse mt-2" id="moreFilters">
            <div class="row">
                <div class="col-md-3">
                    <label asp-for="DiseaseCategoryId" class="form-label">Category</label>
                    <select asp-for="DiseaseCategoryId" class="form-select form-select-sm" asp-items="Model.DiseaseCategories">
                        <option value="">-- All --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="HasSymptoms" class="form-label">Has Symptoms</label>
                    <select asp-for="HasSymptoms" class="form-select form-select-sm">
                        <option value="">-- All --</option>
                        <option value="true">Yes</option>
                        <option value="false">No</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="HasLabResults" class="form-label">Has Lab Results</label>
                    <select asp-for="HasLabResults" class="form-select form-select-sm">
                        <option value="">-- All --</option>
                        <option value="true">Yes</option>
                        <option value="false">No</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="City" class="form-label">Suburb</label>
                    <input asp-for="City" class="form-control form-control-sm" />
                </div>
            </div>
            <div class="row mt-2">
                <div class="col-md-3">
                    <label asp-for="PostalCode" class="form-label">Postcode</label>
                    <input asp-for="PostalCode" class="form-control form-control-sm" />
                </div>
                <div class="col-md-3">
                    <label asp-for="State" class="form-label">State</label>
                    <input asp-for="State" class="form-control form-control-sm" />
                </div>
            </div>
        </div>

        <!-- Custom Fields Section -->
        @if (Model.SearchableCustomFields.Any())
        {
            <div class="mt-2">
                <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#customFieldFilters">
                    <i class="bi bi-ui-checks me-1"></i>Custom Fields (@Model.SearchableCustomFields.Count)
                </button>
            </div>

            <div class="collapse mt-2" id="customFieldFilters">
                @foreach (var category in Model.SearchableCustomFields.GroupBy(f => f.Category))
                {
                    <h6 class="small text-muted mb-2 mt-2">@category.Key</h6>
                    <div class="row">
                        @foreach (var field in category.OrderBy(f => f.DisplayOrder))
                        {
                            var fieldName = $"customfield_{field.Id}";
                            var fieldValue = Model.CustomFieldSearchValues.ContainsKey(field.Id) 
                                ? Model.CustomFieldSearchValues[field.Id] : "";

                            <div class="col-md-3">
                                <label class="form-label">@field.Label</label>

                                @switch (field.FieldType)
                                {
                                    case CustomFieldType.Text:
                                    case CustomFieldType.Email:
                                    case CustomFieldType.Phone:
                                    case CustomFieldType.TextArea:
                                        <input type="text" class="form-control form-control-sm" 
                                               name="@fieldName" value="@fieldValue" />
                                        break;

                                    case CustomFieldType.Number:
                                        <input type="number" class="form-control form-control-sm" 
                                               name="@fieldName" value="@fieldValue" step="any" />
                                        break;

                                    case CustomFieldType.Date:
                                        <input type="date" class="form-control form-control-sm" 
                                               name="@fieldName" value="@fieldValue" />
                                        break;

                                    case CustomFieldType.Checkbox:
                                        <select class="form-select form-select-sm" name="@fieldName">
                                            <option value="">-- All --</option>
                                            <option value="true" selected="@(fieldValue == "true")">Yes</option>
                                            <option value="false" selected="@(fieldValue == "false")">No</option>
                                        </select>
                                        break;

                                    case CustomFieldType.Dropdown:
                                        if (field.LookupTable != null && field.LookupTable.Values != null && field.LookupTable.Values.Any())
                                        {
                                            <select class="form-select form-select-sm" name="@fieldName">
                                                <option value="">-- All --</option>
                                                @foreach (var value in field.LookupTable.Values.OrderBy(v => v.DisplayOrder))
                                                {
                                                    <option value="@value.Id" selected="@(fieldValue == value.Id.ToString())">
                                                        @value.DisplayText
                                                    </option>
                                                }
                                            </select>
                                        }
                                        break;
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }

        <!-- Action Buttons -->
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary btn-sm">
                <i class="bi bi-search me-1"></i>Search
            </button>
            <button type="submit" asp-page-handler="Clear" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-x-circle me-1"></i>Clear
            </button>
        </div>
    </form>
</div>

<!-- Results Section -->
@if (Model.HasSearched)
{
    <div class="card">
        <div class="card-header bg-light py-2">
            <div class="d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-list-check me-2"></i>Results</h6>
                <span class="badge bg-primary">@Model.TotalResults</span>
            </div>
        </div>
        <div class="card-body p-0">
            @if (Model.TotalResults == 0)
            {
                <div class="alert alert-info m-3 mb-0 py-2">
                    <i class="bi bi-info-circle me-2"></i>No cases found matching your search criteria.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-compact mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Case ID</th>
                                <th>Patient</th>
                                <th>Disease</th>
                                <th>Onset</th>
                                <th>Notified</th>
                                <th>Status</th>
                                <th class="text-center">Symp</th>
                                <th class="text-center">Labs</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var caseItem in Model.SearchResults)
                            {
                                <tr>
                                    <td>
                                        <strong><a asp-page="./Details" asp-route-id="@caseItem.Id">@caseItem.FriendlyId</a></strong>
                                    </td>
                                    <td>
                                        @if (caseItem.Patient != null)
                                        {
                                            <a asp-page="/Patients/Details" asp-route-id="@caseItem.PatientId">
                                                @caseItem.Patient.GivenName @caseItem.Patient.FamilyName
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Unknown</span>
                                        }
                                    </td>
                                    <td>
                                        @if (caseItem.Disease != null)
                                        {
                                            <span class="badge bg-secondary">@caseItem.Disease.Name</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>@(caseItem.DateOfOnset?.ToString("dd MMM") ?? "-")</td>
                                    <td>@(caseItem.DateOfNotification?.ToString("dd MMM") ?? "-")</td>
                                    <td>
                                        @if (caseItem.ConfirmationStatus != null)
                                        {
                                            <span class="badge bg-info">@caseItem.ConfirmationStatus.Name</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (caseItem.CaseSymptoms.Any())
                                        {
                                            <span class="badge bg-success">@caseItem.CaseSymptoms.Count</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (caseItem.LabResults.Any())
                                        {
                                            <span class="badge bg-primary">@caseItem.LabResults.Count</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-page="./Details" asp-route-id="@caseItem.Id" class="btn btn-outline-primary" title="View">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-page="./Edit" asp-route-id="@caseItem.Id" class="btn btn-outline-secondary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.TotalResults >= 500)
                {
                    <div class="alert alert-warning m-3 mb-0 py-2">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Note:</strong> Results limited to 500 cases. Please refine your search.
                    </div>
                }
            }
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize Select2 on disease dropdown
            $('.disease-select').select2({
                theme: 'bootstrap-5',
                placeholder: '-- Select Disease --',
                allowClear: true,
                width: '100%'
            });

            // Initialize tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });
    </script>
}
