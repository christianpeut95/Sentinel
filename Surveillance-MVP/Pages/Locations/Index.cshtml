@page
@model Surveillance_MVP.Pages.Locations.IndexModel

@{
    ViewData["Title"] = "Locations";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item active" aria-current="page">Locations</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-geo-alt-fill me-2"></i>Locations</h2>
    <div>
        <a asp-page="./Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Add Location</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm mb-3">
    <div class="card-header bg-light">
        <i class="bi bi-funnel me-2"></i>Search & Filter
    </div>
    <div class="card-body">
        <form method="get">
            <div class="row g-3">
                <div class="col-md-4">
                    <label for="searchTerm" class="form-label">Search</label>
                    <input type="text" class="form-control" id="searchTerm" name="searchTerm" value="@Model.SearchTerm" placeholder="Search by name or address..." />
                </div>
                <div class="col-md-3">
                    <label for="locationTypeId" class="form-label">Location Type</label>
                    <select class="form-select" id="locationTypeId" name="locationTypeId">
                        <option value="">All Types</option>
                        @foreach (var type in Model.LocationTypes)
                        {
                            <option value="@type.Id" selected="@(Model.LocationTypeId == type.Id)">@type.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="geocodingStatus" class="form-label">Geocoding</label>
                    <select class="form-select" id="geocodingStatus" name="geocodingStatus">
                        <option value="">All</option>
                        <option value="Success" selected="@(Model.GeocodingStatus == "Success")">Success</option>
                        <option value="Failed" selected="@(Model.GeocodingStatus == "Failed")">Failed</option>
                        <option value="Pending" selected="@(Model.GeocodingStatus == "Pending")">Pending</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search me-1"></i>Search
                    </button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i>Clear
                    </a>
                </div>
            </div>

            <div class="row g-3 mt-2">
                <div class="col-md-12">
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox" id="highRiskOnly" name="highRiskOnly" value="true" checked="@Model.HighRiskOnly" />
                        <label class="form-check-label" for="highRiskOnly">
                            <i class="bi bi-exclamation-triangle text-warning me-1"></i>High Risk Only
                        </label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox" id="activeOnly" name="activeOnly" value="true" checked="@Model.ActiveOnly" />
                        <label class="form-check-label" for="activeOnly">
                            Active Only
                        </label>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <strong>@Model.Locations.Count</strong> location(s) found
                @if (Model.PendingGeocodeCount > 0)
                {
                    <span class="ms-2">
                        <span class="badge bg-warning text-dark">@Model.PendingGeocodeCount pending geocoding</span>
                    </span>
                }
            </div>
            @if (Model.PendingGeocodeCount > 0)
            {
                <form method="post" asp-page-handler="GeocodeAll">
                    <button type="submit" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-geo me-1"></i>Geocode All Pending
                    </button>
                </form>
            }
        </div>

        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Address</th>
                        <th>Geocoding</th>
                        <th>Organization</th>
                        <th>Events</th>
                        <th>Exposures</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
@foreach (var location in Model.Locations)
{
                    <tr>
                        <td>
                            <strong>@location.Name</strong>
                            @if (location.IsHighRisk)
                            {
                                <span class="ms-1">
                                    <i class="bi bi-exclamation-triangle text-warning" title="High Risk Location"></i>
                                </span>
                            }
                        </td>
                        <td>
                            @if (location.LocationType != null)
                            {
                                <span class="badge bg-secondary">@location.LocationType.Name</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(location.Address))
                            {
                                <small class="text-muted">@location.Address</small>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (location.Latitude.HasValue && location.Longitude.HasValue)
                            {
                                <span class="badge bg-success" title="@location.Latitude, @location.Longitude">
                                    <i class="bi bi-check-circle me-1"></i>Success
                                </span>
                            }
                            else if (location.GeocodingStatus == "Failed")
                            {
                                <span class="badge bg-danger">
                                    <i class="bi bi-x-circle me-1"></i>Failed
                                </span>
                            }
                            else if (location.GeocodingStatus == "Pending")
                            {
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-hourglass-split me-1"></i>Pending
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (location.Organization != null)
                            {
                                <small>@location.Organization.Name</small>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (Model.EventCounts.ContainsKey(location.Id) && Model.EventCounts[location.Id] > 0)
                            {
                                <span class="badge bg-info">@Model.EventCounts[location.Id]</span>
                            }
                            else
                            {
                                <span class="text-muted">0</span>
                            }
                        </td>
                        <td>
                            @if (Model.ExposureCounts.ContainsKey(location.Id) && Model.ExposureCounts[location.Id] > 0)
                            {
                                <span class="badge bg-info">@Model.ExposureCounts[location.Id]</span>
                            }
                            else
                            {
                                <span class="text-muted">0</span>
                            }
                        </td>
                        <td>
                            @if (location.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm" role="group">
                                <a asp-page="./Details" asp-route-id="@location.Id" class="btn btn-outline-info" title="View Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-page="./Edit" asp-route-id="@location.Id" class="btn btn-outline-secondary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (!Model.EventCounts.ContainsKey(location.Id) && !Model.ExposureCounts.ContainsKey(location.Id))
                                {
                                    <button type="button" class="btn btn-outline-danger" onclick="confirmDelete('@location.Id', '@location.Name')" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
}
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (!Model.Locations.Any())
{
    <div class="alert alert-info mt-3">
        <i class="bi bi-info-circle me-2"></i>No locations found. <a asp-page="./Create" class="alert-link">Create your first location</a>.
    </div>
}

<form method="post" asp-page-handler="Delete" id="deleteForm">
    <input type="hidden" name="id" id="deleteId" />
</form>

@section Scripts {
<script>
    function confirmDelete(id, name) {
        if (confirm(`Are you sure you want to delete "${name}"?\n\nThis action cannot be undone.`)) {
            document.getElementById('deleteId').value = id;
            document.getElementById('deleteForm').submit();
        }
    }
</script>
}
