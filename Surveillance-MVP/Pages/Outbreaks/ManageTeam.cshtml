@page
@using Surveillance_MVP.Models
@model Surveillance_MVP.Pages.Outbreaks.ManageTeamModel
@{
    ViewData["Title"] = "Manage Team - " + Model.Outbreak.Name;
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="Index">Outbreaks</a></li>
        <li class="breadcrumb-item"><a asp-page="Details" asp-route-id="@Model.Outbreak.Id">@Model.Outbreak.Name</a></li>
        <li class="breadcrumb-item active" aria-current="page">Manage Team</li>
    </ol>
</nav>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="mb-4">
    <h2><i class="bi bi-people-fill me-2"></i>Manage Investigation Team</h2>
    <p class="text-muted">Add and manage team members for <strong>@Model.Outbreak.Name</strong></p>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-light">
                <h5 class="mb-0">Current Team Members (@Model.TeamMembers.Count)</h5>
            </div>
            <div class="card-body">
                @if (Model.TeamMembers.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>User</th>
                                    <th>Role</th>
                                    <th>Assigned</th>
                                    <th>Assigned By</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var member in Model.TeamMembers)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-2" 
                                                     style="width: 36px; height: 36px;">
                                                    <i class="bi bi-person-fill text-primary"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-semibold">@member.User?.UserName</div>
                                                    <small class="text-muted">@member.User?.Email</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            @switch (member.Role)
                                            {
                                                case OutbreakRole.LeadInvestigator:
                                                    <span class="badge bg-danger">Lead Investigator</span>
                                                    break;
                                                case OutbreakRole.Investigator:
                                                    <span class="badge bg-primary">Investigator</span>
                                                    break;
                                                case OutbreakRole.DataManager:
                                                    <span class="badge bg-info">Data Manager</span>
                                                    break;
                                                case OutbreakRole.LabLiaison:
                                                    <span class="badge bg-warning text-dark">Lab Liaison</span>
                                                    break;
                                                case OutbreakRole.CommunicationsOfficer:
                                                    <span class="badge bg-success">Communications</span>
                                                    break;
                                                case OutbreakRole.TeamMember:
                                                    <span class="badge bg-secondary">Team Member</span>
                                                    break;
                                            }
                                        </td>
                                        <td>
                                            <small>@member.AssignedDate.ToString("MMM d, yyyy")</small>
                                        </td>
                                        <td>
                                            <small class="text-muted">
                                                @if (!string.IsNullOrEmpty(member.AssignedBy))
                                                {
                                                    var assignedByUser = await Context.Users.FindAsync(member.AssignedBy);
                                                    @(assignedByUser?.UserName ?? "System")
                                                }
                                                else
                                                {
                                                    <text>System</text>
                                                }
                                            </small>
                                        </td>
                                        <td>
                                            <form method="post" asp-page-handler="RemoveMember" asp-route-id="@Model.Outbreak.Id" asp-route-memberId="@member.Id" 
                                                  onsubmit="return confirm('Remove @member.User?.UserName from the team?');" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-person-dash"></i> Remove
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="bi bi-people display-1 text-muted"></i>
                        <p class="text-muted mt-3">No team members assigned yet.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-person-plus me-2"></i>Add Team Member</h5>
            </div>
            <div class="card-body">
                @if (Model.AvailableUsers.Any())
                {
                    <form method="post" asp-page-handler="AddMember" asp-route-id="@Model.Outbreak.Id">
                        <div class="mb-3">
                            <label asp-for="SelectedUserId" class="form-label">User</label>
                            <select asp-for="SelectedUserId" class="form-select" required>
                                <option value="">-- Select User --</option>
                                @foreach (var user in Model.AvailableUsers)
                                {
                                    <option value="@user.Id">@user.UserName (@user.Email)</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SelectedRole" class="form-label">Role</label>
                            <select asp-for="SelectedRole" class="form-select" required>
                                <option value="@OutbreakRole.LeadInvestigator">Lead Investigator</option>
                                <option value="@OutbreakRole.Investigator" selected>Investigator</option>
                                <option value="@OutbreakRole.DataManager">Data Manager</option>
                                <option value="@OutbreakRole.LabLiaison">Lab Liaison</option>
                                <option value="@OutbreakRole.CommunicationsOfficer">Communications Officer</option>
                                <option value="@OutbreakRole.TeamMember">Team Member</option>
                            </select>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-person-plus-fill me-1"></i>Add to Team
                            </button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle me-2"></i>All available users have been assigned to the team.
                    </div>
                }
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header bg-light">
                <h6 class="mb-0">Team Roles</h6>
            </div>
            <div class="card-body small">
                <p class="mb-2"><span class="badge bg-danger">Lead Investigator</span></p>
                <p class="small text-muted mb-3">Overall responsibility for the investigation</p>
                
                <p class="mb-2"><span class="badge bg-primary">Investigator</span></p>
                <p class="small text-muted mb-3">Active field investigation and case follow-up</p>
                
                <p class="mb-2"><span class="badge bg-info">Data Manager</span></p>
                <p class="small text-muted mb-3">Data entry, analysis, and reporting</p>
                
                <p class="mb-2"><span class="badge bg-warning text-dark">Lab Liaison</span></p>
                <p class="small text-muted mb-3">Coordinate laboratory testing and results</p>
                
                <p class="mb-2"><span class="badge bg-success">Communications</span></p>
                <p class="small text-muted mb-3">Public health messaging and stakeholder communication</p>
                
                <p class="mb-2"><span class="badge bg-secondary">Team Member</span></p>
                <p class="small text-muted mb-0">General support role</p>
            </div>
        </div>

        <div class="mt-3">
            <a asp-page="Details" asp-route-id="@Model.Outbreak.Id" class="btn btn-secondary w-100">
                <i class="bi bi-arrow-left me-1"></i>Back to Outbreak Details
            </a>
        </div>
    </div>
</div>

@inject ApplicationDbContext Context
