@page
@using Surveillance_MVP.Models
@model Surveillance_MVP.Pages.Outbreaks.IndexModel
@{
    ViewData["Title"] = "Outbreak Management";
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item active" aria-current="page">Outbreaks</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2><i class="bi bi-exclamation-triangle text-danger me-2"></i>Outbreak Management</h2>
        <p class="text-muted">Manage and investigate disease outbreaks</p>
    </div>
    <div>
        <a asp-page="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Declare New Outbreak
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Active Outbreaks</h5>
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="showInactive" 
                   @(Model.ShowInactive ? "checked" : "")
                   onchange="window.location.href='?showInactive=' + this.checked">
            <label class="form-check-label" for="showInactive">
                Show Inactive
            </label>
        </div>
    </div>
    <div class="card-body">
        @if (!Model.Outbreaks.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox display-1 text-muted"></i>
                <p class="text-muted mt-3">No outbreaks found</p>
                <a asp-page="Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>Declare First Outbreak
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Status</th>
                            <th>Name</th>
                            <th>Disease</th>
                            <th>Location/Event</th>
                            <th>Start Date</th>
                            <th>Cases</th>
                            <th>Contacts</th>
                            <th>Lead Investigator</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var outbreak in Model.Outbreaks)
                        {
                            <tr>
                                <td>
                                    @switch (outbreak.Status)
                                    {
                                        case OutbreakStatus.Active:
                                            <span class="badge bg-danger">Active</span>
                                            break;
                                        case OutbreakStatus.Monitoring:
                                            <span class="badge bg-warning">Monitoring</span>
                                            break;
                                        case OutbreakStatus.Resolved:
                                            <span class="badge bg-success">Resolved</span>
                                            break;
                                        case OutbreakStatus.Closed:
                                            <span class="badge bg-secondary">Closed</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <strong>@outbreak.Name</strong>
                                </td>
                                <td>@outbreak.PrimaryDisease?.Name</td>
                                <td>
                                    @if (outbreak.PrimaryLocation != null)
                                    {
                                        <span><i class="bi bi-geo-alt text-primary me-1"></i>@outbreak.PrimaryLocation.Name</span>
                                    }
                                    else if (outbreak.PrimaryEvent != null)
                                    {
                                        <span><i class="bi bi-calendar-event text-primary me-1"></i>@outbreak.PrimaryEvent.Name</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>@outbreak.StartDate.ToString("MMM d, yyyy")</td>
                                <td>
                                    <span class="badge bg-primary">0</span>
                                </td>
                                <td>
                                    <span class="badge bg-info">0</span>
                                </td>
                                <td>@outbreak.LeadInvestigator?.UserName</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-page="Details" asp-route-id="@outbreak.Id" class="btn btn-outline-primary" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-page="Edit" asp-route-id="@outbreak.Id" class="btn btn-outline-secondary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Auto-refresh every 60 seconds for active outbreaks
        setTimeout(function() {
            location.reload();
        }, 60000);
    </script>
}
