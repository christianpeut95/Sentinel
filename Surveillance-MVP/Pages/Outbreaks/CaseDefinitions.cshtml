</div>

<div class="mt-3">
    <a asp-page="Details" asp-route-id="@Model.Outbreak.Id" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Outbreak
    </a>
</div>

<!-- Case Definition Modal -->
<div class="modal fade" id="definitionModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" asp-page-handler="SaveDefinition" asp-route-id="@Model.Outbreak.Id" id="definitionForm">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Case Definition</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="EditingDefinitionId" id="editingDefinitionId">
                    <input type="hidden" name="Definition.Classification" id="definitionClassification">
                    
                    <div class="mb-3">
                        <label class="form-label">Definition Name <span class="text-danger">*</span></label>
                        <input type="text" name="Definition.DefinitionName" class="form-control" id="definitionName" required 
                               placeholder="e.g., Gastroenteritis Outbreak Definition">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Definition Text</label>
                        <textarea name="Definition.DefinitionText" class="form-control" id="definitionText" rows="5" 
                                  placeholder="Describe the criteria for this classification..."></textarea>
                        <small class="text-muted">Provide a clear description of what constitutes this classification.</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Specific Criteria (Optional)</label>
                        <textarea name="Definition.CriteriaJson" class="form-control" id="criteriaJson" rows="4"
                                  placeholder="Enter structured criteria in JSON format or leave blank"></textarea>
                        <small class="text-muted">Define specific measurable criteria for classification (optional).</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Notes</label>
                        <textarea name="Definition.Notes" class="form-control" id="definitionNotes" rows="2" 
                                  placeholder="Additional notes or references..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i>Save Definition
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Serialize only the needed properties to avoid circular reference
        const definitions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.Definitions.Select(d => new {
                d.Id,
                d.Classification,
                d.DefinitionName,
                d.DefinitionText,
                d.CriteriaJson,
                d.Notes,
                d.Version
            })
        ));
        
        function openDefinitionModal(classification, definitionId) {
            const modal = new bootstrap.Modal(document.getElementById('definitionModal'));
            const classificationNames = {
                1: 'Confirmed',
                2: 'Probable',
                3: 'Suspect',
                4: 'Not a Case'
            };
            
            const form = document.getElementById('definitionForm');
            form.reset();
            
            document.getElementById('modalTitle').textContent = 
                (definitionId ? 'Edit ' : 'Create ') + classificationNames[classification] + ' Case Definition';
            document.getElementById('definitionClassification').value = classification;
            document.getElementById('editingDefinitionId').value = definitionId || '';
            
            // Load existing definition data if editing
            if (definitionId) {
                const definition = definitions.find(d => d.Id === definitionId);
                if (definition) {
                    document.getElementById('definitionName').value = definition.DefinitionName || '';
                    document.getElementById('definitionText').value = definition.DefinitionText || '';
                    document.getElementById('criteriaJson').value = definition.CriteriaJson === '{}' ? '' : (definition.CriteriaJson || '');
                    document.getElementById('definitionNotes').value = definition.Notes || '';
                }
            }
            
            modal.show();
        }
    </script>
}


