        </div>
    </div>

    <!-- Not a Case -->
    <div class="col-lg-6">
        <div class="card border-light h-100">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-x-circle-fill me-2"></i>Not a Case</h6>
