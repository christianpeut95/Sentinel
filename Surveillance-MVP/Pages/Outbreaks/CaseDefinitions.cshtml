@page
@using Surveillance_MVP.Models
@model Surveillance_MVP.Pages.Outbreaks.CaseDefinitionsModel
@{
    ViewData["Title"] = "Case Definitions - " + Model.Outbreak.Name;
    
    // Pre-calculate history lists to avoid nested code blocks
    var confirmedHistory = Model.Definitions.Where(d => d.Classification == CaseClassification.Confirmed && !d.IsActive).ToList();
    var probableHistory = Model.Definitions.Where(d => d.Classification == CaseClassification.Probable && !d.IsActive).ToList();
    var suspectHistory = Model.Definitions.Where(d => d.Classification == CaseClassification.Suspect && !d.IsActive).ToList();
    var notacaseHistory = Model.Definitions.Where(d => d.Classification == CaseClassification.NotACase && !d.IsActive).ToList();
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="Index">Outbreaks</a></li>
        <li class="breadcrumb-item"><a asp-page="Details" asp-route-id="@Model.Outbreak.Id">@Model.Outbreak.Name</a></li>
        <li class="breadcrumb-item active" aria-current="page">Case Definitions</li>
    </ol>
</nav>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="mb-4">
    <h2><i class="bi bi-clipboard2-check me-2"></i>Case Definitions</h2>
    <p class="text-muted">Define criteria for classifying cases in <strong>@Model.Outbreak.Name</strong></p>
</div>

<!-- Active Definitions Overview -->
<div class="row g-3 mb-4">
    <!-- Confirmed -->
    <div class="col-lg-6">
        <div class="card border-danger h-100">
            <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-check-circle-fill me-2"></i>Confirmed Case</h6>
                <button type="button" class="btn btn-sm btn-light" onclick="openDefinitionModal(@((int)CaseClassification.Confirmed), null)">
                    <i class="bi bi-plus"></i> Create
                </button>
            </div>
            <div class="card-body">
                @if (Model.ConfirmedDefinition != null)
                {
                    <h6>@Model.ConfirmedDefinition.DefinitionName <small class="text-muted">(v@Model.ConfirmedDefinition.Version)</small></h6>
                    @if (!string.IsNullOrEmpty(Model.ConfirmedDefinition.DefinitionText))
                    {
                        <p class="mb-0">@Model.ConfirmedDefinition.DefinitionText</p>
                    }
                    <div class="mt-3">
                        <button type="button" class="btn btn-sm btn-outline-primary" 
                                onclick="openDefinitionModal(@((int)CaseClassification.Confirmed), @Model.ConfirmedDefinition.Id)">
                            <i class="bi bi-pencil"></i> Edit
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#confirmedHistory">
                            <i class="bi bi-clock-history"></i> History
                        </button>
                    </div>
                    
                    @if (confirmedHistory.Any())
                    {
                        <div class="collapse mt-3" id="confirmedHistory">
                            <h6 class="text-muted">Previous Versions</h6>
                            <ul class="list-group list-group-sm">
                                @foreach (var def in confirmedHistory)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <small><strong>v@def.Version:</strong> @def.DefinitionName</small>
                                            <br>
                                            <small class="text-muted">Effective: @def.EffectiveDate.ToString("MMM d, yyyy")</small>
                                        </div>
                                        <form method="post" asp-page-handler="ActivateDefinition" asp-route-id="@Model.Outbreak.Id" asp-route-definitionId="@def.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Reactivate">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>
                                        </form>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted mb-0">No confirmed case definition set.</p>
                    <button type="button" class="btn btn-sm btn-danger mt-2" onclick="openDefinitionModal(@((int)CaseClassification.Confirmed), null)">
                        <i class="bi bi-plus-circle"></i> Create Definition
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- Probable -->
