

@page
@model Surveillance_MVP.Pages.Settings.IndexModel

@{
    ViewData["Title"] = "Settings";
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item active" aria-current="page">Settings</li>
    </ol>
</nav>

<div class="mb-4">
    <h2><i class="bi bi-gear me-2"></i>Settings</h2>
    <p class="text-muted">Configure and manage system settings</p>
</div>

<!-- System Configuration -->
<div class="mb-5">
    <h5 class="mb-3 fw-semibold text-secondary">System Configuration</h5>
    <div class="row g-3">
        <div class="col-lg-3 col-md-4 col-sm-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-building fs-4 text-primary me-2"></i>
                        <h6 class="card-title mb-0">Organization</h6>
                    </div>
                    <a asp-page="/Settings/Organization" class="stretched-link"></a>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-4 col-sm-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-map fs-4 text-primary me-2"></i>
                        <h6 class="card-title mb-0">Google Maps API</h6>
                    </div>
                    <a asp-page="/Settings/GoogleMaps" class="stretched-link"></a>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-4 col-sm-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-sliders fs-4 text-primary me-2"></i>
                        <h6 class="card-title mb-0">Custom Fields</h6>
                    </div>
                    <a asp-page="/Settings/CustomFields/Index" class="stretched-link"></a>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-4 col-sm-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-eye fs-4 text-primary me-2"></i>
                        <h6 class="card-title mb-0">Field Visibility</h6>
                    </div>
                    <a asp-page="/Settings/CustomFields/Visibility" class="stretched-link"></a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Disease Management -->
<div class="mb-5">
    <h5 class="mb-3 fw-semibold text-secondary">Disease Management</h5>
    <div class="row g-3">
        <div class="col-lg-3 col-md-4 col-sm-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-virus fs-4 text-primary me-2"></i>
                        <h6 class="card-title mb-0">Diseases</h6>
                    </div>
                    <a asp-page="/Settings/Diseases/Index" class="stretched-link"></a>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-4 col-sm-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-heart-pulse fs-4 text-primary me-2"></i>
                        <h6 class="card-title mb-0">Symptoms</h6>
                    </div>
                    <a asp-page="/Settings/Lookups/Symptoms" class="stretched-link"></a>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-4 col-sm-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-journal-check fs-4 text-primary me-2"></i>
                        <h6 class="card-title mb-0">Case Statuses</h6>
                    </div>
                    <a asp-page="/Settings/CaseStatuses/Index" class="stretched-link"></a>
                </div>
            </div>
        </div>
    </div>
</div>

