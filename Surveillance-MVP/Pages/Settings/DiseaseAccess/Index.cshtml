@page
@model Surveillance_MVP.Pages.Settings.DiseaseAccess.IndexModel

@{
    ViewData["Title"] = "Disease Access Control";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item active" aria-current="page">Disease Access Control</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-shield-lock me-2"></i>Disease Access Control</h2>
    <div>
        <a asp-page="./ManageRoles" class="btn btn-primary">
            <i class="bi bi-people-fill me-1"></i>Manage Role Access
        </a>
        <a asp-page="./ManageUsers" class="btn btn-success ms-2">
            <i class="bi bi-person-plus-fill me-1"></i>Manage User Access
        </a>
        <a asp-page="./ViewGrants" class="btn btn-outline-info ms-2">
            <i class="bi bi-list-check me-1"></i>View All Grants
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="alert alert-info">
    <h5><i class="bi bi-info-circle me-2"></i>About Disease Access Control</h5>
    <p class="mb-2">
        Diseases can be marked as <strong>Public</strong> (accessible to everyone) or <strong>Restricted</strong> (requires explicit permission).
    </p>
    <ul class="mb-0">
        <li><strong>Public diseases</strong> are visible to all users regardless of their role</li>
        <li><strong>Restricted diseases</strong> require role-based or user-specific access grants</li>
        <li>User-specific grants can have expiration dates for temporary access</li>
        <li>To change a disease's access level, <a asp-page="/Settings/Diseases/Edit" class="alert-link">edit the disease</a></li>
    </ul>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Disease</th>
                        <th>Category</th>
                        <th class="text-center">Access Level</th>
                        <th class="text-center">Role Grants</th>
                        <th class="text-center">User Grants</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.DiseaseSummaries.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                No active diseases found. <a asp-page="/Settings/Diseases/Create">Create a disease</a>.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var summary in Model.DiseaseSummaries)
                        {
                            <tr class="@(summary.IsRestricted ? "table-warning" : "")">
                                <td>
                                    <strong>@summary.Disease.Name</strong>
                                    @if (!string.IsNullOrEmpty(summary.Disease.Code))
                                    {
                                        <br /><small class="text-muted"><code>@summary.Disease.Code</code></small>
                                    }
                                </td>
                                <td>@(summary.Disease.DiseaseCategory?.Name ?? "Uncategorized")</td>
                                <td class="text-center">
                                    @if (summary.IsRestricted)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-lock-fill"></i> Restricted
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-unlock-fill"></i> Public
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (summary.IsRestricted && summary.RoleAccessCount > 0)
                                    {
                                        <span class="badge bg-primary">@summary.RoleAccessCount</span>
                                    }
                                    else if (summary.IsRestricted)
                                    {
                                        <span class="text-muted">0</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (summary.UserAccessCount > 0)
                                    {
                                        <span class="badge bg-info">@summary.UserAccessCount</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">0</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm" role="group">
                                        @if (summary.IsRestricted)
                                        {
                                            <a asp-page="./ManageRoles" asp-route-diseaseId="@summary.Disease.Id" class="btn btn-outline-primary" title="Manage Role Access">
                                                <i class="bi bi-people-fill"></i>
                                            </a>
                                        }
                                        <a asp-page="./ManageUsers" asp-route-diseaseId="@summary.Disease.Id" class="btn btn-outline-success" title="Manage User Access">
                                            <i class="bi bi-person-plus-fill"></i>
                                        </a>
                                        <a asp-page="/Settings/Diseases/Edit" asp-route-id="@summary.Disease.Id" class="btn btn-outline-secondary" title="Edit Disease">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-page="/Settings/Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Settings
    </a>
</div>
