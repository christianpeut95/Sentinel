@page
@using Surveillance_MVP.Models.Lookups
@model Surveillance_MVP.Pages.Settings.DiseaseAccess.ViewGrantsModel

@{
    ViewData["Title"] = "View All Grants";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Disease Access Control</a></li>
        <li class="breadcrumb-item active" aria-current="page">View All Grants</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-list-check me-2"></i>All Disease Access Grants</h2>
    <div>
        <a asp-page="./ManageRoles" class="btn btn-outline-primary">
            <i class="bi bi-people-fill me-1"></i>Manage Roles
        </a>
        <a asp-page="./ManageUsers" class="btn btn-outline-success ms-2">
            <i class="bi bi-person-plus-fill me-1"></i>Manage Users
        </a>
    </div>
</div>

<div class="alert alert-info">
    <i class="bi bi-info-circle me-2"></i>
    This page shows all diseases that have explicit role or user access grants. 
    Public diseases without any grants are not shown here.
</div>

@if (!Model.DiseaseGrants.Any())
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>
        No access grants found. Diseases are either public or no restricted diseases have been granted access yet.
    </div>
}
else
{
    @foreach (var diseaseGrant in Model.DiseaseGrants)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header @(diseaseGrant.Disease.AccessLevel == DiseaseAccessLevel.Restricted ? "bg-warning text-dark" : "bg-light")">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0">
                            <i class="bi bi-virus me-2"></i>@diseaseGrant.Disease.Name
                        </h5>
                        @if (!string.IsNullOrEmpty(diseaseGrant.Disease.Code))
                        {
                            <small><code>@diseaseGrant.Disease.Code</code></small>
                        }
                        @if (diseaseGrant.Disease.DiseaseCategory != null)
                        {
                            <small class="text-muted ms-2">| @diseaseGrant.Disease.DiseaseCategory.Name</small>
                        }
                    </div>
                    <div>
                        @if (diseaseGrant.Disease.AccessLevel == DiseaseAccessLevel.Restricted)
                        {
                            <span class="badge bg-warning text-dark">
                                <i class="bi bi-lock-fill"></i> Restricted
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success">
                                <i class="bi bi-unlock-fill"></i> Public
                            </span>
                        }
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    @* Role Grants *@
                    <div class="col-lg-6">
                        <h6 class="text-primary mb-3">
                            <i class="bi bi-people-fill me-2"></i>Role Access 
                            <span class="badge bg-primary">@diseaseGrant.RoleGrants.Count</span>
                        </h6>
                        @if (!diseaseGrant.RoleGrants.Any())
                        {
                            <p class="text-muted fst-italic">No role grants</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Role</th>
                                            <th>Granted At</th>
                                            <th>By</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var roleGrant in diseaseGrant.RoleGrants)
                                        {
                                            <tr>
                                                <td><strong>@roleGrant.RoleName</strong></td>
                                                <td>@roleGrant.GrantedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                                <td><small>@roleGrant.GrantedBy</small></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>

                    @* User Grants *@
                    <div class="col-lg-6">
                        <h6 class="text-success mb-3">
                            <i class="bi bi-person-plus-fill me-2"></i>User Access 
                            <span class="badge bg-success">@diseaseGrant.UserGrants.Count(u => !u.IsExpired)</span>
                            @if (diseaseGrant.UserGrants.Any(u => u.IsExpired))
                            {
                                <span class="badge bg-secondary ms-1">@diseaseGrant.UserGrants.Count(u => u.IsExpired) expired</span>
                            }
                        </h6>
                        @if (!diseaseGrant.UserGrants.Any())
                        {
                            <p class="text-muted fst-italic">No user grants</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>User</th>
                                            <th>Expires</th>
                                            <th>By</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var userGrant in diseaseGrant.UserGrants)
                                        {
                                            <tr class="@(userGrant.IsExpired ? "table-secondary" : "")">
                                                <td>
                                                    <strong>@userGrant.UserEmail</strong>
                                                    @if (userGrant.IsExpired)
                                                    {
                                                        <br /><span class="badge bg-danger">EXPIRED</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(userGrant.Reason))
                                                    {
                                                        <br /><small class="text-muted">@userGrant.Reason</small>
                                                    }
                                                </td>
                                                <td>
                                                    @if (userGrant.ExpiresAt.HasValue)
                                                    {
                                                        @userGrant.ExpiresAt.Value.ToLocalTime().ToString("MMM dd, yyyy")
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Never</span>
                                                    }
                                                </td>
                                                <td><small>@userGrant.GrantedBy</small></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="card-footer bg-light">
                <div class="btn-group btn-group-sm" role="group">
                    @if (diseaseGrant.Disease.AccessLevel == DiseaseAccessLevel.Restricted)
                    {
                        <a asp-page="./ManageRoles" asp-route-diseaseId="@diseaseGrant.Disease.Id" class="btn btn-outline-primary">
                            <i class="bi bi-people-fill me-1"></i>Manage Roles
                        </a>
                    }
                    <a asp-page="./ManageUsers" asp-route-diseaseId="@diseaseGrant.Disease.Id" class="btn btn-outline-success">
                        <i class="bi bi-person-plus-fill me-1"></i>Manage Users
                    </a>
                    <a asp-page="/Settings/Diseases/Edit" asp-route-id="@diseaseGrant.Disease.Id" class="btn btn-outline-secondary">
                        <i class="bi bi-pencil me-1"></i>Edit Disease
                    </a>
                </div>
            </div>
        </div>
    }
}

<div class="mt-3">
    <a asp-page="./Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Disease Access
    </a>
</div>
