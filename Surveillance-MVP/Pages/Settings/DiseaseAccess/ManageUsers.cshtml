@page
@using Surveillance_MVP.Models.Lookups
@model Surveillance_MVP.Pages.Settings.DiseaseAccess.ManageUsersModel

@{
    ViewData["Title"] = "Manage User Access";
    ViewBag.SelectedDiseaseId = Model.SelectedDiseaseId;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Disease Access Control</a></li>
        <li class="breadcrumb-item active" aria-current="page">Manage User Access</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-person-plus-fill me-2"></i>Manage Temporary User Access to Diseases</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="alert alert-info">
    <i class="bi bi-info-circle me-2"></i>
    User-specific access can override role-based access and is useful for temporary access grants.
    You can grant access to both <strong>public</strong> and <strong>restricted</strong> diseases.
</div>

<div class="row">
    <div class="col-lg-4 mb-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-virus me-2"></i>Select Disease</h5>
            </div>
            <div class="card-body">
                @if (!Model.AllDiseases.Any())
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        No diseases found.
                    </div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var node in Model.AllDiseases)
                        {
                            @await Html.PartialAsync("_DiseaseHierarchyNode", node)
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        @if (Model.SelectedDisease != null)
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Grant User Access</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="Grant">
                        <input type="hidden" asp-for="SelectedDiseaseId" value="@Model.SelectedDiseaseId" />
                        
                        <div class="alert alert-info">
                            <strong>Selected Disease:</strong> @Model.SelectedDisease.Name
                            @if (Model.SelectedDisease.AccessLevel == DiseaseAccessLevel.Restricted)
                            {
                                <span class="badge bg-warning text-dark ms-2">Restricted</span>
                            }
                            else
                            {
                                <span class="badge bg-success ms-2">Public</span>
                            }
                            @if (Model.SelectedDisease.DiseaseCategory != null)
                            {
                                <span class="ms-2">(@Model.SelectedDisease.DiseaseCategory.Name)</span>
                            }
                        </div>

                        <div class="mb-3">
                            <label asp-for="SelectedUserId" class="form-label">User</label>
                            <select asp-for="SelectedUserId" class="form-select">
                                <option value="">-- Select a User --</option>
                                @foreach (var user in Model.Users)
                                {
                                    var hasAccess = Model.UserGrants.Any(g => g.UserId == user.Id && !g.IsExpired);
                                    <option value="@user.Id" disabled="@hasAccess">
                                        @user.Email @(hasAccess ? "(Already has access)" : "")
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ExpiresAt" class="form-label">Expires At (Optional)</label>
                            <input asp-for="ExpiresAt" class="form-control" type="datetime-local" />
                            <small class="form-text text-muted">Leave blank for permanent access</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Reason" class="form-label">Reason (Optional)</label>
                            <textarea asp-for="Reason" class="form-control" rows="2" maxlength="500" 
                                      placeholder="e.g., Temporary assignment, Investigation support, etc."></textarea>
                            <small class="form-text text-muted">Document why this access was granted</small>
                        </div>

                        @if (Model.SelectedDiseaseHasChildren)
                        {
                            <div class="mb-3 form-check">
                                <input asp-for="ApplyToChildren" class="form-check-input" type="checkbox" />
                                <label asp-for="ApplyToChildren" class="form-check-label">
                                    Apply to all child diseases
                                </label>
                                <div class="form-text">
                                    <i class="bi bi-info-circle me-1"></i>
                                    If checked, this permission will automatically apply to all current and future child diseases.
                                </div>
                            </div>
                        }

                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-1"></i>Grant Access
                        </button>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-list-check me-2"></i>Current User Access Grants</h5>
                </div>
                <div class="card-body">
                    @if (!Model.UserGrants.Any())
                    {
                        <p class="text-muted mb-0">No users have been granted access to this disease yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>User</th>
                                        <th>Granted At</th>
                                        <th>Expires At</th>
                                        <th>Granted By</th>
                                        <th>Reason</th>
                                        <th>Type</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var grant in Model.UserGrants)
                                    {
                                        <tr class="@(grant.IsExpired ? "table-secondary" : grant.IsInherited ? "table-info" : "")">
                                            <td>
                                                <strong>@grant.UserEmail</strong>
                                                @if (grant.IsExpired)
                                                {
                                                    <br /><span class="badge bg-danger">EXPIRED</span>
                                                }
                                            </td>
                                            <td>@grant.GrantedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                            <td>
                                                @if (grant.ExpiresAt.HasValue)
                                                {
                                                    @grant.ExpiresAt.Value.ToLocalTime().ToString("MMM dd, yyyy")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Never</span>
                                                }
                                            </td>
                                            <td>@grant.GrantedByUserName</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(grant.Reason))
                                                {
                                                    <small>@grant.Reason</small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (grant.IsInherited)
                                                {
                                                    <span class="badge bg-info">
                                                        <i class="bi bi-arrow-down-circle"></i> Inherited
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="bi bi-check-circle"></i> Direct
                                                    </span>
                                                    @if (grant.ApplyToChildren)
                                                    {
                                                        <br /><span class="badge bg-primary">
                                                            <i class="bi bi-diagram-3"></i> + Children
                                                        </span>
                                                    }
                                                }
                                            </td>
                                            <td class="text-end">
                                                @if (!grant.IsExpired && !grant.IsInherited)
                                                {
                                                    <form method="post" asp-page-handler="Revoke" class="d-inline">
                                                        <input type="hidden" asp-for="SelectedDiseaseId" value="@Model.SelectedDiseaseId" />
                                                        <input type="hidden" name="userId" value="@grant.UserId" />
                                                        <button type="submit" class="btn btn-sm btn-danger" 
                                                                onclick="return confirm('Are you sure you want to revoke access for this user? @(grant.ApplyToChildren ? "This will also revoke access from all child diseases." : "")');">
                                                            <i class="bi bi-x-circle"></i> Revoke
                                                        </button>
                                                    </form>
                                                }
                                                else if (grant.IsExpired)
                                                {
                                                    <form method="post" asp-page-handler="Revoke" class="d-inline">
                                                        <input type="hidden" asp-for="SelectedDiseaseId" value="@Model.SelectedDiseaseId" />
                                                        <input type="hidden" name="userId" value="@grant.UserId" />
                                                        <button type="submit" class="btn btn-sm btn-outline-secondary">
                                                            <i class="bi bi-trash"></i> Remove
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <span class="text-muted"><i class="bi bi-lock"></i> Inherited</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                <i class="bi bi-arrow-left me-2"></i>Select a disease from the list on the left to manage user access.
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-page="./Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Disease Access
    </a>
</div>
