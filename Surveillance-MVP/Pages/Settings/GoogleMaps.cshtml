@page
@model Surveillance_MVP.Pages.Settings.GoogleMapsModel
@{
    ViewData["Title"] = "Google Maps API Key";
}

<h2>Google Maps API Key</h2>
<hr />

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

<form method="post">
    <div class="form-group mb-2">
        <label for="ApiKey">API Key</label>
        <input asp-for="ApiKey" class="form-control" id="ApiKey" />
        <span asp-validation-for="ApiKey" class="text-danger"></span>
        <small class="form-text text-muted">Enter your Google Maps API key (Places + Geocoding enabled). Stored in appsettings.json.</small>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-page="/Settings/Index" class="btn btn-link">Back</a>
    </div>
</form>
