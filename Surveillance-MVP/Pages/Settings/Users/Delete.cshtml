@page
@model Surveillance_MVP.Pages.Settings.Users.DeleteModel

@{
    ViewData["Title"] = "Delete User";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
            <li class="breadcrumb-item"><a asp-page="./Index">Users</a></li>
            <li class="breadcrumb-item active">Delete User</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Delete User</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger">
                        <h5><i class="bi bi-exclamation-circle me-2"></i>Warning!</h5>
                        <p class="mb-0">
                            This action cannot be undone. Are you sure you want to permanently delete this user account?
                        </p>
                    </div>

                    <h5 class="mb-3">User Details</h5>
                    <dl class="row">
                        <dt class="col-sm-4">Email:</dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4">Username:</dt>
                        <dd class="col-sm-8">@Model.UserName</dd>

                        <dt class="col-sm-4">Status:</dt>
                        <dd class="col-sm-8">
                            @if (Model.IsLockedOut)
                            {
                                <span class="badge bg-danger">Locked</span>
                            }
                            else if (Model.EmailConfirmed)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Pending</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Roles:</dt>
                        <dd class="col-sm-8">
                            @if (Model.UserRoles.Any())
                            {
                                foreach (var role in Model.UserRoles)
                                {
                                    <span class="badge bg-primary me-1">@role</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">No roles assigned</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Created:</dt>
                        <dd class="col-sm-8">
                            <span class="text-muted">N/A</span>
                        </dd>
                    </dl>

                    <form method="post">
                        <input type="hidden" asp-for="UserId" />
                        
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-2"></i>Yes, Delete User
                            </button>
                            <a asp-page="./Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
