@page
@model Surveillance_MVP.Pages.Settings.Surveys.SurveyTemplatesModel

@{
    ViewData["Title"] = "Survey Template Library";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2><i class="bi bi-collection me-2"></i>Survey Template Library</h2>
                    <p class="text-muted">
                        Manage reusable survey templates that can be shared across multiple task templates
                    </p>
                </div>
                <div>
                    <a asp-page="./CreateSurveyTemplate" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-2"></i>Create Survey Template
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Search</label>
                    <input type="text" name="search" class="form-control" 
                           value="@Model.SearchTerm" placeholder="Search by name, description, or tags">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Category</label>
                    <select name="category" class="form-select">
                        <option value="">All Categories</option>
                        <option value="Foodborne" selected="@(Model.CategoryFilter == "Foodborne")">Foodborne</option>
                        <option value="Respiratory" selected="@(Model.CategoryFilter == "Respiratory")">Respiratory</option>
                        <option value="Vector-borne" selected="@(Model.CategoryFilter == "Vector-borne")">Vector-borne</option>
                        <option value="Contact Investigation" selected="@(Model.CategoryFilter == "Contact Investigation")">Contact Investigation</option>
                        <option value="Risk Assessment" selected="@(Model.CategoryFilter == "Risk Assessment")">Risk Assessment</option>
                        <option value="Other" selected="@(Model.CategoryFilter == "Other")">Other</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select name="active" class="form-select">
                        <option value="">All</option>
                        <option value="true" selected="@(Model.ActiveFilter == true)">Active Only</option>
                        <option value="false" selected="@(Model.ActiveFilter == false)">Inactive Only</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-outline-primary me-2">
                        <i class="bi bi-funnel me-1"></i>Filter
                    </button>
                    <a asp-page="./SurveyTemplates" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i>Clear
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Survey Templates List -->
    @if (!Model.SurveyTemplates.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            No survey templates found. Create your first survey template to get started!
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var template in Model.SurveyTemplates)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 @(!template.IsActive ? "border-secondary" : "")">
                        <div class="card-header @(template.IsActive ? "bg-primary text-white" : "bg-secondary text-white")">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <h5 class="mb-0">@template.Name</h5>
                                    @if (!string.IsNullOrEmpty(template.Category))
                                    {
                                        <small><i class="bi bi-tag me-1"></i>@template.Category</small>
                                    }
                                </div>
                                @if (template.IsSystemTemplate)
                                {
                                    <span class="badge bg-warning text-dark ms-2">
                                        <i class="bi bi-shield-lock"></i> System
                                    </span>
                                }
                            </div>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(template.Description))
                            {
                                <p class="card-text text-muted small">@template.Description</p>
                            }

                            <!-- Stats -->
                            <div class="row text-center mb-3">
                                <div class="col-6">
                                    <div class="border rounded p-2">
                                        <div class="fs-4 text-primary">@Model.UsageCounts[template.Id]</div>
                                        <small class="text-muted">Tasks Using</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="border rounded p-2">
                                        <div class="fs-4 text-success">@Model.DiseaseCounts[template.Id]</div>
                                        <small class="text-muted">Diseases</small>
                                    </div>
                                </div>
                            </div>

                            <!-- Applicable Diseases -->
                            @if (template.ApplicableDiseases.Any())
                            {
                                <div class="mb-3">
                                    <small class="text-muted d-block mb-1">
                                        <i class="bi bi-clipboard2-pulse me-1"></i>Applicable Diseases:
                                    </small>
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var diseaseLink in template.ApplicableDiseases.Take(3))
                                        {
                                            <span class="badge bg-info">@diseaseLink.Disease.Name</span>
                                        }
                                        @if (template.ApplicableDiseases.Count > 3)
                                        {
                                            <span class="badge bg-secondary">+@(template.ApplicableDiseases.Count - 3) more</span>
                                        }
                                    </div>
                                </div>
                            }

                            <!-- Tags -->
                            @if (!string.IsNullOrEmpty(template.Tags))
                            {
                                <div class="mb-2">
                                    <small class="text-muted">
                                        <i class="bi bi-tags me-1"></i>
                                        @string.Join(", ", template.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries).Take(3))
                                    </small>
                                </div>
                            }

                            <!-- Version -->
                            <div class="small text-muted">
                                <i class="bi bi-arrow-repeat me-1"></i>Version @template.Version
                            </div>
                        </div>
                        <div class="card-footer bg-transparent">
                            <div class="btn-group w-100" role="group">
                                <a asp-page="./EditSurveyTemplate" asp-route-id="@template.Id" 
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-page="./SurveyTemplateDetails" asp-route-id="@template.Id" 
                                   class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                @if (!template.IsSystemTemplate && Model.UsageCounts[template.Id] == 0)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                            data-bs-toggle="modal" data-bs-target="#deleteModal-@template.Id">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Delete Modal -->
                    <div class="modal fade" id="deleteModal-@template.Id" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Delete Survey Template</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <p>Are you sure you want to delete "<strong>@template.Name</strong>"?</p>
                                    <p class="text-danger">
                                        <i class="bi bi-exclamation-triangle me-2"></i>
                                        This action cannot be undone.
                                    </p>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@template.Id" class="d-inline">
                                        <button type="submit" class="btn btn-danger">Delete</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        // Auto-submit filter form on select change
        $('select[name="category"], select[name="active"]').on('change', function() {
            $(this).closest('form').submit();
        });
    </script>
}
