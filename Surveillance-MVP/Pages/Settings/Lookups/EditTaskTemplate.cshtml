@page
@using Surveillance_MVP.Models
@model Surveillance_MVP.Pages.Settings.Lookups.EditTaskTemplateModel
@{
    ViewData["Title"] = "Edit Task Template";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item"><a asp-page="./TaskTemplates">Task Templates</a></li>
        <li class="breadcrumb-item active" aria-current="page">Edit</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-pencil me-2"></i>Edit Task Template</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<ul class="nav nav-tabs mb-4" id="taskTemplateTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="basic-tab" data-bs-toggle="tab" data-bs-target="#basic" type="button" role="tab">
            <i class="bi bi-info-circle me-1"></i>Basic Information
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="survey-tab" data-bs-toggle="tab" data-bs-target="#survey" type="button" role="tab">
            <i class="bi bi-clipboard-check me-1"></i>Survey Configuration
        </button>
    </li>
</ul>

<div class="tab-content" id="taskTemplateTabContent">
    <!-- Basic Information Tab -->
    <div class="tab-pane fade show active" id="basic" role="tabpanel">
        <div class="row">
            <div class="col-md-8">
                <form method="post" asp-page-handler="SaveBasic">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="TaskTemplate.Id" />

                    <div class="mb-3">
                        <label asp-for="TaskTemplate.Name" class="form-label"></label>
                        <input asp-for="TaskTemplate.Name" class="form-control" />
                        <span asp-validation-for="TaskTemplate.Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TaskTemplate.Description" class="form-label"></label>
                        <textarea asp-for="TaskTemplate.Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="TaskTemplate.Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TaskTemplate.TaskTypeId" class="form-label"></label>
                        <select asp-for="TaskTemplate.TaskTypeId" class="form-select" asp-items="Model.TaskTypes">
                            <option value="">-- Select Task Type --</option>
                        </select>
                        <span asp-validation-for="TaskTemplate.TaskTypeId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TaskTemplate.Instructions" class="form-label"></label>
                        <textarea asp-for="TaskTemplate.Instructions" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="TaskTemplate.Instructions" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox" asp-for="TaskTemplate.IsActive" class="form-check-input" />
                        <label asp-for="TaskTemplate.IsActive" class="form-check-label"></label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>Save Basic Info
                        </button>
                        <a asp-page="./TaskTemplates" class="btn btn-secondary">
                            <i class="bi bi-x-circle me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Survey Configuration Tab -->
    <div class="tab-pane fade" id="survey" role="tabpanel">
        <div class="row">
            <div class="col-md-12">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>Survey System:</strong> Choose to use a survey from the library or create a custom survey for this task.
                </div>

                <form method="post" asp-page-handler="SaveSurvey">
                    <input type="hidden" asp-for="TaskTemplate.Id" />

                    <!-- Survey Source Selection -->
                    <div class="card mb-3">
                        <div class="card-header bg-primary text-white">
                            <i class="bi bi-gear me-2"></i>Survey Source
                        </div>
                        <div class="card-body">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="SurveySourceType" id="surveySourceLibrary" 
                                       value="library" asp-for="SurveySourceType" />
                                <label class="form-check-label" for="surveySourceLibrary">
                                    <strong><i class="bi bi-collection me-1"></i>Use Survey Library</strong>
                                    <small class="d-block text-muted">Select a pre-built survey template from the library</small>
                                </label>
                            </div>
                            <div class="form-check mt-2">
                                <input class="form-check-input" type="radio" name="SurveySourceType" id="surveySourceCustom" 
                                       value="custom" asp-for="SurveySourceType" />
                                <label class="form-check-label" for="surveySourceCustom">
                                    <strong><i class="bi bi-code-square me-1"></i>Custom Survey</strong>
                                    <small class="d-block text-muted">Enter your own SurveyJS JSON definition</small>
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Survey Library Selection (shown when library option selected) -->
                    <div class="card mb-3" id="librarySection" style="display: none;">
                        <div class="card-header">
                            <i class="bi bi-collection me-2"></i>Select Survey Template
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label asp-for="TaskTemplate.SurveyTemplateId" class="form-label">Survey Template</label>
                                <select asp-for="TaskTemplate.SurveyTemplateId" class="form-select" asp-items="Model.SurveyTemplates">
                                    <option value="">-- Select Survey Template --</option>
                                </select>
                                <small class="form-text text-muted">
                                    Don't see the survey you need? 
                                    <a asp-page="/Settings/Surveys/SurveyTemplates" target="_blank">
                                        Create one in the Survey Library <i class="bi bi-box-arrow-up-right"></i>
                                    </a>
                                </small>
                            </div>

                            @if (Model.TaskTemplate.SurveyTemplateId.HasValue)
                            {
                                <div class="alert alert-success">
                                    <i class="bi bi-check-circle me-2"></i>
                                    <strong>Using library survey!</strong> The survey definition and default mappings come from the template.
                                    <div class="mt-2">
                                        <a asp-page="/Settings/Surveys/SurveyTemplateDetails" asp-route-id="@Model.TaskTemplate.SurveyTemplateId" 
                                           target="_blank" class="btn btn-sm btn-outline-success">
                                            <i class="bi bi-eye me-1"></i>View Template
                                        </a>
                                        <a asp-page="/Settings/Surveys/EditSurveyTemplate" asp-route-id="@Model.TaskTemplate.SurveyTemplateId" 
                                           target="_blank" class="btn btn-sm btn-outline-primary ms-2">
                                            <i class="bi bi-pencil me-1"></i>Edit Template
                                        </a>
                                    </div>
                                </div>
                            }

                            <div class="alert alert-info small">
                                <i class="bi bi-info-circle me-2"></i>
                                You can optionally override the default mappings below. If left blank, the template's default mappings will be used.
                            </div>
                        </div>
                    </div>

                    <!-- Custom Survey Section (shown when custom option selected) -->
                    <div class="card mb-3" id="customSection" style="display: none;">
                        <div class="card-header">
                            <i class="bi bi-code-square me-2"></i>Survey Definition (SurveyJS JSON)
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label asp-for="TaskTemplate.SurveyDefinitionJson" class="form-label">
                                    Survey JSON
                                </label>
                                <textarea asp-for="TaskTemplate.SurveyDefinitionJson" 
                                          class="form-control font-monospace" 
                                          rows="20"
                                          id="surveyJson"
                                          placeholder='{"title": "Survey Title", "elements": [...]}'></textarea>
                                <span asp-validation-for="TaskTemplate.SurveyDefinitionJson" class="text-danger"></span>
                                <small class="form-text text-muted">
                                    Paste SurveyJS JSON definition. Leave blank to disable survey for this task.
                                </small>
                            </div>

                            <div class="d-flex gap-2 mb-3">
                                <button type="button" class="btn btn-outline-secondary btn-sm" id="validateJsonBtn">
                                    <i class="bi bi-check-circle me-1"></i>Validate JSON
                                </button>
                                <button type="button" class="btn btn-outline-primary btn-sm" id="previewSurveyBtn">
                                    <i class="bi bi-eye me-1"></i>Preview Survey
                                </button>
                                <button type="button" class="btn btn-outline-info btn-sm" id="formatJsonBtn">
                                    <i class="bi bi-code me-1"></i>Format JSON
                                </button>
                            </div>

                            <div id="jsonValidation" class="alert d-none" role="alert"></div>
                        </div>
                    </div>

                    <!-- Default Mappings (shown for both library and custom) -->
                    <div class="card mb-3">
                        <div class="card-header">
                            <i class="bi bi-arrows-expand me-2"></i>Default Survey Mappings
                        </div>
                        <div class="card-body">
                            <div class="alert alert-info small">
                                <i class="bi bi-info-circle me-2"></i>
                                These mappings apply to ALL diseases that use this task template, unless overridden at the disease level.
                            </div>

                            <div class="mb-3">
                                <label asp-for="TaskTemplate.DefaultInputMappingJson" class="form-label">
                                    <i class="bi bi-download me-1"></i>Input Mapping (Pre-populate survey)
                                </label>
                                <textarea asp-for="TaskTemplate.DefaultInputMappingJson" 
                                          class="form-control font-monospace" 
                                          rows="8"
                                          placeholder='{"patientName": "Patient.GivenName", "caseNumber": "Case.FriendlyId"}'></textarea>
                                <small class="form-text text-muted">
                                    <strong>Available:</strong> <code>Patient.GivenName</code>, <code>Case.FriendlyId</code>, <code>Case.DateOfOnset</code>
                                </small>
                            </div>

                            <div class="mb-3">
                                <label asp-for="TaskTemplate.DefaultOutputMappingJson" class="form-label">
                                    <i class="bi bi-upload me-1"></i>Output Mapping (Save responses)
                                </label>
                                <textarea asp-for="TaskTemplate.DefaultOutputMappingJson" 
                                          class="form-control font-monospace" 
                                          rows="8"
                                          placeholder='{"isolationDate": "Case.IsolationStartDate"}'></textarea>
                                <small class="form-text text-muted">
                                    <strong>Available:</strong> <code>Case.IsolationStartDate</code>, <code>Case.CustomFields.{FieldName}</code>
                                </small>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-save me-1"></i>Save Survey Configuration
                        </button>
                        <a asp-page="./TaskTemplates" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Back to List
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Survey Preview Modal -->
<div class="modal fade" id="surveyPreviewModal" tabindex="-1" aria-labelledby="surveyPreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="surveyPreviewModalLabel">
                    <i class="bi bi-eye me-2"></i>Survey Preview
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="surveyPreviewContainer"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            // Validate JSON
            $('#validateJsonBtn').on('click', function() {
                const jsonText = $('#surveyJson').val().trim();
                const validationDiv = $('#jsonValidation');

                if (!jsonText) {
                    validationDiv.removeClass('d-none alert-success alert-danger')
                               .addClass('alert-warning')
                               .html('<i class="bi bi-exclamation-triangle me-2"></i>Survey JSON is empty. This task will not have a survey.');
                    return;
                }

                try {
                    const parsed = JSON.parse(jsonText);
                    
                    // Basic validation
                    if (!parsed.title && !parsed.elements && !parsed.pages) {
                        throw new Error('Survey must have a "title" and either "elements" or "pages" property');
                    }

                    validationDiv.removeClass('d-none alert-danger alert-warning')
                               .addClass('alert-success')
                               .html('<i class="bi bi-check-circle me-2"></i><strong>Valid JSON!</strong> Survey definition is properly formatted.');
                } catch (error) {
                    validationDiv.removeClass('d-none alert-success alert-warning')
                               .addClass('alert-danger')
                               .html('<i class="bi bi-x-circle me-2"></i><strong>Invalid JSON:</strong> ' + error.message);
                }
            });

            // Format JSON
            $('#formatJsonBtn').on('click', function() {
                const jsonText = $('#surveyJson').val().trim();
                
                if (!jsonText) return;

                try {
                    const parsed = JSON.parse(jsonText);
                    const formatted = JSON.stringify(parsed, null, 2);
                    $('#surveyJson').val(formatted);
                    
                    $('#jsonValidation').removeClass('d-none alert-danger alert-warning')
                                      .addClass('alert-success')
                                      .html('<i class="bi bi-check-circle me-2"></i>JSON formatted successfully!');
                } catch (error) {
                    $('#jsonValidation').removeClass('d-none alert-success alert-warning')
                                      .addClass('alert-danger')
                                      .html('<i class="bi bi-x-circle me-2"></i><strong>Cannot format:</strong> ' + error.message);
                }
            });

            // Preview Survey
            $('#previewSurveyBtn').on('click', function() {
                const jsonText = $('#surveyJson').val().trim();

                if (!jsonText) {
                    alert('Please enter survey JSON first');
                    return;
                }

                try {
                    const surveyJson = JSON.parse(jsonText);
                    
                    // Clear previous preview
                    const container = document.getElementById('surveyPreviewContainer');
                    container.innerHTML = '';
                    
                    // Create survey model
                    const survey = new Survey.Model(surveyJson);
                    
                    // Render survey
                    survey.render(container);
                    
                    // Show modal
                    const modal = new bootstrap.Modal(document.getElementById('surveyPreviewModal'));
                    modal.show();
                } catch (error) {
                    alert('Cannot preview survey: ' + error.message);
                }
            });

            // Toggle survey source sections
            function toggleSurveySections() {
                const sourceType = $('input[name="SurveySourceType"]:checked').val();
                if (sourceType === 'library') {
                    $('#librarySection').show();
                    $('#customSection').hide();
                } else {
                    $('#librarySection').hide();
                    $('#customSection').show();
                }
            }

            // Initial toggle based on current selection
            toggleSurveySections();

            // Handle radio button changes
            $('input[name="SurveySourceType"]').on('change', function() {
                toggleSurveySections();
            });

            // Persist active tab
            var activeTab = localStorage.getItem('taskTemplateEditActiveTab');
            if (activeTab) {
                var tab = new bootstrap.Tab(document.querySelector('#' + activeTab));
                tab.show();
            }

            $('button[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
                localStorage.setItem('taskTemplateEditActiveTab', e.target.id);
            });
        });
    </script>
}
