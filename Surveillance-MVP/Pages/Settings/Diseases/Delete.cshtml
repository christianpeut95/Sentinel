@page
@model Surveillance_MVP.Pages.Settings.Diseases.DeleteModel

@{
    ViewData["Title"] = "Delete Disease";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Diseases</a></li>
        <li class="breadcrumb-item active" aria-current="page">Delete</li>
    </ol>
</nav>

<h2 class="text-danger"><i class="bi bi-trash me-2"></i>Delete Disease</h2>
<hr />

@if (Model.HasSubDiseases)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-2"></i>
        <strong>Cannot delete this disease.</strong> It has <strong>@Model.SubDiseaseCount</strong> sub-type(s). 
        Please delete or reassign the sub-types first.
    </div>
}
else if (Model.CaseCount > 0)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-2"></i>
        <strong>Cannot delete this disease.</strong> It has <strong>@Model.CaseCount</strong> associated case(s).
    </div>
}
else
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>
        Are you sure you want to delete this disease?
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Disease.Name</dd>

            <dt class="col-sm-3">Code</dt>
            <dd class="col-sm-9"><code>@Model.Disease.Code</code></dd>

            <dt class="col-sm-3">Export Code</dt>
            <dd class="col-sm-9"><code>@Model.Disease.ExportCode</code></dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@(Model.Disease.Description ?? "-")</dd>

            <dt class="col-sm-3">Parent Disease</dt>
            <dd class="col-sm-9">
                @if (Model.Disease.ParentDisease != null)
                {
                    <text>@Model.Disease.ParentDisease.Name</text>
                }
                else
                {
                    <text>Root Level</text>
                }
            </dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.Disease.IsActive)
                {
                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> Active</span>
                }
                else
                {
                    <span class="badge bg-secondary"><i class="bi bi-x-circle"></i> Inactive</span>
                }
            </dd>
        </dl>

        @if (!Model.HasSubDiseases && Model.CaseCount == 0)
        {
            <form method="post">
                <input type="hidden" asp-for="Disease.Id" />
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
                <a asp-page="./Index" class="btn btn-outline-secondary ms-2"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
            </form>
        }
        else
        {
            <a asp-page="./Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
        }
    </div>
</div>
