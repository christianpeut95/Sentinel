@page
@model Surveillance_MVP.Pages.Organizations.DetailsModel

@{
    ViewData["Title"] = "Organization Details";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Organizations</a></li>
        <li class="breadcrumb-item active" aria-current="page">Details</li>
    </ol>
</nav>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col">
            <h2 class="fw-semibold">
                <i class="bi bi-building me-2"></i>
                Organization Details
            </h2>
        </div>
        <div class="col text-end">
            <a asp-page="./Edit" asp-route-id="@Model.Organization.Id" class="btn btn-primary">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-page="./Index" class="btn btn-outline-secondary ms-2">
                Back to List
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light fw-semibold">
                    <i class="bi bi-info-circle me-2"></i>Organization Information
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="text-muted small">Organization ID</label>
                            <div><span class="badge bg-secondary fs-6">@Model.Organization.FriendlyId</span></div>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Status</label>
                            <div>
                                @if (Model.Organization.IsActive)
                                {
                                    <span class="badge bg-success fs-6">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary fs-6">Inactive</span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label class="text-muted small">Organization Name</label>
                            <div class="fw-bold fs-5">@Model.Organization.Name</div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="text-muted small">Organization Type</label>
                            <div>
                                @if (Model.Organization.OrganizationType != null)
                                {
                                    <span class="badge bg-info fs-6">@Model.Organization.OrganizationType.Name</span>
                                }
                                else
                                {
                                    <span class="text-muted">Not specified</span>
                                }
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Export Code</label>
                            <div>@(Model.Organization.ExportCode ?? "-")</div>
                        </div>
                    </div>

                    <hr />

                    <h6 class="fw-semibold mb-3"><i class="bi bi-geo-alt me-2"></i>Address</h6>
                    <div class="mb-3">
                        @if (!string.IsNullOrEmpty(Model.Organization.Address))
                        {
                            <p class="mb-0">@Model.Organization.Address</p>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No address on file</p>
                        }
                    </div>

                    <hr />

                    <h6 class="fw-semibold mb-3"><i class="bi bi-telephone me-2"></i>Contact Information</h6>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="text-muted small">Contact Person</label>
                            <div>@(Model.Organization.ContactPerson ?? "-")</div>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Phone</label>
                            <div>
                                @if (!string.IsNullOrEmpty(Model.Organization.Phone))
                                {
                                    <a href="tel:@Model.Organization.Phone">@Model.Organization.Phone</a>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label class="text-muted small">Email</label>
                            <div>
                                @if (!string.IsNullOrEmpty(Model.Organization.Email))
                                {
                                    <a href="mailto:@Model.Organization.Email">@Model.Organization.Email</a>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Organization.Notes))
                    {
                        <hr />
                        <h6 class="fw-semibold mb-3"><i class="bi bi-file-text me-2"></i>Notes</h6>
                        <div class="alert alert-light mb-0">
                            @Model.Organization.Notes
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light fw-semibold">
                    <i class="bi bi-clock-history me-2"></i>Audit Information
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="text-muted small">Created</label>
                        <div>@Model.Organization.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>
                    </div>
                    @if (Model.Organization.ModifiedAt.HasValue)
                    {
                        <div class="mb-3">
                            <label class="text-muted small">Last Modified</label>
                            <div>@Model.Organization.ModifiedAt.Value.ToString("dd MMM yyyy HH:mm")</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
