@page
@model LoginModel
@using Sentinel.Constants

@{
    ViewData["Title"] = "Sign In";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sentinel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #f5f7fa 0%, #e8ecef 100%);
            color: #1a1a1a;
        }

        .login-container {
            width: 100%;
            max-width: 900px;
            padding: 32px;
            animation: fadeIn 0.6s ease-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .login-card {
            background: #ffffff;
            border-radius: 16px;
            padding: 0;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
            display: grid;
            grid-template-columns: 45% 55%;
            min-height: 500px;
            overflow: hidden;
        }

        .login-left {
            background: linear-gradient(135deg, #007AFF 0%, #0051D5 100%);
            padding: 60px 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
        }

        .logo-circle {
            width: 100px;
            height: 100px;
            background: rgba(255, 255, 255, 0.15);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 32px;
            backdrop-filter: blur(10px);
        }

        .logo-circle i {
            font-size: 50px;
            color: #ffffff;
        }

        .login-title {
            font-size: 32px;
            font-weight: 600;
            letter-spacing: -0.5px;
            margin-bottom: 12px;
            text-align: center;
        }

        .login-subtitle {
            font-size: 16px;
            color: rgba(255, 255, 255, 0.9);
            text-align: center;
        }

        .login-right {
            padding: 60px 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .form-title {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 32px;
            color: #1a1a1a;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 8px;
            color: #4a4a4a;
        }

        .form-control {
            width: 100%;
            padding: 12px 16px;
            font-size: 16px;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            background: #ffffff;
            color: #1a1a1a;
            transition: all 0.2s;
        }

        .form-control::placeholder {
            color: #9ca3af;
        }

        .form-control:focus {
            outline: none;
            border-color: #007AFF;
            box-shadow: 0 0 0 3px rgba(0, 122, 255, 0.1);
        }

        .form-check {
            display: flex;
            align-items: center;
            margin-bottom: 24px;
        }

        .form-check-input {
            width: 18px;
            height: 18px;
            margin-right: 10px;
            cursor: pointer;
            border: 1px solid #d1d5db;
        }

        .form-check-input:checked {
            background-color: #007AFF;
            border-color: #007AFF;
        }

        .form-check-label {
            font-size: 14px;
            color: #4a4a4a;
            cursor: pointer;
        }

        .btn-login {
            width: 100%;
            padding: 14px;
            font-size: 16px;
            font-weight: 600;
            border: none;
            border-radius: 8px;
            background: #007AFF;
            color: #ffffff;
            cursor: pointer;
            transition: all 0.2s;
            margin-bottom: 16px;
        }

        .btn-login:hover {
            background: #0051D5;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(0, 122, 255, 0.3);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .login-links {
            text-align: center;
        }

        .login-link {
            color: #007AFF;
            text-decoration: none;
            font-size: 14px;
            transition: color 0.2s;
        }

        .login-link:hover {
            color: #0051D5;
            text-decoration: underline;
        }

        .text-danger {
            color: #dc2626 !important;
            font-size: 13px;
            margin-top: 4px;
        }

        .alert {
            background: #fef2f2;
            border: 1px solid #fca5a5;
            border-radius: 8px;
            padding: 12px 16px;
            margin-bottom: 20px;
            color: #dc2626;
            font-size: 14px;
        }

        .validation-summary-errors ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        @@media (max-width: 768px) {
            .login-card {
                grid-template-columns: 1fr;
            }

            .login-left {
                padding: 40px 30px;
                min-height: auto;
            }

            .login-right {
                padding: 40px 30px;
            }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <div class="login-left">
                <div class="logo-circle">
                    <i class="bi bi-activity"></i>
                </div>
                <h1 class="login-title">@AppVersion.ProductName</h1>
                <p class="login-subtitle">Disease Surveillance System</p>
                <div style="margin-top: 40px; text-align: center; opacity: 0.8; font-size: 14px;">
                    <div style="font-weight: 500;">Version @AppVersion.Version</div>
                    <div style="font-size: 12px; margin-top: 4px;">@AppVersion.ReleaseDate</div>
                </div>
            </div>

            <div class="login-right">
                <h2 class="form-title">Sign In</h2>
                
                <form id="account" method="post">
                    @if (!ModelState.IsValid || Model.ExternalLogins?.Count > 0)
                    {
                        <div asp-validation-summary="ModelOnly" class="alert" role="alert"></div>
                    }

                    @if (!ModelState.IsValid)
                    {
                        <div class="info-box">
                            <i class="bi bi-info-circle"></i>
                            <strong>Troubleshooting:</strong> Make sure you're using the email address that was registered for your account. 
                            Password must be at least 6 characters. Contact your administrator if you continue to have issues.
                        </div>
                    }

                    <div class="form-group">
                        <label asp-for="Input.Email" class="form-label">Email</label>
                        <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" autocomplete="username" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Input.Password" class="form-label">Password</label>
                        <input asp-for="Input.Password" class="form-control" type="password" placeholder="Enter your password" autocomplete="current-password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" asp-for="Input.RememberMe" id="rememberMe" />
                        <label class="form-check-label" asp-for="Input.RememberMe" for="rememberMe">
                            Remember me
                        </label>
                    </div>

                    <button id="login-submit" type="submit" class="btn-login">Sign In</button>

                    <div class="login-links">
                        <a id="forgot-password" asp-page="./ForgotPassword" class="login-link">Forgot your password?</a>
                        @if (Model.ExternalLogins?.Count > 0)
                        {
                            <span style="color: #9ca3af; margin: 0 8px;">•</span>
                            <a id="external-login" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" class="login-link">External login</a>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
