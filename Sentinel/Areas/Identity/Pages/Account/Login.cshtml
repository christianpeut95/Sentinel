@page
@model LoginModel
@using Sentinel.Constants
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    ViewData["Title"] = "Sign In";
    Layout = null;
    var isDemoMode = Configuration.GetValue<bool>("Demo:EnableDemoUsers");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sentinel</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="~/Icons/sentinel-icon.svg" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet">

    <style>
        :root {
            --forest:      #0C2A20;
            --forest-2:    #13382C;
            --moss:        #1E5D44;
            --signal:      #3DD598;
            --signal-dk:   #159C6E;
            --signal-lt:   #D9F2E5;
            --bone:        #F5F3EC;
            --chalk:       #FBFAF5;
            --graphite:    #4A5A55;
            --hairline:    #D8D4C4;
            --status-outbreak: #E04D2B;

            --f-sans: "Geist", ui-sans-serif, system-ui, -apple-system, sans-serif;
            --f-mono: "Geist Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: var(--f-sans);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            -webkit-font-smoothing: antialiased;
            font-feature-settings: "ss01", "ss02", "cv11";
        }

        /* Animated Mesh Gradient Background */
        .mesh-background {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            background: var(--forest);
        }

        .mesh-layer {
            position: absolute;
            width: 100%;
            height: 100%;
            opacity: 1;
        }

        .gradient-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(120px);
            animation-timing-function: ease-in-out;
            animation-iteration-count: infinite;
            animation-direction: alternate;
        }

        .orb-1 {
            width: 900px;
            height: 900px;
            background: radial-gradient(circle, #5AE4B0 0%, transparent 70%);
            top: 10%;
            left: 15%;
            animation: float-1 12s infinite;
        }

        .orb-2 {
            width: 800px;
            height: 800px;
            background: radial-gradient(circle, #3DD598 0%, transparent 70%);
            top: 15%;
            right: 10%;
            animation: float-2 15s infinite;
        }

        .orb-3 {
            width: 1000px;
            height: 1000px;
            background: radial-gradient(circle, #3E4A48 0%, transparent 65%);
            bottom: 10%;
            right: 20%;
            animation: float-3 18s infinite;
        }

        .orb-4 {
            width: 850px;
            height: 850px;
            background: radial-gradient(circle, #1E5D44 0%, transparent 70%);
            bottom: 5%;
            left: 10%;
            animation: float-4 14s infinite;
        }

        .orb-5 {
            width: 750px;
            height: 750px;
            background: radial-gradient(circle, #6B7A78 0%, transparent 65%);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            animation: float-5 16s infinite;
        }

        @@keyframes float-1 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(30px, -40px) scale(1.1); }
        }

        @@keyframes float-2 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(-40px, 30px) scale(1.15); }
        }

        @@keyframes float-3 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(25px, 35px) scale(1.08); }
        }

        @@keyframes float-4 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(-30px, -25px) scale(1.12); }
        }

        @@keyframes float-5 {
            0%, 100% { transform: translate(-50%, -50%) scale(1) rotate(0deg); }
            50% { transform: translate(-50%, -50%) scale(1.05) rotate(5deg); }
        }

        /* Login Container */
        .login-container {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 460px;
            padding: 32px;
            animation: fadeInUp 0.8s ease-out;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .login-card {
            background: var(--chalk);
            border: 1px solid var(--hairline);
            border-radius: 12px;
            padding: 48px;
            box-shadow: 0 20px 60px rgba(12, 42, 32, 0.4);
            backdrop-filter: blur(10px);
        }

        /* Logo */
        .login-logo {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-bottom: 40px;
        }

        .logo-icon {
            width: 64px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            position: relative;
            box-shadow: 0 0 40px rgba(61, 213, 152, 0.3);
            border-radius: 16px;
            overflow: hidden;
        }

        .logo-icon svg {
            width: 64px;
            height: 64px;
        }

        .login-title {
            font-family: var(--f-sans);
            font-size: 28px;
            font-weight: 600;
            letter-spacing: -0.02em;
            color: var(--forest);
            margin-bottom: 8px;
        }

        .login-subtitle {
            font-family: var(--f-mono);
            font-size: 11px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--graphite);
        }

        .form-title {
            font-size: 20px;
            font-weight: 500;
            margin-bottom: 28px;
            color: var(--forest);
            padding-bottom: 16px;
            border-bottom: 1px solid var(--hairline);
        }

        /* Form */
        .form-group {
            margin-bottom: 24px;
        }

        .form-label {
            display: block;
            font-family: var(--f-sans);
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 8px;
            color: var(--forest);
        }

        .form-control {
            width: 100%;
            padding: 12px 16px;
            font-family: var(--f-sans);
            font-size: 14px;
            border: 1px solid var(--hairline);
            border-radius: 8px;
            background: var(--chalk);
            color: var(--forest);
            transition: all 0.2s ease;
        }

        .form-control::placeholder {
            color: var(--graphite);
            opacity: 0.6;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--signal-dk);
            box-shadow: 0 0 0 3px var(--signal-lt);
        }

        .form-check {
            display: flex;
            align-items: center;
            margin-bottom: 28px;
        }

        .form-check-input {
            width: 18px;
            height: 18px;
            margin-right: 10px;
            cursor: pointer;
            border: 1px solid var(--hairline);
            border-radius: 4px;
        }

        .form-check-input:checked {
            background-color: var(--signal-dk);
            border-color: var(--signal-dk);
        }

        .form-check-label {
            font-size: 14px;
            color: var(--graphite);
            cursor: pointer;
        }

        .btn-login {
            width: 100%;
            padding: 14px;
            font-family: var(--f-sans);
            font-size: 14px;
            font-weight: 500;
            border: none;
            border-radius: 8px;
            background: var(--signal-dk);
            color: var(--chalk);
            cursor: pointer;
            transition: all 0.2s ease;
            margin-bottom: 20px;
            letter-spacing: -0.005em;
        }

        .btn-login:hover {
            background: var(--moss);
            transform: translateY(-1px);
            box-shadow: 0 8px 16px rgba(12, 42, 32, 0.2);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .login-links {
            text-align: center;
            padding-top: 24px;
            border-top: 1px solid var(--hairline);
        }

        .login-link {
            color: var(--signal-dk);
            text-decoration: none;
            font-size: 14px;
            transition: color 0.2s;
            font-weight: 500;
        }

        .login-link:hover {
            color: var(--moss);
            text-decoration: underline;
        }

        .text-danger {
            color: var(--status-outbreak) !important;
            font-size: 12px;
            margin-top: 6px;
            font-family: var(--f-mono);
            letter-spacing: 0.02em;
        }

        .alert {
            background: #FBE2D8;
            border: 1px solid #F2BBA4;
            border-radius: 8px;
            padding: 14px 16px;
            margin-bottom: 24px;
            color: #7A2A15;
            font-size: 13px;
        }

        .validation-summary-errors ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .validation-summary-errors li {
            padding: 4px 0;
        }

        /* Demo Banner */
        .demo-banner {
            background: var(--signal-lt);
            border: 1px solid #9BE8C6;
            border-radius: 8px;
            padding: 16px;
            margin-bottom: 24px;
            font-size: 13px;
            color: #0A3F2C;
        }

        .demo-banner strong {
            font-family: var(--f-mono);
            font-size: 10px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            display: block;
            margin-bottom: 8px;
            color: var(--signal-dk);
        }

        .demo-credentials {
            font-family: var(--f-mono);
            font-size: 11px;
            margin-top: 8px;
            padding: 8px;
            background: rgba(255, 255, 255, 0.5);
            border-radius: 4px;
        }

        .demo-user-btn {
            width: 100%;
            padding: 12px 16px;
            margin-bottom: 10px;
            border: 1px solid var(--hairline);
            border-radius: 8px;
            background: var(--chalk);
            color: var(--forest);
            text-align: left;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .demo-user-btn:hover {
            border-color: var(--signal-dk);
            background: var(--signal-lt);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(21, 156, 110, 0.15);
        }

        .demo-user-btn i {
            font-size: 18px;
            color: var(--signal-dk);
        }

        .demo-user-btn strong {
            font-size: 14px;
            display: block;
            color: var(--forest);
        }

        .demo-user-btn small {
            font-size: 11px;
            color: var(--graphite);
            display: block;
            margin-top: 2px;
        }

        .info-box {
            background: var(--signal-lt);
            border: 1px solid #9BE8C6;
            border-radius: 8px;
            padding: 14px;
            margin-bottom: 20px;
            font-size: 13px;
            color: #0A3F2C;
        }

        .info-box i {
            color: var(--signal-dk);
            margin-right: 8px;
        }

        .version-info {
            position: fixed;
            bottom: 20px;
            right: 20px;
            font-family: var(--f-mono);
            font-size: 10px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.4);
            z-index: 5;
        }

        @@media (max-width: 576px) {
            .login-card {
                padding: 32px 24px;
            }

            .login-title {
                font-size: 24px;
            }

            .version-info {
                display: none;
            }
        }
    </style>
</head>
<body>
    <!-- Animated Mesh Gradient Background -->
    <div class="mesh-background">
        <div class="mesh-layer">
            <div class="gradient-orb orb-1"></div>
            <div class="gradient-orb orb-2"></div>
            <div class="gradient-orb orb-3"></div>
            <div class="gradient-orb orb-4"></div>
            <div class="gradient-orb orb-5"></div>
        </div>
    </div>

    <!-- Version Info -->
    <div class="version-info">
        Version @AppVersion.Version • @AppVersion.ReleaseDate
    </div>

    <!-- Login Container -->
    <div class="login-container">
        <div class="login-card">
            <!-- Logo Section -->
            <div class="login-logo">
                <div class="logo-icon">
                    <img src="~/Icons/sentinel-icon.svg" alt="Sentinel Logo" style="width: 64px; height: 64px;" />
                </div>
                <h1 class="login-title">@AppVersion.ProductName</h1>
                <p class="login-subtitle">Disease Surveillance System</p>
            </div>

            <!-- Demo Mode Banner -->
            @if (isDemoMode)
            {
                <div class="demo-banner">
                    <strong>Demo Environment</strong>
                    <p style="margin-bottom: 12px;">Quick login with test accounts below:</p>

                    <form method="post" asp-page-handler="DemoLogin" asp-route-returnUrl="@Model.ReturnUrl">
                        <input type="hidden" name="email" value="manager@sentinel-demo.com" />
                        <input type="hidden" name="password" value="Demo123!@@#Manager" />
                        <button type="submit" class="demo-user-btn">
                            <i class="bi bi-person-badge"></i>
                            <div>
                                <strong>Emma</strong>
                                <small>Surveillance Manager • Full system access</small>
                            </div>
                        </button>
                    </form>

                    <form method="post" asp-page-handler="DemoLogin" asp-route-returnUrl="@Model.ReturnUrl">
                        <input type="hidden" name="email" value="officer@sentinel-demo.com" />
                        <input type="hidden" name="password" value="Demo123!@@#Officer" />
                        <button type="submit" class="demo-user-btn">
                            <i class="bi bi-person-badge"></i>
                            <div>
                                <strong>Isabella</strong>
                                <small>Surveillance Officer • Operational access</small>
                            </div>
                        </button>
                    </form>

                    <form method="post" asp-page-handler="DemoLogin" asp-route-returnUrl="@Model.ReturnUrl">
                        <input type="hidden" name="email" value="tracer@sentinel-demo.com" />
                        <input type="hidden" name="password" value="Demo123!@@#Tracer" />
                        <button type="submit" class="demo-user-btn">
                            <i class="bi bi-person-check"></i>
                            <div>
                                <strong>John</strong>
                                <small>Contact Tracer • Interview queue & surveys</small>
                            </div>
                        </button>
                    </form>

                    <form method="post" asp-page-handler="DemoLogin" asp-route-returnUrl="@Model.ReturnUrl">
                        <input type="hidden" name="email" value="supervisor@sentinel-demo.com" />
                        <input type="hidden" name="password" value="Demo123!@@#Supervisor" />
                        <button type="submit" class="demo-user-btn">
                            <i class="bi bi-person-gear"></i>
                            <div>
                                <strong>Caitlin</strong>
                                <small>Contact Tracing Supervisor • Task management</small>
                            </div>
                        </button>
                    </form>

                    <form method="post" asp-page-handler="DemoLogin" asp-route-returnUrl="@Model.ReturnUrl">
                        <input type="hidden" name="email" value="stiofficer@sentinel-demo.com" />
                        <input type="hidden" name="password" value="Demo123!@@#STI" />
                        <button type="submit" class="demo-user-btn">
                            <i class="bi bi-shield-check"></i>
                            <div>
                                <strong>Megge</strong>
                                <small>STI/BBV Officer • STI/BBV surveillance</small>
                            </div>
                        </button>
                    </form>

                    <div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid #9BE8C6; font-size: 11px; color: var(--graphite);">
                        Or login manually with your credentials below
                    </div>
                </div>
            }

            <!-- Login Form -->
            <form id="account" method="post">
                <h2 class="form-title">Sign In</h2>

                @if (!ModelState.IsValid || Model.ExternalLogins?.Count > 0)
                {
                    <div asp-validation-summary="ModelOnly" class="alert" role="alert"></div>
                }

                @if (!ModelState.IsValid)
                {
                    <div class="info-box">
                        <i class="bi bi-info-circle"></i>
                        <strong>Troubleshooting:</strong> Make sure you're using the email address that was registered for your account. 
                        Password must be at least 6 characters. Contact your administrator if you continue to have issues.
                    </div>
                }

                <div class="form-group">
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" autocomplete="username" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <input asp-for="Input.Password" class="form-control" type="password" placeholder="Enter your password" autocomplete="current-password" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-check">
                    <input class="form-check-input" type="checkbox" asp-for="Input.RememberMe" id="rememberMe" />
                    <label class="form-check-label" asp-for="Input.RememberMe" for="rememberMe">
                        Remember me
                    </label>
                </div>

                <button id="login-submit" type="submit" class="btn-login">Sign In</button>

                <div class="login-links">
                    <a id="forgot-password" asp-page="./ForgotPassword" class="login-link">Forgot your password?</a>
                    @if (Model.ExternalLogins?.Count > 0)
                    {
                        <span style="color: var(--graphite); margin: 0 8px; opacity: 0.5;">•</span>
                        <a id="external-login" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" class="login-link">External login</a>
                    }
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
