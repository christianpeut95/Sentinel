<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" 
                  arguments=".\Sentinel.dll" 
                  stdoutLogEnabled="false" 
                  stdoutLogFile=".\logs\stdout" 
                  hostingModel="inprocess"
                  requestTimeout="00:10:00" />
      
      <!-- Allow large file uploads (100MB) -->
      <security>
        <requestFiltering>
          <!-- 100MB in bytes (104,857,600) -->
          <requestLimits maxAllowedContentLength="104857600" />
        </requestFiltering>
      </security>
      
      <!-- Additional Azure optimizations -->
      <httpProtocol>
        <customHeaders>
          <add name="X-Content-Type-Options" value="nosniff" />
          <add name="X-Frame-Options" value="SAMEORIGIN" />
          <add name="X-XSS-Protection" value="1; mode=block" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>
  
  <!-- System.web section for Azure backwards compatibility -->
  <system.web>
    <httpRuntime maxRequestLength="102400" executionTimeout="600" />
    <!-- 100MB in KB, 10 min timeout -->
  </system.web>
</configuration>
