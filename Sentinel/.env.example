# Environment variables for docker-compose
# Copy this to .env and fill in your actual values
# DO NOT commit .env to git (it's in .gitignore)

# Docker Hub Configuration
DOCKERHUB_USERNAME=your-dockerhub-username
VERSION_TAG=latest

# Application Environment
ASPNETCORE_ENVIRONMENT=Production

# Database Configuration
SQL_PASSWORD=YourStrong!Password123
CONNECTION_STRING=Server=sentinel-db;Database=SentinelDb;User Id=sa;Password=YourStrong!Password123;TrustServerCertificate=True;

# Geocoding Configuration
GEOCODING_PROVIDER=google
GEOCODING_API_KEY=your-google-api-key-here
GEOCODING_EMAIL=your-email@example.com
GEOCODING_DEFAULT_COUNTRY=AU
