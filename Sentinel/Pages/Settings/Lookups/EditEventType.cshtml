@page
@model Sentinel.Pages.Settings.Lookups.EditEventTypeModel

@{
    ViewData["Title"] = "Edit Event Type";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item"><a asp-page="./EventTypes">Event Types</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.EventType.Name</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-pencil me-2"></i>Edit Event Type</h2>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
    <input type="hidden" asp-for="EventType.Id" />

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light fw-semibold">
            <i class="bi bi-info-circle me-2"></i>Event Type Information
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-8 mb-3">
                    <label asp-for="EventType.Name" class="form-label">
                        <span class="text-danger">*</span> @Html.DisplayNameFor(m => m.EventType.Name)
                    </label>
                    <input asp-for="EventType.Name" class="form-control" aria-required="true" placeholder="e.g., Party, Wedding, Conference" />
                    <span asp-validation-for="EventType.Name" class="text-danger small"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="EventType.DisplayOrder" class="form-label">
                        @Html.DisplayNameFor(m => m.EventType.DisplayOrder)
                    </label>
                    <input asp-for="EventType.DisplayOrder" class="form-control" type="number" placeholder="Sort order" />
                    <span asp-validation-for="EventType.DisplayOrder" class="text-danger small"></span>
                    <small class="form-text text-muted">Lower numbers appear first in dropdowns</small>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12 mb-3">
                    <label asp-for="EventType.Description" class="form-label">
                        @Html.DisplayNameFor(m => m.EventType.Description)
                    </label>
                    <textarea asp-for="EventType.Description" class="form-control" rows="3" placeholder="Brief description of this event type..."></textarea>
                    <span asp-validation-for="EventType.Description" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12 mb-3">
                    <div class="form-check">
                        <input asp-for="EventType.IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="EventType.IsActive" class="form-check-label">
                            Active (available for selection)
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between">
        <a asp-page="./EventTypes" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Cancel
        </a>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-circle me-1"></i>Update Event Type
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
