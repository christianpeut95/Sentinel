@page
@model Sentinel.Pages.Settings.Lookups.EditSymptomModel
@{
    ViewData["Title"] = "Edit Symptom";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item"><a asp-page="./Symptoms">Symptoms</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Symptom.Name</li>
    </ol>
</nav>

<div class="container-fluid mt-4">
    <h2>@ViewData["Title"]</h2>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Symptom.Id" />

                        <div class="mb-3">
                            <label asp-for="Symptom.Name" class="form-label"></label>
                            <input asp-for="Symptom.Name" class="form-control" />
                            <span asp-validation-for="Symptom.Name" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Symptom.Code" class="form-label"></label>
                                <input asp-for="Symptom.Code" class="form-control" />
                                <span asp-validation-for="Symptom.Code" class="text-danger"></span>
                                <small class="form-text text-muted">Internal code for the symptom</small>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Symptom.ExportCode" class="form-label"></label>
                                <input asp-for="Symptom.ExportCode" class="form-control" />
                                <span asp-validation-for="Symptom.ExportCode" class="text-danger"></span>
                                <small class="form-text text-muted">Code used for external reporting systems</small>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Symptom.Description" class="form-label"></label>
                            <textarea asp-for="Symptom.Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Symptom.Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Symptom.SortOrder" class="form-label"></label>
                                <input asp-for="Symptom.SortOrder" class="form-control" type="number" />
                                <span asp-validation-for="Symptom.SortOrder" class="text-danger"></span>
                                <small class="form-text text-muted">Controls display order (lower numbers appear first)</small>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="form-check mt-4">
                                    <input asp-for="Symptom.IsActive" class="form-check-input" />
                                    <label asp-for="Symptom.IsActive" class="form-check-label"></label>
                                </div>
                            </div>
                        </div>

                        @if (Model.Symptom.IsDeleted)
                        {
                            <div class="alert alert-warning">
                                <i class="bi bi-exclamation-triangle"></i> This symptom is currently deleted.
                                <strong>Deleted:</strong> @Model.Symptom.DeletedAt?.ToLocalTime().ToString("g")
                            </div>
                        }

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Save Changes
                            </button>
                            <a asp-page="./Symptoms" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                            
                            @if (!Model.Symptom.IsDeleted)
                            {
                                <button type="submit" asp-page-handler="Delete" class="btn btn-danger ms-auto"
                                        onclick="return confirm('Are you sure you want to delete this symptom?');">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            }
                        </div>
                    </form>
                </div>
            </div>

            @if (Model.Symptom.CreatedAt != default)
            {
                <div class="card mt-3">
                    <div class="card-header">
                        <h6 class="mb-0">Audit Information</h6>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-3">Created:</dt>
                            <dd class="col-sm-9">@Model.Symptom.CreatedAt.ToLocalTime().ToString("g")</dd>

                            @if (Model.Symptom.UpdatedAt.HasValue)
                            {
                                <dt class="col-sm-3">Last Updated:</dt>
                                <dd class="col-sm-9">@Model.Symptom.UpdatedAt.Value.ToLocalTime().ToString("g")</dd>
                            }

                            @if (Model.Symptom.IsDeleted)
                            {
                                <dt class="col-sm-3">Deleted:</dt>
                                <dd class="col-sm-9">@Model.Symptom.DeletedAt?.ToLocalTime().ToString("g")</dd>
                            }
                        </dl>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
