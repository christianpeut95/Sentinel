@page
@model Sentinel.Pages.Settings.Lookups.CreateTestMethodModel

@{
    ViewData["Title"] = "Add Test Method";
    Layout = "~/Pages/Shared/_LayoutSentinel.cshtml";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item"><a asp-page="./TestMethods">Test Methods</a></li>
        <li class="breadcrumb-item active" aria-current="page">Add Test Method</li>
    </ol>
</nav>

<div class="sentinel-page-header mb-4">
    <div>
        <h1 class="sentinel-page-title">Add Test Method</h1>
        <p class="sentinel-page-subtitle">Define a new laboratory test methodology</p>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="sentinel-card">
            <div class="sentinel-card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="TestMethod.Name" class="sn-label"></label>
                        <input asp-for="TestMethod.Name" class="sn-input" placeholder="e.g. RT-PCR, ELISA IgM, Culture" autofocus />
                        <span asp-validation-for="TestMethod.Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TestMethod.Description" class="sn-label"></label>
                        <textarea asp-for="TestMethod.Description" class="sn-textarea" rows="3" 
                                  placeholder="Brief description of this test methodology"></textarea>
                        <span asp-validation-for="TestMethod.Description" class="text-danger"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="TestMethod.ExportCode" class="sn-label"></label>
                            <input asp-for="TestMethod.ExportCode" class="sn-input" placeholder="Optional export code" />
                            <span asp-validation-for="TestMethod.ExportCode" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TestMethod.DisplayOrder" class="sn-label"></label>
                            <input asp-for="TestMethod.DisplayOrder" type="number" class="sn-input" />
                            <span asp-validation-for="TestMethod.DisplayOrder" class="text-danger"></span>
                            <small class="sentinel-meta-text">Lower numbers appear first in lists</small>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="TestMethod.IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="TestMethod.IsActive" class="form-check-label">
                                Active (visible in lab result entry)
                            </label>
                        </div>
                    </div>

                    <div class="d-flex gap-2 pt-3 border-top">
                        <button type="submit" class="sn-btn sn-btn--signal">
                            <i class="bi bi-check-lg"></i>
                            Save Test Method
                        </button>
                        <a asp-page="TestMethods" class="sn-btn sn-btn--ghost">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="sentinel-card">
            <div class="sentinel-card-body">
                <h3 class="sentinel-section-title">
                    <i class="bi bi-lightbulb me-2"></i>
                    Examples
                </h3>
                <div class="mb-3">
                    <h5 class="fw-semibold mb-2">Molecular Methods</h5>
                    <ul class="small mb-0">
                        <li>RT-PCR (Reverse Transcription PCR)</li>
                        <li>Real-Time PCR</li>
                        <li>NAAT (Nucleic Acid Amplification)</li>
                        <li>Sequencing</li>
                    </ul>
                </div>
                <div class="mb-3">
                    <h5 class="fw-semibold mb-2">Immunology</h5>
                    <ul class="small mb-0">
                        <li>ELISA IgM / IgG / IgA</li>
                        <li>CLIA (Chemiluminescence)</li>
                        <li>IFA (Immunofluorescence)</li>
                        <li>Lateral Flow / Rapid Test</li>
                    </ul>
                </div>
                <div>
                    <h5 class="fw-semibold mb-2">Culture & Microscopy</h5>
                    <ul class="small mb-0">
                        <li>Bacterial Culture</li>
                        <li>Viral Culture</li>
                        <li>Microscopy</li>
                        <li>Gram Stain</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
