@page
@model Sentinel.Pages.Settings.Lookups.SymptomsModel
@{
    ViewData["Title"] = "Symptoms";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item active" aria-current="page">Symptoms</li>
    </ol>
</nav>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>@ViewData["Title"]</h2>
        <a asp-page="CreateSymptom" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Symptom
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            @if (Model.Symptoms.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Code</th>
                                <th>Export Code</th>
                                <th>Sort Order</th>
                                <th>Status</th>
                                <th style="width: 150px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var symptom in Model.Symptoms)
                            {
                                <tr>
                                    <td>@symptom.Name</td>
                                    <td>@(symptom.Code ?? "-")</td>
                                    <td>@(symptom.ExportCode ?? "-")</td>
                                    <td>@symptom.SortOrder</td>
                                    <td>
                                        @if (symptom.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-page="EditSymptom" asp-route-id="@symptom.Id" class="btn btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> No symptoms defined. Click "Add Symptom" to create one.
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        <a asp-page="/Settings/Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Settings
        </a>
    </div>
</div>
