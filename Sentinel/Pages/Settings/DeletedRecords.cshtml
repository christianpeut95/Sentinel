@page
@model Sentinel.Pages.Settings.DeletedRecordsModel

@{
    ViewData["Title"] = "Deleted Records";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item active" aria-current="page">Deleted Records</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-trash me-2"></i>Deleted Records</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="alert alert-info">
    <i class="bi bi-info-circle me-2"></i>
    This page shows records that have been soft-deleted. You can restore them or permanently delete them.
    <strong>Warning:</strong> Permanent deletion cannot be undone!
</div>

<!-- Filter Tabs -->
<ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item" role="presentation">
        <a class="nav-link @(string.IsNullOrEmpty(Model.Filter) || Model.Filter == "patients" ? "active" : "")" 
           asp-page="/Settings/DeletedRecords" asp-route-filter="patients">
            <i class="bi bi-person me-1"></i>Patients (@Model.DeletedPatients.Count)
        </a>
    </li>
    <li class="nav-item" role="presentation">
        <a class="nav-link @(Model.Filter == "cases" ? "active" : "")" 
           asp-page="/Settings/DeletedRecords" asp-route-filter="cases">
            <i class="bi bi-clipboard-pulse me-1"></i>Cases (@Model.DeletedCases.Count)
        </a>
    </li>
    <li class="nav-item" role="presentation">
        <a class="nav-link @(Model.Filter == "labresults" ? "active" : "")" 
           asp-page="/Settings/DeletedRecords" asp-route-filter="labresults">
            <i class="bi bi-flask me-1"></i>Lab Results (@Model.DeletedLabResults.Count)
        </a>
    </li>
    <li class="nav-item" role="presentation">
        <a class="nav-link @(Model.Filter == "notes" ? "active" : "")" 
           asp-page="/Settings/DeletedRecords" asp-route-filter="notes">
            <i class="bi bi-sticky me-1"></i>Notes (@Model.DeletedNotes.Count)
        </a>
    </li>
    <li class="nav-item" role="presentation">
        <a class="nav-link @(Model.Filter == "exposures" ? "active" : "")" 
           asp-page="/Settings/DeletedRecords" asp-route-filter="exposures">
            <i class="bi bi-arrow-left-right me-1"></i>Exposures (@Model.DeletedExposureEvents.Count)
        </a>
    </li>
</ul>

<!-- Patients Tab -->
@if (string.IsNullOrEmpty(Model.Filter) || Model.Filter == "patients")
{
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <i class="bi bi-person me-2"></i>Deleted Patients
        </div>
        <div class="card-body">
            @if (Model.DeletedPatients.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Patient ID</th>
                                <th>Name</th>
                                <th>Date of Birth</th>
                                <th>Deleted At</th>
                                <th>Deleted By</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var patient in Model.DeletedPatients)
                            {
                                <tr>
                                    <td>@patient.FriendlyId</td>
                                    <td>@patient.GivenName @patient.FamilyName</td>
                                    <td>@(patient.DateOfBirth?.ToString("dd MMM yyyy") ?? "N/A")</td>
                                    <td>@(patient.DeletedAt?.ToString("dd MMM yyyy HH:mm") ?? "N/A")</td>
                                    <td>@(patient.DeletedByUserId ?? "System")</td>
                                    <td class="text-end">
                                        <form method="post" asp-page-handler="RestorePatient" asp-route-id="@patient.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-success" 
                                                    onclick="return confirm('Are you sure you want to restore this patient?')">
                                                <i class="bi bi-arrow-counterclockwise"></i> Restore
                                            </button>
                                        </form>
                                        <form method="post" asp-page-handler="PermanentDeletePatient" asp-route-id="@patient.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-danger" 
                                                    onclick="return confirm('PERMANENT DELETE: Are you absolutely sure? This cannot be undone!')">
                                                <i class="bi bi-trash3"></i> Delete Forever
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0"><i class="bi bi-info-circle me-2"></i>No deleted patients found.</p>
            }
        </div>
    </div>
}

<!-- Cases Tab -->
@if (Model.Filter == "cases")
{
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <i class="bi bi-clipboard-pulse me-2"></i>Deleted Cases
        </div>
        <div class="card-body">
            @if (Model.DeletedCases.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Case ID</th>
                                <th>Patient</th>
                                <th>Disease</th>
                                <th>Type</th>
                                <th>Deleted At</th>
                                <th>Deleted By</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var caseEntity in Model.DeletedCases)
                            {
                                <tr>
                                    <td>@caseEntity.FriendlyId</td>
                                    <td>@(caseEntity.Patient?.GivenName) @(caseEntity.Patient?.FamilyName)</td>
                                    <td>@(caseEntity.Disease?.Name ?? "N/A")</td>
                                    <td>@caseEntity.Type</td>
                                    <td>@(caseEntity.DeletedAt?.ToString("dd MMM yyyy HH:mm") ?? "N/A")</td>
                                    <td>@(caseEntity.DeletedByUserId ?? "System")</td>
                                    <td class="text-end">
                                        <form method="post" asp-page-handler="RestoreCase" asp-route-id="@caseEntity.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-success" 
                                                    onclick="return confirm('Are you sure you want to restore this case?')">
                                                <i class="bi bi-arrow-counterclockwise"></i> Restore
                                            </button>
                                        </form>
                                        <form method="post" asp-page-handler="PermanentDeleteCase" asp-route-id="@caseEntity.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-danger" 
                                                    onclick="return confirm('PERMANENT DELETE: Are you absolutely sure? This cannot be undone!')">
                                                <i class="bi bi-trash3"></i> Delete Forever
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0"><i class="bi bi-info-circle me-2"></i>No deleted cases found.</p>
            }
        </div>
    </div>
}

