        <div class="card-header bg-primary text-white">
            <i class="bi bi-flask me-2"></i>Deleted Lab Results
        </div>
        <div class="card-body">
            @if (Model.DeletedLabResults.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Lab Result ID</th>
                                <th>Case</th>
                                <th>Patient</th>
                                <th>Accession Number</th>
                                <th>Deleted At</th>
                                <th>Deleted By</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var labResult in Model.DeletedLabResults)
                            {
                                <tr>
                                    <td>@labResult.FriendlyId</td>
                                    <td>@(labResult.Case?.FriendlyId ?? "N/A")</td>
                                    <td>@(labResult.Case?.Patient?.GivenName) @(labResult.Case?.Patient?.FamilyName)</td>
                                    <td>@(labResult.AccessionNumber ?? "N/A")</td>
                                    <td>@(labResult.DeletedAt?.ToString("dd MMM yyyy HH:mm") ?? "N/A")</td>
                                    <td>@(labResult.DeletedByUserId ?? "System")</td>
                                    <td class="text-end">
                                        <form method="post" asp-page-handler="RestoreLabResult" asp-route-id="@labResult.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-success" 
                                                    onclick="return confirm('Are you sure you want to restore this lab result?')">
                                                <i class="bi bi-arrow-counterclockwise"></i> Restore
                                            </button>
                                        </form>
                                        <form method="post" asp-page-handler="PermanentDeleteLabResult" asp-route-id="@labResult.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-danger" 
                                                    onclick="return confirm('PERMANENT DELETE: Are you absolutely sure? This cannot be undone!')">
                                                <i class="bi bi-trash3"></i> Delete Forever
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0"><i class="bi bi-info-circle me-2"></i>No deleted lab results found.</p>
            }
        </div>
    </div>
}

<!-- Notes Tab -->
@if (Model.Filter == "notes")
{
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <i class="bi bi-sticky me-2"></i>Deleted Notes
        </div>
        <div class="card-body">
            @if (Model.DeletedNotes.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Subject</th>
                                <th>Type</th>
                                <th>Related To</th>
                                <th>Content Preview</th>
                                <th>Deleted At</th>
                                <th>Deleted By</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var note in Model.DeletedNotes)
                            {
                                <tr>
                                    <td>@(note.Subject ?? "N/A")</td>
                                    <td><span class="badge bg-info">@note.Type</span></td>
                                    <td>
                                        @if (note.Patient != null)
                                        {
                                            <span><i class="bi bi-person"></i> @note.Patient.GivenName @note.Patient.FamilyName</span>
                                        }
                                        else if (note.Case != null)
                                        {
                                            <span><i class="bi bi-clipboard-pulse"></i> Case @note.Case.FriendlyId</span>
                                        }
                                    </td>
                                    <td>@(note.Content.Length > 50 ? note.Content.Substring(0, 50) + "..." : note.Content)</td>
                                    <td>@(note.DeletedAt?.ToString("dd MMM yyyy HH:mm") ?? "N/A")</td>
                                    <td>@(note.DeletedByUserId ?? "System")</td>
                                    <td class="text-end">
                                        <form method="post" asp-page-handler="RestoreNote" asp-route-id="@note.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-success" 
                                                    onclick="return confirm('Are you sure you want to restore this note?')">
                                                <i class="bi bi-arrow-counterclockwise"></i> Restore
                                            </button>
                                        </form>
                                        <form method="post" asp-page-handler="PermanentDeleteNote" asp-route-id="@note.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-danger" 
                                                    onclick="return confirm('PERMANENT DELETE: Are you absolutely sure? This cannot be undone!')">
                                                <i class="bi bi-trash3"></i> Delete Forever
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0"><i class="bi bi-info-circle me-2"></i>No deleted notes found.</p>
            }
        </div>
    </div>
}

<!-- Exposure Events Tab -->
@if (Model.Filter == "exposures")
{
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <i class="bi bi-arrow-left-right me-2"></i>Deleted Exposure Events
        </div>
        <div class="card-body">
            @if (Model.DeletedExposureEvents.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Case</th>
                                <th>Exposure Type</th>
                                <th>Start Date</th>
                                <th>Related To</th>
                                <th>Deleted At</th>
                                <th>Deleted By</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var exposure in Model.DeletedExposureEvents)
                            {
                                <tr>
                                    <td>
                                        @if (exposure.ExposedCase != null)
                                        {
                                            <span>@exposure.ExposedCase.FriendlyId</span>
                                            @if (exposure.ExposedCase.Patient != null)
                                            {
                                                <br />
                                                <small class="text-muted">@exposure.ExposedCase.Patient.GivenName @exposure.ExposedCase.Patient.FamilyName</small>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </td>
                                    <td>@exposure.ExposureType</td>
                                    <td>@exposure.ExposureStartDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if (exposure.Event != null)
                                        {
                                            <span><i class="bi bi-calendar-event me-1"></i>@exposure.Event.Name</span>
                                        }
                                        else if (exposure.Location != null)
                                        {
                                            <span><i class="bi bi-geo-alt me-1"></i>@exposure.Location.Name</span>
                                        }
                                        else if (exposure.SourceCase != null)
                                        {
                                            <span><i class="bi bi-person me-1"></i>@exposure.SourceCase.FriendlyId</span>
                                        }
                                        else if (!string.IsNullOrEmpty(exposure.FreeTextLocation))
                                        {
                                            <span><i class="bi bi-text-left me-1"></i>@exposure.FreeTextLocation</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </td>
                                    <td>@(exposure.DeletedAt?.ToString("dd MMM yyyy HH:mm") ?? "N/A")</td>
                                    <td>@(exposure.DeletedByUserId ?? "System")</td>
                                    <td class="text-end">
                                        <form method="post" asp-page-handler="RestoreExposure" asp-route-id="@exposure.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-success" 
                                                    onclick="return confirm('Are you sure you want to restore this exposure event?')">
                                                <i class="bi bi-arrow-counterclockwise"></i> Restore
                                            </button>
                                        </form>
                                        <form method="post" asp-page-handler="PermanentDeleteExposure" asp-route-id="@exposure.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-danger" 
                                                    onclick="return confirm('PERMANENT DELETE: Are you absolutely sure? This cannot be undone!')">
                                                <i class="bi bi-trash3"></i> Delete Forever
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0"><i class="bi bi-info-circle me-2"></i>No deleted exposure events found.</p>
            }
        </div>
    </div>
}

<div class="mt-4">
    <a asp-page="/Settings/Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Settings
    </a>
</div>
