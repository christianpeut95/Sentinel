@page
@model Sentinel.Pages.Settings.CustomFields.VisibilityModel

@{
    ViewData["Title"] = "Custom Field Visibility";
    ViewData["Subtitle"] = "Configure field visibility rules";
    Layout = "~/Pages/Shared/_LayoutSentinel.cshtml";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
            <li class="breadcrumb-item"><a asp-page="./Index">Custom Fields</a></li>
            <li class="breadcrumb-item active" aria-current="page">Visibility Settings</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2><i class="bi bi-eye me-2"></i>Custom Field Visibility</h2>
            <p class="text-muted">Control where custom fields appear in the patient interface</p>
        </div>
        <a asp-page="./Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back to Custom Fields
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-info-circle me-2"></i>Visibility Options</h5>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded">
                                <h6 class="text-primary"><i class="bi bi-pencil-square me-2"></i>Create/Edit Forms</h6>
                                <p class="small mb-0">Show field when creating or editing a patient record</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded">
                                <h6 class="text-info"><i class="bi bi-file-text me-2"></i>Details Page</h6>
                                <p class="small mb-0">Show field on the patient details view</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded">
                                <h6 class="text-success"><i class="bi bi-table me-2"></i>Patient List</h6>
                                <p class="small mb-0">Show field as a column in the patient list table</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.CustomFields.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox" style="font-size: 4rem; color: #dee2e6;"></i>
                <h5 class="mt-3">No Custom Fields</h5>
                <p class="text-muted">Create custom fields first to manage their visibility.</p>
                <a asp-page="./Create" class="btn btn-primary mt-2">
                    <i class="bi bi-plus-lg me-2"></i>Create Custom Field
                </a>
            </div>
        </div>
    }
    else
    {
        @foreach (var categoryGroup in Model.FieldsByCategory)
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-folder me-2"></i>@categoryGroup.Key</h5>
                        <div class="btn-group btn-group-sm">
                            <button type="button" class="btn btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="bi bi-lightning me-1"></i>Bulk Update
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><h6 class="dropdown-header">Show All On:</h6></li>
                                <li>
                                    <form method="post" asp-page-handler="BulkUpdate" asp-route-category="@categoryGroup.Key" asp-route-property="ShowOnCreateEdit" asp-route-value="true" style="display: inline;">
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-check-circle me-2"></i>Create/Edit Forms
                                        </button>
                                    </form>
                                </li>
                                <li>
                                    <form method="post" asp-page-handler="BulkUpdate" asp-route-category="@categoryGroup.Key" asp-route-property="ShowOnDetails" asp-route-value="true" style="display: inline;">
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-check-circle me-2"></i>Details Page
                                        </button>
                                    </form>
                                </li>
                                <li>
                                    <form method="post" asp-page-handler="BulkUpdate" asp-route-category="@categoryGroup.Key" asp-route-property="ShowOnList" asp-route-value="true" style="display: inline;">
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-check-circle me-2"></i>List
                                        </button>
                                    </form>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li><h6 class="dropdown-header">Hide All From:</h6></li>
                                <li>
                                    <form method="post" asp-page-handler="BulkUpdate" asp-route-category="@categoryGroup.Key" asp-route-property="ShowOnCreateEdit" asp-route-value="false" style="display: inline;">
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-x-circle me-2"></i>Create/Edit Forms
                                        </button>
                                    </form>
                                </li>
                                <li>
                                    <form method="post" asp-page-handler="BulkUpdate" asp-route-category="@categoryGroup.Key" asp-route-property="ShowOnDetails" asp-route-value="false" style="display: inline;">
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-x-circle me-2"></i>Details Page
                                        </button>
                                    </form>
                                </li>
                                <li>
                                    <form method="post" asp-page-handler="BulkUpdate" asp-route-category="@categoryGroup.Key" asp-route-property="ShowOnList" asp-route-value="false" style="display: inline;">
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-x-circle me-2"></i>List
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 40%;">Field</th>
                                    <th class="text-center">Create/Edit</th>
                                    <th class="text-center">Details</th>
                                    <th class="text-center">List</th>
                                    <th class="text-center">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var field in categoryGroup.Value)
                                {
                                    <tr class="@(!field.IsActive ? "table-secondary" : "")">
                                        <td>
                                            <div>
                                                <strong>@field.Label</strong>
                                                @if (field.IsRequired)
                                                {
                                                    <span class="badge bg-danger ms-1">Required</span>
                                                }
                                                @if (!field.IsActive)
                                                {
                                                    <span class="badge bg-secondary ms-1">Inactive</span>
                                                }
                                            </div>
                                            <small class="text-muted">
                                                <code>@field.Name</code> • @field.FieldType
                                                @if (field.LookupTable != null)
                                                {
                                                    <text> • </text>@field.LookupTable.DisplayName
                                                }
                                            </small>
                                        </td>
                                        <td class="text-center">
                                            <form method="post" asp-page-handler="Toggle" asp-route-fieldId="@field.Id" asp-route-property="ShowOnCreateEdit" style="display: inline;">
                                                <button type="submit" class="btn btn-sm @(field.ShowOnCreateEdit ? "btn-success" : "btn-outline-secondary")" title="@(field.ShowOnCreateEdit ? "Hide from Create/Edit" : "Show on Create/Edit")">
                                                    <i class="bi bi-@(field.ShowOnCreateEdit ? "check-circle-fill" : "circle")"></i>
                                                </button>
                                            </form>
                                        </td>
                                        <td class="text-center">
                                            <form method="post" asp-page-handler="Toggle" asp-route-fieldId="@field.Id" asp-route-property="ShowOnDetails" style="display: inline;">
                                                <button type="submit" class="btn btn-sm @(field.ShowOnDetails ? "btn-info" : "btn-outline-secondary")" title="@(field.ShowOnDetails ? "Hide from Details" : "Show on Details")">
                                                    <i class="bi bi-@(field.ShowOnDetails ? "check-circle-fill" : "circle")"></i>
                                                </button>
                                            </form>
                                        </td>
                                        <td class="text-center">
                                            <form method="post" asp-page-handler="Toggle" asp-route-fieldId="@field.Id" asp-route-property="ShowOnList" style="display: inline;">
                                                <button type="submit" class="btn btn-sm @(field.ShowOnList ? "btn-success" : "btn-outline-secondary")" title="@(field.ShowOnList ? "Hide from List" : "Show on List")">
                                                    <i class="bi bi-@(field.ShowOnList ? "check-circle-fill" : "circle")"></i>
                                                </button>
                                            </form>
                                        </td>
                                        <td class="text-center">
                                            @if (field.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Inactive</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>
