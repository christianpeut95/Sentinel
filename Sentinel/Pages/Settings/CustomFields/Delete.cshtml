@page
@model Sentinel.Pages.Settings.CustomFields.DeleteModel

@{
    ViewData["Title"] = "Delete Custom Field";
    ViewData["Subtitle"] = "Remove custom field definition";
    Layout = "~/Pages/Shared/_LayoutSentinel.cshtml";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
            <li class="breadcrumb-item"><a asp-page="./Index">Custom Fields</a></li>
            <li class="breadcrumb-item active" aria-current="page">Delete</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Delete Custom Field</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger">
                        <h5><i class="bi bi-exclamation-circle me-2"></i>Warning!</h5>
                        <p class="mb-0">
                            This action cannot be undone. Deleting this field will permanently remove all patient data associated with it.
                        </p>
                    </div>

                    <h5 class="mb-3">Field Details</h5>
                    <dl class="row">
                        <dt class="col-sm-4">Field Name:</dt>
                        <dd class="col-sm-8"><code>@Model.Field.Name</code></dd>

                        <dt class="col-sm-4">Display Label:</dt>
                        <dd class="col-sm-8">@Model.Field.Label</dd>

                        <dt class="col-sm-4">Category:</dt>
                        <dd class="col-sm-8">@Model.Field.Category</dd>

                        <dt class="col-sm-4">Field Type:</dt>
                        <dd class="col-sm-8"><span class="badge bg-info">@Model.Field.FieldType</span></dd>

                        <dt class="col-sm-4">Required:</dt>
                        <dd class="col-sm-8">
                            @if (Model.Field.IsRequired)
                            {
                                <i class="bi bi-check-circle text-success"></i> <span>Yes</span>
                            }
                            else
                            {
                                <i class="bi bi-x-circle text-muted"></i> <span>No</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Searchable:</dt>
                        <dd class="col-sm-8">
                            @if (Model.Field.IsSearchable)
                            {
                                <i class="bi bi-check-circle text-success"></i> <span>Yes</span>
                            }
                            else
                            {
                                <i class="bi bi-x-circle text-muted"></i> <span>No</span>
                            }
                        </dd>

                        @if (Model.Field.LookupTable != null)
                        {
                            <dt class="col-sm-4">Lookup Table:</dt>
                            <dd class="col-sm-8">@Model.Field.LookupTable.DisplayName</dd>
                        }

                        <dt class="col-sm-4">Data Records:</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-warning text-dark">@Model.DataCount patient(s) have data for this field</span>
                        </dd>
                    </dl>

                    @if (Model.DataCount > 0)
                    {
                        <div class="alert alert-warning">
                            <strong>Data Impact:</strong> This field contains data for @Model.DataCount patient(s). 
                            All of this data will be permanently deleted.
                        </div>
                    }

                    <form method="post">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-2"></i>Yes, Delete Field and All Data
                            </button>
                            <a asp-page="./Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
