@page
@model Sentinel.Pages.Settings.CustomFields.CreateModel

@{
    ViewData["Title"] = "Create Custom Field";
}
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
            <li class="breadcrumb-item"><a asp-page="./Index">Custom Fields</a></li>
            <li class="breadcrumb-item active">Create Field</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Custom Field</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <h5 class="border-bottom pb-2 mb-3">Basic Information</h5>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="Input.Name" class="form-label">Field Name (Internal) *</label>
                                <input asp-for="Input.Name" class="form-control" placeholder="e.g., smoking_status" />
                                <span asp-validation-for="Input.Name" class="text-danger"></span>
                                <small class="form-text text-muted">Lowercase letters, numbers, and underscores only</small>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Input.Label" class="form-label">Display Label *</label>
                                <input asp-for="Input.Label" class="form-control" placeholder="e.g., Smoking Status" />
                                <span asp-validation-for="Input.Label" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Category" class="form-label">Category *</label>
                            <input asp-for="Input.Category" class="form-control" list="existingCategories" />
                            <datalist id="existingCategories">
                                @foreach (var cat in Model.ExistingCategories)
                                {
                                    <option value="@cat">@cat</option>
                                }
                            </datalist>
                            <span asp-validation-for="Input.Category" class="text-danger"></span>
                            <small class="form-text text-muted">Group related fields together</small>
                        </div>

                        <h5 class="border-bottom pb-2 mb-3 mt-4">Field Type & Configuration</h5>

                        <div class="mb-3">
                            <label asp-for="Input.FieldType" class="form-label">Field Type *</label>
                            <select asp-for="Input.FieldType" asp-items="Model.FieldTypeOptions" class="form-select" id="fieldTypeSelect">
                                <option value="">-- Select Type --</option>
                            </select>
                            <span asp-validation-for="Input.FieldType" class="text-danger"></span>
                        </div>

                        <div id="lookupSection" style="display:none;" class="card bg-light mb-3">
                            <div class="card-body">
                                <h6><i class="bi bi-list-ul me-2"></i>Dropdown Configuration</h6>
                                <div class="mb-3">
                                    <label asp-for="Input.LookupTableId" class="form-label">Lookup Table</label>
                                    <select asp-for="Input.LookupTableId" asp-items="Model.LookupTableOptions" class="form-select">
                                        <option value="">-- Select Lookup Table --</option>
                                    </select>
                                    <span asp-validation-for="Input.LookupTableId" class="text-danger"></span>
                                </div>
                                <a asp-page="/Settings/LookupTables/Create" class="btn btn-sm btn-secondary" target="_blank">
                                    <i class="bi bi-plus-lg me-1"></i>Create New Lookup Table
                                </a>
                            </div>
                        </div>

                        <h5 class="border-bottom pb-2 mb-3 mt-4">Field Options</h5>


                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input asp-for="Input.IsRequired" class="form-check-input" />
                                    <label asp-for="Input.IsRequired" class="form-check-label">
                                        Required Field
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input asp-for="Input.IsSearchable" class="form-check-input" />
                                    <label asp-for="Input.IsSearchable" class="form-check-label">
                                        Searchable
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input asp-for="Input.ShowOnList" class="form-check-input" />
                                    <label asp-for="Input.ShowOnList" class="form-check-label">
                                        Show on List
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <div class="form-check form-switch">
                                    <input asp-for="Input.ShowOnPatientForm" class="form-check-input" />
                                    <label asp-for="Input.ShowOnPatientForm" class="form-check-label">
                                        <i class="bi bi-person-fill me-1"></i>Show on Patient Forms
                                    </label>
                                    <small class="form-text text-muted d-block">Display this field when creating/editing patients</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check form-switch">
                                    <input asp-for="Input.ShowOnCaseForm" class="form-check-input" />
                                    <label asp-for="Input.ShowOnCaseForm" class="form-check-label">
                                        <i class="bi bi-file-medical-fill me-1"></i>Show on Case Forms
                                    </label>
                                    <small class="form-text text-muted d-block">Available to link to diseases for case forms</small>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.DisplayOrder" class="form-label">Display Order</label>
                            <input asp-for="Input.DisplayOrder" class="form-control" type="number" />
                            <span asp-validation-for="Input.DisplayOrder" class="text-danger"></span>
                            <small class="form-text text-muted">Lower numbers appear first (0-1000)</small>
                        </div>

                        <hr class="my-4">


                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-2"></i>Create Field
                            </button>
                            <a asp-page="./Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Field Types</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><strong>Text:</strong> Single line text input</li>
                        <li class="mb-2"><strong>Number:</strong> Numeric values</li>
                        <li class="mb-2"><strong>Date:</strong> Date picker</li>
                        <li class="mb-2"><strong>Dropdown:</strong> Select from predefined list</li>
                        <li class="mb-2"><strong>Checkbox:</strong> Yes/No toggle</li>
                        <li class="mb-2"><strong>TextArea:</strong> Multi-line text</li>
                        <li class="mb-2"><strong>Email:</strong> Email address</li>
                        <li class="mb-0"><strong>Phone:</strong> Phone number</li>
                    </ul>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-lightbulb me-2"></i>Tips</h5>
                </div>
                <div class="card-body">
                    <ul class="mb-0">
                        <li>Use descriptive names</li>
                        <li>Group related fields by category</li>
                        <li>Mark fields as searchable for filtering</li>
                        <li>Use lowercase_with_underscores for field names</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('fieldTypeSelect').addEventListener('change', function() {
            var lookupSection = document.getElementById('lookupSection');
            // Show lookup section if Dropdown (value = 3) is selected
            lookupSection.style.display = this.value === '3' ? 'block' : 'none';
        });
    </script>
}
