@page "{id:int?}"
@model Sentinel.Pages.Settings.Jurisdictions.EditModel
@{
    ViewData["Title"] = "Edit Jurisdiction";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Jurisdictions</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Input.Name</li>
    </ol>
</nav>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">
                <i class="bi bi-pencil me-2"></i>Edit Jurisdiction
            </h2>
            <p class="text-muted mb-0">Modify jurisdiction details and boundary data</p>
        </div>
        <a asp-page="./Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <form method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Input.Id" />

                        <div class="mb-3">
                            <label asp-for="Input.JurisdictionTypeId" class="form-label"></label>
                            <select asp-for="Input.JurisdictionTypeId" asp-items="Model.JurisdictionTypes" class="form-select">
                                <option value="">-- Select Jurisdiction Type --</option>
                            </select>
                            <span asp-validation-for="Input.JurisdictionTypeId" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-8">
                                <div class="mb-3">
                                    <label asp-for="Input.Name" class="form-label"></label>
                                    <input asp-for="Input.Name" class="form-control" />
                                    <span asp-validation-for="Input.Name" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="Input.Code" class="form-label"></label>
                                    <input asp-for="Input.Code" class="form-control" />
                                    <span asp-validation-for="Input.Code" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Description" class="form-label"></label>
                            <textarea asp-for="Input.Description" class="form-control" rows="2"></textarea>
                            <span asp-validation-for="Input.Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.ParentJurisdictionId" class="form-label"></label>
                            <select asp-for="Input.ParentJurisdictionId" asp-items="Model.ParentJurisdictions" class="form-select">
                                <option value="">-- No Parent (Top Level) --</option>
                            </select>
                            <span asp-validation-for="Input.ParentJurisdictionId" class="text-danger"></span>
                        </div>

                        <div class="card mb-3 @(Model.HasBoundaryData ? "border-success" : "border-secondary")">
                            <div class="card-header bg-light">
                                <h6 class="mb-0">
                                    <i class="bi bi-map me-2"></i>Boundary Data
                                </h6>
                            </div>
                            <div class="card-body">
                                @if (Model.HasBoundaryData)
                                {
                                    <div class="alert alert-success mb-3">
                                        <i class="bi bi-check-circle me-2"></i>
                                        <strong>Boundary data exists</strong> - This jurisdiction has boundary data configured (GeoJSON polygon).
                                    </div>
                                    
                                    <div class="d-flex gap-2 flex-wrap">
                                        <div class="form-check">
                                            <input asp-for="RemoveBoundaryData" class="form-check-input" type="checkbox" />
                                            <label asp-for="RemoveBoundaryData" class="form-check-label text-danger">
                                                <i class="bi bi-trash me-1"></i>Remove existing boundary data
                                            </label>
                                        </div>
                                    </div>
                                    
                                    <div class="mt-3">
                                        <label for="ShapefileUpload" class="form-label">
                                            <i class="bi bi-upload me-1"></i>Replace with New Shapefile
                                        </label>
                                        <input type="file" 
                                               id="ShapefileUpload" 
                                               name="ShapefileUpload" 
                                               class="form-control" 
                                               accept=".shp,.zip" />
                                        <small class="form-text text-muted">
                                            Upload a shapefile to replace the existing boundary data. Supports .shp or .zip files.
                                        </small>
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-info mb-3">
                                        <i class="bi bi-info-circle me-2"></i>
                                        <strong>No boundary data</strong> - You can upload a shapefile to add boundary data.
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="ShapefileUpload" class="form-label">
                                            <i class="bi bi-upload me-1"></i>Upload Shapefile
                                        </label>
                                        <input type="file" 
                                               id="ShapefileUpload" 
                                               name="ShapefileUpload" 
                                               class="form-control" 
                                               accept=".shp,.zip" />
                                        <small class="form-text text-muted">
                                            Upload a shapefile to add boundary data. Supports .shp or .zip files.
                                        </small>
                                    </div>
                                    
                                    <details class="mt-3">
                                        <summary class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-code me-1"></i>Or manually enter GeoJSON
                                        </summary>
                                        <div class="mt-3">
                                            <label asp-for="Input.BoundaryData" class="form-label">Boundary Data (GeoJSON)</label>
                                            <textarea asp-for="Input.BoundaryData" class="form-control font-monospace" rows="6"></textarea>
                                            <span asp-validation-for="Input.BoundaryData" class="text-danger"></span>
                                            <small class="form-text text-muted">
                                                Optional: Paste valid GeoJSON polygon data.
                                            </small>
                                        </div>
                                    </details>
                                }
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Input.DisplayOrder" class="form-label"></label>
                                    <input asp-for="Input.DisplayOrder" type="number" class="form-control" min="0" />
                                    <span asp-validation-for="Input.DisplayOrder" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label d-block">Status</label>
                                    <div class="form-check form-switch">
                                        <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" role="switch" />
                                        <label asp-for="Input.IsActive" class="form-check-label">
                                            Active (visible in forms)
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4"/>
                        <h6 class="text-muted mb-3"><i class="bi bi-people-fill me-2"></i>Population Data (Optional)</h6>
                        
                        <div class="row">
                            <div class="col-md-5">
                                <div class="mb-3">
                                    <label asp-for="Input.Population" class="form-label"></label>
                                    <input asp-for="Input.Population" type="number" class="form-control" min="0" 
                                           placeholder="e.g., 1000000" />
                                    <span asp-validation-for="Input.Population" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label asp-for="Input.PopulationYear" class="form-label"></label>
                                    <input asp-for="Input.PopulationYear" type="number" class="form-control" 
                                           min="1900" max="2100" placeholder="e.g., 2024" />
                                    <span asp-validation-for="Input.PopulationYear" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="Input.PopulationSource" class="form-label"></label>
                                    <input asp-for="Input.PopulationSource" class="form-control" maxlength="200"
                                           placeholder="e.g., Census Bureau" />
                                    <span asp-validation-for="Input.PopulationSource" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="alert alert-info small">
                            <i class="bi bi-info-circle me-1"></i>
                            Population data can also be imported in bulk. See 
                            <a asp-page="BulkPopulationUpload">Bulk Population Upload</a> for hundreds of jurisdictions.
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-1"></i>Save Changes
                            </button>
                            <a asp-page="./Index" class="btn btn-outline-secondary">
                                Cancel
                            </a>
                            <a asp-page="./Delete" asp-route-id="@Model.Input.Id" class="btn btn-outline-danger ms-auto">
                                <i class="bi bi-trash me-1"></i>Delete
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-light">
                <div class="card-body">
                    <h6 class="card-title">
                        <i class="bi bi-info-circle me-2"></i>Edit Notes
                    </h6>
                    <ul class="mb-0 small">
                        <li class="mb-2">
                            Changing the jurisdiction type will not affect existing patient/case assignments
                        </li>
                        <li class="mb-2">
                            Deactivating will hide from forms but preserve existing data
                        </li>
                        <li>
                            Boundary data updates will affect future address-based auto-detection
                        </li>
                    </ul>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-body">
                    <h6 class="card-title">
                        <i class="bi bi-exclamation-triangle me-2"></i>Before Deleting
                    </h6>
                    <p class="small mb-0">
                        Check if this jurisdiction is assigned to any patients or cases. 
                        Deletion will fail if assignments exist. Consider deactivating instead.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
