@page
@model Sentinel.Pages.Settings.Jurisdictions.IndexModel
@{
    ViewData["Title"] = "Manage Jurisdictions";
    ViewData["Subtitle"] = "Configure jurisdictional hierarchy";
    Layout = "~/Pages/Shared/_LayoutSentinel.cshtml";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item active" aria-current="page">Jurisdictions</li>
    </ol>
</nav>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">
                <i class="bi bi-pin-map me-2"></i>Manage Jurisdictions
            </h2>
            <p class="text-muted mb-0">Create and manage jurisdiction values for geographic classification</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-page="./BulkImport" class="btn btn-success">
                <i class="bi bi-upload me-1"></i>Bulk Import
            </a>
            <a asp-page="./BulkPopulationUpload" class="btn btn-info">
                <i class="bi bi-people-fill me-1"></i>Bulk Population
            </a>
            <a asp-page="./Create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Add Single Jurisdiction
            </a>
            <a asp-page="/Settings/Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back to Settings
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Filter Section -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label for="filterType" class="form-label">Filter by Jurisdiction Type</label>
                    <select asp-for="FilterTypeId" class="form-select" id="filterType" onchange="this.form.submit()">
                        <option value="">All Types</option>
                        @foreach (var type in Model.JurisdictionTypes)
                        {
                            <option value="@type.Id">@type.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-5">
                    <label for="searchTerm" class="form-label">Search by Name or Code</label>
                    <input asp-for="SearchTerm" type="text" class="form-control" id="searchTerm" placeholder="Enter name or code..." />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-outline-primary w-100">
                        <i class="bi bi-search me-1"></i>Search
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Results Summary -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <strong>@Model.TotalCount</strong> jurisdiction(s) found
            @if (Model.TotalCount > 0)
            {
                <text> - Showing page @Model.PageNumber of @Model.TotalPages</text>
            }
            @if (Model.FilterTypeId.HasValue || !string.IsNullOrEmpty(Model.SearchTerm))
            {
                <span class="text-muted">
                    <a asp-page="./Index" class="btn btn-sm btn-link">Clear filters</a>
                </span>
            }
        </div>
        @if (!Model.JurisdictionTypes.Any())
        {
            <div class="alert alert-warning mb-0" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>No jurisdiction types configured.</strong> 
                Please <a asp-page="/Settings/JurisdictionTypes/Index">configure jurisdiction types</a> first.
            </div>
        }
    </div>

    <!-- Jurisdictions Table -->
    @if (Model.Jurisdictions.Any())
    {
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th style="width: 20%;">Name</th>
                                <th style="width: 10%;">Code</th>
                                <th style="width: 20%;">Jurisdiction Type</th>
                                <th style="width: 15%;">Parent</th>
                                <th style="width: 15%;">Description</th>
                                <th style="width: 8%;" class="text-center">Boundary</th>
                                <th style="width: 7%;" class="text-center">Status</th>
                                <th style="width: 5%;" class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var jurisdiction in Model.Jurisdictions)
                            {
                                <tr>
                                    <td>
                                        <strong>@jurisdiction.Name</strong>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(jurisdiction.Code))
                                        {
                                            <code>@jurisdiction.Code</code>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (jurisdiction.JurisdictionType != null)
                                        {
                                            <span class="badge bg-primary">
                                                Field @jurisdiction.JurisdictionType.FieldNumber
                                            </span>
                                            <small class="text-muted ms-1">@jurisdiction.JurisdictionType.Name</small>
                                        }
                                    </td>
                                    <td>
                                        @if (jurisdiction.ParentJurisdiction != null)
                                        {
                                            <small class="text-muted">@jurisdiction.ParentJurisdiction.Name</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(jurisdiction.Description))
                                        {
                                            <small class="text-muted">
                                                @(jurisdiction.Description.Length > 60 
                                                    ? jurisdiction.Description.Substring(0, 60) + "..." 
                                                    : jurisdiction.Description)
                                            </small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(jurisdiction.BoundaryData))
                                        {
                                            <i class="bi bi-map text-success" title="Has boundary data"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-dash-circle text-muted" title="No boundary"></i>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (jurisdiction.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-page="./Edit" asp-route-id="@jurisdiction.Id" class="btn btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-page="./Delete" asp-route-id="@jurisdiction.Id" class="btn btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Pagination Controls -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Jurisdiction pagination" class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                        <a class="page-link" asp-page="./Index" 
                           asp-route-pageNumber="@(Model.PageNumber - 1)"
                           asp-route-filterTypeId="@Model.FilterTypeId"
                           asp-route-searchTerm="@Model.SearchTerm">
                            <i class="bi bi-chevron-left"></i> Previous
                        </a>
                    </li>

                    @{
                        var startPage = Math.Max(1, Model.PageNumber - 2);
                        var endPage = Math.Min(Model.TotalPages, Model.PageNumber + 2);

                        if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-page="./Index" 
                                   asp-route-pageNumber="1"
                                   asp-route-filterTypeId="@Model.FilterTypeId"
                                   asp-route-searchTerm="@Model.SearchTerm">1</a>
                            </li>
                            if (startPage > 2)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }
                        }

                        for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" asp-page="./Index" 
                                   asp-route-pageNumber="@i"
                                   asp-route-filterTypeId="@Model.FilterTypeId"
                                   asp-route-searchTerm="@Model.SearchTerm">@i</a>
                            </li>
                        }

                        if (endPage < Model.TotalPages)
                        {
                            if (endPage < Model.TotalPages - 1)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }
                            <li class="page-item">
                                <a class="page-link" asp-page="./Index" 
                                   asp-route-pageNumber="@Model.TotalPages"
                                   asp-route-filterTypeId="@Model.FilterTypeId"
                                   asp-route-searchTerm="@Model.SearchTerm">@Model.TotalPages</a>
                            </li>
                        }
                    }

                    <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-page="./Index" 
                           asp-route-pageNumber="@(Model.PageNumber + 1)"
                           asp-route-filterTypeId="@Model.FilterTypeId"
                           asp-route-searchTerm="@Model.SearchTerm">
                            Next <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-pin-map text-muted" style="font-size: 4rem;"></i>
                <h4 class="mt-3">No Jurisdictions Found</h4>
                <p class="text-muted">
                    @if (!string.IsNullOrEmpty(Model.SearchTerm) || Model.FilterTypeId.HasValue)
                    {
                        <text>No jurisdictions match your search criteria. Try adjusting your filters.</text>
                    }
                    else
                    {
                        <text>Get started by adding your first jurisdiction.</text>
                    }
                </p>
                @if (Model.JurisdictionTypes.Any())
                {
                    <a asp-page="./Create" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-1"></i>Add First Jurisdiction
                    </a>
                }
            </div>
        </div>
    }

    <!-- Help Section -->
    <div class="mt-4">
        <div class="card bg-light">
            <div class="card-body">
                <h6 class="card-title">
                    <i class="bi bi-lightbulb me-2"></i>Quick Guide
                </h6>
                <ul class="mb-0 small">
                    <li><strong>Jurisdiction Types:</strong> Configure field names in <a asp-page="/Settings/JurisdictionTypes/Index">Jurisdiction Types</a></li>
                    <li><strong>Parent Jurisdictions:</strong> Create hierarchies (e.g., State ? Health District ? LGA)</li>
                    <li><strong>Boundaries:</strong> Upload GeoJSON or shapefiles for automatic address-based assignment</li>
                    <li><strong>Status:</strong> Inactive jurisdictions are hidden from forms but preserve existing data</li>
                </ul>
            </div>
        </div>
    </div>
</div>
