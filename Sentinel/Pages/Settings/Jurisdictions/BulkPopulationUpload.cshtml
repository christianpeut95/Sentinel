@page
@model Sentinel.Pages.Settings.Jurisdictions.BulkPopulationUploadModel
@{
    ViewData["Title"] = "Bulk Population Upload";
    ViewData["Subtitle"] = "Import population data for jurisdictions";
    Layout = "~/Pages/Shared/_LayoutSentinel.cshtml";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Jurisdictions</a></li>
        <li class="breadcrumb-item active" aria-current="page">Bulk Population Upload</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2><i class="bi bi-people-fill me-2"></i>Bulk Population Upload</h2>
        <p class="text-muted mb-0">Upload population data for jurisdictions via CSV file</p>
    </div>
    <div>
        <a asp-page="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Jurisdictions
        </a>
    </div>
</div>

@if (!string.IsNullOrEmpty(TempData["Success"] as string))
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(TempData["Error"] as string))
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-upload me-2"></i>Upload Population Data</h5>
            </div>
            <div class="card-body">
                <div class="alert alert-info">
                    <h6><i class="bi bi-info-circle me-2"></i>CSV Format Requirements</h6>
                    <ul class="mb-0">
                        <li><strong>Required Columns:</strong> JurisdictionCode, Population</li>
                        <li><strong>Optional Columns:</strong> JurisdictionName, PopulationYear, PopulationSource</li>
                        <li>Jurisdiction codes must match existing jurisdictions in the system</li>
                        <li>Population values must be numeric (no commas or formatting)</li>
                        <li>If PopulationYear or PopulationSource are missing, default values will be used</li>
                    </ul>
                </div>

                <form method="post" enctype="multipart/form-data" asp-page-handler="Preview">
                    <div class="mb-3">
                        <label class="form-label">CSV File <span class="text-danger">*</span></label>
                        <input type="file" asp-for="CsvFile" class="form-control" accept=".csv" required />
                        <span asp-validation-for="CsvFile" class="text-danger"></span>
                        <small class="text-muted">Upload a CSV file with population data</small>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Default Population Year</label>
                            <input type="number" asp-for="DefaultPopulationYear" class="form-control" 
                                   placeholder="e.g., 2024" min="1900" max="2100" />
                            <small class="text-muted">Used if PopulationYear column is empty</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Default Population Source</label>
                            <input type="text" asp-for="DefaultPopulationSource" class="form-control" 
                                   placeholder="e.g., Census Bureau" maxlength="200" />
                            <small class="text-muted">Used if PopulationSource column is empty</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <input type="checkbox" asp-for="OverwriteExisting" class="form-check-input" id="overwriteCheck" />
                            <label class="form-check-label" for="overwriteCheck">
                                Overwrite existing population data
                            </label>
                            <div class="text-muted small">If unchecked, jurisdictions with existing population data will be skipped</div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search me-1"></i>Preview Data
                        </button>
                        <button type="submit" asp-page-handler="DownloadTemplate" class="btn btn-outline-secondary">
                            <i class="bi bi-download me-1"></i>Download Template
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="bi bi-question-circle me-2"></i>Help</h6>
            </div>
            <div class="card-body">
                <h6>CSV Template Example:</h6>
                <pre class="bg-light p-2 small rounded"><code>JurisdictionCode,Population,PopulationYear,PopulationSource
STATE01,1000000,2024,Census Bureau
COUNTY01,50000,2024,Local Survey
CITY01,25000,2023,Estimates</code></pre>

                <h6 class="mt-3">Tips:</h6>
                <ul class="small">
                    <li>Use Excel or Google Sheets to prepare your CSV</li>
                    <li>Save as CSV (comma delimited)</li>
                    <li>Ensure jurisdiction codes exactly match your system</li>
                    <li>Population values should be whole numbers</li>
                    <li>Years should be 4-digit format (e.g., 2024)</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@if (Model.PreviewData.Any())
{
    <div class="card">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0"><i class="bi bi-eye me-2"></i>Preview Data</h5>
                <small class="text-muted">Showing first @Model.PreviewData.Count rows</small>
            </div>
            <form method="post" asp-page-handler="Import">
                <button type="submit" class="btn btn-success" 
                        @(Model.ValidationErrors.Any() ? "disabled" : "")>
                    <i class="bi bi-check-circle me-1"></i>Confirm & Import
                </button>
            </form>
        </div>
        <div class="card-body">
            @if (Model.ValidationErrors.Any())
            {
                <div class="alert alert-warning">
                    <h6><i class="bi bi-exclamation-triangle me-2"></i>Validation Errors</h6>
                    <ul class="mb-0">
                        @foreach (var error in Model.ValidationErrors.Take(20))
                        {
                            <li>@error</li>
                        }
                        @if (Model.ValidationErrors.Count > 20)
                        {
                            <li class="text-muted">...and @(Model.ValidationErrors.Count - 20) more errors</li>
                        }
                    </ul>
                </div>
            }

            <div class="table-responsive">
                <table class="table table-hover table-sm">
                    <thead>
                        <tr>
                            <th>Status</th>
                            <th>Jurisdiction Code</th>
                            <th>Jurisdiction Name</th>
                            <th class="text-end">Population</th>
                            <th>Year</th>
                            <th>Source</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.PreviewData)
                        {
                            <tr class="@(!item.Exists ? "table-danger" : "")">
                                <td>
                                    @if (item.Exists)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check"></i> Found</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-x"></i> Not Found</span>
                                    }
                                </td>
                                <td><code>@item.JurisdictionCode</code></td>
                                <td>@item.JurisdictionName</td>
                                <td class="text-end">@item.Population.ToString("N0")</td>
                                <td>@(item.PopulationYear?.ToString() ?? "-")</td>
                                <td>@(item.PopulationSource ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.ValidationErrors.Any())
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle me-2"></i>
                    <strong>All validations passed!</strong> Click "Confirm & Import" to update population data.
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
