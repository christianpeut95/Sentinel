@page
@model Sentinel.Pages.Settings.Occupations.DeleteModel

@{
    ViewData["Title"] = "Delete Occupation";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Occupations/Index">Occupations</a></li>
        <li class="breadcrumb-item active" aria-current="page">Delete: @Model.Occupation.Name</li>
    </ol>
</nav>

<h1>Delete Occupation</h1>

<h3 class="text-danger">Are you sure you want to delete this?</h3>
<div>
    <h4>ANZSCO Occupation</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Occupation.Code)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Occupation.Code)
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Occupation.Name)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Occupation.Name)
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Occupation.MajorGroupName)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Occupation.MajorGroupName)
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Occupation.MinorGroupName)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Occupation.MinorGroupName)
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Occupation.IsActive)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Occupation.IsActive)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="Occupation.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
