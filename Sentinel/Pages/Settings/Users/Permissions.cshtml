@page
@using Sentinel.Models
@model Sentinel.Pages.Settings.Users.PermissionsModel

@{
    ViewData["Title"] = $"Manage Permissions - {Model.User.Email}";
    ViewData["Subtitle"] = "Configure user permissions";
    Layout = "~/Pages/Shared/_LayoutSentinel.cshtml";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
            <li class="breadcrumb-item"><a asp-page="./Index">Users</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.User.Email - Permissions</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Manage User Permissions</h1>
            <p class="text-muted">
                User: <strong>@Model.User.Email</strong>
                @if (Model.UserRoles.Any())
                {
                    <br />
                    <span>Roles: @string.Join(", ", Model.UserRoles)</span>
                }
            </p>
        </div>
        <div>
            <a asp-page="./Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Users
            </a>
        </div>
    </div>

    <div class="alert alert-info" role="alert">
        <i class="bi bi-info-circle"></i>
        <strong>User-Specific Permissions:</strong> These permissions override role-based permissions.
        Permissions granted by roles are shown with a blue badge and cannot be removed here.
    </div>

    <form method="post">
        <div class="card">
            <div class="card-body">
                @foreach (var moduleGroup in Model.PermissionsByModule.OrderBy(g => g.Key))
                {
                    <div class="mb-4">
                        <h5 class="border-bottom pb-2">
                            <i class="bi bi-@GetModuleIcon(moduleGroup.Key)"></i>
                            @moduleGroup.Key
                        </h5>
                        <div class="row">
                            @foreach (var permission in moduleGroup.Value.OrderBy(p => p.Action))
                            {
                                var isGrantedByUser = Model.GrantedPermissionIds.Contains(permission.Id);
                                var isGrantedByRole = Model.RolePermissionIds.Contains(permission.Id);
                                
                                <div class="col-md-6 col-lg-4 mb-3">
                                    <div class="form-check">
                                        <input class="form-check-input" 
                                               type="checkbox" 
                                               name="SelectedPermissions" 
                                               value="@permission.Id"
                                               id="permission_@permission.Id"
                                               @(isGrantedByUser ? "checked" : "")
                                               @(isGrantedByRole ? "disabled" : "") />
                                        <label class="form-check-label" for="permission_@permission.Id">
                                            <strong>@GetFriendlyActionName(permission.Action)</strong>
                                            @if (isGrantedByRole)
                                            {
                                                <span class="badge bg-primary ms-1" title="Granted by role">Role</span>
                                            }
                                            <br />
                                            <small class="text-muted">@permission.Description</small>
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-circle"></i> Save Permissions
            </button>
            <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@functions {
    private string GetModuleIcon(PermissionModule module)
    {
        return module switch
        {
            PermissionModule.Patient => "person",
            PermissionModule.Case => "virus",
            PermissionModule.Settings => "gear",
            PermissionModule.Audit => "clock-history",
            PermissionModule.User => "people",
            PermissionModule.Report => "graph-up",
            _ => "app"
        };
    }

    private string GetFriendlyActionName(PermissionAction action)
    {
        return action switch
        {
            PermissionAction.View => "View",
            PermissionAction.Create => "Create",
            PermissionAction.Edit => "Edit",
            PermissionAction.Delete => "Delete",
            PermissionAction.Search => "Search",
            PermissionAction.Merge => "Merge",
            PermissionAction.Export => "Export",
            PermissionAction.Import => "Import",
            PermissionAction.ManagePermissions => "Manage Permissions",
            PermissionAction.ManageCustomFields => "Manage Custom Fields",
            PermissionAction.ManageCustomLookups => "Manage Custom Lookups",
            PermissionAction.ManageSystemLookups => "Manage System Lookups",
            PermissionAction.ManageOrganization => "Manage Organization",
            PermissionAction.ResetPassword => "Reset Password",
            _ => action.ToString()
        };
    }
}
