@page
@model Sentinel.Pages.Settings.Ancestries.EditModel

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Ancestries/Index">Ancestries</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Ancestry.Name</li>
    </ol>
</nav>

<h1>Edit</h1>

<h4>Ancestry</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Ancestry.Id" />
            <div class="form-group">
                <label asp-for="Ancestry.Name" class="control-label"></label>
                <input asp-for="Ancestry.Name" class="form-control" />
                <span asp-validation-for="Ancestry.Name" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Ancestry.IsActive" /> @Html.DisplayNameFor(model => model.Ancestry.IsActive)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
