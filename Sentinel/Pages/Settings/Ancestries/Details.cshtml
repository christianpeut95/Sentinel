@page
@model Sentinel.Pages.Settings.Ancestries.DetailsModel

@{
    ViewData["Title"] = "Details";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Ancestries/Index">Ancestries</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Ancestry.Name</li>
    </ol>
</nav>

<h1>Details</h1>

<div>
    <h4>Ancestry</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Ancestry.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Ancestry.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Ancestry.IsActive)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Ancestry.IsActive)
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Ancestry.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
