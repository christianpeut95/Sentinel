@page
@model Sentinel.Pages.Settings.LookupTables.CreateModel

@{
    ViewData["Title"] = "Create Lookup Table";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
            <li class="breadcrumb-item"><a asp-page="./Index">Lookup Tables</a></li>
            <li class="breadcrumb-item active" aria-current="page">Create</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Lookup Table</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Input.Name" class="form-label">Internal Name *</label>
                            <input asp-for="Input.Name" class="form-control" placeholder="e.g., smoking_statuses" />
                            <span asp-validation-for="Input.Name" class="text-danger"></span>
                            <small class="form-text text-muted">Lowercase letters, numbers, and underscores only. Used for internal references.</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.DisplayName" class="form-label">Display Name *</label>
                            <input asp-for="Input.DisplayName" class="form-control" placeholder="e.g., Smoking Statuses" />
                            <span asp-validation-for="Input.DisplayName" class="text-danger"></span>
                            <small class="form-text text-muted">The name shown to users in the interface.</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Description" class="form-label">Description</label>
                            <textarea asp-for="Input.Description" class="form-control" rows="3" placeholder="Describe the purpose of this lookup table..."></textarea>
                            <span asp-validation-for="Input.Description" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="Input.IsActive" class="form-check-label">
                                Active (can be used in custom fields)
                            </label>
                        </div>

                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            After creating this lookup table, you'll be able to add values to it.
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-page="./Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-2"></i>Create & Add Values
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-lightbulb me-2"></i>Tips</h5>
                </div>
                <div class="card-body">
                    <h6>What are Lookup Tables?</h6>
                    <p class="small">Lookup tables define the options available in dropdown custom fields.</p>
                    
                    <h6 class="mt-3">Naming Convention</h6>
                    <p class="small">Use descriptive, plural names like <code>smoking_statuses</code>, <code>vaccination_types</code>, etc.</p>
                    
                    <h6 class="mt-3">Examples</h6>
                    <ul class="small">
                        <li>Smoking Statuses: Never, Former, Current</li>
                        <li>Risk Categories: Low, Medium, High</li>
                        <li>Vaccination Types: COVID-19, Influenza, etc.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
