@page
@model Sentinel.Pages.Settings.LookupTables.DeleteModel

@{
    ViewData["Title"] = "Delete Lookup Table";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
            <li class="breadcrumb-item"><a asp-page="./Index">Lookup Tables</a></li>
            <li class="breadcrumb-item active" aria-current="page">Delete: @Model.LookupTable.DisplayName</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-trash me-2"></i>Delete Lookup Table</h4>
                </div>
                <div class="card-body">
                    @if (!Model.CanDelete)
                    {
                        <div class="alert alert-danger">
                            <h5><i class="bi bi-exclamation-triangle me-2"></i>Cannot Delete</h5>
                            <p class="mb-0">This lookup table is currently in use by <strong>@Model.UsedByFieldsCount</strong> custom field(s) and cannot be deleted.</p>
                        </div>

                        <div class="card mb-3">
                            <div class="card-header bg-light">
                                <strong>Used by the following custom fields:</strong>
                            </div>
                            <ul class="list-group list-group-flush">
                                @foreach (var field in Model.UsedByFields)
                                {
                                    <li class="list-group-item">@field</li>
                                }
                            </ul>
                        </div>

                        <p class="text-muted">
                            To delete this lookup table, you must first delete or change the custom fields that reference it.
                        </p>

                        <a asp-page="./Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Back to List
                        </a>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <h5><i class="bi bi-exclamation-triangle me-2"></i>Are you sure you want to delete this lookup table?</h5>
                            <p class="mb-0">This action cannot be undone.</p>
                        </div>

                        <dl class="row">
                            <dt class="col-sm-4">Display Name:</dt>
                            <dd class="col-sm-8">@Model.LookupTable.DisplayName</dd>

                            <dt class="col-sm-4">Internal Name:</dt>
                            <dd class="col-sm-8"><code>@Model.LookupTable.Name</code></dd>

                            @if (!string.IsNullOrEmpty(Model.LookupTable.Description))
                            {
                                <dt class="col-sm-4">Description:</dt>
                                <dd class="col-sm-8">@Model.LookupTable.Description</dd>
                            }

                            <dt class="col-sm-4">Values:</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-info">@Model.ValuesCount value(s)</span>
                            </dd>

                            <dt class="col-sm-4">Status:</dt>
                            <dd class="col-sm-8">
                                @if (Model.LookupTable.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </dd>

                            <dt class="col-sm-4">Created:</dt>
                            <dd class="col-sm-8">@Model.LookupTable.CreatedAt.ToString("dd MMM yyyy HH:mm")</dd>
                        </dl>

                        @if (Model.ValuesCount > 0)
                        {
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle me-2"></i>
                                This will also delete all <strong>@Model.ValuesCount</strong> value(s) associated with this lookup table.
                            </div>
                        }

                        <form method="post">
                            <div class="d-flex justify-content-between">
                                <a asp-page="./Index" class="btn btn-secondary">
                                    <i class="bi bi-arrow-left me-2"></i>Cancel
                                </a>
                                <button type="submit" class="btn btn-danger">
                                    <i class="bi bi-trash me-2"></i>Delete Lookup Table
                                </button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
