@page
@model Sentinel.Pages.Settings.LookupTables.ManageValuesModel

@{
    ViewData["Title"] = "Manage Lookup Values";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
            <li class="breadcrumb-item"><a asp-page="./Index">Lookup Tables</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.LookupTable.DisplayName</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2><i class="bi bi-list-check me-2"></i>Manage Values: @Model.LookupTable.DisplayName</h2>
            @if (!string.IsNullOrEmpty(Model.LookupTable.Description))
            {
                <p class="text-muted">@Model.LookupTable.Description</p>
            }
        </div>
        <a asp-page="./Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back to Lookup Tables
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Existing Values</h5>
                </div>
                <div class="card-body">
                    @if (!Model.Values.Any())
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-inbox" style="font-size: 3rem; color: #dee2e6;"></i>
                            <p class="text-muted mt-2">No values defined yet. Add your first value using the form on the right.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th style="width: 80px;">Order</th>
                                        <th>Display Text</th>
                                        <th>Internal Value</th>
                                        <th>Status</th>
                                        <th style="width: 200px;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.Values.Count; i++)
                                    {
                                        var value = Model.Values[i];
                                        <tr class="@(!value.IsActive ? "table-secondary" : "")">
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <form method="post" asp-page-handler="Reorder" asp-route-id="@Model.LookupTable.Id" asp-route-valueId="@value.Id" asp-route-direction="up" style="display: inline;">
                                                        <button type="submit" class="btn btn-outline-secondary btn-sm" @(i == 0 ? "disabled" : "")>
                                                            <i class="bi bi-arrow-up"></i>
                                                        </button>
                                                    </form>
                                                    <form method="post" asp-page-handler="Reorder" asp-route-id="@Model.LookupTable.Id" asp-route-valueId="@value.Id" asp-route-direction="down" style="display: inline;">
                                                        <button type="submit" class="btn btn-outline-secondary btn-sm" @(i == Model.Values.Count - 1 ? "disabled" : "")>
                                                            <i class="bi bi-arrow-down"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                            <td>
                                                <strong>@value.DisplayText</strong>
                                            </td>
                                            <td>
                                                <code>@value.Value</code>
                                            </td>
                                            <td>
                                                @if (value.IsActive)
                                                {
                                                    <span class="badge bg-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Inactive</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <form method="post" asp-page-handler="ToggleActive" asp-route-id="@Model.LookupTable.Id" asp-route-valueId="@value.Id" style="display: inline;">
                                                        <button type="submit" class="btn btn-outline-info" title="@(value.IsActive ? "Deactivate" : "Activate")">
                                                            <i class="bi bi-@(value.IsActive ? "eye-slash" : "eye")"></i>
                                                        </button>
                                                    </form>
                                                    <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-@value.Id" title="Delete">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>

                                                <!-- Delete Confirmation Modal -->
                                                <div class="modal fade" id="deleteModal-@value.Id" tabindex="-1" aria-labelledby="deleteModalLabel-@value.Id" aria-hidden="true">
                                                    <div class="modal-dialog">
                                                        <div class="modal-content">
                                                            <div class="modal-header bg-danger text-white">
                                                                <h5 class="modal-title" id="deleteModalLabel-@value.Id">Confirm Delete</h5>
                                                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                                            </div>
                                                            <div class="modal-body">
                                                                <p>Are you sure you want to delete the value <strong>"@value.DisplayText"</strong>?</p>
                                                                <p class="text-muted mb-0">This action cannot be undone. If this value is used in patient records, the deletion will fail.</p>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                                <form method="post" asp-page-handler="Delete" asp-route-id="@Model.LookupTable.Id" asp-route-valueId="@value.Id" style="display: inline;">
                                                                    <button type="submit" class="btn btn-danger">Delete</button>
                                                                </form>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="alert alert-info mt-3">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Tips:</strong> Use the arrow buttons to reorder values. Inactive values won't appear in dropdowns but are kept for historical data.
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm sticky-top" style="top: 20px;">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Add New Value</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="Add" asp-route-id="@Model.LookupTable.Id">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Input.Value" class="form-label">Internal Value *</label>
                            <input asp-for="Input.Value" class="form-control" placeholder="e.g., current_smoker" />
                            <span asp-validation-for="Input.Value" class="text-danger"></span>
                            <small class="form-text text-muted">Lowercase, numbers, underscores only</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.DisplayText" class="form-label">Display Text *</label>
                            <input asp-for="Input.DisplayText" class="form-control" placeholder="e.g., Current Smoker" />
                            <span asp-validation-for="Input.DisplayText" class="text-danger"></span>
                            <small class="form-text text-muted">What users will see in dropdowns</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.DisplayOrder" class="form-label">Display Order *</label>
                            <input asp-for="Input.DisplayOrder" class="form-control" type="number" />
                            <span asp-validation-for="Input.DisplayOrder" class="text-danger"></span>
                            <small class="form-text text-muted">Lower numbers appear first</small>
                        </div>

                        <div class="form-check mb-3">
                            <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" checked />
                            <label asp-for="Input.IsActive" class="form-check-label">
                                Active
                            </label>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-plus-lg me-2"></i>Add Value
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
