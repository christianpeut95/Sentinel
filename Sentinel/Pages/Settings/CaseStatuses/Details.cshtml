@page
@model Sentinel.Pages.Settings.CaseStatuses.DetailsModel

@{
    ViewData["Title"] = "Case Status Details";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Case Status</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.CaseStatus.Name</li>
    </ol>
</nav>

<h2><i class="bi bi-info-circle me-2"></i>Case Status Details</h2>
<hr />

<div>
    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.CaseStatus.Name</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@(Model.CaseStatus.Description ?? "-")</dd>

        <dt class="col-sm-3">Display Order</dt>
        <dd class="col-sm-9">@(Model.CaseStatus.DisplayOrder?.ToString() ?? "-")</dd>

        <dt class="col-sm-3">Is Active</dt>
        <dd class="col-sm-9">
            @if (Model.CaseStatus.IsActive)
            {
                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Active</span>
            }
            else
            {
                <span class="badge bg-secondary"><i class="bi bi-x-circle"></i> Inactive</span>
            }
        </dd>
    </dl>
</div>

<div class="mt-3">
    <a asp-page="./Edit" asp-route-id="@Model.CaseStatus.Id" class="btn btn-primary"><i class="bi bi-pencil me-1"></i>Edit</a>
    <a asp-page="./Index" class="btn btn-outline-secondary ms-2"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
</div>
