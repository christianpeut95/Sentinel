@page
@model Sentinel.Pages.Settings.HL7.Configurations.IndexModel

@{
    ViewData["Title"] = "HL7 Configurations";
    Layout = "~/Pages/Shared/_LayoutSentinel.cshtml";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item active" aria-current="page">HL7 Configurations</li>
    </ol>
</nav>

<div class="sentinel-page-header mb-4">
    <div>
        <div class="sentinel-eyebrow">HL7 Interface</div>
        <h1 class="sentinel-page-title">HL7 Configurations</h1>
        <p class="sentinel-page-subtitle">Manage laboratory HL7 message processing configurations</p>
    </div>
    <div>
        <a asp-page="/Settings/HL7/FieldMappings/SelectLab" class="sn-btn sn-btn--signal">
            <i class="bi bi-sliders me-1"></i>Configure Lab Mappings
        </a>
        <a asp-page="./Create" class="sn-btn sn-btn--ghost ms-2">
            <i class="bi bi-plus-circle me-1"></i>Add Configuration
        </a>
        <a asp-page="/Settings/HL7/DiseaseMatching/Index" class="sn-btn sn-btn--ghost ms-2">
            <i class="bi bi-diagram-3 me-1"></i>Disease Matching
        </a>
        <a asp-page="/Settings/HL7/Testing" class="sn-btn sn-btn--ghost ms-2">
            <i class="bi bi-flask me-1"></i>Testing Tools
        </a>
        <a asp-page="/Settings/HL7/Monitoring/Dashboard" class="sn-btn sn-btn--ghost ms-2">
            <i class="bi bi-activity me-1"></i>Monitor
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Monitoring Status Summary -->
@if (Model.MonitoringStatus != null)
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="kpi">
                <div class="kpi-label">Active Watchers</div>
                <div class="kpi-value">@Model.MonitoringStatus.ActiveWatchers</div>
                <div class="kpi-delta">
                    @if (Model.MonitoringStatus.IsMonitoring)
                    {
                        <span class="chip clear" style="font-size:10px;padding:3px 8px">
                            <span class="dot"></span>Monitoring
                        </span>
                    }
                    else
                    {
                        <span class="chip" style="background:#E3E9FB;color:#2A3970;font-size:10px;padding:3px 8px">
                            <span class="dot" style="background:#6B8CF5"></span>Stopped
                        </span>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi">
                <div class="kpi-label">Files Today</div>
                <div class="kpi-value"><em>@Model.MonitoringStatus.FilesProcessedToday</em></div>
                <div class="kpi-delta">@(Model.MonitoringStatus.FilesFailedToday > 0 ? $"↑ {Model.MonitoringStatus.FilesFailedToday} errors" : "No errors")</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi">
                <div class="kpi-label">Errors Today</div>
                <div class="kpi-value" style="color:@(Model.MonitoringStatus.FilesFailedToday > 0 ? "var(--outbreak)" : "inherit")"><em>@Model.MonitoringStatus.FilesFailedToday</em></div>
                <div class="kpi-delta">@(Model.MonitoringStatus.FilesFailedToday > 0 ? "Requires attention" : "All good")</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi">
                <div class="kpi-label">Last File</div>
                <div class="kpi-value" style="font-size:16px;font-family:var(--f-mono)">
                    @if (Model.MonitoringStatus.LastFileProcessedAt != null)
                    {
                        @Model.MonitoringStatus.LastFileProcessedAt.Value.ToLocalTime().ToString("HH:mm")
                    }
                    else
                    {
                        <span style="color:var(--graphite)">—</span>
                    }
                </div>
                <div class="kpi-delta">
                    @if (Model.MonitoringStatus.LastFileProcessedAt != null)
                    {
                        var elapsed = DateTime.UtcNow - Model.MonitoringStatus.LastFileProcessedAt.Value;
                        if (elapsed.TotalMinutes < 60)
                        {
                            @($"{(int)elapsed.TotalMinutes}m ago")
                        }
                        else
                        {
                            @($"{(int)elapsed.TotalHours}h ago")
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Configurations Table -->
<div class="card">
    @if (!Model.Configurations.Any())
    {
        <div class="card-body text-center py-5">
            <div style="font-size:48px;color:var(--graphite);opacity:0.3;margin-bottom:20px">
                <i class="bi bi-diagram-3"></i>
            </div>
            <h5 style="color:var(--graphite);margin-bottom:8px">No HL7 configurations</h5>
            <p style="color:var(--graphite);font-size:14px;margin-bottom:24px">Create a configuration to start processing HL7 laboratory messages.</p>
            <a asp-page="./Create" class="sn-btn sn-btn--signal">
                <i class="bi bi-plus-circle me-1"></i>Create first configuration
            </a>
        </div>
    }
    else
    {
        <table class="sn-table">
            <thead>
                <tr>
                    <th>Configuration</th>
                    <th>Facility</th>
                    <th>File Drop Path</th>
                    <th>Strategies</th>
                    <th>Status</th>
                    <th>Priority</th>
                    <th style="width:180px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var config in Model.Configurations)
                {
                    <tr>
                        <td>
                            <div style="font-weight:500">@config.ConfigurationName</div>
                            @if (!string.IsNullOrWhiteSpace(config.SendingApplication))
                            {
                                <div style="font-family:var(--f-mono);font-size:11px;color:var(--graphite);margin-top:2px">
                                    @config.SendingApplication
                                </div>
                            }
                        </td>
                        <td style="font-family:var(--f-mono);font-size:12px">@config.SendingFacility</td>
                        <td>
                            <code style="font-size:11px;color:var(--graphite)">@config.FileDropPath</code>
                            @if (System.IO.Directory.Exists(config.FileDropPath))
                            {
                                <span class="chip clear" style="font-size:9px;padding:2px 6px;margin-left:6px">
                                    <span class="dot"></span>exists
                                </span>
                            }
                            else
                            {
                                <span class="chip outbreak" style="font-size:9px;padding:2px 6px;margin-left:6px">
                                    <span class="dot"></span>missing
                                </span>
                            }
                        </td>
                        <td style="font-size:12px">
                            <div style="margin-bottom:3px">
                                <strong style="color:var(--graphite)">Patient:</strong> @config.PatientMatchingStrategy.ToString().Replace("_", " ")
                            </div>
                            <div>
                                <strong style="color:var(--graphite)">Duplicate:</strong> @config.DuplicateDetectionStrategy.ToString().Replace("_", " ")
                            </div>
                        </td>
                        <td>
                            @if (config.IsActive)
                            {
                                <span class="chip clear">
                                    <span class="dot"></span>Active
                                </span>
                            }
                            else
                            {
                                <span class="chip" style="background:#E3E9FB;color:#2A3970">
                                    <span class="dot" style="background:#6B8CF5"></span>Inactive
                                </span>
                            }
                            @if (config.IsTestMode)
                            {
                                <span class="chip watch" style="font-size:10px;padding:3px 8px;margin-top:4px">
                                    <span class="dot"></span>Test Mode
                                </span>
                            }
                            @if (config.AutoCreateCases)
                            {
                                <span class="chip info" style="font-size:10px;padding:3px 8px;margin-top:4px">
                                    <span class="dot"></span>Auto-create
                                </span>
                            }
                        </td>
                        <td style="font-family:var(--f-mono);font-size:13px;text-align:center">@config.Priority</td>
                        <td>
                            <div style="display:flex;gap:6px;flex-wrap:wrap">
                                <a asp-page="./ManageDiseases" asp-route-id="@config.Id" class="sn-btn sn-btn--signal sn-btn--sm" title="Manage disease mappings">
                                    <i class="bi bi-diagram-3"></i> Diseases
                                </a>
                                <a asp-page="./Edit" asp-route-id="@config.Id" class="sn-btn sn-btn--ghost sn-btn--sm" title="Edit settings">
                                    <i class="bi bi-gear"></i>
                                </a>
                                <button type="button" class="sn-btn sn-btn--ghost sn-btn--sm" 
                                        onclick="confirmDelete('@config.Id', '@config.ConfigurationName')" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" style="background:var(--chalk);border:1px solid var(--hairline)">
            <div class="modal-header" style="border-bottom:1px solid var(--hairline)">
                <h5 class="modal-title" style="color:var(--forest)">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p style="color:var(--graphite)">Delete configuration <strong id="deleteConfigName"></strong>?</p>
                <p style="color:var(--outbreak);font-size:14px">This will stop file monitoring for this configuration. Processed messages will remain in the database.</p>
            </div>
            <div class="modal-footer" style="border-top:1px solid var(--hairline)">
                <form method="post" id="deleteForm">
                    <input type="hidden" name="id" id="deleteConfigId" />
                    <button type="button" class="sn-btn sn-btn--ghost" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="sn-btn sn-btn--danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id, name) {
            document.getElementById('deleteConfigId').value = id;
            document.getElementById('deleteConfigName').textContent = name;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}
