@page
@model Sentinel.Pages.Settings.HL7.Messages.IndexModel

@{
    ViewData["Title"] = "HL7 Messages";
    Layout = "~/Pages/Shared/_LayoutSentinel.cshtml";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item active" aria-current="page">HL7 Messages</li>
    </ol>
</nav>

<div class="sentinel-page-header mb-4">
    <div>
        <div class="sentinel-eyebrow">HL7 Interface</div>
        <h1 class="sentinel-page-title">HL7 Messages</h1>
        <p class="sentinel-page-subtitle">Review and reprocess HL7 laboratory messages</p>
    </div>
    <div>
        <a asp-page="/Settings/HL7/Monitoring/Dashboard" class="sn-btn sn-btn--ghost">
            <i class="bi bi-activity me-1"></i>Dashboard
        </a>
    </div>
</div>

<!-- Filters -->
<div class="sentinel-card mb-4">
    <div class="sentinel-card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label for="statusFilter" class="sn-label">Status</label>
                <select name="status" id="statusFilter" class="sn-input">
                    <option value="">-- All Statuses --</option>
                    @foreach (var status in Enum.GetValues<Sentinel.Models.HL7ProcessingStatus>())
                    {
                        <option value="@status" selected="@(status.ToString() == Model.StatusFilter)">
                            @status.ToString().Replace("_", " ")
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label for="facilityFilter" class="sn-label">Facility</label>
                <select name="facility" id="facilityFilter" class="sn-input">
                    <option value="">-- All Facilities --</option>
                    @foreach (var facility in Model.Facilities)
                    {
                        <option value="@facility" selected="@(facility == Model.FacilityFilter)">@facility</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label for="dateFrom" class="sn-label">From Date</label>
                <input type="date" name="dateFrom" id="dateFrom" class="sn-input" value="@Model.DateFromFilter?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2">
                <label for="dateTo" class="sn-label">To Date</label>
                <input type="date" name="dateTo" id="dateTo" class="sn-input" value="@Model.DateToFilter?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="sn-btn sn-btn--ghost w-100">
                    <i class="bi bi-funnel me-1"></i>Filter
                </button>
            </div>
        </form>
        @if (Model.HasFilters)
        {
            <div class="mt-3">
                <a asp-page="./Index" class="sn-btn sn-btn--ghost sn-btn--sm">
                    <i class="bi bi-x-circle me-1"></i>Clear all filters
                </a>
            </div>
        }
    </div>
</div>

<!-- Summary Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="kpi">
            <div class="kpi-label">Total Messages</div>
            <div class="kpi-value"><em>@Model.TotalCount</em></div>
            <div class="kpi-delta">
                @if (Model.HasFilters)
                {
                    <text>Filtered results</text>
                }
                else
                {
                    <text>All time</text>
                }
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi">
            <div class="kpi-label">Processed</div>
            <div class="kpi-value"><em>@Model.ProcessedCount</em></div>
            <div class="kpi-delta">@(Model.TotalCount > 0 ? $"{(Model.ProcessedCount * 100.0 / Model.TotalCount):F1}%" : "—")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi">
            <div class="kpi-label">Errors</div>
            <div class="kpi-value" style="color:@(Model.ErrorCount > 0 ? "var(--outbreak)" : "inherit")"><em>@Model.ErrorCount</em></div>
            <div class="kpi-delta up">@(Model.TotalCount > 0 ? $"{(Model.ErrorCount * 100.0 / Model.TotalCount):F1}%" : "—")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi">
            <div class="kpi-label">Manual Review</div>
            <div class="kpi-value"><em>@Model.ReviewCount</em></div>
            <div class="kpi-delta">Requires attention</div>
        </div>
    </div>
</div>

<!-- Messages Table -->
<div class="card">
    @if (!Model.Messages.Any())
    {
        <div class="card-body text-center py-5">
            <div style="font-size:48px;color:var(--graphite);opacity:0.3;margin-bottom:20px">
                <i class="bi bi-inbox"></i>
            </div>
            <h5 style="color:var(--graphite);margin-bottom:8px">No messages found</h5>
            <p style="color:var(--graphite);font-size:14px">
                @if (Model.HasFilters)
                {
                    <text>No messages match your filter criteria. Try adjusting the filters.</text>
                }
                else
                {
                    <text>No HL7 messages have been processed yet.</text>
                }
            </p>
        </div>
    }
    else
    {
        <table class="sn-table">
            <thead>
                <tr>
                    <th>Received</th>
                    <th>Message ID</th>
                    <th>Configuration</th>
                    <th>Patient</th>
                    <th>Test(s)</th>
                    <th>Status</th>
                    <th>Cases</th>
                    <th style="width:120px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var msg in Model.Messages)
                {
                    <tr>
                        <td style="font-family:var(--f-mono);font-size:12px">
                            <div>@msg.ReceivedAt.ToLocalTime().ToString("MM/dd/yyyy")</div>
                            <div style="color:var(--graphite)">@msg.ReceivedAt.ToLocalTime().ToString("HH:mm:ss")</div>
                        </td>
                        <td style="font-family:var(--f-mono);font-size:11px">@msg.MessageControlId</td>
                        <td>
                            <div style="font-weight:500;font-size:13px">@msg.Configuration?.ConfigurationName</div>
                            <div style="font-family:var(--f-mono);font-size:11px;color:var(--graphite);margin-top:2px">
                                @msg.SendingFacility
                            </div>
                        </td>
                        <td style="font-size:13px">
                            @if (msg.Patient != null)
                            {
                                <div>@msg.Patient.GivenName @msg.Patient.FamilyName</div>
                                @if (!string.IsNullOrWhiteSpace(msg.Patient.FriendlyId))
                                {
                                    <div style="font-family:var(--f-mono);font-size:11px;color:var(--graphite);margin-top:2px">
                                        @msg.Patient.FriendlyId
                                    </div>
                                }
                            }
                            else
                            {
                                <span style="color:var(--graphite)">—</span>
                            }
                        </td>
                        <td style="font-family:var(--f-mono);font-size:11px">
                            @if (msg.Segments?.Any() == true)
                            {
                                var obxSegments = msg.Segments.Where(s => s.SegmentType == "OBX").Take(2).ToList();
                                foreach (var segment in obxSegments)
                                {
                                    <div>@segment.RawSegment.Substring(0, Math.Min(20, segment.RawSegment.Length))...</div>
                                }
                                var totalObx = msg.Segments.Count(s => s.SegmentType == "OBX");
                                if (totalObx > 2)
                                {
                                    <div style="color:var(--graphite)">+@(totalObx - 2) more</div>
                                }
                            }
                            else
                            {
                                <span style="color:var(--graphite)">—</span>
                            }
                        </td>
                        <td>
                            @switch (msg.Status)
                            {
                                case Sentinel.Models.HL7ProcessingStatus.ProcessedSuccessfully:
                                    <span class="chip clear">
                                        <span class="dot"></span>Processed
                                    </span>
                                    break;
                                case Sentinel.Models.HL7ProcessingStatus.ProcessingFailed:
                                    <span class="chip outbreak">
                                        <span class="dot"></span>Error
                                    </span>
                                    break;
                                case Sentinel.Models.HL7ProcessingStatus.DuplicateDetected:
                                    <span class="chip watch">
                                        <span class="dot"></span>Duplicate
                                    </span>
                                    break;
                                case Sentinel.Models.HL7ProcessingStatus.AwaitingManualReview:
                                    <span class="chip info">
                                        <span class="dot"></span>Review
                                    </span>
                                    break;
                                default:
                                    <span class="chip" style="background:#E3E9FB;color:#2A3970">
                                        <span class="dot" style="background:#6B8CF5"></span>@msg.Status
                                    </span>
                                    break;
                            }
                        </td>
                        <td style="font-family:var(--f-mono);font-size:13px;text-align:center">
                            @if (msg.Case != null)
                            {
                                <a asp-page="/Cases/Details" asp-route-id="@msg.Case.Id" style="color:var(--signal-dk);font-weight:500">
                                    1
                                </a>
                            }
                            else
                            {
                                <span style="color:var(--graphite)">—</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm" role="group">
                                <a asp-page="./Details" asp-route-id="@msg.Id" class="sn-btn sn-btn--ghost sn-btn--sm" title="View Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (msg.Status == Sentinel.Models.HL7ProcessingStatus.ProcessingFailed || 
                                     msg.Status == Sentinel.Models.HL7ProcessingStatus.AwaitingManualReview)
                                {
                                    <button type="button" class="sn-btn sn-btn--ghost sn-btn--sm" 
                                            onclick="reprocessMessage('@msg.Id')" title="Reprocess">
                                        <i class="bi bi-arrow-clockwise"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="p-3 border-top">
                <nav>
                    <ul class="pagination pagination-sm justify-content-center mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-page="./Index" asp-route-page="@(Model.CurrentPage - 1)" 
                               asp-route-status="@Model.StatusFilter" asp-route-facility="@Model.FacilityFilter"
                               asp-route-dateFrom="@Model.DateFromFilter?.ToString("yyyy-MM-dd")" 
                               asp-route-dateTo="@Model.DateToFilter?.ToString("yyyy-MM-dd")">Previous</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-page="./Index" asp-route-page="@i"
                                   asp-route-status="@Model.StatusFilter" asp-route-facility="@Model.FacilityFilter"
                                   asp-route-dateFrom="@Model.DateFromFilter?.ToString("yyyy-MM-dd")" 
                                   asp-route-dateTo="@Model.DateToFilter?.ToString("yyyy-MM-dd")">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-page="./Index" asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-status="@Model.StatusFilter" asp-route-facility="@Model.FacilityFilter"
                               asp-route-dateFrom="@Model.DateFromFilter?.ToString("yyyy-MM-dd")" 
                               asp-route-dateTo="@Model.DateToFilter?.ToString("yyyy-MM-dd")">Next</a>
                        </li>
                    </ul>
                </nav>
                <div class="text-center mt-2" style="font-family:var(--f-mono);font-size:11px;color:var(--graphite)">
                    Showing @((Model.CurrentPage - 1) * 50 + 1)–@Math.Min(Model.CurrentPage * 50, Model.TotalCount) of @Model.TotalCount messages
                </div>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        function reprocessMessage(id) {
            if (confirm('Reprocess this message? This will attempt to re-extract data and re-match cases.')) {
                fetch(`/api/hl7/reprocess/${id}`, { method: 'POST' })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            alert('Message reprocessed successfully.');
                            location.reload();
                        } else {
                            alert('Error reprocessing message: ' + data.error);
                        }
                    })
                    .catch(error => alert('Error: ' + error));
            }
        }
    </script>
}
