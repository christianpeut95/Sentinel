@page
@using Sentinel.Models
@model Sentinel.Pages.Settings.HL7.TestingModel
@{
    ViewData["Title"] = "HL7 Testing Tools";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>🧪 HL7 Testing & Management</h1>
            <p class="text-muted">Reprocess messages, view status, and manage test data</p>
        </div>
        <div>
            <a asp-page="/Settings/HL7/Configurations/Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to Configurations
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <pre class="mb-0" style="white-space: pre-wrap;">@TempData["SuccessMessage"]</pre>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["WarningMessage"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <pre class="mb-0" style="white-space: pre-wrap;">@TempData["WarningMessage"]</pre>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-x-circle-fill"></i>
            <pre class="mb-0" style="white-space: pre-wrap;">@TempData["ErrorMessage"]</pre>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Monitoring Status Card -->
    @if (Model.MonitoringStatus != null)
    {
        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-activity"></i> File Monitor Status</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3">
                        <div class="mb-3">
                            <strong>Status:</strong>
                            @if (Model.MonitoringStatus.IsMonitoring)
                            {
                                <span class="badge bg-success">🟢 Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">⚫ Inactive</span>
                            }
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <strong>Active Watchers:</strong>
                            <span class="badge bg-primary">@Model.MonitoringStatus.ActiveWatchers</span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <strong>Files Today:</strong>
                            <span class="badge bg-success">@Model.MonitoringStatus.FilesProcessedToday success</span>
                            <span class="badge bg-danger">@Model.MonitoringStatus.FilesFailedToday failed</span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <strong>Started:</strong>
                            @if (Model.MonitoringStatus.MonitoringStartedAt.HasValue)
                            {
                                <span>@Model.MonitoringStatus.MonitoringStartedAt.Value.ToString("g")</span>
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </div>
                    </div>
                </div>
                @if (Model.MonitoringStatus.MonitoredPaths.Any())
                {
                    <div class="mt-2">
                        <strong>Monitored Paths:</strong>
                        <ul class="mb-0">
                            @foreach (var path in Model.MonitoringStatus.MonitoredPaths)
                            {
                                <li><code>@path</code></li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Quick Actions Card -->
    <div class="card mb-4">
        <div class="card-header bg-warning">
            <h5 class="mb-0"><i class="bi bi-tools"></i> Quick Actions</h5>
        </div>
        <div class="card-body">
            <div class="d-flex gap-2">
                <form method="post" asp-page-handler="ClearAll" 
                      onsubmit="return confirm('⚠️ This will delete ALL HL7 messages, lab results, and cases from the database.\n\nPatients will NOT be deleted.\n\nThis action cannot be undone. Continue?');">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash3"></i> Clear All Test Data
                    </button>
                </form>
                <button type="button" class="btn btn-secondary" onclick="location.reload()">
                    <i class="bi bi-arrow-clockwise"></i> Refresh
                </button>
            </div>
            <div class="mt-3">
                <small class="text-muted">
                    <strong>Clear All:</strong> Removes all HL7 messages and their related lab results and cases. 
                    Useful for resetting your test environment.
                </small>
            </div>
        </div>
    </div>

    <!-- Messages Table Card -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-file-earmark-medical"></i> Recent HL7 Messages (Last 100)</h5>
        </div>
        <div class="card-body">
            @if (!Model.Messages.Any())
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> No HL7 messages found. Drop an HL7 file into a monitored folder to get started.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Message ID</th>
                                <th>Type</th>
                                <th>Status</th>
                                <th>Received</th>
                                <th>Processed</th>
                                <th>Patient</th>
                                <th>Lab Result</th>
                                <th>Case</th>
                                <th style="width: 180px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var message in Model.Messages)
                            {
                                <tr class="@(message.Status == HL7ProcessingStatus.ProcessingFailed ? "table-danger" : "")">
                                    <td>
                                        <code class="small">@message.MessageControlId</code>
                                        @if (!string.IsNullOrEmpty(message.ErrorMessage))
                                        {
                                            <br />
                                            <small class="text-danger" title="@message.ErrorMessage">
                                                <i class="bi bi-exclamation-triangle"></i> Error
                                            </small>
                                        }
                                    </td>
                                    <td><small>@(message.MessageType ?? "-")</small></td>
                                    <td>
                                        @switch (message.Status)
                                        {
                                            case HL7ProcessingStatus.ProcessedSuccessfully:
                                                <span class="badge bg-success" title="Processed successfully">✅ Success</span>
                                                break;
                                            case HL7ProcessingStatus.ProcessingFailed:
                                                <span class="badge bg-danger" title="@message.ErrorMessage">❌ Failed</span>
                                                break;
                                            case HL7ProcessingStatus.AwaitingManualReview:
                                                <span class="badge bg-warning text-dark" title="Requires manual review">⚠️ Review</span>
                                                break;
                                            case HL7ProcessingStatus.ParsingFailed:
                                                <span class="badge bg-danger" title="Failed to parse">❌ Parse Error</span>
                                                break;
                                            case HL7ProcessingStatus.Received:
                                            case HL7ProcessingStatus.QueuedForParsing:
                                            case HL7ProcessingStatus.QueuedForProcessing:
                                                <span class="badge bg-secondary" title="Not yet processed">⏳ Pending</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">@message.Status</span>
                                                break;
                                        }
                                    </td>
                                    <td><small>@message.ReceivedAt.ToString("g")</small></td>
                                    <td><small>@(message.ProcessedAt?.ToString("g") ?? "-")</small></td>
                                    <td>
                                        @if (message.PatientId.HasValue)
                                        {
                                            <a asp-page="/Patients/Details" asp-route-id="@message.PatientId" 
                                               class="text-decoration-none" target="_blank">
                                                @message.PatientName
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (message.HasLabResult && message.LabResultId.HasValue)
                                        {
                                            <a asp-page="/LabResults/Details" asp-route-id="@message.LabResultId" 
                                               class="text-decoration-none" target="_blank">
                                                <i class="bi bi-check-circle text-success"></i> View
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (message.HasCase && message.CaseId.HasValue)
                                        {
                                            <a asp-page="/Cases/Details" asp-route-id="@message.CaseId" 
                                               class="text-decoration-none" target="_blank">
                                                <i class="bi bi-check-circle text-success"></i> View
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <button type="button" class="btn btn-info btn-sm" 
                                                    onclick="viewDetails('@message.Id')" 
                                                    title="View message details">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <form method="post" asp-page-handler="Reprocess" asp-route-messageId="@message.Id" 
                                                  class="d-inline" onsubmit="return confirm('Reprocess this message? This will delete existing lab results and cases.');">
                                                <button type="submit" class="btn btn-primary btn-sm" title="Reprocess this message">
                                                    <i class="bi bi-arrow-clockwise"></i>
                                                </button>
                                            </form>
                                            <form method="post" asp-page-handler="DeleteMessage" asp-route-messageId="@message.Id" 
                                                  class="d-inline" onsubmit="return confirm('Delete this message and all related data (lab results, cases)?');">
                                                <button type="submit" class="btn btn-danger btn-sm" title="Delete this message">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Message Details Modal -->
<div class="modal fade" id="detailsModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">HL7 Message Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="detailsContent">
                    <div class="text-center">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function viewDetails(messageId) {
            const modal = new bootstrap.Modal(document.getElementById('detailsModal'));
            modal.show();

            try {
                const response = await fetch(`?handler=ViewDetails&messageId=${messageId}`);
                const data = await response.json();

                let html = '<div class="container-fluid">';

                // Message Info
                html += '<h6 class="border-bottom pb-2 mb-3">Message Information</h6>';
                html += '<div class="row mb-3">';
                html += `<div class="col-md-4"><strong>Control ID:</strong> <code>${data.messageControlId}</code></div>`;
                html += `<div class="col-md-4"><strong>Type:</strong> ${data.messageType || '-'}</div>`;
                html += `<div class="col-md-4"><strong>Status:</strong> <span class="badge bg-secondary">${data.status}</span></div>`;
                html += '</div>';

                if (data.errorMessage) {
                    html += `<div class="alert alert-danger"><strong>Error:</strong> ${data.errorMessage}</div>`;
                }

                // Patient Info
                if (data.patient) {
                    html += '<h6 class="border-bottom pb-2 mb-3 mt-4">Patient Information</h6>';
                    html += '<div class="row mb-3">';
                    html += `<div class="col-md-4"><strong>ID:</strong> ${data.patient.friendlyId}</div>`;
                    html += `<div class="col-md-4"><strong>Name:</strong> ${data.patient.firstName} ${data.patient.lastName}</div>`;
                    html += `<div class="col-md-4"><strong>DOB:</strong> ${new Date(data.patient.dateOfBirth).toLocaleDateString()}</div>`;
                    html += '</div>';
                }

                // Lab Result Info
                if (data.labResult) {
                    html += '<h6 class="border-bottom pb-2 mb-3 mt-4">Lab Result Information</h6>';
                    html += '<div class="row mb-3">';
                    html += `<div class="col-md-6"><strong>ID:</strong> ${data.labResult.friendlyId}</div>`;
                    html += `<div class="col-md-6"><strong>Collection Date:</strong> ${new Date(data.labResult.specimenCollectionDate).toLocaleDateString()}</div>`;
                    html += '</div>';

                    if (data.labResult.markers && data.labResult.markers.length > 0) {
                        html += '<h6 class="mt-3">Markers:</h6>';
                        html += '<table class="table table-sm table-bordered">';
                        html += '<thead><tr><th>Test Code</th><th>Test Name</th><th>Result</th><th>Value</th><th>Units</th><th>Flag</th></tr></thead>';
                        html += '<tbody>';
                        data.labResult.markers.forEach(marker => {
                            html += '<tr>';
                            html += `<td><code>${marker.testCode}</code></td>`;
                            html += `<td>${marker.testName || '-'}</td>`;
                            html += `<td>${marker.qualitativeResult || '-'}</td>`;
                            html += `<td>${marker.quantitativeValue || '-'}</td>`;
                            html += `<td>${marker.units || '-'}</td>`;
                            html += `<td>${marker.interpretationFlag || '-'}</td>`;
                            html += '</tr>';
                        });
                        html += '</tbody></table>';
                    }
                }

                // Processing Notes
                if (data.processingNotes) {
                    html += '<h6 class="border-bottom pb-2 mb-3 mt-4">Processing Notes</h6>';
                    html += `<pre class="bg-light p-3" style="white-space: pre-wrap; max-height: 300px; overflow-y: auto;">${data.processingNotes}</pre>`;
                }

                // Raw Content (collapsed)
                html += '<h6 class="border-bottom pb-2 mb-3 mt-4">Raw HL7 Content</h6>';
                html += '<div class="accordion" id="rawContentAccordion">';
                html += '<div class="accordion-item">';
                html += '<h2 class="accordion-header">';
                html += '<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#rawContent">Click to view raw content</button>';
                html += '</h2>';
                html += '<div id="rawContent" class="accordion-collapse collapse" data-bs-parent="#rawContentAccordion">';
                html += '<div class="accordion-body">';
                html += `<pre style="white-space: pre-wrap; font-size: 0.8rem; max-height: 400px; overflow-y: auto;">${data.rawContent || 'No raw content available'}</pre>`;
                html += '</div></div></div></div>';

                html += '</div>';

                document.getElementById('detailsContent').innerHTML = html;
            } catch (error) {
                document.getElementById('detailsContent').innerHTML = 
                    `<div class="alert alert-danger">Error loading details: ${error.message}</div>`;
            }
        }
    </script>
}
