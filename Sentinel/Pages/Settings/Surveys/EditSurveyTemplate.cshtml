@page
@model Sentinel.Pages.Settings.Surveys.EditSurveyTemplateModel
@using Sentinel.Models

@{
    ViewData["Title"] = "Edit Survey Template";
}
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item"><a asp-page="./SurveyTemplates">Survey Templates</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.SurveyTemplate.Name</li>
    </ol>
</nav>

<div class="container-fluid">
<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h2><i class="bi bi-pencil me-2"></i>Edit Survey Template</h2>
                <p class="text-muted">Update reusable survey template</p>
            </div>
            <div class="text-end">
                @if (Model.SurveyTemplate.IsActive)
                {
                    <span class="badge bg-success">
                        <i class="bi bi-check-circle me-1"></i>Active
                    </span>
                }
                else
                {
                    <span class="badge bg-secondary">
                        <i class="bi bi-circle me-1"></i>Inactive
                    </span>
                }
            </div>
        </div>
            
        @if (Model.TaskTemplateUsageCount > 0)
        {
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>In Use:</strong> This survey template is currently used by <strong>@Model.TaskTemplateUsageCount</strong> task template(s).
                Changes to the survey definition will increment the version number.
            </div>
        }
            
        @if (Model.SurveyTemplate.IsSystemTemplate)
        {
            <div class="alert alert-danger">
                <i class="bi bi-shield-lock me-2"></i>
                <strong>System Template:</strong> This is a system template and cannot be edited.
            </div>
        }
        </div>
    </div>

    <form method="post">
        <input type="hidden" asp-for="SurveyTemplate.Id" />
        
        <div class="row">
            <!-- Left Column - Basic Info -->
            <div class="col-lg-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <i class="bi bi-info-circle me-2"></i>Basic Information
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="SurveyTemplate.Name" class="form-label required"></label>
                            <input asp-for="SurveyTemplate.Name" class="form-control" />
                            <span asp-validation-for="SurveyTemplate.Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SurveyTemplate.Description" class="form-label"></label>
                            <textarea asp-for="SurveyTemplate.Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="SurveyTemplate.Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SurveyTemplate.Category" class="form-label"></label>
                            <select asp-for="SurveyTemplate.Category" class="form-select">
                                <option value="">-- Select Category --</option>
                                <option value="Foodborne">Foodborne</option>
                                <option value="Respiratory">Respiratory</option>
                                <option value="Vector-borne">Vector-borne</option>
                                <option value="Contact Investigation">Contact Investigation</option>
                                <option value="Risk Assessment">Risk Assessment</option>
                                <option value="Symptom Screening">Symptom Screening</option>
                                <option value="Exposure History">Exposure History</option>
                                <option value="Other">Other</option>
                            </select>
                            <span asp-validation-for="SurveyTemplate.Category" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SurveyTemplate.Tags" class="form-label"></label>
                            <input asp-for="SurveyTemplate.Tags" class="form-control" 
                                   placeholder="Enter comma-separated tags (e.g., food, history, investigation)" />
                            <span asp-validation-for="SurveyTemplate.Tags" class="text-danger"></span>
                            <small class="form-text text-muted">
                                Tags help organize and search for survey templates
                            </small>
                        </div>

                        <div class="form-check mb-3">
                            <input asp-for="SurveyTemplate.IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="SurveyTemplate.IsActive" class="form-check-label">
                                Active (available for use)
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Applicable Diseases -->
                <div class="card mb-4">
                    <div class="card-header">
                        <i class="bi bi-clipboard2-pulse me-2"></i>Applicable Diseases
                    </div>
                    <div class="card-body">
                        <p class="text-muted small">
                            Select which diseases this survey template applies to. This helps organize surveys and makes them easier to find.
                        </p>
                        <div class="border rounded p-3" style="max-height: 300px; overflow-y: auto;">
                            @foreach (var disease in Model.Diseases)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="SelectedDiseaseIds" 
                                           value="@disease.Value" id="disease-@disease.Value"
                                           @(Model.SelectedDiseaseIds.Contains(Guid.Parse(disease.Value)) ? "checked" : "") />
                                    <label class="form-check-label" for="disease-@disease.Value">
                                        @disease.Text
                                    </label>
                                </div>
                            }
                        </div>
                        <small class="form-text text-muted mt-2 d-block">
                            <i class="bi bi-info-circle me-1"></i>
                            Optional: Select all diseases that this survey might be used for
                        </small>
                    </div>
                </div>

                <!-- Version History -->
                @if (Model.AllVersions.Any())
                {
                    <div class="card mb-4">
                        <div class="card-header">
                            <i class="bi bi-clock-history me-2"></i>Version History
                            <span class="badge bg-primary ms-2">@Model.AllVersions.Count</span>
                        </div>
                        <div class="card-body">
                            <div class="list-group list-group-flush" style="max-height: 350px; overflow-y: auto;">
                                @foreach (var version in Model.AllVersions)
                                {
                                    <div class="list-group-item @(version.Id == Model.SurveyTemplate.Id ? "active" : "")">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div class="flex-grow-1">
                                                <h6 class="mb-1">
                                                    <i class="bi bi-tag me-1"></i>
                                                    Version @version.VersionNumber
                                                    @if (version.Id == Model.SurveyTemplate.Id)
                                                    {
                                                        <span class="badge bg-light text-dark ms-1">Current</span>
                                                    }
                                                </h6>
                                                <div class="mb-2">
                                                    @switch (version.VersionStatus)
                                                    {
                                                        case Sentinel.Models.SurveyVersionStatus.Draft:
                                                            <span class="badge bg-secondary">Draft</span>
                                                            break;
                                                        case Sentinel.Models.SurveyVersionStatus.Active:
                                                            <span class="badge bg-success">Active</span>
                                                            break;
                                                        case Sentinel.Models.SurveyVersionStatus.Archived:
                                                            <span class="badge bg-warning text-dark">Archived</span>
                                                            break;
                                                    }
                                                    @if (version.IsActive)
                                                    {
                                                        <span class="badge bg-success ms-1">Enabled</span>
                                                    }
                                                </div>
                                                <small class="text-muted d-block">
                                                    <i class="bi bi-calendar me-1"></i>
                                                    Created: @version.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                                                    @if (!string.IsNullOrEmpty(version.CreatedBy))
                                                    {
                                                        <span>by @version.CreatedBy</span>
                                                    }
                                                </small>
                                                @if (version.PublishedAt.HasValue)
                                                {
                                                    <small class="text-muted d-block">
                                                        <i class="bi bi-check-circle me-1"></i>
                                                        Published: @version.PublishedAt.Value.ToString("MMM dd, yyyy HH:mm")
                                                        @if (!string.IsNullOrEmpty(version.PublishedBy))
                                                        {
                                                            <span>by @version.PublishedBy</span>
                                                        }
                                                    </small>
                                                }
                                                @if (!string.IsNullOrEmpty(version.VersionNotes))
                                                {
                                                    <small class="text-muted d-block mt-1">
                                                        <i class="bi bi-journal-text me-1"></i>
                                                        @version.VersionNotes
                                                    </small>
                                                }
                                            </div>
                                            @if (version.Id != Model.SurveyTemplate.Id)
                                            {
                                                <div class="ms-2">
                                                    <a asp-page="./SurveyTemplateDetails" asp-route-id="@version.Id" 
                                                       class="btn btn-sm btn-outline-primary" title="View this version">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

                <!-- Usage Information -->
                @if (Model.TaskTemplateUsageCount > 0)
                {
                    <div class="card mb-4">
                        <div class="card-header bg-info text-white">
                            <i class="bi bi-graph-up me-2"></i>Usage Information
                        </div>
                        <div class="card-body">
                            <div class="mb-2">
                                <strong>Used in:</strong> @Model.TaskTemplateUsageCount task template(s)
                            </div>
                            <small class="text-muted">
                                <i class="bi bi-info-circle me-1"></i>
                                Changes will affect all task templates using this survey
                            </small>
                        </div>
                    </div>
                }
            </div>

            <!-- Right Column - Survey Definition & Mappings -->
            <div class="col-lg-6">
                <!-- Survey Definition -->
                <div class="card mb-4">
                    <div class="card-header">
                        <i class="bi bi-pencil-square me-2"></i>Survey Definition
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info">
                            <i class="bi bi-exclamation-circle me-1"></i>
                            Changes to survey definition will increment the version number
                        </div>
                        
                        @if (string.IsNullOrWhiteSpace(Model.SurveyTemplate.SurveyDefinitionJson))
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-file-earmark-plus" style="font-size: 3rem; color: #ccc;"></i>
                                <h5 class="mt-3">No Survey Defined</h5>
                                <p class="text-muted">Use the visual designer to create your survey</p>
                                <button type="button" class="btn btn-primary btn-lg" id="openDesignerBtn">
                                    <i class="bi bi-pencil-square me-2"></i>Open Visual Designer
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <div class="alert alert-success">
                                    <i class="bi bi-check-circle me-2"></i>
                                    Survey definition exists
                                    @{
                                        var surveyObj = System.Text.Json.JsonDocument.Parse(Model.SurveyTemplate.SurveyDefinitionJson);
                                        if (surveyObj.RootElement.TryGetProperty("elements", out var elements))
                                        {
                                            <span class="badge bg-success ms-2">@elements.GetArrayLength() question(s)</span>
                                        }
                                    }
                                </div>
                                
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-primary" id="openDesignerBtn">
                                        <i class="bi bi-pencil-square me-1"></i>Edit in Visual Designer
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary" id="viewJsonBtn">
                                        <i class="bi bi-code-square me-1"></i>View JSON
                                    </button>
                                </div>
                            </div>
                        }

                        <!-- Hidden input to store the JSON -->
                        <input type="hidden" asp-for="SurveyTemplate.SurveyDefinitionJson" id="surveyJson" />
                    </div>
                </div>

                <!-- Field Mappings (New Unified System) -->
                <div class="card mb-4">
                    <div class="card-header">
                        <i class="bi bi-arrows-expand me-2"></i>Field Mappings
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info small">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Survey-Level Mappings:</strong> These are default mappings used when this survey is assigned to a task.
                            <br><br>
                            <strong>Mapping Hierarchy (Override Priority):</strong>
                            <ol class="mb-0 ps-3">
                                <li><strong>Disease-Level</strong> (highest priority) - Set in Disease Edit page</li>
                                <li><strong>Task Template-Level</strong> - Set in Task Template Edit page</li>
                                <li><strong>Survey-Level</strong> (lowest priority) - Set here (default for all uses)</li>
                            </ol>
                            <br>
                            <span class="text-primary">
                                <i class="bi bi-lightbulb"></i> 
                                To see disease-specific mappings for this survey, go to Settings ? Diseases ? Edit Disease ? Tasks & Surveys tab.
                            </span>
                        </div>

                        @* New unified mapping system *@
                        <component type="typeof(Sentinel.Components.SurveyMappingEditor)" 
                                   render-mode="ServerPrerendered"
                                   param-ConfigurationType="Sentinel.Models.MappingConfigurationType.Survey"
                                   param-ConfigurationId="Model.SurveyTemplate.Id"
                                   param-SurveyTemplateId="Model.SurveyTemplate.Id" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <a asp-page="./SurveyTemplates" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-2"></i>Cancel
                    </a>
                    <button type="submit" class="btn btn-primary" @(Model.SurveyTemplate.IsSystemTemplate ? "disabled" : "")>
                        <i class="bi bi-save me-2"></i>Update Survey Template
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Survey Preview Modal -->
<div class="modal fade" id="surveyPreviewModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-eye me-2"></i>Survey Preview
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="surveyPreviewContainer"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        const surveyTemplateId = '@Model.SurveyTemplate.Id';
        let designerWindow = null;
        
        // Open designer in a popup window
        $('#openDesignerBtn').on('click', function() {
            const designerUrl = `/Settings/Surveys/DesignSurvey/${surveyTemplateId}?returnUrl=${encodeURIComponent(window.location.pathname)}`;
            
            // Open in a large popup window
            const width = Math.min(1400, screen.width * 0.9);
            const height = Math.min(900, screen.height * 0.9);
            const left = (screen.width - width) / 2;
            const top = (screen.height - height) / 2;
            
            designerWindow = window.open(
                designerUrl,
                'surveyDesigner',
                `width=${width},height=${height},left=${left},top=${top},menubar=no,toolbar=no,location=no,status=no,scrollbars=yes,resizable=yes`
            );
            
            if (designerWindow) {
                designerWindow.focus();
            } else {
                alert('Please allow popups for this site to use the visual designer.');
            }
        });
        
        // View JSON button
        $('#viewJsonBtn').on('click', function() {
            const json = $('#surveyJson').val();
            if (!json) {
                alert('No survey definition available.');
                return;
            }
            
            try {
                const parsed = JSON.parse(json);
                const formatted = JSON.stringify(parsed, null, 2);
                
                // Show in a modal
                const modalHtml = `
                    <div class="modal fade" id="jsonViewModal" tabindex="-1">
                        <div class="modal-dialog modal-xl">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">
                                        <i class="bi bi-code-square me-2"></i>Survey JSON
                                    </h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <pre class="bg-light p-3 border rounded" style="max-height: 600px; overflow: auto;"><code>${formatted}</code></pre>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
                
                // Remove any existing modal
                $('#jsonViewModal').remove();
                
                // Add and show modal
                $('body').append(modalHtml);
                const modal = new bootstrap.Modal(document.getElementById('jsonViewModal'));
                modal.show();
                
                // Clean up after close
                $('#jsonViewModal').on('hidden.bs.modal', function() {
                    $(this).remove();
                });
            } catch (e) {
                alert('Error parsing JSON: ' + e.message);
            }
        });
        
        // Listen for messages from designer window (optional)
        window.addEventListener('message', function(event) {
            // You can handle messages from the designer window here if needed
            if (event.data && event.data.type === 'surveySaved') {                // Optionally reload the page to show updated data
                // location.reload();
            }
        });
    </script>
}
