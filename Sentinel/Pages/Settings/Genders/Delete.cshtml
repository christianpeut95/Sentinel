@page
@model Sentinel.Pages.Settings.Genders.DeleteModel

@{
    ViewData["Title"] = "Delete Gender";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Gender</a></li>
        <li class="breadcrumb-item active" aria-current="page">Delete: @Model.Gender.Name</li>
    </ol>
</nav>

<h2><i class="bi bi-trash me-2"></i>Delete Gender</h2>
<hr />

<div class="alert alert-danger" role="alert">
    <h5 class="alert-heading"><i class="bi bi-exclamation-triangle me-2"></i>Are you sure you want to delete this?</h5>
    <p>This action cannot be undone.</p>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Gender.Name</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@(Model.Gender.Description ?? "-")</dd>

        <dt class="col-sm-3">Display Order</dt>
        <dd class="col-sm-9">@(Model.Gender.DisplayOrder?.ToString() ?? "-")</dd>

        <dt class="col-sm-3">Is Active</dt>
        <dd class="col-sm-9">
            @if (Model.Gender.IsActive)
            {
                <span class="badge bg-success">Active</span>
            }
            else
            {
                <span class="badge bg-secondary">Inactive</span>
            }
        </dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="Gender.Id" />
        <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
        <a asp-page="./Index" class="btn btn-outline-secondary ms-2"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
    </form>
</div>
