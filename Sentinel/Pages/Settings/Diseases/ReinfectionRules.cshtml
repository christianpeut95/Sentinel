@page "{diseaseId:guid?}"
@model Sentinel.Pages.Settings.Diseases.ReinfectionRulesModel

@{
    ViewData["Title"] = "Reinfection Rules";
    Layout = "~/Pages/Shared/_LayoutSentinel.cshtml";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Settings/Index">Settings</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Diseases</a></li>
        <li class="breadcrumb-item active" aria-current="page">Reinfection Rules</li>
    </ol>
</nav>

<div class="sentinel-page-header mb-4">
    <div>
        <div class="sentinel-eyebrow">Disease Configuration</div>
        <h1 class="sentinel-page-title">Reinfection Rules</h1>
        <p class="sentinel-page-subtitle">Configure how lab results are matched to existing cases</p>
    </div>
</div>

<!-- Disease Filter -->
<div class="sentinel-card mb-4">
    <div class="sentinel-card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-6">
                <label for="diseaseFilter" class="sn-label">Filter by Disease</label>
                <select name="diseaseId" id="diseaseFilter" class="sn-input" onchange="this.form.submit()">
                    <option value="">-- All Diseases --</option>
                    @foreach (var disease in Model.AllDiseases)
                    {
                        <option value="@disease.Id" selected="@(disease.Id == Model.SelectedDiseaseId)">
                            @disease.Name
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <a asp-page="./ReinfectionRulesEdit" asp-route-diseaseId="@Model.SelectedDiseaseId" 
                   class="sn-btn sn-btn--signal">
                    <i class="bi bi-plus-circle me-1"></i>Add Reinfection Rule
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Info Alert -->
<div class="alert alert-info mb-4" role="alert">
    <h5 style="font-weight:600;margin-bottom:8px">
        <i class="bi bi-info-circle me-2"></i>About Reinfection Rules
    </h5>
    <p style="margin-bottom:0">
        Reinfection rules determine when incoming lab results should create a new case versus being added to an existing case.
        Each disease can have one rule that defines the matching strategy and time windows.
    </p>
</div>

@if (Model.Rules.Any())
{
    <div class="sentinel-card">
        <div class="sentinel-card-body" style="padding:0">
            <div class="sn-table-container">
                <table class="sn-table">
                    <thead>
                        <tr>
                            <th>Disease</th>
                            <th>Rule Type</th>
                            <th>Reinfection Window</th>
                            <th>Case Matching Strategy</th>
                            <th>Options</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rule in Model.Rules)
                        {
                            <tr>
                                <td>
                                    <strong>@rule.Disease?.Name</strong>
                                </td>
                                <td>
                                    @switch (rule.RuleType)
                                    {
                                        case Sentinel.Models.Lookups.ReinfectionRuleType.NoReinfection:
                                            <span class="chip chip--info">
                                                <i class="bi bi-lock me-1"></i>No Reinfection
                                            </span>
                                            break;
                                        case Sentinel.Models.Lookups.ReinfectionRuleType.TimeWindow:
                                            <span class="chip chip--watch">
                                                <i class="bi bi-clock me-1"></i>Time Window
                                            </span>
                                            break;
                                        case Sentinel.Models.Lookups.ReinfectionRuleType.AlwaysNewCase:
                                            <span class="chip chip--outbreak">
                                                <i class="bi bi-plus-circle me-1"></i>Always New Case
                                            </span>
                                            break;
                                        case Sentinel.Models.Lookups.ReinfectionRuleType.ChronicDisease:
                                            <span class="chip chip--clear">
                                                <i class="bi bi-arrow-repeat me-1"></i>Chronic Disease
                                            </span>
                                            break;
                                        case Sentinel.Models.Lookups.ReinfectionRuleType.ManualReview:
                                            <span class="chip chip--info">
                                                <i class="bi bi-eye me-1"></i>Manual Review
                                            </span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @if (rule.ReinfectionWindowDays.HasValue)
                                    {
                                        <span style="font-family:var(--f-mono);color:var(--graphite)">
                                            @rule.ReinfectionWindowDays.Value days
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="color:var(--graphite-lt)">—</span>
                                    }
                                </td>
                                <td>
                                    @switch (rule.CaseMatchingStrategy)
                                    {
                                        case Sentinel.Models.Lookups.CaseMatchingStrategy.DateWindowMatching:
                                            <span style="font-size:13px;color:var(--graphite)">Date Window</span>
                                            break;
                                        case Sentinel.Models.Lookups.CaseMatchingStrategy.MostRecentOpenCase:
                                            <span style="font-size:13px;color:var(--graphite)">Most Recent Open</span>
                                            break;
                                        case Sentinel.Models.Lookups.CaseMatchingStrategy.AnyOpenCase:
                                            <span style="font-size:13px;color:var(--graphite)">Any Open Case</span>
                                            break;
                                        case Sentinel.Models.Lookups.CaseMatchingStrategy.ExactDateMatch:
                                            <span style="font-size:13px;color:var(--graphite)">Exact Date Match</span>
                                            break;
                                        case Sentinel.Models.Lookups.CaseMatchingStrategy.ManualAssignmentOnly:
                                            <span style="font-size:13px;color:var(--graphite)">Manual Assignment Only</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <div style="display:flex;gap:6px;flex-wrap:wrap">
                                        @if (rule.IsChronic)
                                        {
                                            <span class="chip" style="font-size:11px">Chronic</span>
                                        }
                                        @if (rule.AlwaysCreateNewCase)
                                        {
                                            <span class="chip" style="font-size:11px">Always New</span>
                                        }
                                        @if (rule.MatchOnTestType)
                                        {
                                            <span class="chip" style="font-size:11px">Match Test</span>
                                        }
                                        @if (rule.RequireConfirmationForNewCase)
                                        {
                                            <span class="chip" style="font-size:11px">Confirm New</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @if (rule.IsActive)
                                    {
                                        <span class="chip chip--clear">Active</span>
                                    }
                                    else
                                    {
                                        <span class="chip">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-page="./ReinfectionRulesEdit" asp-route-id="@rule.Id" 
                                       class="sn-btn sn-btn--ghost" style="padding:6px 12px">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <button type="button" class="sn-btn sn-btn--ghost" 
                                            style="padding:6px 12px"
                                            data-bs-toggle="modal" 
                                            data-bs-target="#deleteModal-@rule.Id">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Delete Modals -->
    @foreach (var rule in Model.Rules)
    {
        <div class="modal fade" id="deleteModal-@rule.Id" tabindex="-1" aria-labelledby="deleteModalLabel-@rule.Id" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="deleteModalLabel-@rule.Id">Confirm Delete</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure you want to delete the reinfection rule for <strong>@rule.Disease?.Name</strong>?</p>
                        <p class="text-danger">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            <strong>Warning:</strong> This will affect how future lab results are matched to cases for this disease.
                        </p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="sn-btn sn-btn--ghost" data-bs-dismiss="modal">Cancel</button>
                        <form method="post" asp-page-handler="Delete" style="display:inline">
                            <input type="hidden" name="id" value="@rule.Id" />
                            <input type="hidden" name="diseaseId" value="@Model.SelectedDiseaseId" />
                            <button type="submit" class="sn-btn sn-btn--ghost" style="color:var(--outbreak)">
                                <i class="bi bi-trash me-1"></i>Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="sentinel-card">
        <div class="sentinel-card-body text-center" style="padding:60px 20px">
            <i class="bi bi-clipboard-data" style="font-size:48px;color:var(--graphite-lt);margin-bottom:16px"></i>
            <h5 style="color:var(--graphite);margin-bottom:8px">No Reinfection Rules</h5>
            <p style="color:var(--graphite);margin-bottom:24px">
                @if (Model.SelectedDiseaseId.HasValue)
                {
                    <text>No reinfection rules found for the selected disease.</text>
                }
                else
                {
                    <text>No reinfection rules have been configured yet.</text>
                }
            </p>
            <a asp-page="./ReinfectionRulesEdit" asp-route-diseaseId="@Model.SelectedDiseaseId" 
               class="sn-btn sn-btn--signal">
                <i class="bi bi-plus-circle me-1"></i>Add First Rule
            </a>
        </div>
    </div>
}

<!-- Help Section -->
<div class="row mt-4">
    <div class="col-lg-12">
        <div class="sentinel-card" style="background:var(--paper)">
            <div class="sentinel-card-body">
                <h5 style="font-weight:600;margin-bottom:16px">
                    <i class="bi bi-question-circle me-2" style="color:var(--signal-dk)"></i>Rule Type Examples
                </h5>
                <div class="row">
                    <div class="col-md-6">
                        <div style="margin-bottom:16px">
                            <strong style="color:var(--forest)">No Reinfection (HIV, Hepatitis B)</strong>
                            <p style="font-size:13px;color:var(--graphite);margin:4px 0 0 0">
                                All lab results append to the patient's single case. Used for chronic/lifelong diseases.
                            </p>
                        </div>
                        <div style="margin-bottom:16px">
                            <strong style="color:var(--forest)">Time Window (Influenza: 90 days)</strong>
                            <p style="font-size:13px;color:var(--graphite);margin:4px 0 0 0">
                                New case only if last positive was more than 90 days ago. Most common for acute diseases.
                            </p>
                        </div>
                        <div style="margin-bottom:16px">
                            <strong style="color:var(--forest)">Always New Case (Food Poisoning)</strong>
                            <p style="font-size:13px;color:var(--graphite);margin:4px 0 0 0">
                                Each positive result creates a separate case. Used for diseases with frequent reinfection.
                            </p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div style="margin-bottom:16px">
                            <strong style="color:var(--forest)">Chronic Disease (Tuberculosis)</strong>
                            <p style="font-size:13px;color:var(--graphite);margin:4px 0 0 0">
                                All results append to most recent case. Used for diseases with long treatment periods.
                            </p>
                        </div>
                        <div style="margin-bottom:16px">
                            <strong style="color:var(--forest)">Manual Review</strong>
                            <p style="font-size:13px;color:var(--graphite);margin:4px 0 0 0">
                                Results flagged for staff review before case assignment. Used for complex scenarios.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
