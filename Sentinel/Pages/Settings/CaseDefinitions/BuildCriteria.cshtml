        // Toggle logical operator (AND/OR) for a criterion
        async function toggleLogicalOperator(criterionId, currentOperator) {
            // LogicalOperator enum: AND=1, OR=2, NOT=3
            // Fix invalid values (0 or anything else) to default to AND (1)
            let validOperator = currentOperator;
            if (currentOperator !== 1 && currentOperator !== 2) {
                console.warn(`Invalid operator ${currentOperator} for criterion ${criterionId}, defaulting to AND (1)`);
                validOperator = 1; // Default to AND
            }

            // Toggle between AND (1) and OR (2)
            const newOperator = validOperator === 1 ? 2 : 1;
            const newOperatorLabel = newOperator === 1 ? 'AND' : 'OR';

            console.log(`Toggling criterion ${criterionId}: ${validOperator} → ${newOperator} (${newOperatorLabel})`);

            try {
                const response = await fetch(`/api/case-definitions/@Model.DefinitionId/criteria/${criterionId}/operator`, {
                    method: 'PATCH',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ logicalOperator: newOperator })
                });

                if (response.ok) {
                    location.reload();
                } else {
                    alert('Failed to update operator');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred while updating operator');
            }
        }

