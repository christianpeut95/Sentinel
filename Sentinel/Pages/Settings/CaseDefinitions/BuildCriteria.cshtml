@page
@model Sentinel.Pages.Settings.CaseDefinitions.BuildCriteriaModel
@using Sentinel.Models.CaseDefinitions
@{
    ViewData["Title"] = "Build Criteria";
    Layout = "~/Pages/Shared/_LayoutSentinel.cshtml";
}

<link rel="stylesheet" href="~/css/sentinel-design-system.css" />

<style>
    .wizard-container {
        max-width: 1000px;
        margin: 0 auto;
    }

    .wizard-steps {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 3rem;
        padding: 2rem 0;
        border-bottom: 1px solid var(--hairline);
    }

    .wizard-step {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .wizard-step-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 1rem;
        background: var(--paper);
        color: var(--graphite);
        border: 2px solid var(--hairline);
        transition: all 0.2s;
    }

    .wizard-step.active .wizard-step-circle {
        background: var(--forest);
        color: var(--signal);
        border-color: var(--forest);
    }

    .wizard-step.completed .wizard-step-circle {
        background: var(--signal-dk);
        color: white;
        border-color: var(--signal-dk);
    }

    .wizard-step-label {
        font-size: 0.875rem;
        color: var(--graphite);
        font-weight: 500;
    }

    .wizard-step.active .wizard-step-label {
        color: var(--forest);
        font-weight: 600;
    }

    .wizard-connector {
        width: 80px;
        height: 2px;
        background: var(--hairline);
        margin: 0 1rem;
    }

    .wizard-step.completed + .wizard-connector {
        background: var(--signal-dk);
    }

    .criterion-card {
        background: var(--chalk);
        border: 1px solid var(--hairline);
        border-radius: 8px;
        padding: 1.25rem;
        margin-bottom: 0.75rem;
        transition: all 0.2s;
    }

    .criterion-card:hover {
        border-color: var(--signal-dk);
        box-shadow: 0 2px 8px rgba(61, 213, 152, 0.15);
    }

    .criterion-card.has-children {
        background: var(--signal-lt);
        border-color: var(--signal-dk);
        border-width: 2px;
    }

    .criterion-card[data-level="1"],
    .criterion-card[data-level="2"] {
        background: #fff;
        margin-top: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .criterion-type-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--f-mono);
        font-size: 0.625rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 0.25rem 0.625rem;
        border-radius: 4px;
        font-weight: 500;
    }

    .criterion-type-laboratory {
        background: #e0f2fe;
        color: #075985;
        border: 1px solid #bae6fd;
    }

    .criterion-type-clinical {
        background: #fce7f3;
        color: #9f1239;
        border: 1px solid #fbcfe8;
    }

    .criterion-type-customfield {
        background: var(--signal-lt);
        color: var(--signal-dk);
        border: 1px solid var(--signal-dk);
    }

    .criterion-type-demographic {
        background: #fef3c7;
        color: #92400e;
        border: 1px solid #fde68a;
    }

    .add-criterion-btn {
        width: 100%;
        padding: 1.25rem;
        background: var(--chalk);
        border: 2px dashed var(--hairline);
        border-radius: 8px;
        color: var(--graphite);
        font-size: 0.9375rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    .add-criterion-btn:hover {
        border-color: var(--signal-dk);
        color: var(--signal-dk);
        background: var(--signal-lt);
    }

    .specimen-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 0.5rem;
        max-height: 300px;
        overflow-y: auto;
        padding: 0.5rem;
        border: 1px solid var(--hairline);
        border-radius: 6px;
        background: var(--chalk);
    }

    .specimen-item {
        padding: 0.625rem;
        border: 1px solid var(--hairline);
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s;
        background: white;
    }

    .specimen-item:hover {
        border-color: var(--signal-dk);
        background: var(--signal-lt);
    }

    .specimen-item.selected {
        border-color: var(--signal-dk);
        background: var(--signal-lt);
        font-weight: 500;
    }

    .specimen-item-name {
        font-size: 0.875rem;
        color: var(--forest);
        margin-bottom: 0.25rem;
    }

    .specimen-item-code {
        font-family: var(--f-mono);
        font-size: 0.75rem;
        color: var(--graphite);
    }

    .selected-items-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 0.75rem;
    }

    .selected-item-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.375rem 0.75rem;
        background: var(--signal-lt);
        border: 1px solid var(--signal-dk);
        border-radius: 999px;
        font-size: 0.813rem;
        color: var(--forest);
    }

    .selected-item-chip button {
        background: none;
        border: none;
        color: var(--signal-dk);
        cursor: pointer;
        padding: 0;
        font-size: 1rem;
        line-height: 1;
    }

    .logical-operator-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.375rem 0.875rem;
        background: var(--paper);
        border: 1px solid var(--hairline);
        border-radius: 999px;
        font-family: var(--f-mono);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        color: var(--forest);
        cursor: pointer;
        transition: all 0.2s;
    }

    .logical-operator-toggle:hover {
        background: var(--signal-lt);
        border-color: var(--signal-dk);
        color: var(--signal-dk);
    }

    .operator-label {
        min-width: 28px;
        text-align: center;
    }
</style>

<div class="container-fluid px-4 py-4">
    <div class="wizard-container">
        <!-- Header -->
        <div class="text-center mb-4">
            <div class="text-label mb-2">CREATE CASE DEFINITION</div>
            <h1 class="page-title mb-2">Build Criteria</h1>
            <p class="text-muted">Define the conditions that must be met for case classification</p>
        </div>

        <!-- Wizard Steps -->
        <div class="wizard-steps">
            <div class="wizard-step completed">
                <div class="wizard-step-circle">✓</div>
                <div class="wizard-step-label">Basic Information</div>
            </div>
            <div class="wizard-connector"></div>
            <div class="wizard-step active">
                <div class="wizard-step-circle">●</div>
                <div class="wizard-step-label">Build Criteria</div>
            </div>
            <div class="wizard-connector"></div>
            <div class="wizard-step">
                <div class="wizard-step-circle">○</div>
                <div class="wizard-step-label">Review & Save</div>
            </div>
        </div>

        <!-- Definition Summary -->
        <div class="sentinel-card mb-4" style="background: var(--signal-lt); border-color: var(--signal-dk);">
            <div class="row g-2 align-items-center">
                <div class="col-auto">
                    <i class="bi bi-info-circle" style="font-size: 1.5rem; color: var(--signal-dk);"></i>
                </div>
                <div class="col">
                    <div class="text-label">DEFINING</div>
                    <div style="font-weight: 600; font-size: 1rem;">
                        @Model.Definition.Disease?.Name — @Model.Definition.ConfirmationStatus?.Name
                    </div>
                </div>
            </div>
        </div>

        <!-- Criteria List -->
        <div class="sentinel-card mb-4">
            <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem;">
                <i class="bi bi-list-check"></i>
                Criteria Rules
            </h3>
            <p class="text-muted mb-3" style="font-size: 0.875rem;">
                A case meets this definition when:
            </p>

            <div id="criteriaContainer">
                @if (!Model.Criteria.Any())
                {
                    <div class="text-center py-5" style="color: var(--graphite);">
                        <i class="bi bi-diagram-3" style="font-size: 3rem; opacity: 0.3;"></i>
                        <p class="mt-3 mb-0">No criteria added yet. Start by adding your first criterion below.</p>
                    </div>
                }
                else
                {
                    var rootCriteria = Model.Criteria.Where(c => c.ParentCriteriaId == null).OrderBy(c => c.DisplayOrder).ToList();

                    for (int i = 0; i < rootCriteria.Count; i++)
                    {
                        var criterion = rootCriteria[i];
                        var isFirst = i == 0;
                        var isLast = i == rootCriteria.Count - 1;
                        var hasChildren = criterion.ChildCriteria?.Any() == true;
                        var nextCriterion = !isLast ? rootCriteria[i + 1] : null;
                        var previousCriterion = !isFirst ? rootCriteria[i - 1] : null;

                        @* Show logical operator toggle between root criteria (only if not grouped) *@
                        @* The toggle shows BEFORE this criterion, so it updates the PREVIOUS criterion's operator *@
                        @if (!isFirst && !hasChildren)
                        {
                            <div style="text-align: center; margin: -0.5rem 0;">
                                <div class="logical-operator-toggle" 
                                     data-criterion-id="@previousCriterion.Id" 
                                     data-operator="@((int)previousCriterion.LogicalOperator)"
                                     onclick="toggleLogicalOperator(@previousCriterion.Id, @((int)previousCriterion.LogicalOperator))">
                                    <span class="operator-label">@(previousCriterion.LogicalOperator == LogicalOperator.AND ? "AND" : "OR")</span>
                                    <i class="bi bi-arrow-down-up" style="font-size: 0.75rem; margin-left: 0.25rem;"></i>
                                </div>
                            </div>
                        }

                        @* Group container start *@
                        @if (hasChildren)
                        {
                            var children = criterion.ChildCriteria.OrderBy(c => c.DisplayOrder).ToList();
                            <div style="border: 2px solid var(--signal-dk); border-radius: 8px; padding: 1rem; background: var(--signal-lt); margin-bottom: 1rem;">
                                @* Show operator before group if not first *@
                                @* The toggle shows BEFORE this group, so it updates the PREVIOUS criterion's operator *@
                                @if (!isFirst)
                                {
                                    <div style="text-align: center; margin: -2rem 0 1rem 0;">
                                        <div class="logical-operator-toggle" 
                                             data-criterion-id="@previousCriterion.Id" 
                                             data-operator="@((int)previousCriterion.LogicalOperator)"
                                             onclick="toggleLogicalOperator(@previousCriterion.Id, @((int)previousCriterion.LogicalOperator))"
                                             style="background: white;">
                                            <span class="operator-label">@(previousCriterion.LogicalOperator == LogicalOperator.AND ? "AND" : "OR")</span>
                                            <i class="bi bi-arrow-down-up" style="font-size: 0.75rem; margin-left: 0.25rem;"></i>
                                        </div>
                                    </div>
                                }

                                <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; color: var(--signal-dk); font-weight: 600; font-size: 0.875rem;">
                                    <i class="bi bi-braces"></i> GROUP START
                                </div>

                                @* Parent criterion *@
                                <div class="criterion-card" 
                                     data-criterion-id="@criterion.Id" 
                                     data-order="@criterion.DisplayOrder"
                                     data-level="0"
                                     style="background: white; margin-bottom: 0.75rem;">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div class="d-flex align-items-start gap-2 flex-grow-1">
                                            @* Reorder buttons *@
                                            <div class="d-flex flex-column" style="gap: 2px;">
                                                <button type="button" 
                                                        class="sn-btn sn-btn-ghost" 
                                                        style="padding: 2px 6px; font-size: 0.75rem; @(isFirst ? "visibility: hidden;" : "")"
                                                        onclick="moveCriterion(@criterion.Id, 'up')"
                                                        title="Move up">
                                                    <i class="bi bi-chevron-up"></i>
                                                </button>
                                                <button type="button" 
                                                        class="sn-btn sn-btn-ghost" 
                                                        style="padding: 2px 6px; font-size: 0.75rem; @(isLast ? "visibility: hidden;" : "")"
                                                        onclick="moveCriterion(@criterion.Id, 'down')"
                                                        title="Move down">
                                                    <i class="bi bi-chevron-down"></i>
                                                </button>
                                            </div>

                                            <div class="flex-grow-1">
                                                <div class="d-flex align-items-center gap-2 mb-2">
                                                    @switch (criterion.CriterionType)
                                                    {
                                                        case CriterionType.Laboratory:
                                                            <span class="criterion-type-badge criterion-type-laboratory">
                                                                <i class="bi bi-clipboard-pulse"></i> Laboratory
                                                            </span>
                                                            break;
                                                        case CriterionType.Clinical:
                                                            <span class="criterion-type-badge criterion-type-clinical">
                                                                <i class="bi bi-heart-pulse"></i> Clinical
                                                            </span>
                                                            break;
                                                        case CriterionType.CustomField:
                                                            <span class="criterion-type-badge criterion-type-customfield">
                                                                <i class="bi bi-ui-checks"></i> Custom Field
                                                            </span>
                                                            break;
                                                        case CriterionType.Demographic:
                                                            <span class="criterion-type-badge criterion-type-demographic">
                                                                <i class="bi bi-person"></i> Case Data
                                                            </span>
                                                            break;
                                                    }
                                                </div>

                                                <div style="font-size: 0.9375rem; line-height: 1.6;">
                                                    @Html.Raw(criterion.DisplayText)
                                                </div>
                                            </div>
                                        </div>

                                        <div class="btn-group btn-group-sm">
                                            <button type="button" class="sn-btn sn-btn-ghost sn-btn-sm" onclick="editCriterion(@criterion.Id)" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button type="button" class="sn-btn sn-btn-ghost sn-btn-sm" onclick="deleteCriterion(@criterion.Id)" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                @* Child criteria within group *@
                                @for (int j = 0; j < children.Count; j++)
                                {
                                    var child = children[j];
                                    var childIsFirst = j == 0;
                                    var childIsLast = j == children.Count - 1;
                                    var previousChild = !childIsFirst ? children[j - 1] : null;

                                    @* Toggle shows BEFORE this child, so it updates either the parent (if first child) or previous child *@
                                    <div style="text-align: center; margin: 0.5rem 0;">
                                        @if (childIsFirst)
                                        {
                                            @* First child: toggle updates the PARENT criterion's operator *@
                                            <div class="logical-operator-toggle" 
                                                 data-criterion-id="@criterion.Id" 
                                                 data-operator="@((int)criterion.LogicalOperator)"
                                                 onclick="toggleLogicalOperator(@criterion.Id, @((int)criterion.LogicalOperator))">
                                                <span class="operator-label">@(criterion.LogicalOperator == LogicalOperator.AND ? "AND" : "OR")</span>
                                                <i class="bi bi-arrow-down-up" style="font-size: 0.75rem; margin-left: 0.25rem;"></i>
                                            </div>
                                        }
                                        else
                                        {
                                            @* Subsequent children: toggle updates the PREVIOUS child's operator *@
                                            <div class="logical-operator-toggle" 
                                                 data-criterion-id="@previousChild.Id" 
                                                 data-operator="@((int)previousChild.LogicalOperator)"
                                                 onclick="toggleLogicalOperator(@previousChild.Id, @((int)previousChild.LogicalOperator))">
                                                <span class="operator-label">@(previousChild.LogicalOperator == LogicalOperator.AND ? "AND" : "OR")</span>
                                                <i class="bi bi-arrow-down-up" style="font-size: 0.75rem; margin-left: 0.25rem;"></i>
                                            </div>
                                        }
                                    </div>

                                    <div class="criterion-card" 
                                         data-criterion-id="@child.Id" 
                                         data-order="@child.DisplayOrder"
                                         data-level="1"
                                         style="background: white; @(childIsLast ? "" : "margin-bottom: 0.75rem;")">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div class="d-flex align-items-start gap-2 flex-grow-1">
                                                @* Reorder buttons for children *@
                                                <div class="d-flex flex-column" style="gap: 2px;">
                                                    <button type="button" 
                                                            class="sn-btn sn-btn-ghost" 
                                                            style="padding: 2px 6px; font-size: 0.75rem; @(j == 0 ? "visibility: hidden;" : "")"
                                                            onclick="moveCriterion(@child.Id, 'up')"
                                                            title="Move up">
                                                        <i class="bi bi-chevron-up"></i>
                                                    </button>
                                                    <button type="button" 
                                                            class="sn-btn sn-btn-ghost" 
                                                            style="padding: 2px 6px; font-size: 0.75rem; @(childIsLast ? "visibility: hidden;" : "")"
                                                            onclick="moveCriterion(@child.Id, 'down')"
                                                            title="Move down">
                                                        <i class="bi bi-chevron-down"></i>
                                                    </button>
                                                </div>

                                                <div class="flex-grow-1">
                                                    <div class="d-flex align-items-center gap-2 mb-2">
                                                        @switch (child.CriterionType)
                                                        {
                                                            case CriterionType.Laboratory:
                                                                <span class="criterion-type-badge criterion-type-laboratory">
                                                                    <i class="bi bi-clipboard-pulse"></i> Laboratory
                                                                </span>
                                                                break;
                                                            case CriterionType.Clinical:
                                                                <span class="criterion-type-badge criterion-type-clinical">
                                                                    <i class="bi bi-heart-pulse"></i> Clinical
                                                                </span>
                                                                break;
                                                            case CriterionType.CustomField:
                                                                <span class="criterion-type-badge criterion-type-customfield">
                                                                    <i class="bi bi-ui-checks"></i> Custom Field
                                                                </span>
                                                                break;
                                                            case CriterionType.Demographic:
                                                                <span class="criterion-type-badge criterion-type-demographic">
                                                                    <i class="bi bi-person"></i> Case Data
                                                                </span>
                                                                break;
                                                        }
                                                    </div>

                                                    <div style="font-size: 0.9375rem; line-height: 1.6;">
                                                        @Html.Raw(child.DisplayText)
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="btn-group btn-group-sm">
                                                <button type="button" class="sn-btn sn-btn-ghost sn-btn-sm" onclick="moveCriterionToParent(@child.Id, null)" title="Ungroup">
                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                </button>
                                                <button type="button" class="sn-btn sn-btn-ghost sn-btn-sm" onclick="editCriterion(@child.Id)" title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button type="button" class="sn-btn sn-btn-ghost sn-btn-sm" onclick="deleteCriterion(@child.Id)" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                }

                                @* Add criteria to group buttons *@
                                <div style="margin-top: 1rem; padding-top: 0.75rem; border-top: 1px dashed var(--signal-dk);">
                                    <div style="font-size: 0.75rem; color: var(--graphite); margin-bottom: 0.5rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">
                                        <i class="bi bi-plus-circle"></i> Add to Group
                                    </div>
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <button type="button" class="add-criterion-btn" style="padding: 0.625rem; font-size: 0.8125rem;" onclick="openAddToGroupModal(@criterion.Id, 'laboratory')">
                                                <i class="bi bi-clipboard-pulse"></i>
                                                <span>Lab Test</span>
                                            </button>
                                        </div>
                                        <div class="col-6">
                                            <button type="button" class="add-criterion-btn" style="padding: 0.625rem; font-size: 0.8125rem;" onclick="openAddToGroupModal(@criterion.Id, 'clinical')">
                                                <i class="bi bi-heart-pulse"></i>
                                                <span>Clinical</span>
                                            </button>
                                        </div>
                                        <div class="col-6">
                                            <button type="button" class="add-criterion-btn" style="padding: 0.625rem; font-size: 0.8125rem;" onclick="openAddToGroupModal(@criterion.Id, 'customfield')">
                                                <i class="bi bi-ui-checks"></i>
                                                <span>Custom Field</span>
                                            </button>
                                        </div>
                                        <div class="col-6">
                                            <button type="button" class="add-criterion-btn" style="padding: 0.625rem; font-size: 0.8125rem;" onclick="openAddToGroupModal(@criterion.Id, 'demographic')">
                                                <i class="bi bi-person"></i>
                                                <span>Case Data</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                <div style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.75rem; color: var(--signal-dk); font-weight: 600; font-size: 0.875rem;">
                                    <i class="bi bi-braces"></i> GROUP END
                                </div>
                            </div>
                        }
                        else
                        {
                            @* Regular criterion (not grouped) *@
                            <div class="criterion-card" 
                                 data-criterion-id="@criterion.Id" 
                                 data-order="@criterion.DisplayOrder"
                                 data-level="0">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="d-flex align-items-start gap-2 flex-grow-1">
                                        @* Reorder buttons *@
                                        <div class="d-flex flex-column" style="gap: 2px;">
                                            <button type="button" 
                                                    class="sn-btn sn-btn-ghost" 
                                                    style="padding: 2px 6px; font-size: 0.75rem; @(isFirst ? "visibility: hidden;" : "")"
                                                    onclick="moveCriterion(@criterion.Id, 'up')"
                                                    title="Move up">
                                                <i class="bi bi-chevron-up"></i>
                                            </button>
                                            <button type="button" 
                                                    class="sn-btn sn-btn-ghost" 
                                                    style="padding: 2px 6px; font-size: 0.75rem; @(isLast ? "visibility: hidden;" : "")"
                                                    onclick="moveCriterion(@criterion.Id, 'down')"
                                                    title="Move down">
                                                <i class="bi bi-chevron-down"></i>
                                            </button>
                                        </div>

                                        <div class="flex-grow-1">
                                            <div class="d-flex align-items-center gap-2 mb-2">
                                                @switch (criterion.CriterionType)
                                                {
                                                    case CriterionType.Laboratory:
                                                        <span class="criterion-type-badge criterion-type-laboratory">
                                                            <i class="bi bi-clipboard-pulse"></i> Laboratory
                                                        </span>
                                                        break;
                                                    case CriterionType.Clinical:
                                                        <span class="criterion-type-badge criterion-type-clinical">
                                                            <i class="bi bi-heart-pulse"></i> Clinical
                                                        </span>
                                                        break;
                                                    case CriterionType.CustomField:
                                                        <span class="criterion-type-badge criterion-type-customfield">
                                                            <i class="bi bi-ui-checks"></i> Custom Field
                                                        </span>
                                                        break;
                                                    case CriterionType.Demographic:
                                                        <span class="criterion-type-badge criterion-type-demographic">
                                                            <i class="bi bi-person"></i> Case Data
                                                        </span>
                                                        break;
                                                }
                                            </div>

                                            <div style="font-size: 0.9375rem; line-height: 1.6;">
                                                @Html.Raw(criterion.DisplayText)
                                            </div>
                                        </div>
                                    </div>

                                    <div class="btn-group btn-group-sm">
                                        @if (!isLast && nextCriterion?.ParentCriteriaId == null)
                                        {
                                            <button type="button" class="sn-btn sn-btn-ghost sn-btn-sm" onclick="moveCriterionToParent(@nextCriterion.Id, @criterion.Id)" title="Group with below">
                                                <i class="bi bi-braces"></i>
                                            </button>
                                        }
                                        <button type="button" class="sn-btn sn-btn-ghost sn-btn-sm" onclick="editCriterion(@criterion.Id)" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button type="button" class="sn-btn sn-btn-ghost sn-btn-sm" onclick="deleteCriterion(@criterion.Id)" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                }
            </div>
        </div>

        <!-- Add Criterion Buttons -->
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <button type="button" class="add-criterion-btn" data-bs-toggle="modal" data-bs-target="#labCriterionModal" onclick="resetToRootLevel()">
                    <i class="bi bi-clipboard-pulse" style="font-size: 1.25rem;"></i>
                    <span>Add Laboratory Test Criterion</span>
                </button>
            </div>
            <div class="col-md-6">
                <button type="button" class="add-criterion-btn" data-bs-toggle="modal" data-bs-target="#clinicalCriterionModal" onclick="resetToRootLevel()">
                    <i class="bi bi-heart-pulse" style="font-size: 1.25rem;"></i>
                    <span>Add Clinical Symptom Criterion</span>
                </button>
            </div>
            <div class="col-md-6">
                <button type="button" class="add-criterion-btn" data-bs-toggle="modal" data-bs-target="#customFieldModal" onclick="resetToRootLevel()">
                    <i class="bi bi-ui-checks" style="font-size: 1.25rem;"></i>
                    <span>Add Custom Field Criterion</span>
                </button>
            </div>
            <div class="col-md-6">
                <button type="button" class="add-criterion-btn" data-bs-toggle="modal" data-bs-target="#caseFieldModal" onclick="resetToRootLevel()">
                    <i class="bi bi-person" style="font-size: 1.25rem;"></i>
                    <span>Add Case Data Criterion</span>
                </button>
            </div>
        </div>

        <!-- Navigation -->
        <div class="d-flex justify-content-between">
            <a asp-page="./Create" asp-route-id="@Model.DefinitionId" class="sn-btn sn-btn-ghost">
                <i class="bi bi-arrow-left"></i>
                Back
            </a>
            <div class="d-flex gap-2">
                <a asp-page="./Index" class="sn-btn sn-btn-ghost">
                    <i class="bi bi-x-lg"></i>
                    Save as Draft
                </a>
                <a asp-page="./Review" asp-route-id="@Model.DefinitionId" class="sn-btn sn-btn-signal">
                    Next: Review & Save
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Lab Criterion Modal -->
<div class="modal fade" id="labCriterionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header" style="background: var(--signal-lt); border-bottom: 2px solid var(--signal-dk);">
                <h5 class="modal-title">
                    <i class="bi bi-clipboard-pulse"></i>
                    Laboratory Test Criterion
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="labCriterionForm">
                    <input type="hidden" id="labDefinitionId" value="@Model.DefinitionId" />

                    <!-- Specimen Types -->
                    <div class="mb-4">
                        <label class="text-label">Specimen Types *</label>
                        <input type="text" class="sn-input mb-2" id="specimenSearch" placeholder="Search specimens..." />
                        <div class="specimen-grid" id="specimenGrid">
                            @foreach (var specimen in Model.SpecimenTypes)
                            {
                                <div class="specimen-item" data-id="@specimen.Id" onclick="toggleSpecimen(this)">
                                    <div class="specimen-item-name">@specimen.Name</div>
                                    @if (!string.IsNullOrEmpty(specimen.SnomedCode))
                                    {
                                        <div class="specimen-item-code">SNOMED: @specimen.SnomedCode</div>
                                    }
                                </div>
                            }
                        </div>
                        <div class="selected-items-list" id="selectedSpecimens"></div>

                        <!-- Storage Preference for Specimen -->
                        <div class="mt-3" style="padding: 0.75rem; background: var(--chalk); border: 1px solid var(--hairline); border-radius: 6px;">
                            <label class="text-label" style="font-size: 0.75rem; color: var(--graphite);">HOW TO STORE MATCHED VALUES</label>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="specimenStoragePreference" id="specimenStoreAsReceived" value="1" checked>
                                <label class="form-check-label" for="specimenStoreAsReceived">
                                    Store as originally sent in HL7 message
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="specimenStoragePreference" id="specimenStoreAsCanonical" value="2">
                                <label class="form-check-label" for="specimenStoreAsCanonical">
                                    Store as canonical value:
                                </label>
                                <select class="sn-input mt-2" id="canonicalSpecimenType" style="font-size: 0.875rem;" disabled>
                                    <option value="">Select canonical specimen type...</option>
                                    @foreach (var specimen in Model.SpecimenTypes)
                                    {
                                        <option value="@specimen.Id">@specimen.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Pathogens -->
                    <div class="mb-4">
                        <label class="text-label">Detected Pathogens/Biomarkers *</label>
                        <input type="text" class="sn-input mb-2" id="pathogenSearch" placeholder="Search pathogens..." />
                        <div class="specimen-grid" id="pathogenGrid">
                            @foreach (var pathogen in Model.Pathogens)
                            {
                                <div class="specimen-item" data-id="@pathogen.Id" data-name="@pathogen.Name" onclick="togglePathogen(this)">
                                    <div class="specimen-item-name">@pathogen.Name</div>
                                </div>
                            }
                        </div>
                        <div class="selected-items-list" id="selectedPathogens"></div>

                        <!-- Storage Preference for Pathogen/Biomarker -->
                        <div class="mt-3" style="padding: 0.75rem; background: var(--chalk); border: 1px solid var(--hairline); border-radius: 6px;">
                            <label class="text-label" style="font-size: 0.75rem; color: var(--graphite);">HOW TO STORE MATCHED VALUES</label>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="pathogenStoragePreference" id="pathogenStoreAsReceived" value="1" checked>
                                <label class="form-check-label" for="pathogenStoreAsReceived">
                                    Store as originally sent in HL7 message
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="pathogenStoragePreference" id="pathogenStoreAsCanonical" value="2">
                                <label class="form-check-label" for="pathogenStoreAsCanonical">
                                    Store as canonical value:
                                </label>
                                <select class="sn-input mt-2" id="canonicalPathogen" style="font-size: 0.875rem;" disabled>
                                    <option value="">Select canonical pathogen/biomarker...</option>
                                    @foreach (var pathogen in Model.Pathogens)
                                    {
                                        <option value="@pathogen.Id">@pathogen.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Test Methods -->
                    <div class="mb-4">
                        <label class="text-label">Test Methods</label>
                        <input type="text" class="sn-input mb-2" id="testMethodSearch" placeholder="Search test methods..." />
                        <div class="specimen-grid" id="testMethodGrid">
                            @foreach (var method in Model.TestMethods)
                            {
                                <div class="specimen-item" data-id="@method.Id" data-name="@method.Name" onclick="toggleTestMethod(this)">
                                    <div class="specimen-item-name">@method.Name</div>
                                </div>
                            }
                        </div>
                        <div class="selected-items-list" id="selectedTestMethods"></div>

                        <!-- Storage Preference for Test Method -->
                        <div class="mt-3" style="padding: 0.75rem; background: var(--chalk); border: 1px solid var(--hairline); border-radius: 6px;">
                            <label class="text-label" style="font-size: 0.75rem; color: var(--graphite);">HOW TO STORE MATCHED VALUES</label>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="testMethodStoragePreference" id="testMethodStoreAsReceived" value="1" checked>
                                <label class="form-check-label" for="testMethodStoreAsReceived">
                                    Store as originally sent in HL7 message
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="testMethodStoragePreference" id="testMethodStoreAsCanonical" value="2">
                                <label class="form-check-label" for="testMethodStoreAsCanonical">
                                    Store as canonical value:
                                </label>
                                <select class="sn-input mt-2" id="canonicalTestMethod" style="font-size: 0.875rem;" disabled>
                                    <option value="">Select canonical test method...</option>
                                    @foreach (var method in Model.TestMethods)
                                    {
                                        <option value="@method.Id">@method.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Result Values -->
                    <div class="mb-4">
                        <label class="text-label">Result Values *</label>
                        <div class="text-muted" style="font-size: 0.75rem; margin-bottom: 0.5rem;">
                            Select common values or add custom ones
                        </div>
                        <input type="text" class="sn-input mb-2" id="resultValueSearch" placeholder="Search or type custom value..." />
                        <button type="button" class="btn btn-sm sn-btn-secondary mb-2" onclick="addCustomResultValue()" style="width: 100%;">
                            <i class="bi bi-plus-circle"></i> Add Custom Value from Search Box
                        </button>
                        <div class="specimen-grid" id="resultValueGrid">
                            <div class="specimen-item" data-value="Positive" onclick="toggleResultValue(this)">
                                <div class="specimen-item-name">Positive</div>
                            </div>
                            <div class="specimen-item" data-value="Negative" onclick="toggleResultValue(this)">
                                <div class="specimen-item-name">Negative</div>
                            </div>
                            <div class="specimen-item" data-value="Detected" onclick="toggleResultValue(this)">
                                <div class="specimen-item-name">Detected</div>
                            </div>
                            <div class="specimen-item" data-value="Not Detected" onclick="toggleResultValue(this)">
                                <div class="specimen-item-name">Not Detected</div>
                            </div>
                            <div class="specimen-item" data-value="Reactive" onclick="toggleResultValue(this)">
                                <div class="specimen-item-name">Reactive</div>
                            </div>
                            <div class="specimen-item" data-value="Non-Reactive" onclick="toggleResultValue(this)">
                                <div class="specimen-item-name">Non-Reactive</div>
                            </div>
                            <div class="specimen-item" data-value="Indeterminate" onclick="toggleResultValue(this)">
                                <div class="specimen-item-name">Indeterminate</div>
                            </div>
                            <div class="specimen-item" data-value="Equivocal" onclick="toggleResultValue(this)">
                                <div class="specimen-item-name">Equivocal</div>
                            </div>
                            <div class="specimen-item" data-value="Inconclusive" onclick="toggleResultValue(this)">
                                <div class="specimen-item-name">Inconclusive</div>
                            </div>
                        </div>
                        <div class="selected-items-list" id="selectedResultValues"></div>

                        <!-- Storage Preference for Result Values -->
                        <div class="mt-3" style="padding: 0.75rem; background: var(--chalk); border: 1px solid var(--hairline); border-radius: 6px;">
                            <label class="text-label" style="font-size: 0.75rem; color: var(--graphite);">HOW TO STORE MATCHED VALUES</label>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="resultStoragePreference" id="resultStoreAsReceived" value="1" checked>
                                <label class="form-check-label" for="resultStoreAsReceived">
                                    Store as originally sent in HL7 message
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="resultStoragePreference" id="resultStoreAsCanonical" value="2">
                                <label class="form-check-label" for="resultStoreAsCanonical">
                                    Store as canonical value:
                                </label>
                                <input type="text" class="sn-input mt-2" id="canonicalResultValue" placeholder="Enter canonical result value..." style="font-size: 0.875rem;" disabled />
                            </div>
                        </div>
                    </div>

                    <!-- Time Constraint -->
                    <div class="mb-4">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="enableTimeConstraint">
                            <label class="form-check-label" for="enableTimeConstraint">
                                Add time constraint
                            </label>
                        </div>
                        <div id="timeConstraintFields" style="display: none;">
                            <div class="row g-2">
                                <div class="col-md-4">
                                    <label class="text-label">Within</label>
                                    <input type="number" class="sn-input" id="timeConstraintDays" value="14" min="1" />
                                </div>
                                <div class="col-md-4">
                                    <label class="text-label">Days</label>
                                    <select class="sn-input" id="timeConstraintDirection">
                                        <option value="before">Before</option>
                                        <option value="after">After</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="text-label">Relative To</label>
                                    <select class="sn-input" id="timeConstraintRelativeTo">
                                        <option value="OnsetDate">Symptom Onset</option>
                                        <option value="ReportDate">Report Date</option>
                                        <option value="DiagnosisDate">Diagnosis Date</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="sn-btn sn-btn-ghost" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="sn-btn sn-btn-signal" onclick="saveLabCriterion()">Add Criterion</button>
            </div>
        </div>
    </div>
</div>

