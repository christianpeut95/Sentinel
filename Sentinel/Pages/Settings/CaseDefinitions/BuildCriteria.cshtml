@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Selected items tracking
        let selectedSpecimenIds = [];
        let selectedSymptomIds = [];
        let selectedPathogenIds = []; // Changed from selectedPathogenNames to selectedPathogenIds
        let selectedTestMethodIds = [];
        let selectedResultValues = [];
        window.currentParentCriterionId = null; // Track which group we're adding to (null = root level)

        // Toggle specimen selection
        function toggleSpecimen(element) {
            const id = parseInt(element.dataset.id);
            const name = element.querySelector('.specimen-item-name').textContent;

            if (selectedSpecimenIds.includes(id)) {
                selectedSpecimenIds = selectedSpecimenIds.filter(x => x !== id);
                element.classList.remove('selected');
            } else {
                selectedSpecimenIds.push(id);
                element.classList.add('selected');
            }

            updateSelectedSpecimens();
        }

        function updateSelectedSpecimens() {
            const container = document.getElementById('selectedSpecimens');
            container.innerHTML = '';

            selectedSpecimenIds.forEach(id => {
                const item = document.querySelector(`[data-id="${id}"]`);
                const name = item.querySelector('.specimen-item-name').textContent;

                const chip = document.createElement('div');
                chip.className = 'selected-item-chip';
                chip.innerHTML = `
                    <span>${name}</span>
                    <button type="button" onclick="removeSpecimen(${id})">×</button>
                `;
                container.appendChild(chip);
            });
        }

        function removeSpecimen(id) {
            selectedSpecimenIds = selectedSpecimenIds.filter(x => x !== id);
            document.querySelector(`[data-id="${id}"]`).classList.remove('selected');
            updateSelectedSpecimens();
        }

        // Toggle symptom selection
        function toggleSymptom(element) {
            const id = parseInt(element.dataset.id);
            const name = element.querySelector('.specimen-item-name').textContent;

            if (selectedSymptomIds.includes(id)) {
                selectedSymptomIds = selectedSymptomIds.filter(x => x !== id);
                element.classList.remove('selected');
            } else {
                selectedSymptomIds.push(id);
                element.classList.add('selected');
            }

            updateSelectedSymptoms();
        }

        function updateSelectedSymptoms() {
            const container = document.getElementById('selectedSymptoms');
            container.innerHTML = '';

            selectedSymptomIds.forEach(id => {
                const item = document.querySelector(`#symptomGrid [data-id="${id}"]`);
                const name = item.querySelector('.specimen-item-name').textContent;

                const chip = document.createElement('div');
