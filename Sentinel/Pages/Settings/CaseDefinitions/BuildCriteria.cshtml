        // Save Lab Criterion
        async function saveLabCriterion() {
            console.log('saveLabCriterion called, editingCriterionId:', window.editingCriterionId);

            if (selectedSpecimenIds.length === 0) {
                alert('Please select at least one specimen type');
                return;
            }

            if (selectedPathogenIds.length === 0) {
                alert('Please select at least one pathogen/biomarker');
                return;
            }

            if (selectedResultValues.length === 0) {
                alert('Please enter at least one result value');
                return;
            }

            const pathogenIds = selectedPathogenIds; // Now sending IDs instead of names
            const testMethods = selectedTestMethodIds;
            const resultValues = selectedResultValues;

            // Capture storage preferences
            const specimenStoragePref = parseInt(document.querySelector('input[name="specimenStoragePreference"]:checked').value);
            const pathogenStoragePref = parseInt(document.querySelector('input[name="pathogenStoragePreference"]:checked').value);
            const testMethodStoragePref = parseInt(document.querySelector('input[name="testMethodStoragePreference"]:checked').value);
            const resultStoragePref = parseInt(document.querySelector('input[name="resultStoragePreference"]:checked').value);

            const canonicalSpecimenTypeId = specimenStoragePref === 2 ? parseInt(document.getElementById('canonicalSpecimenType').value) || null : null;
            const canonicalPathogenIdValue = pathogenStoragePref === 2 ? document.getElementById('canonicalPathogen').value || null : null;
            const canonicalTestMethodId = testMethodStoragePref === 2 ? parseInt(document.getElementById('canonicalTestMethod').value) || null : null;
            const canonicalResultValue = resultStoragePref === 2 ? document.getElementById('canonicalResultValue').value.trim() || null : null;

            console.log('Storage preferences:', {
                specimenStoragePref,
                canonicalSpecimenTypeId,
                pathogenStoragePref,
                canonicalPathogenIdValue,
                testMethodStoragePref,
                canonicalTestMethodId,
                resultStoragePref,
                canonicalResultValue
            });

            // Validate canonical selections if storage preference is set to canonical
            if (specimenStoragePref === 2 && !canonicalSpecimenTypeId) {
                alert('Please select a canonical specimen type');
                return;
            }
            if (pathogenStoragePref === 2 && !canonicalPathogenIdValue) {
                alert('Please select a canonical pathogen/biomarker');
                return;
            }
            if (testMethodStoragePref === 2 && testMethods.length > 0 && !canonicalTestMethodId) {
                alert('Please select a canonical test method');
                return;
            }
            if (resultStoragePref === 2 && !canonicalResultValue) {
                alert('Please enter a canonical result value');
                return;
            }

            let timeConstraint = null;
            if (document.getElementById('enableTimeConstraint').checked) {
                timeConstraint = {
                    days: parseInt(document.getElementById('timeConstraintDays').value),
                    relativeTo: document.getElementById('timeConstraintRelativeTo').value,
                    direction: document.getElementById('timeConstraintDirection').value
                };
            }

            // Build display text
            const specimenNames = selectedSpecimenIds.map(id => {
                const item = document.querySelector(`#specimenGrid [data-id="${id}"]`);
                return item.querySelector('.specimen-item-name').textContent;
            });

            const pathogenNames = pathogenIds.map(id => {
                const item = document.querySelector(`#pathogenGrid [data-id="${id}"]`);
                return item.dataset.name;
            });

            let displayText = `<strong>Laboratory:</strong> ${pathogenNames.join(' OR ')} detected in ${specimenNames.join(' OR ')}`;
            if (testMethods.length > 0) {
                const methodNames = testMethods.map(id => {
                    const item = document.querySelector(`#testMethodGrid [data-id="${id}"]`);
                    return item.dataset.name;
                });
                displayText += ` by ${methodNames.join(' OR ')}`;
            }
            displayText += `, result: ${resultValues.join(' OR ')}`;
            if (timeConstraint) {
                displayText += ` (within ${timeConstraint.days} days ${timeConstraint.direction} ${timeConstraint.relativeTo})`;
            }

            const data = {
                logicalOperator: 2, // OR (default for lab criteria - allows multiple result types)
                groupNumber: 1,
                parentCriteriaId: window.currentParentCriterionId || null,
                specimenTypeIds: selectedSpecimenIds,
                pathogenNames: pathogenIds, // Now sending pathogen GUIDs (as strings)
                testMethodIds: testMethods,
                resultValues: resultValues,
                timeConstraint: timeConstraint,
                displayText: displayText,
                // Storage preferences (ensure correct types)
                specimenStoragePreference: specimenStoragePref,
                canonicalSpecimenTypeId: canonicalSpecimenTypeId,
                pathogenStoragePreference: pathogenStoragePref,
                canonicalPathogenId: canonicalPathogenIdValue, // This is a Guid string
                testMethodStoragePreference: testMethodStoragePref,
                canonicalTestMethodId: canonicalTestMethodId,
                resultStoragePreference: resultStoragePref,
                canonicalResultValue: canonicalResultValue
            };

            console.log('Sending data:', JSON.stringify(data, null, 2));

            try {
                const isEditing = window.editingCriterionId !== null && window.editingCriterionId !== undefined;
                const url = isEditing 
                    ? `/api/case-definitions/@Model.DefinitionId/criteria/${window.editingCriterionId}/laboratory`
                    : '/api/case-definitions/@Model.DefinitionId/criteria/laboratory';
                const method = isEditing ? 'PUT' : 'POST';

                console.log(`Making ${method} request to:`, url);

                const response = await fetch(url, {
                    method: method,
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });

                console.log('Response status:', response.status);

                if (response.ok) {
                    const responseData = await response.json();
                    console.log('Response data:', responseData);
                    window.currentParentCriterionId = null;
                    window.editingCriterionId = null;
                    location.reload();
                } else {
                    const errorText = await response.text();
                    console.error('Failed to save criterion:', errorText);
                    alert('Failed to save criterion: ' + errorText);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred while saving: ' + error.message);
            }
        }

        // Save Clinical Criterion
        async function saveClinicalCriterion() {
            if (selectedSymptomIds.length === 0) {
                alert('Please select at least one symptom');
                return;
            }

            const mode = document.querySelector('input[name="clinicalMode"]:checked').value;
            const requireAll = mode === 'all';
            const minCount = mode === 'min' ? parseInt(document.getElementById('clinicalMinCount').value) : null;

            const severityFilter = document.getElementById('enableSeverity').checked 
                ? document.getElementById('severityFilter').value 
                : null;

            // Build display text
            const symptomNames = selectedSymptomIds.map(id => {
                const item = document.querySelector(`#symptomGrid [data-id="${id}"]`);
                return item.querySelector('.specimen-item-name').textContent;
            });

            let displayText = '<strong>Clinical:</strong> Patient must have ';
            if (requireAll) {
                displayText += `<strong>ALL</strong> of: ${symptomNames.join(', ')}`;
            } else if (minCount) {
                displayText += `<strong>at least ${minCount}</strong> of: ${symptomNames.join(', ')}`;
            } else {
                displayText += `<strong>ANY</strong> of: ${symptomNames.join(', ')}`;
            }

            if (severityFilter) {
                displayText += ` (severity: ${severityFilter})`;
            }

            const data = {
                logicalOperator: requireAll ? 1 : 2, // AND if all required, OR if any
                groupNumber: 1,
                parentCriteriaId: window.currentParentCriterionId || null,
                symptomIds: selectedSymptomIds,
                requireAll: requireAll,
                minCount: minCount,
                severityFilter: severityFilter,
                displayText: displayText
            };

            try {
                const isEditing = window.editingCriterionId !== null && window.editingCriterionId !== undefined;
                const url = isEditing 
                    ? `/api/case-definitions/@Model.DefinitionId/criteria/${window.editingCriterionId}/clinical`
                    : '/api/case-definitions/@Model.DefinitionId/criteria/clinical';
                const method = isEditing ? 'PUT' : 'POST';

                const response = await fetch(url, {
                    method: method,
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    window.currentParentCriterionId = null;
                    window.editingCriterionId = null;
                    location.reload();
                } else {
                    alert('Failed to save criterion');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred while saving');
            }
        }

