        // Update custom field operators based on field type
        function updateCustomFieldOperators() {
            const select = document.getElementById('customFieldSelect');
            const selectedOption = select.options[select.selectedIndex];
            const fieldType = selectedOption?.dataset.type;

            const operatorSelect = document.getElementById('customFieldOperator');

            // Reset to default options
            operatorSelect.innerHTML = `
                <option value="Equals">Equals</option>
                <option value="NotEquals">Does not equal</option>
                <option value="IsPresent">Is present (has any value)</option>
                <option value="IsEmpty">Is empty (no value)</option>
            `;

            // Add type-specific operators
            if (fieldType === 'Text' || fieldType === 'TextArea') {
                operatorSelect.insertAdjacentHTML('beforeend', '<option value="Contains">Contains</option>');
            }

            if (fieldType === 'Number' || fieldType === 'Date') {
                operatorSelect.insertAdjacentHTML('beforeend', '<option value="GreaterThan">Greater than</option>');
                operatorSelect.insertAdjacentHTML('beforeend', '<option value="LessThan">Less than</option>');
                operatorSelect.insertAdjacentHTML('beforeend', '<option value="Between">Between</option>');
            }
        }

        // Edit Criterion - Load existing data and open appropriate modal
        async function editCriterion(criterionId) {
            try {
                const response = await fetch(`/api/case-definitions/@Model.DefinitionId/criteria/${criterionId}`);
                if (!response.ok) {
                    alert('Failed to load criterion data');
                    return;
                }

                const criterion = await response.json();
                console.log('Loaded criterion for editing:', criterion);
                console.log('Storage preferences from API:', criterion.storagePreferences);

                window.editingCriterionId = criterionId;

                // Clear existing selections
                clearAllSelections();

                // Parse the ValueJson
                const valueData = JSON.parse(criterion.valueJson);
                console.log('Parsed valueData:', valueData);

                // Open the appropriate modal based on criterion type
                switch (criterion.criterionType) {
                    case 2: // Laboratory
                        await loadLabCriterionForEdit(valueData, criterion.storagePreferences);
                        const labModal = new bootstrap.Modal(document.getElementById('labCriterionModal'));
                        document.querySelector('#labCriterionModal .modal-footer button.sn-btn-signal').textContent = 'Update Criterion';
                        labModal.show();
                        break;

                    case 1: // Clinical
                        loadClinicalCriterionForEdit(valueData);
                        const clinicalModal = new bootstrap.Modal(document.getElementById('clinicalCriterionModal'));
                        document.querySelector('#clinicalCriterionModal .modal-footer button.sn-btn-signal').textContent = 'Update Criterion';
                        clinicalModal.show();
                        break;

                    case 5: // CustomField
                        loadCustomFieldCriterionForEdit(valueData);
                        const customModal = new bootstrap.Modal(document.getElementById('customFieldModal'));
                        document.querySelector('#customFieldModal .modal-footer button.sn-btn-signal').textContent = 'Update Criterion';
                        customModal.show();
                        break;

                    case 4: // Demographic (Case Data)
                        loadCaseDataCriterionForEdit(valueData, criterion.fieldPath);
                        const caseModal = new bootstrap.Modal(document.getElementById('caseFieldModal'));
                        document.querySelector('#caseFieldModal .modal-footer button.sn-btn-signal').textContent = 'Update Criterion';
                        caseModal.show();
                        break;
                }
            } catch (error) {
                console.error('Error loading criterion:', error);
                alert('An error occurred while loading the criterion');
            }
        }

        // Load lab criterion data into the modal for editing
        async function loadLabCriterionForEdit(valueData, storagePreferences) {
            console.log('loadLabCriterionForEdit called with:', { valueData, storagePreferences });

            // Set specimen types
            if (valueData.specimenTypeIds) {
                selectedSpecimenIds = [...valueData.specimenTypeIds];
                selectedSpecimenIds.forEach(id => {
                    const element = document.querySelector(`#specimenGrid [data-id="${id}"]`);
                    if (element) element.classList.add('selected');
                });
                updateSelectedSpecimens();
            }

            // Set pathogens
            if (valueData.pathogenNames) {
                selectedPathogenNames = [...valueData.pathogenNames];
                selectedPathogenNames.forEach(name => {
                    const element = Array.from(document.querySelectorAll('#pathogenGrid .specimen-item')).find(el => 
                        el.querySelector('.specimen-item-name').textContent === name
                    );
                    if (element) element.classList.add('selected');
                });
                updateSelectedPathogens();
            }

            // Set test methods
            if (valueData.testMethodIds) {
                selectedTestMethodIds = [...valueData.testMethodIds];
                selectedTestMethodIds.forEach(id => {
                    const element = document.querySelector(`#testMethodGrid [data-id="${id}"]`);
                    if (element) element.classList.add('selected');
                });
                updateSelectedTestMethods();
            }

            // Set result values
            if (valueData.resultValues) {
                selectedResultValues = [...valueData.resultValues];
                updateSelectedResultValues();
            }

            // Set time constraint
            if (valueData.timeConstraint) {
                document.getElementById('enableTimeConstraint').checked = true;
                document.getElementById('timeConstraintFields').style.display = 'block';
                document.getElementById('timeConstraintDays').value = valueData.timeConstraint.days;
                document.getElementById('timeConstraintRelativeTo').value = valueData.timeConstraint.relativeTo;
                document.getElementById('timeConstraintDirection').value = valueData.timeConstraint.direction;
            }

            // Determine which source to use for storage preferences
            // Priority: storagePreferences (from separate table) > valueData (from JSON)
            let prefs;
            let source;

            if (storagePreferences && (
                storagePreferences.specimenStoragePreference || 
                storagePreferences.pathogenStoragePreference || 
                storagePreferences.testMethodStoragePreference || 
                storagePreferences.resultStoragePreference
            )) {
                // Use storagePreferences from the CaseDefinitionLabCriteria table
                prefs = storagePreferences;
                source = 'storagePreferences (CaseDefinitionLabCriteria table)';
            } else if (valueData.specimenStoragePreference || valueData.pathogenStoragePreference || 
                       valueData.testMethodStoragePreference || valueData.resultStoragePreference) {
                // Use storage preferences from valueData (stored in ValueJson)
                prefs = valueData;
                source = 'valueData (ValueJson field)';
            } else {
                // No storage preferences found, use defaults
                prefs = {};
                source = 'defaults (none found)';
            }

            console.log('Using preferences from:', source, prefs);

            // Specimen storage preference
            const specimenPref = prefs.specimenStoragePreference || 1;
            console.log('Setting specimen storage preference to:', specimenPref, 'canonical:', prefs.canonicalSpecimenTypeId);
            const specimenRadio = document.querySelector(`input[name="specimenStoragePreference"][value="${specimenPref}"]`);
            if (specimenRadio) {
                specimenRadio.checked = true;
                if (specimenPref === 2 && prefs.canonicalSpecimenTypeId) {
                    document.getElementById('canonicalSpecimenType').disabled = false;
                    document.getElementById('canonicalSpecimenType').value = prefs.canonicalSpecimenTypeId;
                }
            }

            // Pathogen storage preference
            const pathogenPref = prefs.pathogenStoragePreference || 1;
            console.log('Setting pathogen storage preference to:', pathogenPref, 'canonical:', prefs.canonicalPathogenId);
            const pathogenRadio = document.querySelector(`input[name="pathogenStoragePreference"][value="${pathogenPref}"]`);
            if (pathogenRadio) {
                pathogenRadio.checked = true;
                if (pathogenPref === 2 && prefs.canonicalPathogenId) {
                    document.getElementById('canonicalPathogen').disabled = false;
                    document.getElementById('canonicalPathogen').value = prefs.canonicalPathogenId;
                }
            }

            // Test method storage preference
            const testMethodPref = prefs.testMethodStoragePreference || 1;
            console.log('Setting test method storage preference to:', testMethodPref, 'canonical:', prefs.canonicalTestMethodId);
            const testMethodRadio = document.querySelector(`input[name="testMethodStoragePreference"][value="${testMethodPref}"]`);
            if (testMethodRadio) {
                testMethodRadio.checked = true;
                if (testMethodPref === 2 && prefs.canonicalTestMethodId) {
                    document.getElementById('canonicalTestMethod').disabled = false;
                    document.getElementById('canonicalTestMethod').value = prefs.canonicalTestMethodId;
                }
            }

            // Result storage preference
            const resultPref = prefs.resultStoragePreference || 1;
            console.log('Setting result storage preference to:', resultPref, 'canonical:', prefs.canonicalResultValue);
            const resultRadio = document.querySelector(`input[name="resultStoragePreference"][value="${resultPref}"]`);
            if (resultRadio) {
                resultRadio.checked = true;
                if (resultPref === 2 && prefs.canonicalResultValue) {
                    document.getElementById('canonicalResultValue').disabled = false;
                    document.getElementById('canonicalResultValue').value = prefs.canonicalResultValue;
                }
            }

            console.log('Finished loading lab criterion for edit');
        }

        // Load clinical criterion data into the modal for editing
        function loadClinicalCriterionForEdit(valueData) {
            // Set symptoms
            if (valueData.symptomIds) {
                selectedSymptomIds = [...valueData.symptomIds];
                selectedSymptomIds.forEach(id => {
                    const element = document.querySelector(`#symptomGrid [data-id="${id}"]`);
                    if (element) element.classList.add('selected');
                });
                updateSelectedSymptoms();
            }

            // Set mode (all/any/min)
            if (valueData.requireAll) {
                document.getElementById('clinicalAll').checked = true;
            } else if (valueData.minCount) {
                document.getElementById('clinicalMin').checked = true;
                document.getElementById('clinicalMinCount').value = valueData.minCount;
            } else {
                document.getElementById('clinicalAny').checked = true;
            }

            // Set severity
            if (valueData.severityFilter) {
                document.getElementById('enableSeverity').checked = true;
                document.getElementById('severityFields').style.display = 'block';
                document.getElementById('severityFilter').value = valueData.severityFilter;
            }
        }

        // Load custom field criterion data into the modal for editing
        function loadCustomFieldCriterionForEdit(valueData) {
            if (valueData.customFieldId) {
                document.getElementById('customFieldSelect').value = valueData.customFieldId;
                updateCustomFieldOperators();
            }

            if (valueData.operator) {
                document.getElementById('customFieldOperator').value = valueData.operator;
            }

            if (valueData.value) {
                document.getElementById('customFieldValue').value = valueData.value;
            }
        }

        // Load case data criterion into the modal for editing
        function loadCaseDataCriterionForEdit(valueData, fieldPath) {
            if (fieldPath) {
                document.getElementById('caseFieldPath').value = fieldPath;
            }

            if (valueData.operator) {
                document.getElementById('caseFieldOperator').value = valueData.operator;
            }

            if (valueData.value) {
                document.getElementById('caseFieldValue').value = valueData.value;
            }
        }

        // Reset modal button text when closing
        document.querySelectorAll('.modal').forEach(modal => {
            modal.addEventListener('hidden.bs.modal', function() {
                const saveButton = this.querySelector('.modal-footer button.sn-btn-signal');
                if (saveButton) {
                    const modalId = this.id;
                    if (modalId === 'labCriterionModal') {
                        saveButton.textContent = 'Add Criterion';
                    } else if (modalId === 'clinicalCriterionModal') {
                        saveButton.textContent = 'Add Criterion';
                    } else if (modalId === 'customFieldModal') {
                        saveButton.textContent = 'Add Criterion';
                    } else if (modalId === 'caseFieldModal') {
                        saveButton.textContent = 'Add Criterion';
                    }
                }
                window.editingCriterionId = null;
            });
        });
    </script>
}
