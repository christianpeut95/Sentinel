            <div class="modal-footer">
                <button type="button" class="sn-btn sn-btn-ghost" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="sn-btn sn-btn-signal" onclick="saveClinicalCriterion()">Add Criterion</button>
            </div>
        </div>
    </div>
