@page
@model Sentinel.Pages.Settings.IndexModel
@using Sentinel.Constants

@{
    ViewData["Title"] = "Settings";
    ViewData["Subtitle"] = "System Configuration & Administration";
    Layout = "~/Pages/Shared/_LayoutSentinel.cshtml";
}

<style>
    /* Settings Page Styling - Consistent with Dashboard */
    .settings-container {
        max-width: 1440px;
        margin: 0 auto;
    }

    .settings-hero {
        background: linear-gradient(135deg, var(--signal-lt) 0%, var(--chalk) 100%);
        border-radius: 16px;
        padding: 2.5rem;
        color: var(--forest);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        border: 1px solid var(--hairline);
        margin-bottom: 2.5rem;
    }

    .settings-hero h1 {
        font-size: 2rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: var(--forest);
        letter-spacing: -0.5px;
    }

    .settings-hero p {
        color: var(--graphite);
        font-size: 1rem;
        margin: 0;
    }

    .category-section {
        margin-bottom: 3rem;
    }

    .category-header {
        display: flex;
        align-items: center;
        margin-bottom: 1.25rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid #e2e8f0;
    }

    .category-header-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        color: white;
        margin-right: 1rem;
    }

    .category-header h3 {
        margin: 0;
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--forest);
        flex: 1;
    }

    .category-header .category-description {
        font-size: 0.875rem;
        color: var(--graphite);
        margin: 0;
        margin-top: 0.25rem;
    }

    /* Color Schemes for Categories - Sentinel Green Variants */
    .category-system { background: linear-gradient(135deg, var(--slate) 0%, var(--slate-2) 100%); }
    .category-disease { background: linear-gradient(135deg, var(--signal-dk) 0%, var(--moss) 100%); }
    .category-lab { background: linear-gradient(135deg, var(--signal-dk) 0%, var(--forest-2) 100%); }
    .category-exposure { background: linear-gradient(135deg, var(--signal) 0%, var(--signal-dk) 100%); }
    .category-contact { background: linear-gradient(135deg, var(--moss) 0%, var(--forest-2) 100%); }
    .category-task { background: linear-gradient(135deg, var(--signal-dk) 0%, var(--moss) 100%); }
    .category-demo { background: linear-gradient(135deg, var(--signal-dk) 0%, var(--forest) 100%); }
    .category-security { background: linear-gradient(135deg, var(--forest) 0%, var(--forest-2) 100%); }
    .category-admin { background: linear-gradient(135deg, var(--moss) 0%, var(--forest-2) 100%); }
    .category-outbreak { background: linear-gradient(135deg, var(--status-outbreak) 0%, #991b1b 100%); }

    .setting-card {
        background: var(--chalk);
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        transition: all 0.3s ease;
        border: 1px solid var(--hairline);
        height: 100%;
        position: relative;
        display: flex;
        flex-direction: column;
    }

    .setting-card:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
        transform: translateY(-3px);
        border-color: var(--signal-dk);
    }

    .setting-card-icon {
        width: 50px;
        height: 50px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1rem;
        background: var(--signal-lt);
        color: var(--signal-dk);
    }

    .setting-card h5 {
        color: var(--forest);
        font-weight: 600;
        margin-bottom: 0.5rem;
        font-size: 1rem;
    }

    .setting-card p {
        color: var(--graphite);
        font-size: 0.813rem;
        line-height: 1.5;
        margin: 0;
        flex: 1;
    }

    .setting-card .stretched-link {
        text-decoration: none;
    }

    .setting-card-highlight {
        border: 2px solid var(--signal-dk);
        background: linear-gradient(135deg, var(--chalk) 0%, var(--signal-lt) 100%);
    }

    .setting-card-highlight .setting-card-icon {
        background: linear-gradient(135deg, var(--signal-dk) 0%, var(--moss) 100%);
        color: white;
    }

    /* Quick Links Section */
    .quick-links {
        background: var(--chalk);
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        border: 1px solid var(--hairline);
        margin-bottom: 2.5rem;
    }

    .quick-links h4 {
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--forest);
        margin-bottom: 1rem;
    }

    .quick-link-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: var(--signal-lt);
        border: 1px solid var(--hairline);
        border-radius: 8px;
        color: var(--forest);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: all 0.2s;
    }

    .quick-link-btn:hover {
        background: var(--signal-dk);
        color: white;
        border-color: var(--signal-dk);
    }

    @@media (max-width: 768px) {
        .settings-hero {
            padding: 1.5rem;
        }

        .settings-hero h1 {
            font-size: 1.5rem;
        }

        .category-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .category-header-icon {
            margin-bottom: 0.75rem;
        }
    }
</style>

<div class="container-fluid settings-container">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Settings</li>
        </ol>
    </nav>

    <!-- Hero Section -->
    <div class="settings-hero">
        <div class="d-flex justify-content-between align-items-start flex-wrap">
            <div>
                <h1><i class="bi bi-gear-fill me-2"></i>System Settings & Configuration</h1>
                <p>Configure system-wide settings, manage lookup tables, and customize your surveillance system</p>
            </div>
            <div class="text-end" style="color: #718096;">
                <div style="font-size: 0.875rem; font-weight: 500;">@AppVersion.ProductName @AppVersion.FullVersionString</div>
                <div style="font-size: 0.75rem; margin-top: 2px;">@AppVersion.ReleaseDate</div>
            </div>
        </div>
    </div>

    <!-- Quick Access Section -->
    <div class="quick-links">
        <h4><i class="bi bi-lightning-fill me-2"></i>Quick Access</h4>
        <div class="d-flex flex-wrap gap-2">
            <a asp-page="/Settings/Organization" class="quick-link-btn">
                <i class="bi bi-building"></i> Organization
            </a>
            <a asp-page="/Settings/Users/Index" class="quick-link-btn">
                <i class="bi bi-person-gear"></i> User Management
            </a>
            <a asp-page="/Settings/Diseases/Index" class="quick-link-btn">
                <i class="bi bi-virus"></i> Diseases
            </a>
            <a asp-page="/Settings/DiseaseAccess/Index" class="quick-link-btn">
                <i class="bi bi-shield-lock"></i> Disease Access
            </a>
            <a asp-page="/Locations/Index" class="quick-link-btn">
                <i class="bi bi-geo-alt"></i> Locations
            </a>
            <a asp-page="/Settings/CustomFields/Index" class="quick-link-btn">
                <i class="bi bi-sliders"></i> Custom Fields
            </a>
        </div>
    </div>

    <!-- System Configuration -->
    <div class="category-section">
        <div class="category-header">
            <div class="category-header-icon category-system">
                <i class="bi bi-gear-fill"></i>
            </div>
            <div>
                <h3>System Configuration</h3>
                <p class="category-description">Core system settings, API integrations, and custom field management</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-building"></i>
                    </div>
                    <h5>Organization Details</h5>
                    <p>Configure your organization name, logo, and contact information</p>
                    <a asp-page="/Settings/Organization" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-sliders"></i>
                    </div>
                    <h5>Custom Fields</h5>
                    <p>Create and manage custom data fields for patients, cases, and contacts</p>
                    <a asp-page="/Settings/CustomFields/Index" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-eye"></i>
                    </div>
                    <h5>Field Visibility</h5>
                    <p>Control which fields are visible or required throughout the system</p>
                    <a asp-page="/Settings/CustomFields/Visibility" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-hdd-stack"></i>
                    </div>
                    <h5>Database Backups</h5>
                    <p>Create, restore, and manage automated database backups and disaster recovery</p>
                    <a asp-page="/Settings/Backups/Index" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-info-circle"></i>
                    </div>
                    <h5>About Sentinel</h5>
                    <p>Version information, system details, and product information</p>
                    <a asp-page="/Settings/About" class="stretched-link"></a>
                </div>
            </div>
        </div>
    </div>

    <!-- Disease & Case Management -->
    <div class="category-section">
        <div class="category-header">
            <div class="category-header-icon category-disease">
                <i class="bi bi-virus"></i>
            </div>
            <div>
                <h3>Disease & Case Management</h3>
                <p class="category-description">Manage diseases, symptoms, case classifications, and clinical data</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-virus"></i>
                    </div>
                    <h5>Diseases</h5>
                    <p>Configure notifiable diseases, ICD codes, and disease-specific settings</p>
                    <a asp-page="/Settings/Diseases/Index" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-heart-pulse"></i>
                    </div>
                    <h5>Symptoms</h5>
                    <p>Manage symptom types for disease surveillance and case investigation</p>
                    <a asp-page="/Settings/Lookups/Symptoms" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-journal-check"></i>
                    </div>
                    <h5>Case Statuses</h5>
                    <p>Define case investigation statuses and classification categories</p>
                    <a asp-page="/Settings/CaseStatuses/Index" class="stretched-link"></a>
                </div>
            </div>
        </div>
    </div>

    <!-- Laboratory Management -->
    <div class="category-section">
        <div class="category-header">
            <div class="category-header-icon category-lab">
                <i class="bi bi-hospital"></i>
            </div>
            <div>
                <h3>Laboratory & Testing</h3>
                <p class="category-description">Configure laboratory settings, specimen types, test types, and result classifications</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-building"></i>
                    </div>
                    <h5>Organization Types</h5>
                    <p>Define types of laboratories and healthcare organizations</p>
                    <a asp-page="/Settings/Lookups/OrganizationTypes" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-droplet"></i>
                    </div>
                    <h5>Specimen Types</h5>
                    <p>Configure specimen collection types (blood, swab, urine, etc.)</p>
                    <a asp-page="/Settings/Lookups/SpecimenTypes" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-clipboard2-pulse"></i>
                    </div>
                    <h5>Test Types</h5>
                    <p>Manage laboratory test types and diagnostic procedures</p>
                    <a asp-page="/Settings/Lookups/TestTypes" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-check2-square"></i>
                    </div>
                    <h5>Test Results</h5>
                    <p>Define result classifications (positive, negative, inconclusive, etc.)</p>
                    <a asp-page="/Settings/Lookups/TestResults" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-rulers"></i>
                    </div>
                    <h5>Result Units</h5>
                    <p>Configure measurement units for quantitative test results</p>
                    <a asp-page="/Settings/Lookups/ResultUnits" class="stretched-link"></a>
                </div>
            </div>
        </div>
    </div>

    <!-- Exposure & Location Tracking -->
    <div class="category-section">
        <div class="category-header">
            <div class="category-header-icon category-exposure">
                <i class="bi bi-geo-alt-fill"></i>
            </div>
            <div>
                <h3>Exposure & Location Tracking</h3>
                <p class="category-description">Manage locations, events, and exposure site classification for contact tracing</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-geo-alt"></i>
                    </div>
                    <h5>Locations</h5>
                    <p>Manage registered locations and exposure sites in your jurisdiction</p>
                    <a asp-page="/Locations/Index" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-tags"></i>
                    </div>
                    <h5>Location Types</h5>
                    <p>Define location categories (schools, hospitals, restaurants, etc.)</p>
                    <a asp-page="/Settings/Lookups/LocationTypes" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-calendar-event"></i>
                    </div>
                    <h5>Events</h5>
                    <p>Manage recorded events and gatherings for exposure tracking</p>
                    <a asp-page="/Events/Index" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-tags"></i>
                    </div>
                    <h5>Event Types</h5>
                    <p>Classify events (conferences, weddings, sporting events, etc.)</p>
                    <a asp-page="/Settings/Lookups/EventTypes" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-map"></i>
                    </div>
                    <h5>Jurisdiction Types</h5>
                    <p>Configure the 5 jurisdiction field names (LHD, LGA, Statistical Areas, etc.)</p>
                    <a asp-page="/Settings/JurisdictionTypes/Index" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-pin-map"></i>
                    </div>
                    <h5>Jurisdictions</h5>
                    <p>Manage jurisdiction values and upload boundary shapefiles for geocoding</p>
                    <a asp-page="/Settings/Jurisdictions/Index" class="stretched-link"></a>
                </div>
            </div>
        </div>
    </div>

    <!-- Contact Tracing -->
    <div class="category-section">
        <div class="category-header">
            <div class="category-header-icon category-contact">
                <i class="bi bi-people-fill"></i>
            </div>
            <div>
                <h3>Contact Tracing</h3>
                <p class="category-description">Configure contact classifications and manage contact investigation settings</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-diagram-3"></i>
                    </div>
                    <h5>Contact Classifications</h5>
                    <p>Define contact types (household, close, casual contact, etc.)</p>
                    <a asp-page="/Settings/Lookups/ContactClassifications" class="stretched-link"></a>
                </div>
            </div>
        </div>
    </div>

    <!-- Task Management & Workflows -->
    <div class="category-section">
        <div class="category-header">
            <div class="category-header-icon category-task">
                <i class="bi bi-check2-square"></i>
            </div>
            <div>
                <h3>Task Management & Workflows</h3>
                <p class="category-description">Configure task types, templates, and survey forms for case investigations</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-tags"></i>
                    </div>
                    <h5>Task Types</h5>
                    <p>Define task categories for case and contact management workflows</p>
                    <a asp-page="/Settings/Lookups/TaskTypes" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-clipboard-check"></i>
                    </div>
                    <h5>Task Templates</h5>
                    <p>Create reusable task templates for common investigation procedures</p>
                    <a asp-page="/Settings/Lookups/TaskTemplates" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-collection"></i>
                    </div>
                    <h5>Survey Templates</h5>
                    <p>Design custom survey forms for epidemiological data collection</p>
                    <a asp-page="/Settings/Surveys/SurveyTemplates" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-activity"></i>
                    </div>
                    <h5>Survey Activity Log</h5>
                    <p>See a record of every completed interview — what data was saved, what needs review, and any problems</p>
                    <a asp-page="./Surveys/SubmissionLog" class="stretched-link"></a>
                </div>
            </div>
        </div>
    </div>

    <!-- Demographics & Reference Data -->
    <div class="category-section">
        <div class="category-header">
            <div class="category-header-icon category-demo">
                <i class="bi bi-person-vcard"></i>
            </div>
            <div>
                <h3>Demographics & Reference Data</h3>
                <p class="category-description">Manage patient demographic lookups including countries, languages, and identity data</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-globe"></i>
                    </div>
                    <h5>Countries</h5>
                    <p>Manage country codes and names for travel history tracking</p>
                    <a asp-page="/Settings/Countries/Index" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-translate"></i>
                    </div>
                    <h5>Languages</h5>
                    <p>Configure languages for patient communication preferences</p>
                    <a asp-page="/Settings/Languages/Index" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-people"></i>
                    </div>
                    <h5>Ancestries</h5>
                    <p>Manage ancestry classifications for demographic reporting</p>
                    <a asp-page="/Settings/Ancestries/Index" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-list-check"></i>
                    </div>
                    <h5>ATSI Status</h5>
                    <p>Aboriginal and Torres Strait Islander status classifications</p>
                    <a asp-page="/Settings/AtsiStatuses/Index" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-gender-ambiguous"></i>
                    </div>
                    <h5>Sex at Birth</h5>
                    <p>Configure biological sex classifications for medical records</p>
                    <a asp-page="/Settings/SexAtBirths/Index" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-gender-trans"></i>
                    </div>
                    <h5>Gender Identity</h5>
                    <p>Manage gender identity options for inclusive patient records</p>
                    <a asp-page="/Settings/Genders/Index" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="setting-card">
                    <div class="setting-card-icon">
                        <i class="bi bi-map"></i>
                    </div>
                    <h5>States</h5>
                    <p>Manage states and sub-national administrative regions for address validation</p>
                    <a asp-page="/Settings/States/Index" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
