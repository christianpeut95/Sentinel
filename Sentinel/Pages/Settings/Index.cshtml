@page
@model Sentinel.Pages.Settings.IndexModel
@using Sentinel.Constants

@{
    ViewData["Title"] = "Settings";
    ViewData["Subtitle"] = "System Configuration & Administration";
    Layout = "~/Pages/Shared/_LayoutSentinel.cshtml";
}

<style>
    /* iOS-Style Settings Layout */
    .settings-shell {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 0;
        min-height: calc(100vh - 180px);
        background: var(--bone);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(12, 42, 32, 0.06);
        border: 1px solid var(--hairline);
    }

    /* Sidebar */
    .settings-sidebar {
        background: var(--paper);
        border-right: 1px solid var(--hairline);
        overflow-y: auto;
        padding: 0;
    }

    .settings-sidebar-header {
        padding: 24px 20px 16px;
        border-bottom: 1px solid var(--hairline);
        background: linear-gradient(135deg, var(--signal-lt) 0%, var(--paper) 100%);
    }

    .settings-sidebar-header h1 {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--forest);
        margin: 0 0 4px;
        letter-spacing: -0.5px;
    }

    .settings-sidebar-header p {
        font-size: 0.813rem;
        color: var(--graphite);
        margin: 0;
    }

    .settings-category-group {
        padding: 12px 0;
        border-bottom: 1px solid rgba(216, 212, 196, 0.5);
    }

    .settings-category-group:last-child {
        border-bottom: none;
    }

    .settings-category-label {
        font-family: var(--f-mono);
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--graphite);
        padding: 8px 20px 6px;
        font-weight: 500;
    }

    .settings-category-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 20px;
        color: var(--forest);
        text-decoration: none;
        transition: background 0.12s ease;
        cursor: pointer;
        border-left: 3px solid transparent;
    }

    .settings-category-item:hover {
        background: var(--chalk);
    }

    .settings-category-item.active {
        background: var(--chalk);
        border-left-color: var(--signal-dk);
        color: var(--forest);
        font-weight: 500;
    }

    .settings-category-icon {
        font-size: 18px;
        width: 24px;
        text-align: center;
        color: var(--signal-dk);
        opacity: 0.8;
    }

    .settings-category-item.active .settings-category-icon {
        opacity: 1;
    }

    .settings-category-info {
        flex: 1;
    }

    .settings-category-name {
        font-size: 0.875rem;
        line-height: 1.4;
        letter-spacing: -0.01em;
    }

    .settings-category-count {
        font-family: var(--f-mono);
        font-size: 10px;
        color: var(--slate);
        margin-left: auto;
    }

    /* Content Area */
    .settings-content {
        background: var(--bone);
        overflow-y: auto;
        padding: 32px 40px 60px;
    }

    .settings-content-header {
        margin-bottom: 28px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--hairline);
    }

    .settings-content-eyebrow {
        font-family: var(--f-mono);
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--graphite);
        margin-bottom: 8px;
    }

    .settings-content-title {
        font-size: 2rem;
        font-weight: 600;
        color: var(--forest);
        margin: 0 0 8px;
        letter-spacing: -0.5px;
    }

    .settings-content-subtitle {
        font-size: 0.938rem;
        color: var(--graphite);
        margin: 0;
        line-height: 1.6;
    }

    /* Settings Grid */
    .settings-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 12px;
    }

    .setting-row {
        background: var(--chalk);
        border: 1px solid var(--hairline);
        border-radius: 8px;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
        text-decoration: none;
        transition: all 0.15s ease;
    }

    .setting-row:hover {
        background: white;
        border-color: var(--signal-dk);
        box-shadow: 0 2px 8px rgba(12, 42, 32, 0.08);
        transform: translateX(2px);
    }

    .setting-row-icon {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        background: var(--signal-lt);
        color: var(--signal-dk);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }

    .setting-row-info {
        flex: 1;
        min-width: 0;
    }

    .setting-row-title {
        font-size: 0.938rem;
        font-weight: 500;
        color: var(--forest);
        margin: 0 0 2px;
        letter-spacing: -0.01em;
    }

    .setting-row-desc {
        font-size: 0.813rem;
        color: var(--graphite);
        margin: 0;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .setting-row-chevron {
        font-size: 14px;
        color: var(--slate-lt);
        flex-shrink: 0;
    }

    /* Search bar */
    .settings-search {
        padding: 16px 20px 12px;
        border-bottom: 1px solid var(--hairline);
        background: var(--paper);
    }

    .settings-search input {
        width: 100%;
        padding: 8px 12px 8px 36px;
        border: 1px solid var(--hairline);
        border-radius: 8px;
        background: var(--chalk);
        font-size: 0.875rem;
        transition: all 0.12s;
    }

    .settings-search input:focus {
        outline: none;
        border-color: var(--signal-dk);
        box-shadow: 0 0 0 3px rgba(61, 213, 152, 0.15);
    }

    .settings-search-wrapper {
        position: relative;
    }

    .settings-search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--graphite);
        font-size: 14px;
        pointer-events: none;
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .settings-shell {
            grid-template-columns: 240px 1fr;
        }

        .settings-content {
            padding: 24px 28px;
        }
    }

    @@media (max-width: 768px) {
        .settings-shell {
            grid-template-columns: 1fr;
        }

        .settings-sidebar {
            border-right: none;
            border-bottom: 1px solid var(--hairline);
            max-height: 300px;
        }

        .settings-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="container-fluid px-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Settings</li>
        </ol>
    </nav>

    <!-- iOS-Style Settings Shell -->
    <div class="settings-shell">
        <!-- Sidebar -->
        <div class="settings-sidebar">
            <div class="settings-sidebar-header">
                <h1>Settings</h1>
                <p>@AppVersion.ProductName @AppVersion.FullVersionString</p>
            </div>

            <!-- Search -->
            <div class="settings-search">
                <div class="settings-search-wrapper">
                    <i class="bi bi-search settings-search-icon"></i>
                    <input type="search" placeholder="Search settings..." id="settingsSearchInput">
                </div>
            </div>

            <!-- Categories -->
            <div class="settings-category-group">
                <div class="settings-category-label">System</div>
                <a href="#" class="settings-category-item active" data-category="system">
                    <i class="bi bi-gear-fill settings-category-icon"></i>
                    <div class="settings-category-info">
                        <div class="settings-category-name">System Configuration</div>
                    </div>
                    <span class="settings-category-count">5</span>
                </a>
            </div>

            <div class="settings-category-group">
                <div class="settings-category-label">Clinical</div>
                <a href="#" class="settings-category-item" data-category="disease">
                    <i class="bi bi-virus settings-category-icon"></i>
                    <div class="settings-category-info">
                        <div class="settings-category-name">Disease & Case Management</div>
                    </div>
                    <span class="settings-category-count">5</span>
                </a>
                <a href="#" class="settings-category-item" data-category="lab">
                    <i class="bi bi-hospital settings-category-icon"></i>
                    <div class="settings-category-info">
                        <div class="settings-category-name">Laboratory & Testing</div>
                    </div>
                    <span class="settings-category-count">5</span>
                </a>
                <a href="#" class="settings-category-item" data-category="hl7">
                    <i class="bi bi-hdd-network settings-category-icon"></i>
                    <div class="settings-category-info">
                        <div class="settings-category-name">HL7 Interface</div>
                    </div>
                    <span class="settings-category-count">5</span>
                </a>
            </div>

            <div class="settings-category-group">
                <div class="settings-category-label">Surveillance</div>
                <a href="#" class="settings-category-item" data-category="exposure">
                    <i class="bi bi-geo-alt-fill settings-category-icon"></i>
                    <div class="settings-category-info">
                        <div class="settings-category-name">Exposure & Location</div>
                    </div>
                    <span class="settings-category-count">6</span>
                </a>
                <a href="#" class="settings-category-item" data-category="contact">
                    <i class="bi bi-people-fill settings-category-icon"></i>
                    <div class="settings-category-info">
                        <div class="settings-category-name">Contact Tracing</div>
                    </div>
                    <span class="settings-category-count">1</span>
                </a>
                <a href="#" class="settings-category-item" data-category="task">
                    <i class="bi bi-check2-square settings-category-icon"></i>
                    <div class="settings-category-info">
                        <div class="settings-category-name">Tasks & Workflows</div>
                    </div>
                    <span class="settings-category-count">4</span>
                </a>
            </div>

            <div class="settings-category-group">
                <div class="settings-category-label">Data</div>
                <a href="#" class="settings-category-item" data-category="demographics">
                    <i class="bi bi-person-vcard settings-category-icon"></i>
                    <div class="settings-category-info">
                        <div class="settings-category-name">Demographics</div>
                    </div>
                    <span class="settings-category-count">8</span>
                </a>
            </div>

            <div class="settings-category-group">
                <div class="settings-category-label">Administration</div>
                <a href="#" class="settings-category-item" data-category="security">
                    <i class="bi bi-shield-lock-fill settings-category-icon"></i>
                    <div class="settings-category-info">
                        <div class="settings-category-name">Security & Access</div>
                    </div>
                    <span class="settings-category-count">3</span>
                </a>
                <a href="#" class="settings-category-item" data-category="admin">
                    <i class="bi bi-tools settings-category-icon"></i>
                    <div class="settings-category-info">
                        <div class="settings-category-name">System Administration</div>
                    </div>
                    <span class="settings-category-count">4</span>
                </a>
            </div>
        </div>

        <!-- Content Area -->
        <div class="settings-content">
            <!-- System Configuration Content -->
            <div class="settings-content-section" id="system-content">
                <div class="settings-content-header">
                    <div class="settings-content-eyebrow">System</div>
                    <h2 class="settings-content-title">System Configuration</h2>
                    <p class="settings-content-subtitle">Core system settings, API integrations, and custom field management</p>
                </div>

                <div class="settings-grid">
                    <a asp-page="/Settings/Organization" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-building"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Organization Details</div>
                            <div class="setting-row-desc">Configure your organization name, logo, and contact information</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/CustomFields/Index" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-sliders"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Custom Fields</div>
                            <div class="setting-row-desc">Create and manage custom data fields for patients, cases, and contacts</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/CustomFields/Visibility" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-eye"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Field Visibility</div>
                            <div class="setting-row-desc">Control which fields are visible or required throughout the system</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/Backups/Index" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-hdd-stack"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Database Backups</div>
                            <div class="setting-row-desc">Create, restore, and manage automated database backups</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/About" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-info-circle"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">About Sentinel</div>
                            <div class="setting-row-desc">Version information, system details, and product information</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>
                </div>
            </div>

            <!-- Disease & Case Management Content (Hidden by default) -->
            <div class="settings-content-section" id="disease-content" style="display:none;">
                <div class="settings-content-header">
                    <div class="settings-content-eyebrow">Clinical</div>
                    <h2 class="settings-content-title">Disease & Case Management</h2>
                    <p class="settings-content-subtitle">Manage diseases, symptoms, case classifications, and clinical data</p>
                </div>

                <div class="settings-grid">
                    <a asp-page="/Settings/Diseases/Index" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-virus"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Diseases</div>
                            <div class="setting-row-desc">Configure notifiable diseases, ICD codes, and disease-specific settings</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/Lookups/Symptoms" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-heart-pulse"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Symptoms</div>
                            <div class="setting-row-desc">Manage symptom types for disease surveillance and case investigation</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/CaseStatuses/Index" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-journal-check"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Case Statuses</div>
                            <div class="setting-row-desc">Define case investigation statuses and classification categories</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/CaseDefinitions/Index" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-diagram-3"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Case Definitions</div>
                            <div class="setting-row-desc">Build automated classification rules for case confirmation criteria</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/Diseases/ReinfectionRules" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-arrow-repeat"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Reinfection Rules</div>
                            <div class="setting-row-desc">Configure case matching and reinfection detection rules per disease</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>
                </div>
            </div>

            <!-- Lab Content (Hidden) -->
            <div class="settings-content-section" id="lab-content" style="display:none;">
                <div class="settings-content-header">
                    <div class="settings-content-eyebrow">Clinical</div>
                    <h2 class="settings-content-title">Laboratory & Testing</h2>
                    <p class="settings-content-subtitle">Configure laboratory settings, specimen types, test types, and result classifications</p>
                </div>

                <div class="settings-grid">
                    <a asp-page="/Settings/Pathogens/Index" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-bug"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Pathogens & Biomarkers</div>
                            <div class="setting-row-desc">Manage laboratory test targets with LOINC codes for HL7 integration</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/Lookups/OrganizationTypes" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-building"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Organization Types</div>
                            <div class="setting-row-desc">Define types of laboratories and healthcare organizations</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/Lookups/SpecimenTypes" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-droplet"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Specimen Types</div>
                            <div class="setting-row-desc">Configure specimen collection types (blood, swab, urine, etc.)</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/Lookups/TestMethods" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-clipboard-pulse"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Test Methods</div>
                            <div class="setting-row-desc">Laboratory test methodologies (PCR, ELISA, Culture, etc.)</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/Lookups/TestResults" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-check-circle"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Test Results</div>
                            <div class="setting-row-desc">Configure qualitative test result options (Positive, Negative, Indeterminate, etc.)</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/Lookups/ResultUnits" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-rulers"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Result Units</div>
                            <div class="setting-row-desc">Configure measurement units for quantitative test results</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>
                </div>
            </div>

            <!-- HL7 Content (Hidden) -->
            <div class="settings-content-section" id="hl7-content" style="display:none;">
                <div class="settings-content-header">
                    <div class="settings-content-eyebrow">Clinical</div>
                    <h2 class="settings-content-title">HL7 Interface & Integration</h2>
                    <p class="settings-content-subtitle">Electronic laboratory results integration, file monitoring, and message processing</p>
                </div>

                <div class="settings-grid">
                    <a asp-page="/Settings/HL7/Monitoring/Dashboard" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-activity"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">HL7 Monitoring Dashboard</div>
                            <div class="setting-row-desc">Real-time monitoring of file processing, message status, and system health</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/HL7/Configurations/Index" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-gear-wide-connected"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">HL7 Configurations</div>
                            <div class="setting-row-desc">Configure file drop locations, parsing rules, and automatic processing</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/HL7/Messages/Index" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-envelope"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">HL7 Messages</div>
                            <div class="setting-row-desc">View, search, and reprocess incoming HL7 laboratory messages</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/HL7/FieldMappings/Index" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-diagram-2"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Field Mappings</div>
                            <div class="setting-row-desc">Map HL7 test codes to custom fields for disease-specific data extraction</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/HL7/DiseaseMatching/Index" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-virus"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Disease Matching Rules</div>
                            <div class="setting-row-desc">Configure how HL7 messages match to diseases using LOINC/SNOMED codes</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>
                </div>
            </div>

            <!-- Exposure Content (Hidden) -->
            <div class="settings-content-section" id="exposure-content" style="display:none;">
                <div class="settings-content-header">
                    <div class="settings-content-eyebrow">Surveillance</div>
                    <h2 class="settings-content-title">Exposure & Location Tracking</h2>
                    <p class="settings-content-subtitle">Manage locations, events, and exposure site classification for contact tracing</p>
                </div>

                <div class="settings-grid">
                    <a asp-page="/Locations/Index" class="setting-row">
                        <div class="setting-row-icon">
                            <i class="bi bi-geo-alt"></i>
                        </div>
                        <div class="setting-row-info">
                            <div class="setting-row-title">Locations</div>
                            <div class="setting-row-desc">Manage registered locations and exposure sites in your jurisdiction</div>
                        </div>
                        <i class="bi bi-chevron-right setting-row-chevron"></i>
                    </a>

                    <a asp-page="/Settings/Lookups/LocationTypes" class="setting-row">
                        <div class="setting-row-icon">
