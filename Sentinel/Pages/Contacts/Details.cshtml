    $('#editFromViewBtn').on('click', function() {
        closeViewLabResultModal();
        if (currentLabResultId) {
            editLabResult(currentLabResultId);
        }
    });

    // Close modal handler
    function closeViewLabResultModal() {
        var $modal = $('#viewLabResultModal');
        $modal.removeClass('show');
        $modal.css('display', 'none');
        $('.modal-backdrop').remove();
        $('body').removeClass('modal-open').css('overflow', '');
