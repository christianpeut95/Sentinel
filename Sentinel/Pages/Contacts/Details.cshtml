@page
@model Sentinel.Pages.Contacts.DetailsModel
@using Sentinel.Models

@{
    ViewData["Title"] = "Contact Details";
    Layout = "~/Pages/Shared/_LayoutSentinel.cshtml";
}

<style>
/* Modern Apple Aesthetic - Purple/Violet Theme for Contacts */
.case-details-container {
    width: 100%;
    /* Full width - no max-width constraint */
}

/* Header Section */
.case-header {
    background: linear-gradient(135deg, var(--signal-lt) 0%, var(--chalk) 100%);
    border-radius: 16px;
    padding: 2rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 2px 8px rgba(21, 156, 110, 0.08);
    border: 1px solid rgba(21, 156, 110, 0.15);
}

.case-header h1 {
    font-size: 2rem;
    font-weight: 600;
    color: #2d3748;
    margin-bottom: 0.5rem;
    letter-spacing: -0.5px;
}

.case-header h1 i {
    color: var(--signal-dk);
}

.case-header .subtitle {
    color: #718096;
    font-size: 1rem;
    margin-bottom: 0;
}

/* Quick Action Buttons */
.quick-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1rem;
}

.quick-action-btn {
    background: white;
    border: 1px solid var(--hairline);
    border-radius: 10px;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--signal-dk);
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
}

.quick-action-btn:hover {
    background: var(--signal-lt);
    border-color: var(--signal-dk);
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(21, 156, 110, 0.15);
    color: var(--forest);
}

.quick-action-btn i {
    font-size: 1rem;
}

.quick-action-btn.primary {
    background: var(--signal-dk);
    color: white;
    border-color: var(--signal-dk);
}

.quick-action-btn.primary:hover {
    background: var(--forest);
    color: white;
    border-color: var(--forest);
}

.quick-action-btn.success {
    background: #10b981;
    color: white;
    border-color: #10b981;
}

.quick-action-btn.success:hover {
    background: #059669;
    color: white;
    border-color: #059669;
}

/* Compact Card Design */
    .info-card {
        background: white;
        border-radius: 12px;
        padding: 1.25rem;
        box-shadow: 0 2px 8px rgba(21, 156, 110, 0.06);
        border: 1px solid rgba(21, 156, 110, 0.1);
        margin-bottom: 1rem;
        height: 100%;
    }

    .info-card:hover {
        box-shadow: 0 4px 12px rgba(21, 156, 110, 0.12);
        transform: translateY(-1px);
        transition: all 0.2s ease;
    }

    .info-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--signal-lt);
    }

    .info-card-title {
        font-size: 1rem;
        font-weight: 600;
        color: #2d3748;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .info-card-title i {
        color: var(--signal-dk);
    }

    .info-card-action {
        padding: 0.35rem 0.75rem;
        font-size: 0.75rem;
        border-radius: 8px;
        background: var(--signal-lt);
        border: 1px solid var(--hairline);
        color: var(--signal-dk);
        font-weight: 600;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .info-card-action:hover {
        background: var(--signal-dk);
        color: white;
        border-color: var(--signal-dk);
    }

    /* Compact Info Rows */
    .info-row {
        display: grid;
        grid-template-columns: 140px 1fr;
        gap: 0.75rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid #f7fafc;
        font-size: 0.875rem;
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-label {
        color: #718096;
        font-weight: 500;
    }

    .info-value {
        color: #2d3748;
        font-weight: 600;
    }

    /* Badges */
    .badge {
        padding: 0.35rem 0.65rem;
        font-size: 0.75rem;
        font-weight: 600;
        border-radius: 6px;
    }

    .badge.badge-grey {
        background: #718096;
        color: white;
    }

    .badge.badge-teal {
        background: var(--signal-dk);
        color: white;
    }

    .badge.badge-slate {
        background: var(--forest);
        color: white;
    }

    .badge.badge-amber {
        background: var(--signal-dk);
        color: white;
    }

    .badge.badge-purple {
        background: var(--signal-dk);
        color: white;
    }

    /* Compact Table */
    .compact-table {
        font-size: 0.875rem;
    }

    .compact-table th {
        background: #f7fafc;
        color: #4a5568;
        font-weight: 600;
        border: none;
        padding: 0.5rem 0.75rem;
    }

    .compact-table td {
        padding: 0.5rem 0.75rem;
        border-bottom: 1px solid #f7fafc;
    }

    .compact-table tr:last-child td {
        border-bottom: none;
    }

    /* Note Item */
    .note-item {
        background: var(--signal-lt);
        border-left: 3px solid var(--signal-dk);
        padding: 0.75rem;
        margin-bottom: 0.75rem;
        border-radius: 8px;
        font-size: 0.875rem;
    }

    .note-item .note-header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        margin-bottom: 0.5rem;
    }


    .note-item .note-meta {
        font-size: 0.75rem;
        color: var(--forest);
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 2rem 1rem;
        color: #718096;
    }

    .empty-state i {
        font-size: 2.5rem;
        color: #cbd5e0;
        margin-bottom: 0.75rem;
    }

    .empty-state p {
        margin: 0.5rem 0;
        font-size: 0.875rem;
    }

    /* Breadcrumb */
    .breadcrumb {
        background: transparent;
        padding: 0;
        margin-bottom: 1rem;
        font-size: 0.875rem;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        color: #cbd5e0;
    }

    .breadcrumb-item a {
        color: #4a5568;
        text-decoration: none;
    }

    .breadcrumb-item a:hover {
        color: #2d3748;
    }

    .breadcrumb-item.active {
        color: #718096;
    }

    /* Responsive Grid - 3 column layout */
    .case-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 1rem;
        grid-auto-rows: auto;
    }

    /* Tablet view - 2 columns */
    @@media (max-width: 1200px) {
        .case-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    /* Mobile view - 1 column */
    @@media (max-width: 768px) {
        .case-grid {
            grid-template-columns: 1fr;
        }
    }

    /* Left column cards - explicit positioning */
    .info-card.case-info-card {
        grid-column: 1;
        grid-row: 1;
    }

    .info-card.patient-info-card {
        grid-column: 1;
        grid-row: 2;
    }

    .info-card.symptoms-card {
        grid-column: 1;
        grid-row: 3;
    }

    /* Wide cards spanning 2 columns */
    .info-card.wide {
        grid-column: span 2;
    }

    /* Tasks - positioned at row 1, column 2 */
    .info-card.tasks-card {
        grid-column: 2;
        grid-row: 1;
    }

    /* Notes - positioned at row 1, column 3 */
    .info-card.notes-card {
        grid-column: 3;
        grid-row: 1;
    }

    /* Exposures - positioned at row 2, columns 2-3 (WIDE) */
    .info-card.acquisitions-card {
        grid-column: 2;
        grid-row: 2;
    }

    .info-card.transmissions-card {
        grid-column: 3;
        grid-row: 2;
    }

    /* Lab Results - positioned at row 3, columns 2-3 (WIDE) */
    .info-card.lab-results-card {
        grid-column: 2 / span 2;
        grid-row: 3;
    }

    @@media (max-width: 1200px) {
        .info-card.wide {
            grid-column: span 2;
        }
        
        .info-card.case-info-card,
        .info-card.patient-info-card,
        .info-card.symptoms-card,
        .info-card.lab-results-card,
        .info-card.acquisitions-card, .info-card.transmissions-card,
        .info-card.tasks-card,
        .info-card.notes-card {
            grid-column: auto;
            grid-row: auto;
        }
    }

    @@media (max-width: 768px) {
        .info-card.wide {
            grid-column: span 1;
        }
        
        .info-card.case-info-card,
        .info-card.patient-info-card,
        .info-card.symptoms-card,
        .info-card.lab-results-card,
        .info-card.acquisitions-card, .info-card.transmissions-card,
        .info-card.tasks-card,
        .info-card.notes-card {
            grid-column: auto;
            grid-row: auto;
        }
    }

    /* Half-height cards */
    .info-card.half-height {
        max-height: 400px;
    }

    .info-card.half-height .compact-table {
        display: block;
        max-height: 280px;
        overflow-y: auto;
    }

    /* Alerts */
    .alert {
        border-radius: 10px;
        border: none;
        padding: 0.75rem 1rem;
        font-size: 0.875rem;
        margin-bottom: 1rem;
    }

    /* Modal z-index fixes - CRITICAL FOR VIEW LAB MODAL */
    .modal {
        z-index: 1055 !important;
    }

    .modal-backdrop {
        z-index: 1050 !important;
    }

    .modal-dialog {
        z-index: 1056 !important;
        position: relative;
    }

    /* Force modal to display when shown */
    .modal.show {
        display: block !important;
        opacity: 1 !important;
    }

    .modal.show .modal-dialog {
        transform: none !important;
    }

    /* View Lab Result Modal - Force visibility */
    #viewLabResultModal.show {
        display: block !important;
        visibility: visible !important;
    }

    #viewLabResultModal .modal-dialog {
        pointer-events: auto !important;
        opacity: 1 !important;
        transform: translateY(0) !important;
    }

    #viewLabResultModal.show .modal-content {
        visibility: visible !important;
        opacity: 1 !important;
    }

    /* Keyboard navigation enhancements */
    .field-focused {
        background-color: #f8f9ff;
        border-radius: 6px;
        padding: 8px;
        margin: -8px;
        transition: background-color 0.2s;
    }
    
    kbd {
        background-color: #f4f4f4;
        border: 1px solid #ccc;
        border-radius: 3px;
        box-shadow: 0 1px 0 rgba(0,0,0,0.2);
        color: #333;
        display: inline-block;
        font-family: 'Courier New', monospace;
        font-size: 0.85em;
        line-height: 1;
        padding: 2px 5px;
        white-space: nowrap;
    }
    
    /* Better focus indicators for accessibility */
    #addLabResultModal input:focus,
    #addLabResultModal select:focus,
    #addLabResultModal textarea:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
    }
    
    .select2-container--default .select2-selection--single:focus {
        border-color: #667eea;
        outline: 0;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
    }

    /* Exposures Modal Enhancements */
    #viewAllExposuresModal .sticky-top {
        position: sticky;
        top: 0;
        z-index: 10;
        background: #f8f9fa;
    }

    #viewAllExposuresModal .table-responsive {
        position: relative;
    }

    #allExposuresTable tbody tr {
        transition: background-color 0.2s ease;
    }

    #allExposuresTable tbody tr:hover {
        background-color: #f8f9fa;
    }
</style>


<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Contacts</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Contact.FriendlyId</li>
    </ol>
</nav>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ExposureInfo"] != null)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        <i class="bi bi-info-circle-fill me-2"></i>@TempData["ExposureInfo"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ExposureWarning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ExposureWarning"]
        <a asp-page="/Cases/Exposures/Create" asp-route-caseId="@Model.Contact.Id" class="alert-link ms-2">Add exposure now</a>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="case-details-container">
    <!-- Header Section -->
    <div class="case-header">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h1>
                    <i class="bi bi-person-circle"></i>
                    Contact @Model.Contact.FriendlyId
                </h1>
                @if (Model.Contact.Patient != null)
                {
                    <p class="subtitle mb-0">
                        <strong>@Model.Contact.Patient.GivenName @Model.Contact.Patient.FamilyName</strong>
                        @if (Model.Contact.Disease != null)
                        {
                            <span class="mx-2">•</span>
                            <span>@Model.Contact.Disease.Name</span>
                        }
                        @if (Model.Contact.ConfirmationStatus != null)
                        {
                            <span class="mx-2">•</span>
                            <span class="badge badge-purple">@Model.Contact.ConfirmationStatus.Name</span>
                        }
                    </p>
                }
            </div>
            <div class="text-end">
                <a asp-page="./Index" class="quick-action-btn">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="quick-actions">
            <a asp-page="./Edit" asp-route-id="@Model.Contact.Id" class="quick-action-btn primary">
                <i class="bi bi-pencil"></i> Edit Contact
            </a>
            <button type="button" class="quick-action-btn success" data-bs-toggle="modal" data-bs-target="#addNoteModal">
                <i class="bi bi-plus-circle"></i> Add Note
            </button>
            <button type="button" class="quick-action-btn success" onclick="openAddLabResult()">
                <i class="bi bi-plus-circle"></i> Add Lab Result
            </button>
            <button type="button" class="quick-action-btn success" onclick="openAddExposure()">
                <i class="bi bi-plus-circle"></i> Add Exposure
            </button>
            <button type="button" class="quick-action-btn success" onclick="openAddTask()">
                <i class="bi bi-plus-circle"></i> Add Task
            </button>
            @if (Model.Contact.Patient != null)
            {
                <a asp-page="/Patients/Details" asp-route-id="@Model.Contact.PatientId" class="quick-action-btn">
                    <i class="bi bi-person"></i> View Patient
                </a>
            }
            <a asp-page="/Cases/AuditHistory" asp-route-id="@Model.Contact.Id" class="quick-action-btn">
                <i class="bi bi-clock-history"></i> Audit Log
            </a>
        </div>
    </div>

    <!-- Main Content Grid -->
    <!-- 3-Column Layout: Left = Case/Patient/Symptoms stacked | Right = Lab Results/Tasks/Exposures+Notes -->
    <div class="case-grid">
        <!-- LEFT COLUMN: Case Information -->
        <div class="info-card case-info-card">
            <div class="info-card-header">
                <h3 class="info-card-title">
                    <i class="bi bi-clipboard-data"></i>
                    Case Information
                </h3>
                <a asp-page="./Edit" asp-route-id="@Model.Contact.Id" class="info-card-action">
                    <i class="bi bi-pencil"></i> Edit
                </a>
            </div>
            @if (Model.Contact.Disease != null)
            {
                <div class="info-row">
                    <div class="info-label">Disease</div>
                    <div class="info-value">
                        <strong>@Model.Contact.Disease.Name</strong>
                        <br/><small class="text-muted">@Model.Contact.Disease.Code (@Model.Contact.Disease.ExportCode)</small>
                    </div>
                </div>
            }
            <div class="info-row">
                <div class="info-label">Confirmation Status</div>
                <div class="info-value">
                    @if (Model.Contact.ConfirmationStatus != null)
                    {
                        <span class="badge badge-purple">@Model.Contact.ConfirmationStatus.Name</span>
                    }
                    else
                    {
                        <span class="text-muted">Not set</span>
                    }
                </div>
            </div>
            <div class="info-row">
                <div class="info-label">Date of Onset</div>
                <div class="info-value">
                    @if (Model.Contact.DateOfOnset.HasValue)
                    {
                        <i class="bi bi-calendar-event me-1 text-primary"></i>
                        @Model.Contact.DateOfOnset.Value.ToString("dd MMM yyyy")
                    }
                    else
                    {
                        <span class="text-muted">Not specified</span>
                    }
                </div>
            </div>
            <div class="info-row">
                <div class="info-label">Date of Notification</div>
                <div class="info-value">
                    @if (Model.Contact.DateOfNotification.HasValue)
                    {
                        <i class="bi bi-calendar-check me-1 text-success"></i>
                        @Model.Contact.DateOfNotification.Value.ToString("dd MMM yyyy")
                    }
                    else
                    {
                        <span class="text-muted">Not specified</span>
                    }
                </div>
            </div>
        </div>

        <!-- LEFT COLUMN: Patient Information (stacked below Case) -->
        @if (Model.Contact.Patient != null)
        {
            <div class="info-card patient-info-card">
                <div class="info-card-header">
                    <h3 class="info-card-title">
                        <i class="bi bi-person-badge"></i>
                        Patient Information
                    </h3>
                    <a asp-page="/Patients/Details" asp-route-id="@Model.Contact.PatientId" class="info-card-action">
                        <i class="bi bi-eye"></i> View
                    </a>
                </div>
                <div class="info-row">
                    <div class="info-label">Patient ID</div>
                    <div class="info-value">
                        <a asp-page="/Patients/Details" asp-route-id="@Model.Contact.PatientId">
                            @Model.Contact.Patient.FriendlyId
                        </a>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-label">Name</div>
                    <div class="info-value">@Model.Contact.Patient.GivenName @Model.Contact.Patient.FamilyName</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Date of Birth</div>
                    <div class="info-value">
                        @if (Model.Contact.Patient.DateOfBirth.HasValue)
                        {
                            var age = DateTime.Now.Year - Model.Contact.Patient.DateOfBirth.Value.Year;
                            <span>@Model.Contact.Patient.DateOfBirth.Value.ToString("dd MMM yyyy") <small class="text-muted">(@age yrs)</small></span>
                        }
                        else
                        {
                            <span class="text-muted">Not specified</span>
                        }
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-label">Gender</div>
                    <div class="info-value">@(Model.Contact.Patient.Gender?.Name ?? "-")</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Email</div>
                    <div class="info-value">
                        @if (!string.IsNullOrWhiteSpace(Model.Contact.Patient.EmailAddress))
                        {
                            <a href="mailto:@Model.Contact.Patient.EmailAddress">
                                <i class="bi bi-envelope me-1"></i>@Model.Contact.Patient.EmailAddress
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">Not provided</span>
                        }
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-label">Mobile Phone</div>
                    <div class="info-value">
                        @if (!string.IsNullOrWhiteSpace(Model.Contact.Patient.MobilePhone))
                        {
                            <a href="tel:@Model.Contact.Patient.MobilePhone">
                                <i class="bi bi-phone me-1"></i>@Model.Contact.Patient.MobilePhone
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">Not provided</span>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- LEFT COLUMN: Symptoms (stacked below Patient) -->
        <div class="info-card symptoms-card">
            <div class="info-card-header">
                <h3 class="info-card-title">
                    <i class="bi bi-heart-pulse"></i>
                    Symptoms (@Model.CaseSymptoms.Count)
                </h3>
                <a asp-page="./Edit" asp-route-id="@Model.Contact.Id" class="info-card-action">
                    <i class="bi bi-pencil"></i> Edit
                </a>
            </div>
            @if (Model.CaseSymptoms.Any())
            {
                <table class="compact-table w-100">
                    <thead>
                        <tr>
                            <th>Symptom</th>
                            <th>Onset</th>
                            <th>Severity</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var symptom in Model.CaseSymptoms)
                        {
                            <tr>
                                <td>
                                    <strong>@symptom.Symptom?.Name</strong>
                                    @if (symptom.Symptom?.Code == "OTHER" && !string.IsNullOrEmpty(symptom.OtherSymptomText))
                                    {
                                        <br/><small class="text-muted">(@symptom.OtherSymptomText)</small>
                                    }
                                </td>
                                <td>
                                    @if (symptom.OnsetDate.HasValue)
                                    {
                                        <span>@symptom.OnsetDate.Value.ToString("dd MMM")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(symptom.Severity))
                                    {
                                        var severityClass = symptom.Severity.ToLower() switch
                                        {
                                            "mild" => "bg-success",
                                            "moderate" => "bg-warning",
                                            "severe" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                        <span class="badge @severityClass">@symptom.Severity</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                
                @if (Model.CaseSymptoms.Any(cs => cs.OnsetDate.HasValue))
                {
                    var earliestOnset = Model.CaseSymptoms.Where(cs => cs.OnsetDate.HasValue).Min(cs => cs.OnsetDate!.Value);
                    <div class="alert alert-info mt-3 mb-0" style="padding: 0.5rem 0.75rem; font-size: 0.75rem;">
                        <i class="bi bi-info-circle me-1"></i>
                        <strong>Earliest onset:</strong> @earliestOnset.ToString("dd MMM yyyy")
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-heart-pulse"></i>
                    <p>No symptoms recorded</p>
                    <a asp-page="./Edit" asp-route-id="@Model.Contact.Id" class="info-card-action">Add Symptoms</a>
                </div>
            }
        </div>

        <!-- RIGHT SIDE (2 columns): Lab Results - Wide and Half Height -->
        <div class="info-card wide half-height lab-results-card">
            <div class="info-card-header">
                <h3 class="info-card-title">
                    <i class="bi bi-clipboard-pulse"></i>
                    Lab Results (@Model.LabResults.Count)
                </h3>
                <button type="button" class="info-card-action" onclick="openAddLabResult()">
                    <i class="bi bi-plus-circle"></i> Add
                </button>
            </div>
            @if (Model.LabResults.Any())
            {
                <table class="compact-table w-100">
                    <thead>
                        <tr>
                            <th>Test</th>
                            <th>Tested For</th>
                            <th>Result</th>
                            <th>Collected</th>
                            <th>Reported</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var labResult in Model.LabResults)
                        {
                            <tr>
                                <td>
                                    <strong>@(labResult.TestType?.Name ?? "-")</strong>
                                    <br/><small class="text-muted">@(labResult.SpecimenType?.Name ?? "-")</small>
                                    @if (labResult.IsAmended)
                                    {
                                        <br/><span class="badge bg-warning text-dark" style="font-size: 0.65rem;"><i class="bi bi-pencil-square"></i> Amended</span>
                                    }
                                </td>
                                <td>
                                    @if (labResult.TestedDisease != null)
                                    {
                                        <small class="text-muted">@labResult.TestedDisease.Name</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (labResult.TestResult != null)
                                    {
                                        var resultClass = labResult.TestResult.Name?.ToLower() switch
                                        {
                                            "positive" => "bg-danger",
                                            "negative" => "bg-success",
                                            "indeterminate" or "equivocal" => "bg-warning",
                                            _ => "bg-secondary"
                                        };
                                        <span class="badge @resultClass">@labResult.TestResult.Name</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (labResult.SpecimenCollectionDate.HasValue)
                                    {
                                        <small>@labResult.SpecimenCollectionDate.Value.ToString("dd MMM yyyy")</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (labResult.ResultDate.HasValue)
                                    {
                                        <small>@labResult.ResultDate.Value.ToString("dd MMM yyyy")</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-link p-0" onclick="window.viewLabResult('@labResult.Id')" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-clipboard-pulse"></i>
                    <p>No lab results yet</p>
                    <button type="button" class="info-card-action" onclick="openAddLabResult()">Add Lab Result</button>
                </div>
            }
        </div>

        <!-- RIGHT SIDE: Acquisitions (How THIS contact was exposed) -->
        <div class="info-card acquisitions-card">
            <div class="info-card-header">
                <h3 class="info-card-title">
                    <i class="bi bi-arrow-down-circle"></i>
                    Acquisitions (@Model.Acquisitions.Count)
                </h3>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#viewAllExposuresModal">
                        <i class="bi bi-list-ul"></i> View All
                    </button>
                </div>
            </div>
            @if (Model.Acquisitions.Any())
            {
                <table class="table table-sm table-hover">
                    <thead>
                        <tr>
                            <th style="width: 120px;">Type</th>
                            <th>Source/Location</th>
                            <th style="width: 90px;">Date</th>
                            <th style="width: 100px;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exposure in Model.Acquisitions.OrderByDescending(e => e.ExposureStartDate).Take(5))
                        {
                            <tr>
                                <td>
                                    @switch (exposure.ExposureType)
                                    {
                                        case Sentinel.Models.ExposureType.Event:
                                            <span class="badge badge-teal"><i class="bi bi-calendar-event"></i> Event</span>
                                            break;
                                        case Sentinel.Models.ExposureType.Location:
                                            <span class="badge badge-slate"><i class="bi bi-geo-alt"></i> Location</span>
                                            break;
                                        case Sentinel.Models.ExposureType.Contact:
                                            <span class="badge badge-amber"><i class="bi bi-people"></i> Contact</span>
                                            break;
                                        case Sentinel.Models.ExposureType.Travel:
                                            <span class="badge badge-grey"><i class="bi bi-airplane"></i> Travel</span>
                                            break;
                                        case Sentinel.Models.ExposureType.LocallyAcquired:
                                            <span class="badge badge-teal"><i class="bi bi-house"></i> Locally Acquired</span>
                                            break;
                                        default:
                                            <span class="badge badge-grey">Unknown</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <small>
                                        @if (exposure.ExposureType == Sentinel.Models.ExposureType.Contact && exposure.SourceCase != null)
                                        {
                                            <div>
                                                <strong><i class="bi bi-person"></i> 
                                                    <a asp-page="/Cases/Details" asp-route-id="@exposure.SourceCase.Id">
                                                        @if (exposure.SourceCase.Patient != null)
                                                        {
                                                            <text>@exposure.SourceCase.Patient.GivenName @exposure.SourceCase.Patient.FamilyName</text>
                                                        }
                                                        else
                                                        {
                                                            <text>Case @exposure.SourceCase.FriendlyId</text>
                                                        }
                                                    </a>
                                                </strong>
                                            </div>
                                        }
                                        else if (exposure.Event != null)
                                        {
                                            <a asp-page="/Events/Details" asp-route-id="@exposure.Event.Id">@exposure.Event.Name</a>
                                        }
                                        else if (exposure.Location != null)
                                        {
                                            <a asp-page="/Locations/Details" asp-route-id="@exposure.Location.Id">@exposure.Location.Name</a>
                                        }
                                        else if (!string.IsNullOrEmpty(exposure.FreeTextLocation))
                                        {
                                            <text>@exposure.FreeTextLocation</text>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </small>
                                </td>
                                <td><small>@exposure.ExposureStartDate.ToString("dd MMM")</small></td>
                                <td>
                                    @switch (exposure.ExposureStatus)
                                    {
                                        case Sentinel.Models.ExposureStatus.ConfirmedExposure:
                                            <span class="badge bg-danger">Confirmed</span>
                                            break;
                                        case Sentinel.Models.ExposureStatus.UnderInvestigation:
                                            <span class="badge bg-warning">Investigating</span>
                                            break;
                                        case Sentinel.Models.ExposureStatus.PotentialExposure:
                                            <span class="badge bg-info">Potential</span>
                                            break;
                                        case Sentinel.Models.ExposureStatus.RuledOut:
                                            <span class="badge bg-success">Ruled Out</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">Unknown</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (Model.Acquisitions.Count > 5)
                {
                    <div class="text-center mt-2">
                        <small class="text-muted">Showing 5 of @Model.Acquisitions.Count exposures</small>
                        <button type="button" class="btn btn-sm btn-link p-0 ms-2" data-bs-toggle="modal" data-bs-target="#viewAllExposuresModal">
                            <i class="bi bi-arrows-angle-expand"></i> View All
                        </button>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-diagram-3"></i>
                    <p>No exposures recorded</p>
                </div>
            }
        </div>

        <!-- RIGHT SIDE: Transmissions (Cases this contact exposed) -->
        <div class="info-card transmissions-card">
            <div class="info-card-header">
                <h3 class="info-card-title">
                    <i class="bi bi-arrow-up-circle"></i>
                    Transmissions (@Model.Transmissions.Count)
                </h3>
                <div class="d-flex gap-1">
                    <a asp-page="/Cases/Contacts/BulkCreate"
                       asp-route-caseId="@Model.Contact.Id"
                       class="btn btn-sm btn-outline-primary"
                       title="Bulk Add Contacts">
                        <i class="bi bi-people-fill"></i>
                    </a>
                    <button type="button" class="btn btn-sm btn-outline-success" onclick="openAddExposure()" title="Add Exposure">
                        <i class="bi bi-plus-circle"></i>
                    </button>
                </div>
            </div>
            @if (Model.Transmissions.Any())
            {
                <table class="compact-table w-100">
                    <thead>
                        <tr>
                            <th>Case ID</th>
                            <th>Patient</th>
                            <th>Disease</th>
                            <th>Status</th>
                            <th>Exposure Date</th>
                            <th>Contact Type</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exposure in Model.Transmissions.OrderByDescending(e => e.ExposureStartDate).Take(5))
                        {
                            <tr>
                                <td>
                                    <a asp-page="/Cases/Details" asp-route-id="@exposure.ExposedCaseId" class="fw-bold" style="color: #7c3aed;">
                                        @exposure.ExposedCase?.FriendlyId
                                    </a>
                                </td>
                                <td>
                                    @if (exposure.ExposedCase?.Patient != null)
                                    {
                                        <small>@exposure.ExposedCase.Patient.FamilyName, @exposure.ExposedCase.Patient.GivenName</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <small>@(exposure.ExposedCase?.Disease?.Name ?? "-")</small>
                                </td>
                                <td>
                                    @if (exposure.ExposedCase?.ConfirmationStatus != null)
                                    {
                                        <span class="badge badge-purple">@exposure.ExposedCase.ConfirmationStatus.Name</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <small>@exposure.ExposureStartDate.ToString("dd MMM yyyy")</small>
                                </td>
                                <td>
                                    @if (exposure.ContactClassification != null)
                                    {
                                        <span class="badge badge-slate">@exposure.ContactClassification.Name</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-page="/Cases/Details" asp-route-id="@exposure.ExposedCaseId" class="btn btn-sm btn-link p-0" title="View Case" style="color: #7c3aed;">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (Model.Transmissions.Count > 5)
                {
                    <div class="text-center mt-2">
                        <small class="text-muted">Showing 5 of @Model.Transmissions.Count linked cases</small>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-link-45deg"></i>
                    <p>No cases linked to this contact yet</p>
                    <small class="text-muted">Cases are linked when they have an exposure record where this contact is the RelatedCase</small>
                </div>
            }
        </div>

        <!-- RIGHT SIDE (2 columns): Tasks - Wide and Half Height -->
        <div class="info-card wide half-height tasks-card">
            <div class="info-card-header">
                <h3 class="info-card-title">
                    <i class="bi bi-list-check"></i>
                    Tasks (@Model.Tasks.Count)
                </h3>
                <button type="button" class="info-card-action" onclick="openAddTask()">
                    <i class="bi bi-plus-circle"></i> Add
                </button>
            </div>
            @if (Model.Tasks.Any())
            {
                <table class="compact-table w-100">
                    <thead>
                        <tr>
                            <th>Task</th>
                            <th>Assigned To</th>
                            <th>Survey</th>
                            <th>Priority</th>
                            <th>Due</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in Model.Tasks.OrderBy(t => t.DueDate ?? DateTime.MaxValue).Take(5))
                        {
                            <tr>
                                <td>
                                    <strong>@(task.TaskTemplate?.Name ?? task.Title)</strong>
                                    @if (task.TaskType != null)
                                    {
                                        <br/><small class="text-muted">@task.TaskType.Name</small>
                                    }
                                    @if (task.CallAttempts?.Any() == true)
                                    {
                                        <br/>
                                        <span class="badge bg-info" style="font-size: 0.65rem;">
                                            <i class="bi bi-telephone"></i> @task.CallAttempts.Count call(s)
                                        </span>
                                        <button type="button" class="btn btn-sm btn-link p-0 ms-1" 
                                                onclick="showCallHistory('@task.Id')" 
                                                title="View Call History"
                                                style="font-size: 0.7rem;">
                                            <i class="bi bi-clock-history"></i>
                                        </button>
                                    }
                                </td>
                                <td>
                                    @if (task.AssignedToUser != null)
                                    {
                                        <small>@task.AssignedToUser.UserName</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Unassigned</span>
                                    }
                                </td>
                                <td>
                                    @if (task.TaskTemplate?.SurveyTemplate != null)
                                    {
                                        <small class="text-muted">
                                            <i class="bi bi-clipboard-check"></i>
                                            @task.TaskTemplate.SurveyTemplate.Name
                                        </small>
                                    }
                                    else if (!string.IsNullOrEmpty(task.TaskTemplate?.SurveyDefinitionJson))
                                    {
                                        <small class="text-muted">
                                            <i class="bi bi-clipboard-check"></i>
                                            Custom Survey
                                        </small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var priorityClass = task.Priority switch
                                        {
                                            TaskPriority.Low => "badge-grey",
                                            TaskPriority.Medium => "badge-slate",
                                            TaskPriority.High => "badge-amber",
                                            TaskPriority.Urgent => "bg-danger",
                                            _ => "badge-grey"
                                        };
                                    }
                                    <span class="badge @priorityClass">@task.Priority</span>
                                </td>
                                <td>
                                    @if (task.DueDate.HasValue)
                                    {
                                        <small>@task.DueDate.Value.ToString("dd MMM")</small>
                                        @if (task.Status == CaseTaskStatus.Overdue)
                                        {
                                            <br/><span class="badge bg-danger" style="font-size: 0.65rem;">Overdue</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var statusClass = task.Status switch
                                        {
                                            CaseTaskStatus.Pending => "badge-grey",
                                            CaseTaskStatus.InProgress => "badge-teal",
                                            CaseTaskStatus.Completed => "bg-success",
                                            CaseTaskStatus.Cancelled => "bg-dark",
                                            CaseTaskStatus.Overdue => "bg-danger",
                                            CaseTaskStatus.WaitingForPatient => "badge-amber",
                                            _ => "badge-grey"
                                        };
                                    }
                                    <span class="badge @statusClass">@task.Status</span>
                                </td>
                                <td class="text-end">
                                    @{
                                        var hasSurvey = (task.TaskTemplate?.SurveyTemplateId.HasValue == true) || 
                                                        !string.IsNullOrEmpty(task.TaskTemplate?.SurveyDefinitionJson);
                                        var isCompletedWithSurvey = task.Status == CaseTaskStatus.Completed && hasSurvey && !string.IsNullOrEmpty(task.SurveyResponseJson);
                                    }

                                    @if (isCompletedWithSurvey)
                                    {
                                        <a asp-page="/Tasks/ViewSurveyResult" asp-route-id="@task.Id" class="btn btn-sm btn-link p-0 me-1" title="View Survey Results">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    }
                                    else if (task.Status != CaseTaskStatus.Completed && task.Status != CaseTaskStatus.Cancelled)
                                    {
                                        if (hasSurvey)
                                        {
                                            <a asp-page="/Tasks/CompleteSurvey" asp-route-id="@task.Id" class="btn btn-sm btn-link p-0 me-1" title="Complete Survey">
                                                <i class="bi bi-clipboard-check"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-link p-0 me-1" onclick="openCompleteTaskModal('@task.Id', '@task.TaskTemplate?.Name')" title="Complete">
                                                <i class="bi bi-check-circle"></i>
                                            </button>
                                        }
                                        <a href="javascript:void(0)" onclick="openEditTaskWindow('@task.Id', '@Model.Contact.Id')" class="btn btn-sm btn-link p-0 text-primary me-1" title="Edit Task">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-link p-0 text-info" onclick="logCallAttempt('@task.Id', '@(task.TaskTemplate?.Name ?? task.Title)')" title="Log Call">
                                            <i class="bi bi-telephone-plus"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (Model.Tasks.Count > 5)
                {
                    <div class="text-center mt-2">
                        <small class="text-muted">Showing 5 of @Model.Tasks.Count tasks</small>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-list-check"></i>
                    <p>No tasks yet</p>
                    <button type="button" class="info-card-action" onclick="openAddTask()">Add Task</button>
                </div>
            }
        </div>

        <!-- RIGHT SIDE: Notes & Communications -->
        <div class="info-card notes-card">
            <div class="info-card-header">
                <h3 class="info-card-title">
                    <i class="bi bi-chat-left-text"></i>
                    Notes (@Model.Notes.Count)
                </h3>
                <button type="button" class="info-card-action" data-bs-toggle="modal" data-bs-target="#addNoteModal">
                    <i class="bi bi-plus-circle"></i> Add
                </button>
            </div>
            @if (Model.Notes.Any())
            {
                <div style="max-height: 400px; overflow-y: auto;">
                    @foreach (var note in Model.Notes)
                    {
                        <div class="note-item">
                            <div class="note-header">
                                <div>
                                    @if (note.Type == "SMS")
                                    {
                                        <span class="badge badge-teal"><i class="bi bi-chat-dots"></i> SMS</span>
                                    }
                                    else if (note.Type == "Phone Call")
                                    {
                                        <span class="badge badge-grey"><i class="bi bi-telephone"></i> Call</span>
                                    }
                                    else if (note.Type == "Email")
                                    {
                                        <span class="badge badge-slate"><i class="bi bi-envelope"></i> Email</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-grey"><i class="bi bi-chat-left-text"></i> Note</span>
                                    }
                                    @if (!string.IsNullOrEmpty(note.Subject))
                                    {
                                        <strong class="ms-2">@note.Subject</strong>
                                    }
                                </div>
                                <form method="post" asp-page-handler="DeleteNote" asp-route-id="@Model.Contact.Id" asp-route-noteId="@note.Id" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-link text-danger p-0" onclick="return confirm('Delete this note?');" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                            <p class="mb-1" style="font-size: 0.875rem;">@note.Content</p>
                            <div class="note-meta">
                                <i class="bi bi-person me-1"></i>@(note.CreatedBy ?? "Unknown")
                                <span class="mx-1">•</span>
                                @note.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-chat-left-text"></i>
                    <p>No notes yet</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- View All Exposures Modal -->
<div class="modal fade" id="viewAllExposuresModal" tabindex="-1" aria-labelledby="viewAllExposuresModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewAllExposuresModalLabel">
                    <i class="bi bi-diagram-3 me-2"></i>All Exposures (@Model.Acquisitions.Count)
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @if (Model.Acquisitions.Any())
                {
                    <!-- Filter and Sort Controls -->
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label small text-muted">Filter by Type</label>
                            <select class="form-select form-select-sm" id="exposureTypeFilter">
                                <option value="">All Types</option>
                                <option value="Event">Event</option>
                                <option value="Location">Location</option>
                                <option value="Contact">Contact</option>
                                <option value="Travel">Travel</option>
                                <option value="LocallyAcquired">Locally Acquired</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-muted">Filter by Status</label>
                            <select class="form-select form-select-sm" id="exposureStatusFilter">
                                <option value="">All Statuses</option>
                                <option value="ConfirmedExposure">Confirmed</option>
                                <option value="UnderInvestigation">Under Investigation</option>
                                <option value="PotentialExposure">Potential</option>
                                <option value="RuledOut">Ruled Out</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-muted">Sort by</label>
                            <select class="form-select form-select-sm" id="exposureSortOrder">
                                <option value="date-desc">Date (Newest First)</option>
                                <option value="date-asc">Date (Oldest First)</option>
                                <option value="type">Type</option>
                                <option value="status">Status</option>
                            </select>
                        </div>
                    </div>

                    <!-- Results Count -->
                    <div class="alert alert-light py-2 mb-3">
                        <i class="bi bi-info-circle me-1"></i>
                        Showing <strong id="exposureCount">@Model.Acquisitions.Count</strong> of @Model.Acquisitions.Count exposures
                    </div>

                    <!-- Exposures Table -->
                    <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                        <table class="table table-hover table-sm" id="allExposuresTable">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Type</th>
                                    <th>Details</th>
                                    <th>Date</th>
                                    <th>End Date</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var exposure in Model.Acquisitions.OrderByDescending(e => e.ExposureStartDate))
                                {
                                    <tr data-type="@exposure.ExposureType" data-status="@exposure.ExposureStatus" data-date="@exposure.ExposureStartDate.ToString("yyyy-MM-dd")">
                                        <td>
                                            @switch (exposure.ExposureType)
                                            {
                                                case Sentinel.Models.ExposureType.Event:
                                                    <span class="badge badge-teal"><i class="bi bi-calendar-event"></i> Event</span>
                                                    break;
                                                case Sentinel.Models.ExposureType.Location:
                                                    <span class="badge badge-slate"><i class="bi bi-geo-alt"></i> Location</span>
                                                    break;
                                                case Sentinel.Models.ExposureType.Contact:
                                                    <span class="badge badge-amber"><i class="bi bi-people"></i> Contact</span>
                                                    break;
                                                case Sentinel.Models.ExposureType.Travel:
                                                    <span class="badge badge-grey"><i class="bi bi-airplane"></i> Travel</span>
                                                    break;
                                                case Sentinel.Models.ExposureType.LocallyAcquired:
                                                    <span class="badge badge-teal"><i class="bi bi-house"></i> Locally Acquired</span>
                                                    break;
                                                default:
                                                    <span class="badge badge-grey">Unknown</span>
                                                    break;
                                            }
                                        </td>
                                        <td>
                                            @if (exposure.Event != null)
                                            {
                                                <strong>@exposure.Event.Name</strong>
                                                @if (exposure.Event.Location != null)
                                                {
                                                    <br/><small class="text-muted"><i class="bi bi-geo-alt"></i> @exposure.Event.Location.Name</small>
                                                }
                                            }
                                            else if (exposure.Location != null)
                                            {
                                                <strong>@exposure.Location.Name</strong>
                                                @if (!string.IsNullOrEmpty(exposure.Location.Address))
                                                {
                                                    <br/><small class="text-muted">@exposure.Location.Address</small>
                                                }
                                            }
                                            else if (exposure.SourceCase != null)
                                            {
                                                <strong>Case @exposure.SourceCase.FriendlyId</strong>
                                                @if (exposure.SourceCase.Patient != null)
                                                {
                                                    <br/><small class="text-muted">@exposure.SourceCase.Patient.GivenName @exposure.SourceCase.Patient.FamilyName</small>
                                                }
                                            }
                                            else if (exposure.ExposureType == Sentinel.Models.ExposureType.LocallyAcquired)
                                            {
                                                @if (!string.IsNullOrEmpty(exposure.AddressLine))
                                                {
                                                    <strong>@exposure.AddressLine</strong>
                                                    @if (!string.IsNullOrEmpty(exposure.City))
                                                    {
                                                        <br/><small class="text-muted">@exposure.City</small>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Patient's Residence</span>
                                                }
                                            }
                                            else if (!string.IsNullOrEmpty(exposure.FreeTextLocation))
                                            {
                                                <text>@exposure.FreeTextLocation</text>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                            @if (!string.IsNullOrEmpty(exposure.Description))
                                            {
                                                <br/><small class="text-muted"><i class="bi bi-chat-left-text"></i> @exposure.Description.Substring(0, Math.Min(50, exposure.Description.Length))@(exposure.Description.Length > 50 ? "..." : "")</small>
                                            }
                                        </td>
                                        <td>
                                            <strong>@exposure.ExposureStartDate.ToString("dd MMM yyyy")</strong>
                                        </td>
                                        <td>
                                            @if (exposure.ExposureEndDate.HasValue)
                                            {
                                                <text>@exposure.ExposureEndDate.Value.ToString("dd MMM yyyy")</text>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            @switch (exposure.ExposureStatus)
                                            {
                                                case Sentinel.Models.ExposureStatus.ConfirmedExposure:
                                                    <span class="badge bg-danger">Confirmed</span>
                                                    break;
                                                case Sentinel.Models.ExposureStatus.UnderInvestigation:
                                                    <span class="badge bg-warning text-dark">Investigating</span>
                                                    break;
                                                case Sentinel.Models.ExposureStatus.PotentialExposure:
                                                    <span class="badge bg-info">Potential</span>
                                                    break;
                                                case Sentinel.Models.ExposureStatus.RuledOut:
                                                    <span class="badge bg-success">Ruled Out</span>
                                                    break;
                                                default:
                                                    <span class="badge bg-secondary">Unknown</span>
                                                    break;
                                            }
                                        </td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-link p-0" onclick="openEditExposure('@exposure.Id')" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        No exposures have been recorded for this case.
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="openAddExposure()">
                    <i class="bi bi-plus-circle me-1"></i>Add New Exposure
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Add Note Modal -->
<div class="modal fade" id="addNoteModal" tabindex="-1" aria-labelledby="addNoteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" asp-page-handler="AddNote" asp-route-id="@Model.Contact.Id" enctype="multipart/form-data">
                <div class="modal-header">
