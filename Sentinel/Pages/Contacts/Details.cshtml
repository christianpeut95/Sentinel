                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Lab Result Modal -->
<div class="modal fade" id="addLabResultModal" tabindex="-1" aria-labelledby="addLabResultModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <form method="post" asp-page-handler="AddLabResult" asp-route-id="@Model.Contact.Id" enctype="multipart/form-data" id="labResultForm">
                <div class="modal-header bg-light">
                    <div>
                        <h5 class="modal-title mb-1" id="addLabResultModalLabel">
                            <i class="bi bi-clipboard-plus me-2 text-primary"></i>Add Laboratory Result
                        </h5>
                        <small class="text-muted">Complete all required fields marked with <span class="text-danger">*</span></small>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <!-- Validation Alert -->
                    <div id="labResultValidationAlert" class="alert alert-danger d-none mb-3" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Please correct the following:</strong>
                        <ul id="labResultValidationList" class="mb-0 mt-2"></ul>
                    </div>

                    <!-- Patient & Case Context -->
                    <div class="alert alert-info mb-4">
                        <div class="row">
                            <div class="col-md-4">
                                <small class="text-muted d-block">Patient</small>
                                <strong>@Model.Contact.Patient?.GivenName @Model.Contact.Patient?.FamilyName</strong>
                            </div>
                            <div class="col-md-4">
                                <small class="text-muted d-block">Date of Birth</small>
                                <strong>@(Model.Contact.Patient?.DateOfBirth?.ToString("dd MMM yyyy") ?? "Unknown")</strong>
                            </div>
                            <div class="col-md-4">
                                <small class="text-muted d-block">Case Disease</small>
                                <strong>@Model.Contact.Disease?.Name</strong>
                            </div>
                        </div>
                    </div>

                    <!-- Section 1: Test Details -->
                    <h6 class="border-bottom pb-2 mb-3">
                        <i class="bi bi-clipboard2-pulse me-2 text-primary"></i>Test Information
                    </h6>
                    <div class="modal-body">
                    <!-- Section 1: Test Details -->
                    <h6 class="border-bottom pb-2 mb-3">
                        <i class="bi bi-clipboard2-pulse me-2 text-primary"></i>Test Information
                    </h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NewLabResult.TestedDiseaseId" class="form-label">
                                Test For (Disease/Pathogen) <span class="text-danger">*</span>
                                <i class="bi bi-info-circle text-muted" title="Defaults to case disease"></i>
                            </label>
                            <select asp-for="NewLabResult.TestedDiseaseId" class="form-select select2-disease" id="diseaseSelect" required>
                                <option value="">Select Disease</option>
                            </select>
                            <small class="form-text text-muted">Auto-populated with case disease</small>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NewLabResult.TestTypeId" class="form-label">
                                Test Type <span class="text-danger">*</span>
                            </label>
                            <select asp-for="NewLabResult.TestTypeId" class="form-select" asp-items="Model.TestTypesList" id="testTypeSelect" required>
                                <option value="">Select Test Type</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NewLabResult.SpecimenTypeId" class="form-label">
                                Specimen Type <span class="text-danger">*</span>
                            </label>
                            <select asp-for="NewLabResult.SpecimenTypeId" class="form-select" asp-items="Model.SpecimenTypesList" required>
                                <option value="">Select Specimen Type</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NewLabResult.TestResultId" class="form-label">
                                Test Result <span class="text-danger">*</span>
                            </label>
                            <select asp-for="NewLabResult.TestResultId" class="form-select select2-testresult" id="testResultSelect" required>
                                <option value="">Select Test Type First</option>
                            </select>
                            <small class="form-text text-muted">Results filtered by test type</small>
                        </div>
                    </div>

                    <!-- Section 2: Key Dates -->
                    <h6 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="bi bi-calendar-event me-2 text-primary"></i>Critical Dates
                    </h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NewLabResult.SpecimenCollectionDate" class="form-label">
                                Specimen Collection Date <span class="text-danger">*</span>
                                <i class="bi bi-exclamation-circle text-warning" id="collectionDateWarning" style="display:none;" 
                                   title="Date seems unusual - please verify"></i>
                            </label>
                            <input asp-for="NewLabResult.SpecimenCollectionDate" class="form-control" type="date" id="specimenCollectionDate" required />
                            <div class="invalid-feedback" id="collectionDateError"></div>
                            <small class="form-text text-muted" id="collectionDateHelp">Must be after birth date and before result date</small>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NewLabResult.ResultDate" class="form-label">
                                Result Date <span class="text-danger">*</span>
                            </label>
                            <input asp-for="NewLabResult.ResultDate" class="form-control" type="date" id="resultDate" required />
                            <div class="invalid-feedback" id="resultDateError"></div>
                            <small class="form-text text-muted">Date laboratory reported the result</small>
                        </div>
                    </div>

                    <!-- Date Validation Warnings -->
                    <div id="dateValidationWarnings" class="alert alert-warning mt-3 d-none">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Date Validation Warnings:</strong>
                        <ul id="dateWarningsList" class="mb-0 mt-2"></ul>
                    </div>

                    <!-- Section 3: Laboratory & Provider -->
                    <h6 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="bi bi-building me-2 text-primary"></i>Laboratory & Provider
                    </h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NewLabResult.LaboratoryId" class="form-label">Laboratory</label>
                            <select asp-for="NewLabResult.LaboratoryId" class="form-select select2-organization" id="laboratorySelect">
                                <option value="">Select Laboratory</option>
                            </select>
                            <small class="form-text text-muted">Type to search</small>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NewLabResult.OrderingProviderId" class="form-label">Ordering Provider</label>
                            <select asp-for="NewLabResult.OrderingProviderId" class="form-select select2-organization" id="orderingProviderSelect">
                                <option value="">Select Provider</option>
                            </select>
                            <small class="form-text text-muted">Type to search</small>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="NewLabResult.AccessionNumber" class="form-label">Accession Number</label>
                            <input asp-for="NewLabResult.AccessionNumber" class="form-control" placeholder="Lab reference/accession number" />
                            <small class="form-text text-muted">Laboratory's internal reference number</small>
                        </div>
                    </div>

                    <!-- Section 4: Quantitative Results -->
                    <h6 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="bi bi-graph-up me-2 text-primary"></i>Quantitative Results (Optional)
                    </h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NewLabResult.QuantitativeResult" class="form-label">Quantitative Result</label>
                            <input asp-for="NewLabResult.QuantitativeResult" class="form-control" type="number" step="0.01" placeholder="e.g., 5.2" />
                            <small class="form-text text-muted">Numeric value if applicable</small>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NewLabResult.ResultUnitsId" class="form-label">Units</label>
                            <select asp-for="NewLabResult.ResultUnitsId" class="form-select" asp-items="Model.ResultUnitsList">
                                <option value="">Select Units</option>
                            </select>
                            <small class="form-text text-muted">e.g., mg/dL, copies/mL</small>
                        </div>
                    </div>

                    <!-- Section 5: Additional Information -->
                    <h6 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="bi bi-chat-dots me-2 text-primary"></i>Additional Information
                    </h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NewLabResult.Notes" class="form-label">Notes</label>
                            <textarea asp-for="NewLabResult.Notes" class="form-control" rows="3" placeholder="Any additional notes or context..."></textarea>
                            <small class="form-text text-muted">Internal notes about the test</small>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NewLabResult.LabInterpretation" class="form-label">Lab Interpretation</label>
                            <textarea asp-for="NewLabResult.LabInterpretation" class="form-control" rows="3" placeholder="Laboratory's interpretation or comments..."></textarea>
                            <small class="form-text text-muted">Lab's official interpretation</small>
                        </div>
                        <div class="col-md-12">
                            <div class="form-check">
                                <input asp-for="NewLabResult.IsAmended" class="form-check-input" type="checkbox" />
                                <label asp-for="NewLabResult.IsAmended" class="form-check-label">
                                    Amended Result
                                    <i class="bi bi-info-circle text-muted ms-1" title="Check if this replaces a previous result"></i>
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Section 6: Attachment -->
                    <h6 class="border-bottom pb-2 mb-3 mt-4">
                        <i class="bi bi-paperclip me-2 text-primary"></i>Attachment
                    </h6>
                    <div class="mb-3">
                        <label asp-for="LabResultAttachment" class="form-label">Upload Lab Report</label>
                        <input asp-for="LabResultAttachment" type="file" class="form-control" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.gif" />
                        <small class="form-text text-muted">
                            <i class="bi bi-info-circle me-1"></i>
                            PDF, Word, or image files (max 10MB). Useful for scanned/faxed reports.
                        </small>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn btn-primary" id="saveLabResultBtn">
                        <i class="bi bi-save me-1"></i>Save Lab Result
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

