                            <select id="edit_TestTypeId" name="NewLabResult.TestTypeId" class="form-select">
                                <option value="">Select Test Type</option>
                                @foreach (var item in Model.TestTypesList)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="edit_TestResultId" class="form-label">Test Result</label>
                            <select id="edit_TestResultId" name="NewLabResult.TestResultId" class="form-select select2-testresult-edit">
                                <option value="">Select Test Type First</option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="edit_ResultDate" class="form-label">Result Date</label>
                            <input id="edit_ResultDate" name="NewLabResult.ResultDate" class="form-control" type="date" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="edit_QuantitativeResult" class="form-label">Quantitative Result</label>
                            <input id="edit_QuantitativeResult" name="NewLabResult.QuantitativeResult" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="edit_ResultUnitsId" class="form-label">Units</label>
                            <select id="edit_ResultUnitsId" name="NewLabResult.ResultUnitsId" class="form-select">
                                <option value="">Select Units</option>
                                @foreach (var item in Model.ResultUnitsList)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <div class="form-check">
                                <input id="edit_IsAmended" name="NewLabResult.IsAmended" class="form-check-input" type="checkbox" />
                                <label for="edit_IsAmended" class="form-check-label">Amended Result</label>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="edit_Notes" class="form-label">Notes</label>
                            <textarea id="edit_Notes" name="NewLabResult.Notes" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="edit_LabInterpretation" class="form-label">Lab Interpretation</label>
                            <textarea id="edit_LabInterpretation" name="NewLabResult.LabInterpretation" class="form-control" rows="3"></textarea>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="edit_Attachment" class="form-label">Attachment</label>
                        <input id="edit_Attachment" name="LabResultAttachment" type="file" class="form-control" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.gif" />
                        <small class="form-text text-muted">Optional: Upload new file to replace existing attachment</small>
                        <div id="currentAttachment" class="mt-2"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

