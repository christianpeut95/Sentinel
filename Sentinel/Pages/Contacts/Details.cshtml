    // Attach close handler to close button
    $('#viewLabResultModal [data-bs-dismiss="modal"]').on('click', function() {
        closeViewLabResultModal();
    });

    function editLabResult(labResultId) {
        currentLabResultId = labResultId;
        
        // Use jQuery modal API
        $('#editLabResultModal').modal('show');
        $('#editLabResultId').val(labResultId);

        var caseId = '@Model.Contact.Id';
        $('#editLabResultForm').attr('action', '/Contacts/Details?id=' + caseId + '&handler=UpdateLabResult&labResultId=' + labResultId);

        // Load the lab result data
        $.get('@Url.Page("/Contacts/Details", "LabResultDetails")', { labResultId: labResultId }, function(response) {
            if (response.success) {
                var data = response.data;
                
                // Populate form fields
                $('#edit_AccessionNumber').val(data.accessionNumber);
                $('#edit_SpecimenCollectionDate').val(data.specimenCollectionDate);
                $('#edit_SpecimenTypeId').val(data.specimenTypeId);
                $('#edit_TestTypeId').val(data.testTypeId);
                $('#edit_ResultDate').val(data.resultDate);
                $('#edit_QuantitativeResult').val(data.quantitativeResult);
                $('#edit_ResultUnitsId').val(data.resultUnitsId);
                $('#edit_IsAmended').prop('checked', data.isAmended);
                $('#edit_Notes').val(data.notes);
                $('#edit_LabInterpretation').val(data.labInterpretation);

                // Initialize Select2 for edit organization fields with current value
                if (data.laboratoryId) {
                    var newOption = new Option(data.laboratoryName, data.laboratoryId, true, true);
                    $('#edit_LaboratoryId').append(newOption).trigger('change');
                }
                
                if (data.orderingProviderId) {
                    var newOption = new Option(data.orderingProviderName, data.orderingProviderId, true, true);
                    $('#edit_OrderingProviderId').append(newOption).trigger('change');
                }

                // Initialize Select2 for edit disease field with current value
                if (data.testedDiseaseId) {
                    var newOption = new Option(data.testedDiseaseName, data.testedDiseaseId, true, true);
                    $('#edit_TestedDiseaseId').append(newOption).trigger('change');
                }

                // Initialize Select2 for edit test result field with current value
                if (data.testResultId && data.testTypeId) {
                    var newOption = new Option(data.testResultName, data.testResultId, true, true);
                    $('#edit_TestResultId').append(newOption).trigger('change');
                }

                // Show current attachment if exists
                if (data.attachmentPath) {
                    $('#currentAttachment').html(
                        '<div class="alert alert-info">' +
                        '<i class="bi bi-paperclip me-2"></i>Current: ' +
                        '<a href="' + data.attachmentPath + '" target="_blank">' + data.attachmentFileName + '</a>' +
                        '</div>'
                    );
                } else {
                    $('#currentAttachment').html('');
                }

                // Trigger test type change to enable test result dropdown
                if (data.testTypeId) {
                    $('#edit_TestTypeId').trigger('change');
                }
            } else {
                alert('Failed to load lab result details');
                $('#editLabResultModal').modal('hide');
            }
        }).fail(function(error) {            alert('Error loading lab result details');
            $('#editLabResultModal').modal('hide');
        });
    }

    // Expose functions to global scope for inline onclick handlers
    window.openAddLabResult = openAddLabResult;
    window.openAddExposure = openAddExposure;
    window.openEditExposure = openEditExposure;
    window.viewLabResult = viewLabResult;
    window.editLabResult = editLabResult;

    // ========================================================================
    // EXPOSURES FILTERING AND SORTING
    // ========================================================================
    function filterAndSortExposures() {
        var typeFilter = $('#exposureTypeFilter').val();
        var statusFilter = $('#exposureStatusFilter').val();
        var sortOrder = $('#exposureSortOrder').val();
        
        var rows = $('#allExposuresTable tbody tr').get();
        
        // Filter rows
        var visibleCount = 0;
        rows.forEach(function(row) {
            var $row = $(row);
            var showRow = true;
            
            if (typeFilter && $row.data('type') !== typeFilter) {
                showRow = false;
            }
            
            if (statusFilter && $row.data('status') !== statusFilter) {
                showRow = false;
            }
            
            if (showRow) {
                $row.show();
                visibleCount++;
            } else {
                $row.hide();
            }
        });
        
        // Update count
        $('#exposureCount').text(visibleCount);
        
        // Sort visible rows
        rows.sort(function(a, b) {
            var $a = $(a);
            var $b = $(b);
            
            switch(sortOrder) {
                case 'date-desc':
                    return $b.data('date').localeCompare($a.data('date'));
                case 'date-asc':
                    return $a.data('date').localeCompare($b.data('date'));
                case 'type':
                    return $a.data('type').localeCompare($b.data('type'));
                case 'status':
                    return $a.data('status').localeCompare($b.data('status'));
                default:
                    return 0;
            }
        });
        
        // Reorder rows in table
        $('#allExposuresTable tbody').append(rows);
    }

    // Attach event handlers for exposure filters
    $('#exposureTypeFilter, #exposureStatusFilter, #exposureSortOrder').on('change', function() {
        filterAndSortExposures();
    });

    // Reset filters when modal is closed
    $('#viewAllExposuresModal').on('hidden.bs.modal', function() {
        $('#exposureTypeFilter').val('');
        $('#exposureStatusFilter').val('');
        $('#exposureSortOrder').val('date-desc');
        $('#allExposuresTable tbody tr').show();
        $('#exposureCount').text($('#allExposuresTable tbody tr').length);
    });


    // ========================================================================
    // DOCUMENT READY - INITIALIZATION CODE
    // ========================================================================
    $(document).ready(function() {        // Patient contact information
        var patientEmail = '@(Model.Contact.Patient?.EmailAddress ?? "")';
        var patientMobile = '@(Model.Contact.Patient?.MobilePhone ?? "")';
        var patientHome = '@(Model.Contact.Patient?.HomePhone ?? "")';

        // Edit button click handler
        $('#editFromViewBtn').on('click', function() {
            $('#viewLabResultModal').modal('hide');
            setTimeout(function() {
                if (currentLabResultId) {
                    editLabResult(currentLabResultId);
                }
            }, 300);
        });

        // Show/hide recipient field based on type selection
        $('#noteTypeSelect').on('change', function() {
            var selectedType = $(this).val();
            
            if (selectedType === 'SMS' || selectedType === 'Phone Call' || selectedType === 'Email') {
                $('#recipientField').show();
                
                // Auto-populate recipient based on type
                if (selectedType === 'Email') {
                    $('#NewNote_Recipient').attr('placeholder', 'Email address');
                    if (patientEmail) {
                        $('#NewNote_Recipient').val(patientEmail);
                    }
                } else if (selectedType === 'SMS') {
                    $('#NewNote_Recipient').attr('placeholder', 'Phone number');
                    if (patientMobile) {
                        $('#NewNote_Recipient').val(patientMobile);
                    } else if (patientHome) {
                        $('#NewNote_Recipient').val(patientHome);
                    }
                } else if (selectedType === 'Phone Call') {
                    $('#NewNote_Recipient').attr('placeholder', 'Phone number');
                    // Prefer mobile for phone calls, fallback to home
                    if (patientMobile) {
                        $('#NewNote_Recipient').val(patientMobile);
                    } else if (patientHome) {
                        $('#NewNote_Recipient').val(patientHome);
                    }
                }
            } else {
                $('#recipientField').hide();
                $('#NewNote_Recipient').val('');
            }
        });

        // Trigger on modal open to handle pre-filled values
        $('#addNoteModal').on('shown.bs.modal', function() {
            $('#noteTypeSelect').trigger('change');
        });

        // ========================================================================
        // LAB RESULT VALIDATION & AUTO-POPULATION
        // ========================================================================

        // Case and Patient Data for Validation
        var caseDisease = {
            id: '@Model.Contact.DiseaseId',
            name: '@Model.Contact.Disease?.Name'
        };
        var patientDOB = '@(Model.Contact.Patient?.DateOfBirth?.ToString("yyyy-MM-dd") ?? "")';
        var caseOnsetDate = '@(Model.Contact.DateOfOnset?.ToString("yyyy-MM-dd") ?? "")';
        var caseNotificationDate = '@(Model.Contact.DateOfNotification?.ToString("yyyy-MM-dd") ?? "")';

        // Auto-populate disease when modal opens
        $('#addLabResultModal').on('shown.bs.modal', function() {
            if (caseDisease.id && caseDisease.id !== '') {
                // Initialize Select2 with case disease
                var newOption = new Option(caseDisease.name, caseDisease.id, true, true);
                $('#diseaseSelect').append(newOption).trigger('change');
            }
            
            // Reset validation
            resetLabResultValidation();
        });

        // Date Validation Functions
        function validateLabResultDates() {
            var collectionDate = $('#specimenCollectionDate').val();
            var resultDate = $('#resultDate').val();
            var errors = [];
            var warnings = [];

            // Clear previous validation
            $('#specimenCollectionDate').removeClass('is-invalid');
            $('#resultDate').removeClass('is-invalid');
            $('#dateValidationWarnings').addClass('d-none');
            $('#collectionDateWarning').hide();

            if (!collectionDate || !resultDate) {
                return true; // Don't validate if dates not entered yet
            }

            var collectionDateObj = new Date(collectionDate);
            var resultDateObj = new Date(resultDate);
            var today = new Date();
            today.setHours(0, 0, 0, 0);

            // HARD VALIDATIONS (Errors)
            
            // 1. Collection date cannot be before birth date
            if (patientDOB && patientDOB !== '') {
                var dobObj = new Date(patientDOB);
                if (collectionDateObj < dobObj) {
                    errors.push('Specimen collection date cannot be before patient birth date (' + formatDate(dobObj) + ')');
                    $('#specimenCollectionDate').addClass('is-invalid');
                    $('#collectionDateError').text('Cannot be before birth date');
                }
            }

            // 2. Collection date cannot be after result date
            if (collectionDateObj > resultDateObj) {
                errors.push('Specimen collection date cannot be after result date');
                $('#specimenCollectionDate').addClass('is-invalid');
                $('#resultDate').addClass('is-invalid');
                $('#collectionDateError').text('Cannot be after result date');
                $('#resultDateError').text('Cannot be before collection date');
            }

            // 3. Result date cannot be in the future
            if (resultDateObj > today) {
                errors.push('Result date cannot be in the future');
                $('#resultDate').addClass('is-invalid');
                $('#resultDateError').text('Cannot be in the future');
            }

            // SOFT VALIDATIONS (Warnings)
            
            // 4. Collection date more than 3 months before case onset
            if (caseOnsetDate && caseOnsetDate !== '') {
                var onsetObj = new Date(caseOnsetDate);
                var monthsDiff = monthDiff(collectionDateObj, onsetObj);
                
                if (Math.abs(monthsDiff) > 3) {
                    warnings.push('Specimen collection date is ' + Math.abs(monthsDiff) + ' months ' + 
                                (monthsDiff > 0 ? 'before' : 'after') + ' case onset date (' + formatDate(onsetObj) + ')');
                    $('#collectionDateWarning').show();
                }
            }

            // 5. Collection date more than 3 months from notification date
            if (caseNotificationDate && caseNotificationDate !== '') {
                var notifObj = new Date(caseNotificationDate);
                var monthsDiff = monthDiff(collectionDateObj, notifObj);
                
                if (Math.abs(monthsDiff) > 3) {
                    warnings.push('Specimen collection date is ' + Math.abs(monthsDiff) + ' months ' + 
                                (monthsDiff > 0 ? 'before' : 'after') + ' notification date (' + formatDate(notifObj) + ')');
                    $('#collectionDateWarning').show();
                }
            }

            // 6. Result date more than 30 days after collection
            var daysDiff = dayDifference(collectionDateObj, resultDateObj);
            if (daysDiff > 30) {
                warnings.push('Result date is ' + daysDiff + ' days after collection date - verify turnaround time');
            }

            // Display errors
            if (errors.length > 0) {
                $('#labResultValidationAlert').removeClass('d-none');
                $('#labResultValidationList').empty();
                errors.forEach(function(error) {
                    $('#labResultValidationList').append('<li>' + error + '</li>');
                });
                return false;
            } else {
                $('#labResultValidationAlert').addClass('d-none');
            }

            // Display warnings
            if (warnings.length > 0) {
                $('#dateValidationWarnings').removeClass('d-none');
                $('#dateWarningsList').empty();
                warnings.forEach(function(warning) {
                    $('#dateWarningsList').append('<li>' + warning + '</li>');
                });
            }

            return true;
        }

        // Helper Functions
        function formatDate(date) {
            var options = { year: 'numeric', month: 'short', day: 'numeric' };
            return date.toLocaleDateString('en-GB', options);
        }

        function monthDiff(d1, d2) {
            var months = (d2.getFullYear() - d1.getFullYear()) * 12;
            months -= d1.getMonth();
            months += d2.getMonth();
            return months;
        }

        function dayDifference(d1, d2) {
            var diffTime = Math.abs(d2 - d1);
            var diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)); 
            return diffDays;
        }

        function resetLabResultValidation() {
            $('#labResultValidationAlert').addClass('d-none');
            $('#dateValidationWarnings').addClass('d-none');
            $('#specimenCollectionDate').removeClass('is-invalid');
            $('#resultDate').removeClass('is-invalid');
            $('#collectionDateWarning').hide();
        }

        // Attach validation to date fields
        $('#specimenCollectionDate, #resultDate').on('change blur', function() {
            validateLabResultDates();
        });

        // Form submission validation
        $('#labResultForm').on('submit', function(e) {
            if (!validateLabResultDates()) {
                e.preventDefault();
                $('html, body').animate({
                    scrollTop: $('#labResultValidationAlert').offset().top - 100
                }, 500);
                return false;
            }
            
            // Show loading state
            $('#saveLabResultBtn').prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Saving...');
        });

        // Reset form when modal closes
        $('#addLabResultModal').on('hidden.bs.modal', function() {
            $('#labResultForm')[0].reset();
            resetLabResultValidation();
            $('#diseaseSelect').val(null).trigger('change');
            $('#saveLabResultBtn').prop('disabled', false).html('<i class="bi bi-save me-1"></i>Save Lab Result');
        });

        // ========================================================================
        // EXISTING SELECT2 INITIALIZATION
        // ========================================================================
        
        // Configure Select2 with keyboard-friendly settings
        var select2Config = {
            dropdownParent: $('#addLabResultModal'),
            width: '100%',
            allowClear: true,
            selectOnClose: false,
            closeOnSelect: true,
            dropdownAutoWidth: false
        };

        $('.select2-organization').select2($.extend({}, select2Config, {
            placeholder: 'Type to search or press Enter...',
            minimumInputLength: 2,
            ajax: {
                url: '@Url.Page("/Contacts/Details", "SearchOrganizations")',
                dataType: 'json',
