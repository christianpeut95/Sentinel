@page
@model Sentinel.Pages.Contacts.DeleteModel

@{
    ViewData["Title"] = "Delete Contact";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Contacts</a></li>
        <li class="breadcrumb-item active" aria-current="page">Delete</li>
    </ol>
</nav>

<h2><i class="bi bi-trash me-2"></i>Delete Contact</h2>
<h3 class="text-danger">Are you sure you want to delete this contact?</h3>

<div class="alert alert-warning">
    <i class="bi bi-exclamation-triangle me-2"></i>
    This action will soft delete the contact. It can be recovered from the Deleted Records page.
</div>

<div>
    <dl class="row">
        <dt class="col-sm-3">Contact ID</dt>
        <dd class="col-sm-9">@Model.Contact.FriendlyId</dd>
        
        <dt class="col-sm-3">Patient</dt>
        <dd class="col-sm-9">
            @if (Model.Contact.Patient != null)
            {
                @Model.Contact.Patient.GivenName @Model.Contact.Patient.FamilyName
            }
        </dd>
        
        <dt class="col-sm-3">Disease</dt>
        <dd class="col-sm-9">@Model.Contact.Disease?.Name</dd>
        
        <dt class="col-sm-3">Date of Onset</dt>
        <dd class="col-sm-9">@Model.Contact.DateOfOnset?.ToString("dd/MM/yyyy")</dd>
        
        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.Contact.ConfirmationStatus?.Name</dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="Contact.Id" />
        <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
        <a asp-page="./Index" class="btn btn-secondary ms-2"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
    </form>
</div>
