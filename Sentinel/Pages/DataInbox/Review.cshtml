    DuplicateMatchData GetDuplicateMatchData(Dictionary<string, object?> changeSnapshot, Dictionary<string, object?> entityData)
    {
        var data = new DuplicateMatchData();
        
        try
        {
            // Try to extract survey data
            if (entityData.ContainsKey("surveyData"))
            {
                var surveyDataObj = entityData["surveyData"];
                if (surveyDataObj != null)
                {
                    try
                    {
                        if (surveyDataObj is Dictionary<string, object> dict)
                        {
                            data.SurveyData = dict;
                        }
                        else
                        {
                            var jsonString = surveyDataObj.ToString();
                            if (!string.IsNullOrEmpty(jsonString))
                            {
                                data.SurveyData = JsonSerializer.Deserialize<Dictionary<string, object>>(jsonString) ?? new();
                            }
                        }
                    }
                    catch { }
                }
            }
            
            // Try to extract new patient data (the one being submitted)
            if (changeSnapshot.ContainsKey("newPatient"))
            {
                data.NewPatient = ParsePatientContext(changeSnapshot["newPatient"]);
            }
            else if (entityData.ContainsKey("newPatient"))
            {
                data.NewPatient = ParsePatientContext(entityData["newPatient"]);
            }
            else if (entityData.ContainsKey("submittedPatient"))
            {
                data.NewPatient = ParsePatientContext(entityData["submittedPatient"]);
            }
            
            // Try to extract potential matches (MULTIPLE!)
            if (changeSnapshot.ContainsKey("potentialDuplicates"))
            {
                data.PotentialMatches = ParsePotentialMatches(changeSnapshot["potentialDuplicates"]);
            }
            else if (entityData.ContainsKey("potentialDuplicates"))
            {
                data.PotentialMatches = ParsePotentialMatches(entityData["potentialDuplicates"]);
            }
            // Fallback to single match
            else if (changeSnapshot.ContainsKey("existingPatient") || entityData.ContainsKey("existingPatient"))
            {
                var existingPatientData = changeSnapshot.ContainsKey("existingPatient") 
                    ? changeSnapshot["existingPatient"] 
                    : entityData["existingPatient"];
                    
                if (existingPatientData != null)
                {
                    var patient = ParsePatientContext(existingPatientData);
                    if (patient != null)
                    {
                        var matchScore = 0;
                        var matchReasons = new List<string>();
                        
                        if (changeSnapshot.ContainsKey("matchScore"))
                        {
                            matchScore = Convert.ToInt32(changeSnapshot["matchScore"]);
                        }
                        else if (entityData.ContainsKey("matchScore"))
                        {
                            matchScore = Convert.ToInt32(entityData["matchScore"]);
                        }
                        
                        if (changeSnapshot.ContainsKey("matchReasons"))
                        {
                            matchReasons = ParseMatchReasons(changeSnapshot["matchReasons"]);
                        }
                        else if (entityData.ContainsKey("matchReasons"))
                        {
                            matchReasons = ParseMatchReasons(entityData["matchReasons"]);
                        }
                        
                        data.PotentialMatches.Add(new PotentialMatch
                        {
                            Patient = patient,
                            MatchScore = matchScore,
                            MatchReasons = matchReasons
                        });
                    }
                }
            }
            // FALLBACK: Use the Patient from context as a potential match
            else if (Model.ReviewDetail.Patient != null)
            {
                data.PotentialMatches.Add(new PotentialMatch
                {
                    Patient = Model.ReviewDetail.Patient,
                    MatchScore = 0,
                    MatchReasons = new List<string>()
                });
            }
            
            // Try to reconstruct new patient from EntityData if not found
            if (data.NewPatient == null && entityData.Any())
            {
                data.NewPatient = new PatientContext
                {
                    GivenName = entityData.ContainsKey("GivenName") ? entityData["GivenName"]?.ToString() ?? "" : "",
                    FamilyName = entityData.ContainsKey("FamilyName") ? entityData["FamilyName"]?.ToString() ?? "" : "",
                    DateOfBirth = entityData.ContainsKey("DateOfBirth") && DateTime.TryParse(entityData["DateOfBirth"]?.ToString(), out var dob) ? dob : null,
                    MobilePhone = entityData.ContainsKey("MobilePhone") ? entityData["MobilePhone"]?.ToString() : null,
                    EmailAddress = entityData.ContainsKey("EmailAddress") ? entityData["EmailAddress"]?.ToString() : null,
                    Address = entityData.ContainsKey("StreetAddress") ? entityData["StreetAddress"]?.ToString() : null,
                    City = entityData.ContainsKey("City") ? entityData["City"]?.ToString() : null,
                    State = entityData.ContainsKey("Province") ? entityData["Province"]?.ToString() : null,
                    Postcode = entityData.ContainsKey("PostalCode") ? entityData["PostalCode"]?.ToString() : null
                };
            }
            
            // Calculate match scores if missing
            if (data.NewPatient != null)
            {
                foreach (var match in data.PotentialMatches.Where(m => m.MatchScore == 0))
                {
                    var reasons = match.MatchReasons;
                    match.MatchScore = CalculateBasicMatchScore(data.NewPatient, match.Patient, ref reasons);
                    match.MatchReasons = reasons;
                }
            }
            
            // Set overall match score to highest
            if (data.PotentialMatches.Any())
            {
                var topMatch = data.PotentialMatches.OrderByDescending(m => m.MatchScore).First();
                data.MatchScore = topMatch.MatchScore;
                if (!data.MatchReasons.Any())
                {
                    data.MatchReasons = topMatch.MatchReasons;
                }
            }
        }
        catch { }
        
        return data;
    }

    List<PotentialMatch> ParsePotentialMatches(object? matchesData)
    {
        var matches = new List<PotentialMatch>();
        
        if (matchesData == null) return matches;
        
        try
        {
            // Try to parse as JSON array
            var jsonString = matchesData.ToString();
            if (!string.IsNullOrEmpty(jsonString))
            {
                if (jsonString.StartsWith("["))
                {
                    var matchArray = JsonSerializer.Deserialize<List<Dictionary<string, JsonElement>>>(jsonString);
                    if (matchArray != null)
                    {
                        foreach (var matchObj in matchArray)
                        {
                            PatientContext? patient = null;
                            int score = 0;
                            var reasons = new List<string>();
                            
                            if (matchObj.ContainsKey("patient") || matchObj.ContainsKey("Patient"))
                            {
                                var key = matchObj.ContainsKey("patient") ? "patient" : "Patient";
                                patient = ParsePatientContext(matchObj[key]);
                            }
                            
                            if (matchObj.ContainsKey("matchScore"))
                            {
                                score = matchObj["matchScore"].GetInt32();
                            }
                            else if (matchObj.ContainsKey("MatchScore"))
                            {
                                score = matchObj["MatchScore"].GetInt32();
                            }
                            
                            if (matchObj.ContainsKey("matchReasons"))
                            {
                                reasons = ParseMatchReasons(matchObj["matchReasons"]);
                            }
                            else if (matchObj.ContainsKey("MatchReasons"))
                            {
                                reasons = ParseMatchReasons(matchObj["MatchReasons"]);
                            }
                            
                            if (patient != null)
                            {
                                matches.Add(new PotentialMatch
                                {
                                    Patient = patient,
                                    MatchScore = score,
                                    MatchReasons = reasons
                                });
                            }
                        }
                    }
                }
            }
        }
        catch { }
        
        return matches;
    }

    List<string> ParseMatchReasons(object? reasons)
    {
        if (reasons == null) return new List<string>();
        
        try
        {
            if (reasons is List<string> list)
            {
                return list;
            }
            else if (reasons is JsonElement element && element.ValueKind == JsonValueKind.Array)
            {
                return element.EnumerateArray()
                    .Select(e => e.GetString() ?? "")
                    .Where(s => !string.IsNullOrEmpty(s))
                    .ToList();
            }
            else if (reasons is string str && str.StartsWith("["))
            {
                return JsonSerializer.Deserialize<List<string>>(str) ?? new List<string>();
            }
        }
        catch { }
        
        return new List<string>();
    }

    int CalculateBasicMatchScore(PatientContext newPat, PatientContext existingPat, ref List<string> reasons)
    {
        int score = 0;
        reasons = reasons ?? new List<string>();
        
        // Name match
        if (!string.IsNullOrEmpty(newPat.GivenName) && !string.IsNullOrEmpty(existingPat.GivenName))
        {
            if (newPat.GivenName.Equals(existingPat.GivenName, StringComparison.OrdinalIgnoreCase))
            {
                score += 30;
                reasons.Add("? Same first name");
            }
        }
        
        if (!string.IsNullOrEmpty(newPat.FamilyName) && !string.IsNullOrEmpty(existingPat.FamilyName))
        {
            if (newPat.FamilyName.Equals(existingPat.FamilyName, StringComparison.OrdinalIgnoreCase))
            {
                score += 30;
                reasons.Add("? Same last name");
            }
        }
        
        // Date of birth match
        if (newPat.DateOfBirth.HasValue && existingPat.DateOfBirth.HasValue)
        {
            if (newPat.DateOfBirth.Value.Date == existingPat.DateOfBirth.Value.Date)
            {
                score += 30;
                reasons.Add("? Same date of birth");
            }
        }
        
        // Phone match
        if (!string.IsNullOrEmpty(newPat.MobilePhone) && !string.IsNullOrEmpty(existingPat.MobilePhone))
        {
            if (newPat.MobilePhone.Replace(" ", "").Replace("-", "") == existingPat.MobilePhone.Replace(" ", "").Replace("-", ""))
            {
                score += 20;
                reasons.Add("? Same phone number");
            }
        }
        
        // Address match
        if (!string.IsNullOrEmpty(newPat.Address) && !string.IsNullOrEmpty(existingPat.Address))
        {
            if (newPat.Address.Contains(existingPat.Address, StringComparison.OrdinalIgnoreCase) ||
                existingPat.Address.Contains(newPat.Address, StringComparison.OrdinalIgnoreCase))
            {
                score += 15;
                reasons.Add("? Similar address");
            }
        }
        
        return score;
    }

    PatientContext? ParsePatientContext(object? data)
    {
        if (data == null) return null;
        
        try
        {
            // If it's already a PatientContext, return it
            if (data is PatientContext pc) return pc;
            
            // Try to deserialize from JSON
            var jsonString = data.ToString();
            if (!string.IsNullOrEmpty(jsonString))
            {
                return JsonSerializer.Deserialize<PatientContext>(jsonString);
            }
        }
        catch { }
        
        return null;
    }

    string GetDifferenceClass(object? value1, object? value2)
    {
        var str1 = value1?.ToString()?.Trim().ToLower() ?? "";
        var str2 = value2?.ToString()?.Trim().ToLower() ?? "";
        
        if (string.IsNullOrEmpty(str1) && string.IsNullOrEmpty(str2))
            return ""; // Both empty
            
        if (str1 == str2)
            return "table-success"; // Same
            
        return "table-warning"; // Different
    }

    string GetMatchConfidenceClass(int matchScore)
    {
        if (matchScore >= 80) return "bg-danger"; // High match - likely same person
        if (matchScore >= 50) return "bg-warning"; // Medium match - uncertain
        return "bg-info"; // Low match - probably different
    }
}

@section Scripts {
<script>
    // Function to reprocess a failed survey
    async function reprocessSurvey(taskId) {
        try {
            const btn = event.target;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Reprocessing...';
            
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            if (!token) {
                throw new Error('Anti-forgery token not found');
            }
            
            // Get the task to retrieve survey responses
            const taskResponse = await fetch(`/api/tasks/${taskId}`, {
                headers: {
                    'RequestVerificationToken': token
                }
            });
            
            if (!taskResponse.ok) {
                throw new Error('Failed to retrieve task data');
            }
            
            const taskData = await taskResponse.json();
            const surveyResponses = JSON.parse(taskData.surveyResponseJson);
            
            // Retry the survey submission
            const response = await fetch(`/Tasks/CompleteSurvey/${taskId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(surveyResponses)
            });
            
            if (!response.ok) {
                throw new Error(`Server returned ${response.status}`);
            }
            
            const result = await response.json();
            
            if (result.success) {
                alert('Survey reprocessed successfully! The review item will be marked as resolved.');
                window.location.reload();
            } else {
                throw new Error(result.error || 'Reprocessing failed');
            }
        } catch (error) {            alert('Failed to reprocess survey: ' + error.message);
            
            const btn = event.target;
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-arrow-repeat"></i> Retry Automatic Processing';
        }
    }
</script>
}
