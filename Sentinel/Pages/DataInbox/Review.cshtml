    // NEW: Load duplicate data directly from ReviewQueue entity
    DuplicateMatchData GetDuplicateMatchDataFromReviewQueue(ReviewQueue? reviewQueue)
    {
        var data = new DuplicateMatchData();
        
        if (reviewQueue == null) return data;
        
        try
        {
            // Parse proposed entity data (the new patient being submitted)
            if (!string.IsNullOrEmpty(reviewQueue.ProposedEntityDataJson))
            {
                var proposedData = JsonSerializer.Deserialize<Dictionary<string, object>>(
                    reviewQueue.ProposedEntityDataJson
                );
                
                if (proposedData != null)
                {
                    // Build PatientContext from proposed data
                    data.NewPatient = new PatientContext
                    {
                        GivenName = proposedData.GetValueOrDefault("Patient.GivenName")?.ToString() ?? "",
                        FamilyName = proposedData.GetValueOrDefault("Patient.FamilyName")?.ToString() ?? "",
                        DateOfBirth = proposedData.ContainsKey("Patient.DateOfBirth") && 
                            DateTime.TryParse(proposedData["Patient.DateOfBirth"]?.ToString(), out var dob) ? dob : null,
                        MobilePhone = proposedData.GetValueOrDefault("Patient.MobilePhone")?.ToString(),
                        EmailAddress = proposedData.GetValueOrDefault("Patient.EmailAddress")?.ToString(),
                        Address = proposedData.GetValueOrDefault("Patient.StreetAddress")?.ToString(),
                        City = proposedData.GetValueOrDefault("Patient.City")?.ToString(),
                        State = proposedData.GetValueOrDefault("Patient.Province")?.ToString(),
                        Postcode = proposedData.GetValueOrDefault("Patient.PostalCode")?.ToString()
                    };
                }
            }
            
            // Parse potential matches
            if (!string.IsNullOrEmpty(reviewQueue.PotentialMatchesJson))
            {
                var matchesArray = JsonSerializer.Deserialize<List<Dictionary<string, JsonElement>>>(
                    reviewQueue.PotentialMatchesJson
                );
                
                if (matchesArray != null)
                {
                    foreach (var matchObj in matchesArray)
                    {
                        if (matchObj.ContainsKey("MatchedFields") && matchObj.ContainsKey("ConfidenceScore"))
                        {
                            var matchedFields = matchObj["MatchedFields"];
                            var score = matchObj["ConfidenceScore"].GetDouble();
                            var entityId = matchObj.ContainsKey("ExistingEntityId") 
                                ? matchObj["ExistingEntityId"].GetGuid() 
                                : Guid.Empty;
                            
                            // Load the actual patient from database
                            var patient = Model.GetPatientByIdAsync(entityId).Result;
                            
                            if (patient != null)
                            {
                                var reasons = new List<string>();
                                
                                // Extract match reasons from matched fields
                                if (matchedFields.ValueKind == JsonValueKind.Object)
                                {
                                    var fields = JsonSerializer.Deserialize<Dictionary<string, object>>(
                                        matchedFields.GetRawText()
                                    );
                                    
                                    if (fields != null)
                                    {
                                        foreach (var field in fields.Keys)
                                        {
                                            if (field.Contains("GivenName")) reasons.Add("? Same first name");
                                            if (field.Contains("FamilyName")) reasons.Add("? Same last name");
                                            if (field.Contains("DateOfBirth")) reasons.Add("? Same date of birth");
                                            if (field.Contains("Phone")) reasons.Add("? Same phone number");
                                        }
                                    }
                                }
                                
                                data.PotentialMatches.Add(new PotentialMatch
                                {
                                    Patient = new PatientContext
                                    {
                                        Id = patient.Id,
                                        FriendlyId = patient.FriendlyId,
                                        GivenName = patient.GivenName,
                                        FamilyName = patient.FamilyName,
                                        DateOfBirth = patient.DateOfBirth,
                                        MobilePhone = patient.MobilePhone,
                                        EmailAddress = patient.EmailAddress,
                                        Address = patient.AddressLine,
                                        City = patient.City,
                                        State = patient.State,
                                        Postcode = patient.PostalCode
                                    },
                                    MatchScore = (int)(score * 100),
                                    MatchReasons = reasons
                                });
                            }
                        }
                    }
                }
            }
            
            // Set overall match score
            if (data.PotentialMatches.Any())
            {
                var topMatch = data.PotentialMatches.OrderByDescending(m => m.MatchScore).First();
                data.MatchScore = topMatch.MatchScore;
                data.MatchReasons = topMatch.MatchReasons;
            }
            
            // Calculate match scores if needed
            if (data.NewPatient != null)
            {
                foreach (var match in data.PotentialMatches.Where(m => m.MatchScore == 0))
                {
                    var reasons = match.MatchReasons;
                    match.MatchScore = CalculateBasicMatchScore(data.NewPatient, match.Patient, ref reasons);
                    match.MatchReasons = reasons;
                }
            }
        }
        catch (Exception ex)
        {
            // Note: Cannot log from Razor @functions block
            // Error details: ex.Message
        }
        
        return data;
    }

