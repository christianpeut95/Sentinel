@page
@model Sentinel.Pages.Cases.SearchModel
@using Sentinel.Models

@{
    ViewData["Title"] = "Search Cases";
    ViewData["Subtitle"] = "Advanced search across all cases";
}
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}

<!-- Page Header -->
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-6);">
    <div>
        <h1 style="font-family: var(--f-sans); font-weight: 600; font-size: 28px; letter-spacing: -0.02em; color: var(--forest); margin: 0; display: flex; align-items: center; gap: var(--spacing-2);">
            <i class="bi bi-search" style="color: var(--signal-dk);"></i>
            Advanced Case Search
        </h1>
    </div>
    <a asp-page="./Index" class="btn-sentinel-secondary">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</div>

<!-- Search Form -->
<div class="sentinel-card" style="margin-bottom: var(--spacing-5);">
    <div class="sentinel-card-header">
        <h3 class="sentinel-card-title">
            <i class="bi bi-funnel"></i>
            Search Criteria
        </h3>
    </div>
    <div class="sentinel-card-body">
    <form method="get">
        <div class="row g-3">
            <div class="col-md-3">
                <label asp-for="CaseId" class="sentinel-label">Case ID</label>
                <input asp-for="CaseId" class="sentinel-input" placeholder="C-2024-00001" />
            </div>
            <div class="col-md-3">
                <label asp-for="PatientName" class="sentinel-label">Patient Name</label>
                <input asp-for="PatientName" class="sentinel-input" placeholder="First Last" />
            </div>
            <div class="col-md-3">
                <label asp-for="DiseaseId" class="sentinel-label">Disease</label>
                <select asp-for="DiseaseId" class="sentinel-input disease-select" asp-items="Model.Diseases">
                    <option value="">-- All --</option>
                </select>
            </div>
            <div class="col-md-3">
                <label asp-for="ConfirmationStatusId" class="sentinel-label">Status</label>
                <select asp-for="ConfirmationStatusId" class="sentinel-input" asp-items="Model.ConfirmationStatuses">
                    <option value="">-- All --</option>
                </select>
            </div>
        </div>

        <div class="row g-3" style="margin-top: var(--spacing-3);">
            <div class="col-md-3">
                <label asp-for="OnsetDateFrom" class="sentinel-label">Onset From</label>
                <input asp-for="OnsetDateFrom" class="sentinel-input" type="date" />
            </div>
            <div class="col-md-3">
                <label asp-for="OnsetDateTo" class="sentinel-label">Onset To</label>
                <input asp-for="OnsetDateTo" class="sentinel-input" type="date" />
            </div>
            <div class="col-md-3">
                <label asp-for="NotificationDateFrom" class="sentinel-label">Notified From</label>
                <input asp-for="NotificationDateFrom" class="sentinel-input" type="date" />
            </div>
            <div class="col-md-3">
                <label asp-for="NotificationDateTo" class="sentinel-label">Notified To</label>
                <input asp-for="NotificationDateTo" class="sentinel-input" type="date" />
            </div>
        </div>

        <!-- Collapsible Additional Filters -->
        <div style="margin-top: var(--spacing-4);">
            <button class="btn-sentinel-secondary" style="padding: 8px 14px; font-size: 13px;" type="button" data-bs-toggle="collapse" data-bs-target="#moreFilters">
                <i class="bi bi-plus-circle"></i> More Filters
            </button>
        </div>

        <div class="collapse" style="margin-top: var(--spacing-4);" id="moreFilters">
            <div style="background: var(--bone); border: 1px solid var(--hairline); border-radius: var(--radius-md); padding: var(--spacing-4);">
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="DiseaseCategoryId" class="sentinel-label">Category</label>
                    <select asp-for="DiseaseCategoryId" class="sentinel-input" asp-items="Model.DiseaseCategories">
                        <option value="">-- All --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="HasSymptoms" class="sentinel-label">Has Symptoms</label>
                    <select asp-for="HasSymptoms" class="sentinel-input">
                        <option value="">-- All --</option>
                        <option value="true">Yes</option>
                        <option value="false">No</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="HasLabResults" class="sentinel-label">Has Lab Results</label>
                    <select asp-for="HasLabResults" class="sentinel-input">
                        <option value="">-- All --</option>
                        <option value="true">Yes</option>
                        <option value="false">No</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="City" class="sentinel-label">Suburb</label>
                    <input asp-for="City" class="sentinel-input" />
                </div>
            </div>
            <div class="row g-3" style="margin-top: var(--spacing-2);">
                <div class="col-md-3">
                    <label asp-for="PostalCode" class="sentinel-label">Postcode</label>
                    <input asp-for="PostalCode" class="sentinel-input" />
                </div>
                <div class="col-md-3">
                    <label asp-for="State" class="sentinel-label">State</label>
                    <input asp-for="State" class="sentinel-input" />
                </div>
            </div>
            </div>
        </div>

        <!-- Custom Fields Section -->
        @if (Model.SearchableCustomFields.Any())
        {
            <div style="margin-top: var(--spacing-4);">
                <button class="btn-sentinel-secondary" style="padding: 8px 14px; font-size: 13px;" type="button" data-bs-toggle="collapse" data-bs-target="#customFieldFilters">
                    <i class="bi bi-ui-checks"></i> Custom Fields (@Model.SearchableCustomFields.Count)
                </button>
            </div>

            <div class="collapse" style="margin-top: var(--spacing-4);" id="customFieldFilters">
                <div style="background: var(--bone); border: 1px solid var(--hairline); border-radius: var(--radius-md); padding: var(--spacing-4);">
                @foreach (var category in Model.SearchableCustomFields.GroupBy(f => f.Category))
                {
                    <h6 style="font-size: 12px; color: var(--graphite); margin-bottom: var(--spacing-2); margin-top: var(--spacing-3); text-transform: uppercase; letter-spacing: 0.5px;">@category.Key</h6>
                    <div class="row g-3">
                        @foreach (var field in category.OrderBy(f => f.DisplayOrder))
                        {
                            var fieldName = $"customfield_{field.Id}";
                            var fieldValue = Model.CustomFieldSearchValues.ContainsKey(field.Id) 
                                ? Model.CustomFieldSearchValues[field.Id] : "";

                            <div class="col-md-3">
                                <label class="sentinel-label">@field.Label</label>

                                @switch (field.FieldType)
                                {
                                    case CustomFieldType.Text:
                                    case CustomFieldType.Email:
                                    case CustomFieldType.Phone:
                                    case CustomFieldType.TextArea:
                                        <input type="text" class="sentinel-input" 
                                               name="@fieldName" value="@fieldValue" />
                                        break;

                                    case CustomFieldType.Number:
                                        <input type="number" class="sentinel-input" 
                                               name="@fieldName" value="@fieldValue" step="any" />
                                        break;

                                    case CustomFieldType.Date:
                                        <input type="date" class="sentinel-input" 
                                               name="@fieldName" value="@fieldValue" />
                                        break;

                                    case CustomFieldType.Checkbox:
                                        <select class="sentinel-input" name="@fieldName">
                                            <option value="">-- All --</option>
                                            <option value="true" selected="@(fieldValue == "true")">Yes</option>
                                            <option value="false" selected="@(fieldValue == "false")">No</option>
                                        </select>
                                        break;

                                    case CustomFieldType.Dropdown:
                                        if (field.LookupTable != null && field.LookupTable.Values != null && field.LookupTable.Values.Any())
                                        {
                                            <select class="sentinel-input" name="@fieldName">
                                                <option value="">-- All --</option>
                                                @foreach (var value in field.LookupTable.Values.OrderBy(v => v.DisplayOrder))
                                                {
                                                    <option value="@value.Id" selected="@(fieldValue == value.Id.ToString())">
                                                        @value.DisplayText
                                                    </option>
                                                }
                                            </select>
                                        }
                                        break;
                                }
                            </div>
                        }
                    </div>
                }
                </div>
            </div>
        }

        <!-- Action Buttons -->
        <div class="d-flex gap-2" style="margin-top: var(--spacing-4);">
            <button type="submit" class="btn-sentinel-primary">
                <i class="bi bi-search"></i> Search
            </button>
            <button type="submit" asp-page-handler="Clear" class="btn-sentinel-secondary">
                <i class="bi bi-x-circle"></i> Clear
            </button>
        </div>
    </form>
    </div>
</div>

<!-- Results Section -->
@if (Model.HasSearched)
{
    <div class="sentinel-card">
        <div class="sentinel-card-header">
            <h3 class="sentinel-card-title">
                <i class="bi bi-list-check"></i>
                Search Results
                <span class="chip-info" style="margin-left: var(--spacing-2);">@Model.TotalResults result(s)</span>
            </h3>
        </div>
        <div class="sentinel-card-body" style="padding: 0;">
            @if (Model.TotalResults == 0)
            {
                <div style="background: #E6F3FF; border: 1px solid #99CCFF; border-radius: var(--radius-md); padding: var(--spacing-4); margin: var(--spacing-4); color: #004080;">
                    <i class="bi bi-info-circle" style="margin-right: var(--spacing-2);"></i>
                    No cases found matching your search criteria.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="patient-table" style="margin-bottom: 0;">
                        <thead>
                            <tr>
                                <th>Case ID</th>
                                <th>Patient</th>
                                <th>Disease</th>
                                <th>Onset</th>
                                <th>Notified</th>
                                <th>Status</th>
                                <th class="text-center">Symp</th>
                                <th class="text-center">Labs</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var caseItem in Model.SearchResults)
                            {
                                <tr>
                                    <td>
                                        <strong><a asp-page="./Details" asp-route-id="@caseItem.Id" style="color: var(--signal-dk); text-decoration: none;">@caseItem.FriendlyId</a></strong>
                                    </td>
                                    <td>
                                        @if (caseItem.Patient != null)
                                        {
                                            <a asp-page="/Patients/Details" asp-route-id="@caseItem.PatientId" style="color: var(--signal-dk); text-decoration: none;">
                                                @caseItem.Patient.GivenName @caseItem.Patient.FamilyName
                                            </a>
                                        }
                                        else
                                        {
                                            <span style="color: var(--graphite); font-style: italic;">Unknown</span>
                                        }
                                    </td>
                                    <td>
                                        @if (caseItem.Disease != null)
                                        {
                                            <span class="chip-neutral">@caseItem.Disease.Name</span>
                                        }
                                        else
                                        {
                                            <span style="color: var(--graphite);">-</span>
                                        }
                                    </td>
                                    <td>@(caseItem.DateOfOnset?.ToString("dd MMM") ?? "-")</td>
                                    <td>@(caseItem.DateOfNotification?.ToString("dd MMM") ?? "-")</td>
                                    <td>
                                        @if (caseItem.ConfirmationStatus != null)
                                        {
                                            <span class="chip-info">@caseItem.ConfirmationStatus.Name</span>
                                        }
                                        else
                                        {
                                            <span style="color: var(--graphite);">-</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (caseItem.CaseSymptoms.Any())
                                        {
                                            <span class="chip-success">@caseItem.CaseSymptoms.Count</span>
                                        }
                                        else
                                        {
                                            <span style="color: var(--graphite);">-</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (caseItem.LabResults.Any())
                                        {
                                            <span class="chip-info">@caseItem.LabResults.Count</span>
                                        }
                                        else
                                        {
                                            <span style="color: var(--graphite);">-</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-page="./Details" asp-route-id="@caseItem.Id" class="btn-sentinel-secondary" style="padding: 4px 10px; font-size: 12px;" title="View">
                                                <i class="bi bi-eye"></i> View
                                            </a>
                                            <a asp-page="./Edit" asp-route-id="@caseItem.Id" class="btn-sentinel-secondary" style="padding: 4px 10px; font-size: 12px;" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.TotalResults >= 500)
                {
                    <div style="background: #FFF4E6; border: 1px solid #FFD699; border-radius: var(--radius-md); padding: var(--spacing-4); margin: var(--spacing-4); margin-bottom: 0; color: #804000;">
                        <i class="bi bi-exclamation-triangle" style="margin-right: var(--spacing-2);"></i>
                        <strong>Note:</strong> Results limited to 500 cases. Please refine your search.
                    </div>
                }
            }
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize Select2 on disease dropdown
            $('.disease-select').select2({
                theme: 'bootstrap-5',
                placeholder: '-- Select Disease --',
                allowClear: true,
                width: '100%'
            });

            // Initialize tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });
    </script>
}
