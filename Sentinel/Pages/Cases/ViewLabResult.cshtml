@page
@model Sentinel.Pages.Cases.ViewLabResultModel
@{
    Layout = null;
    var labResult = Model.LabResult;
    var caseId = Request.Query["caseId"].ToString();
    var saved = Request.Query["saved"].ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lab Result - @labResult.FriendlyId</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sentinel-design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body style="padding: 24px; background: var(--bone);">

<div style="max-width: 940px; margin: 0 auto 32px; display: flex; justify-content: space-between; align-items: flex-start; padding-bottom: 20px; border-bottom: 1px solid var(--hairline);">
    <div>
        <div class="text-label" style="margin-bottom: 8px;">
            Lab Result Details
        </div>
        <h1 class="text-h2" style="margin: 0;">
            <i class="bi bi-clipboard-pulse" style="color: var(--signal-dk);"></i>
            @labResult.FriendlyId
        </h1>
        @if (labResult.IsAmended)
        {
            <span class="chip" style="background: #FBEDD1; color: #6A4410; font-size: 11px; padding: 4px 10px; border: 1px solid #EBD196; margin-top: 8px; display: inline-block;">
                <i class="bi bi-pencil-square"></i> AMENDED
            </span>
        }
    </div>
    <div>
        <button type="button" class="sn-btn sn-btn--ghost sn-btn--sm" onclick="window.close()">
            <i class="bi bi-x-lg"></i> Close
        </button>
        <button type="button" class="sn-btn sn-btn--ghost sn-btn--sm" onclick="window.print()" style="margin-left: 8px;">
            <i class="bi bi-printer"></i> Print
        </button>
    </div>
</div>

<div style="max-width: 940px; margin: 0 auto;">
    @if (saved == "true")
    {
        <div style="background: var(--signal-lt); border: 1px solid #9BE8C6; border-radius: 6px; padding: 16px 20px; margin-bottom: 20px; color: #0A3F2C;">
            <i class="bi bi-check-circle-fill"></i> <strong>Changes saved successfully!</strong>
        </div>
    }

    <!-- Organizations -->
    <div class="sentinel-card" style="margin-bottom: 20px;">
        <div class="sentinel-card-header">
            <h3 class="text-h3" style="margin: 0;">
                <i class="bi bi-building" style="color: var(--signal-dk);"></i> Organizations
            </h3>
        </div>
        <div style="padding: 20px;">
            <div class="row">
                <div class="col-md-6">
                    <div class="text-label" style="margin-bottom: 6px;">Laboratory</div>
                    <div style="font-size: 14px;">@(labResult.Laboratory?.Name ?? "-")</div>
                </div>
                <div class="col-md-6">
                    <div class="text-label" style="margin-bottom: 6px;">Ordering Provider</div>
                    <div style="font-size: 14px;">@(labResult.OrderingProvider?.Name ?? "-")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Specimen & Test -->
    <div class="sentinel-card" style="margin-bottom: 20px;">
        <div class="sentinel-card-header">
            <h3 class="text-h3" style="margin: 0;">
                <i class="bi bi-clipboard2-pulse" style="color: var(--signal-dk);"></i> Specimen & Test
            </h3>
        </div>
        <div style="padding: 20px;">
            <div class="row">
                <div class="col-md-4">
                    <div class="text-label" style="margin-bottom: 6px;">Collection Date</div>
                    <div style="font-size: 14px;">@(labResult.SpecimenCollectionDate?.ToString("dd MMM yyyy") ?? "-")</div>
                </div>
                <div class="col-md-4">
                    <div class="text-label" style="margin-bottom: 6px;">Specimen Type</div>
                    <div style="font-size: 14px;">@(labResult.SpecimenType?.Name ?? "-")</div>
                </div>
                <div class="col-md-4">
            <div class="field-label">Accession #</div>
            <div class="field-value @(string.IsNullOrEmpty(labResult.AccessionNumber) ? "empty" : "")">
                @(labResult.AccessionNumber ?? "-")
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-6">
            <div class="field-label">Tested For</div>
            <div class="field-value @(labResult.TestedDisease == null ? "empty" : "")">
                @(labResult.TestedDisease?.Name ?? "-")
            </div>
        </div>
        <div class="col-md-6">
                            <div class="text-label" style="margin-bottom: 6px;">Result Date</div>
                            <div style="font-size: 14px;">@(labResult.ResultDate?.ToString("dd MMM yyyy") ?? "-")</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Test Markers/Results -->
            <div class="sentinel-card" style="margin-bottom: 20px;">
                <div class="sentinel-card-header">
                    <h3 class="text-h3" style="margin: 0;">
                        <i class="bi bi-virus" style="color: var(--signal-dk);"></i> Test Results (@labResult.Markers.Count Markers)
                    </h3>
                </div>
                <div style="padding: 20px;">
                    @if (labResult.Markers.Any())
                    {
                        <div style="display: flex; flex-direction: column; gap: 12px;">
                            @foreach (var marker in labResult.Markers.OrderBy(m => m.DisplayOrder))
                            {
                                var resultStyle = marker.QualitativeResultText?.ToLower() switch
                                {
                                    "detected" or "positive" or "reactive" => "background: #FBE2D8; border-color: #F2BBA4; color: #7A2A15;",
                                    "not detected" or "negative" or "non-reactive" => "background: var(--signal-lt); border-color: #9BE8C6; color: #0A3F2C;",
                                    "indeterminate" or "equivocal" => "background: #FBEDD1; border-color: #EBD196; color: #6A4410;",
                                    _ => "background: var(--chalk); border-color: var(--hairline); color: var(--graphite);"
                                };

                                <div style="@resultStyle border: 1px solid; border-radius: 6px; padding: 12px; display: grid; grid-template-columns: 2fr 1fr 2fr; gap: 16px; align-items: center;">
                                    <!-- Left: Pathogen & Test Method -->
                                    <div>
                                        <div style="font-weight: 600; font-size: 14px; margin-bottom: 4px;">
                                            @(marker.Pathogen?.Name ?? "Unknown Pathogen")
                                        </div>
                                        @if (marker.TestMethod != null)
                                        {
                                            <div style="font-size: 12px; opacity: 0.8;">
                                                @marker.TestMethod.Name
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(marker.LOINCCode))
                                        {
                                            <div class="text-mono" style="font-size: 11px; opacity: 0.7; margin-top: 4px;">@marker.LOINCCode</div>
                                        }
                                    </div>

                                    <!-- Middle: Result Status -->
                                    <div style="text-align: center;">
                                        @if (!string.IsNullOrEmpty(marker.QualitativeResultText))
                                        {
                                            <div style="font-weight: 700; font-size: 16px; letter-spacing: 0.5px;">
                                                @marker.QualitativeResultText.ToUpper()
                                            </div>
                                        }
                                    </div>

                                    <!-- Right: Quantitative Values -->
                                    <div style="text-align: right;">
                                        @if (marker.QuantitativeValue.HasValue)
                                        {
                                            <div style="font-family: var(--f-mono); font-size: 14px;">
                                                <strong style="font-size: 16px;">@marker.QuantitativeValue.Value</strong> 
                                                <span style="opacity: 0.8;">@marker.QuantitativeUnit</span>
                                            </div>
                                            @if (marker.ReferenceRangeLow.HasValue || marker.ReferenceRangeHigh.HasValue)
                                            {
                                                <div style="font-size: 11px; opacity: 0.7; margin-top: 2px;">
                                                    Ref: @(marker.ReferenceRangeLow?.ToString() ?? "—")–@(marker.ReferenceRangeHigh?.ToString() ?? "—")
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(marker.InterpretationFlag))
                                            {
                                                <div style="font-weight: 600; font-size: 12px; margin-top: 4px;">
                                                    [@marker.InterpretationFlag]
                                                </div>
                                            }
                                        }
                                        else if (string.IsNullOrEmpty(marker.QualitativeResultText))
                                        {
                                            <div style="opacity: 0.6; font-style: italic;">No result</div>
                                        }
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(marker.Notes))
                                {
                                    <div style="margin-top: -8px; margin-bottom: 4px; padding: 8px 12px; background: rgba(255,255,255,0.3); border-radius: 0 0 6px 6px; font-size: 12px; font-style: italic; opacity: 0.9;">
                                        <i class="bi bi-chat-left-text" style="margin-right: 4px;"></i>@marker.Notes
                                    </div>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <div style="text-align: center; padding: 40px; color: var(--graphite);">
                            <i class="bi bi-inbox" style="font-size: 48px; opacity: 0.3; display: block; margin-bottom: 12px;"></i>
                            <p>No test markers recorded</p>
                                        </div>
                                    }
                                </div>
                            </div>

                        <!-- Additional Information -->
                        <div class="sentinel-card" style="margin-bottom: 20px;">
                            <div class="sentinel-card-header">
                                <h3 class="text-h3" style="margin: 0;">
                                    <i class="bi bi-journal-text" style="color: var(--signal-dk);"></i> Additional Information
                                </h3>
                            </div>
                            <div style="padding: 20px;">
                                <div class="row">
        <div class="col-md-12">
            <div class="field-label">Units</div>
            <div class="field-value @(labResult.ResultUnits == null ? "empty" : "")">
                @(labResult.ResultUnits?.Name ?? "-")
            </div>
        </div>
    </div>

    <!-- Additional Info -->
    @if (!string.IsNullOrEmpty(labResult.Notes) || !string.IsNullOrEmpty(labResult.LabInterpretation))
    {
        <div class="section-title">
            <i class="bi bi-chat-dots"></i>Notes
        </div>
        @if (!string.IsNullOrEmpty(labResult.Notes))
        {
            <div class="field-label">Internal Notes</div>
            <div class="alert alert-light">@labResult.Notes</div>
        }
        @if (!string.IsNullOrEmpty(labResult.LabInterpretation))
        {
            <div class="field-label">Lab Interpretation</div>
            <div class="alert alert-light">@labResult.LabInterpretation</div>
        }
    }

    <!-- Attachment -->
    @if (!string.IsNullOrEmpty(labResult.AttachmentPath))
    {
        <div class="section-title">
            <i class="bi bi-paperclip"></i>Attachment
        </div>
        <a href="@labResult.AttachmentPath" target="_blank" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-download me-1"></i>@(labResult.AttachmentFileName ?? "Download")
        </a>
    }


        <!-- Metadata Section -->
        <div class="section-title">
            <i class="bi bi-info-circle"></i>Record Info
        </div>
        <div class="row">
            <div class="col-md-6">
                <div class="field-label">Created</div>
                <div class="field-value">@labResult.CreatedAt.ToString("dd MMM yy HH:mm")</div>
                            <div class="col-md-6">
                                <div class="text-label" style="margin-bottom: 6px;">Lab Interpretation</div>
                                <div style="font-size: 14px;">@(labResult.LabInterpretation ?? "-")</div>
                            </div>
                            <div class="col-md-6">
                                <div class="text-label" style="margin-bottom: 6px;">Notes</div>
                                <div style="font-size: 14px;">@(labResult.Notes ?? "-")</div>
                            </div>
                        </div>
                        @if (labResult.ModifiedAt.HasValue)
                        {
                            <div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--hairline);">
                                <div class="text-label" style="margin-bottom: 6px;">Last Modified</div>
                                <div style="font-size: 14px;">@labResult.ModifiedAt.Value.ToString("dd MMM yyyy HH:mm")</div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Attachment Section (if exists) -->
                @if (!string.IsNullOrEmpty(labResult.AttachmentPath))
                {
                    <div class="sentinel-card" style="margin-bottom: 20px;">
                        <div class="sentinel-card-header">
                            <h3 class="text-h3" style="margin: 0;">
                                <i class="bi bi-paperclip" style="color: var(--signal-dk);"></i> Attachment
                            </h3>
                        </div>
                        <div style="padding: 20px;">
                            <div style="display: flex; align-items: center; gap: 12px;">
                                <i class="bi bi-file-earmark-pdf" style="font-size: 32px; color: var(--signal-dk);"></i>
                                <div style="flex: 1;">
                                    <div style="font-weight: 600; margin-bottom: 4px;">@labResult.AttachmentFileName</div>
                                    <div class="text-meta">@(labResult.AttachmentSize.HasValue ? $"{labResult.AttachmentSize.Value / 1024:N0} KB" : "Unknown size")</div>
                                </div>
                                <a href="@labResult.AttachmentPath" target="_blank" class="sn-btn sn-btn--ghost sn-btn--sm">
                                    <i class="bi bi-download"></i> Download
                                </a>
                            </div>
                        </div>
                    </div>
                }

            </div>

            <script src="~/lib/jquery/dist/jquery.min.js"></script>
            <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
            </body>
            </html>
