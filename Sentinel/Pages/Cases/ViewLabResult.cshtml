@page
@model Sentinel.Pages.Cases.ViewLabResultModel
@{
    Layout = null;
    var labResult = Model.LabResult;
    var caseId = Request.Query["caseId"].ToString();
    var saved = Request.Query["saved"].ToString();
}
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lab Result - @labResult.FriendlyId</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
    <style>
        body {
            background: #f8f9fa;
            padding: 0.75rem;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 0.875rem;
        }
        .lab-result-container {
            background: white;
            border-radius: 8px;
            padding: 1rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }
        .header {
            border-bottom: 2px solid #e9ecef;
            padding-bottom: 0.6rem;
            margin-bottom: 0.75rem;
        }
        .header h1 {
            font-size: 1.25rem;
            font-weight: 600;
            color: #2d3748;
            margin-bottom: 0.25rem;
        }
        .header .subtitle {
            color: #718096;
            font-size: 0.8rem;
        }
        .section-title {
            font-size: 0.9rem;
            font-weight: 600;
            color: #2d3748;
            margin-bottom: 0.4rem;
            margin-top: 0.75rem;
            padding-bottom: 0.25rem;
            border-bottom: 1px solid #e9ecef;
        }
        .section-title i {
            color: #4299e1;
            margin-right: 0.35rem;
            font-size: 0.85rem;
        }
        .field-label {
            font-size: 0.65rem;
            font-weight: 600;
            color: #718096;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            margin-bottom: 0.1rem;
        }
        .field-value {
            font-size: 0.85rem;
            color: #2d3748;
            margin-bottom: 0.5rem;
            line-height: 1.3;
        }
        .field-value.empty {
            color: #a0aec0;
            font-style: italic;
        }
        .field-value strong {
            color: #1a202c;
            font-weight: 600;
        }
        .badge {
            font-size: 0.7rem;
            padding: 0.2rem 0.5rem;
        }
        .alert {
            border-radius: 6px;
            border: none;
            padding: 0.5rem;
            margin-bottom: 0.4rem;
            font-size: 0.8rem;
        }
        .btn-toolbar {
            margin-top: 0.75rem;
            padding-top: 0.75rem;
            border-top: 1px solid #e9ecef;
            display: flex;
            gap: 0.4rem;
            justify-content: space-between;
        }
        .btn-toolbar .left-buttons,
        .btn-toolbar .right-buttons {
            display: flex;
            gap: 0.4rem;
        }
        .btn {
            border-radius: 6px;
            font-weight: 500;
            padding: 0.35rem 0.75rem;
            font-size: 0.8rem;
        }
        .btn i {
            font-size: 0.85rem;
        }
        .row {
            margin-bottom: 0.3rem;
        }
        .col-md-6, .col-md-4, .col-md-12 {
            padding-left: 0.4rem;
            padding-right: 0.4rem;
        }
        @@media print {
            body {
                background: white;
                padding: 0;
            }
            .btn-toolbar {
                display: none;
            }
        }
    </style>
</head>
<body>
<div class="lab-result-container">
    @if (saved == "true")
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" style="font-size: 0.85rem; padding: 0.5rem;">
            <i class="bi bi-check-circle-fill me-2"></i><strong>Changes saved successfully!</strong>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="font-size: 0.7rem; padding: 0.3rem;"></button>
        </div>
    }
    <div class="header">
        <h1><i class="bi bi-clipboard-pulse me-2"></i>Lab Result</h1>
        <div class="subtitle">
            <strong>ID:</strong> <span class="badge bg-secondary">@labResult.FriendlyId</span>
            @if (labResult.IsAmended)
            {
                <span class="badge bg-info ms-1">Amended</span>
            }
        </div>
    </div>

    <!-- Organizations -->
    <div class="section-title">
        <i class="bi bi-building"></i>Organizations
    </div>
    <div class="row">
        <div class="col-md-6">
            <div class="field-label">Laboratory</div>
            <div class="field-value @(labResult.Laboratory == null ? "empty" : "")">
                @(labResult.Laboratory?.Name ?? "-")
            </div>
        </div>
        <div class="col-md-6">
            <div class="field-label">Ordering Provider</div>
            <div class="field-value @(labResult.OrderingProvider == null ? "empty" : "")">
                @(labResult.OrderingProvider?.Name ?? "-")
            </div>
        </div>
    </div>

    <!-- Specimen & Test -->
    <div class="section-title">
        <i class="bi bi-clipboard2-pulse"></i>Specimen & Test
    </div>
    <div class="row">
        <div class="col-md-4">
            <div class="field-label">Collection Date</div>
            <div class="field-value @(!labResult.SpecimenCollectionDate.HasValue ? "empty" : "")">
                @(labResult.SpecimenCollectionDate?.ToString("dd MMM yy") ?? "-")
            </div>
        </div>
        <div class="col-md-4">
            <div class="field-label">Specimen Type</div>
            <div class="field-value @(labResult.SpecimenType == null ? "empty" : "")">
                @(labResult.SpecimenType?.Name ?? "-")
            </div>
        </div>
        <div class="col-md-4">
            <div class="field-label">Accession #</div>
            <div class="field-value @(string.IsNullOrEmpty(labResult.AccessionNumber) ? "empty" : "")">
                @(labResult.AccessionNumber ?? "-")
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-4">
            <div class="field-label">Test Type</div>
            <div class="field-value @(labResult.TestType == null ? "empty" : "")">
                @(labResult.TestType?.Name ?? "-")
            </div>
        </div>
        <div class="col-md-4">
            <div class="field-label">Test Result</div>
            <div class="field-value @(labResult.TestResult == null ? "empty" : "")">
                <strong>@(labResult.TestResult?.Name ?? "-")</strong>
            </div>
        </div>
        <div class="col-md-4">
            <div class="field-label">Tested For</div>
            <div class="field-value @(labResult.TestedDisease == null ? "empty" : "")">
                @(labResult.TestedDisease?.Name ?? "-")
            </div>
        </div>
    </div>

    <!-- Results -->
    <div class="section-title">
        <i class="bi bi-graph-up"></i>Results
    </div>
    <div class="row">
        <div class="col-md-4">
            <div class="field-label">Result Date</div>
            <div class="field-value @(!labResult.ResultDate.HasValue ? "empty" : "")">
                @(labResult.ResultDate?.ToString("dd MMM yy") ?? "-")
            </div>
        </div>
        <div class="col-md-4">
            <div class="field-label">Quantitative</div>
            <div class="field-value @(!labResult.QuantitativeResult.HasValue ? "empty" : "")">
                @(labResult.QuantitativeResult?.ToString() ?? "-")
            </div>
        </div>
        <div class="col-md-4">
            <div class="field-label">Units</div>
            <div class="field-value @(labResult.ResultUnits == null ? "empty" : "")">
                @(labResult.ResultUnits?.Name ?? "-")
            </div>
        </div>
    </div>

    <!-- Additional Info -->
    @if (!string.IsNullOrEmpty(labResult.Notes) || !string.IsNullOrEmpty(labResult.LabInterpretation))
    {
        <div class="section-title">
            <i class="bi bi-chat-dots"></i>Notes
        </div>
        @if (!string.IsNullOrEmpty(labResult.Notes))
        {
            <div class="field-label">Internal Notes</div>
            <div class="alert alert-light">@labResult.Notes</div>
        }
        @if (!string.IsNullOrEmpty(labResult.LabInterpretation))
        {
            <div class="field-label">Lab Interpretation</div>
            <div class="alert alert-light">@labResult.LabInterpretation</div>
        }
    }

    <!-- Attachment -->
    @if (!string.IsNullOrEmpty(labResult.AttachmentPath))
    {
        <div class="section-title">
            <i class="bi bi-paperclip"></i>Attachment
        </div>
        <a href="@labResult.AttachmentPath" target="_blank" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-download me-1"></i>@(labResult.AttachmentFileName ?? "Download")
        </a>
    }


        <!-- Metadata Section -->
        <div class="section-title">
            <i class="bi bi-info-circle"></i>Record Info
        </div>
        <div class="row">
            <div class="col-md-6">
                <div class="field-label">Created</div>
                <div class="field-value">@labResult.CreatedAt.ToString("dd MMM yy HH:mm")</div>
            </div>
            @if (labResult.ModifiedAt.HasValue)
            {
                <div class="col-md-6">
                    <div class="field-label">Modified</div>
                    <div class="field-value">@labResult.ModifiedAt.Value.ToString("dd MMM yy HH:mm")</div>
                </div>
            }
        </div>

        <!-- Action Buttons -->
        <div class="btn-toolbar">
            <div class="left-buttons">
                @if (!string.IsNullOrEmpty(caseId))
                {
                    <a href="/Cases/EditLabResult?labResultId=@labResult.Id&caseId=@caseId" class="btn btn-primary">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                }
                <button type="button" class="btn btn-secondary" onclick="window.print()">
                    <i class="bi bi-printer me-1"></i>Print
                </button>
            </div>
            <div class="right-buttons">
                <button type="button" class="btn btn-outline-secondary" onclick="window.close()">
                    <i class="bi bi-x-circle me-1"></i>Close
                </button>
            </div>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
