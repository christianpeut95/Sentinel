@page
@model Sentinel.Pages.Cases.EditModel
@using Sentinel.Models
@using Sentinel.Models.Lookups

@{
    ViewData["Title"] = "Edit Case";
    Layout = "~/Pages/Shared/_LayoutSentinel.cshtml";
}


<nav aria-label="breadcrumb" style="margin-bottom: 1rem;">
    <ol class="breadcrumb" style="background: transparent; padding: 0; font-size: 0.875rem; font-family: var(--f-sans); color: var(--graphite);">
        <li class="breadcrumb-item"><a asp-page="/Index" style="color: var(--graphite); text-decoration: none;">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index" style="color: var(--graphite); text-decoration: none;">Cases</a></li>
        <li class="breadcrumb-item"><a asp-page="./Details" asp-route-id="@Model.Case.Id" style="color: var(--graphite); text-decoration: none;">@Model.Case.FriendlyId</a></li>
        <li class="breadcrumb-item active" aria-current="page" style="color: var(--slate);">Edit</li>
    </ol>
</nav>

@if (TempData["ErrorMessage"] != null)
{
    <div style="background: #FBE2D8; border: 1px solid #F2BBA4; border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.875rem; margin-bottom: 1rem; color: var(--forest); font-family: var(--f-sans);" class="alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2" style="color: var(--status-outbreak);"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div style="background: var(--signal-lt); border: 1px solid #9BE8C6; border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.875rem; margin-bottom: 1rem; color: var(--forest); font-family: var(--f-sans);" class="alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2" style="color: var(--signal-dk);"></i>@TempData["SuccessMessage"]
        @if (TempData["OnsetDateUpdated"] != null && (bool)TempData["OnsetDateUpdated"])
        {
            <br/>
            <strong><i class="bi bi-calendar-check me-1"></i>Note:</strong> 
            <text>Case date of onset was automatically updated to match the earliest symptom onset date.</text>
        }
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="case-edit-container">
    <!-- Header Section -->
    <div style="background: var(--bone); border-bottom: 1px solid var(--hairline); border-radius: 12px; padding: 2rem; margin-bottom: 1.5rem;">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h1 style="font-family: var(--f-sans); font-weight: 600; font-size: 2rem; color: var(--forest); margin-bottom: 0.5rem; letter-spacing: -0.02em;">
                    <i class="bi bi-pencil-square"></i>
                    Edit Case @Model.Case.FriendlyId
                </h1>
                @if (Model.Case.Patient != null)
                {
                    <p style="color: var(--graphite); font-size: 1rem; margin-bottom: 0; font-family: var(--f-sans);">
                        <strong style="color: var(--forest);">@Model.Case.Patient.GivenName @Model.Case.Patient.FamilyName</strong>
                        @if (Model.Case.Disease != null)
                        {
                            <span class="mx-2">•</span>
                            <span>@Model.Case.Disease.Name</span>
                        }
                    </p>
                }
            </div>
            <div class="text-end">
                <a asp-page="./Details" asp-route-id="@Model.Case.Id" class="btn-sentinel-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Details
                </a>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="quick-actions">
            <a asp-page="./AuditHistory" asp-route-id="@Model.Case.Id" class="btn-sentinel-secondary">
                <i class="bi bi-clock-history"></i> Audit Log
            </a>
            @if (Model.Case.Patient != null)
            {
                <a asp-page="/Patients/Details" asp-route-id="@Model.Case.PatientId" class="btn-sentinel-secondary">
                    <i class="bi bi-person"></i> View Patient
                </a>
            }
        </div>
    </div>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>
    <input type="hidden" asp-for="Case.Id" />
    <input type="hidden" asp-for="Case.FriendlyId" />
    <input type="hidden" asp-for="Case.Type" />
    <input type="hidden" asp-for="Case.PatientId" />

    <!-- First Row: 3 Column Grid -->
    <div class="case-grid">
        <!-- Column 1: Case Information (spans 2 columns on large screens) -->
        <div class="sentinel-card" style="grid-column: span 2;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--hairline);">
                <h3 style="font-family: var(--f-sans); font-weight: 500; font-size: 1.25rem; color: var(--forest); margin: 0; display: flex; align-items: center; gap: 8px;">
                    <i class="bi bi-clipboard-data" style="color: var(--signal-dk);"></i>
                    Case Information
                </h3>
            </div>
            <div class="sentinel-card-body">
                <div class="mb-3">
                    <label asp-for="Case.DateOfOnset" class="form-label fw-bold">
                        Date of Onset
                        <i class="bi bi-info-circle text-info" 
                           data-bs-toggle="tooltip" 
                           title="This will be automatically updated to the earliest symptom onset date if it's earlier than the current value"></i>
                    </label>
                    <input asp-for="Case.DateOfOnset" class="form-control" type="date" />
                    <span asp-validation-for="Case.DateOfOnset" class="text-danger"></span>
                    <small class="form-text text-muted">
                        <i class="bi bi-lightbulb"></i> Tip: Auto-updates if you enter an earlier symptom onset date
                    </small>
                </div>

                <div class="mb-3">
                    <label asp-for="Case.DateOfNotification" class="form-label fw-bold">Date of Notification</label>
                    <input asp-for="Case.DateOfNotification" class="form-control" type="date" />
                    <span asp-validation-for="Case.DateOfNotification" class="text-danger"></span>
                </div>

                <hr class="my-4" />
                
                <h5 class="mb-3"><i class="bi bi-clipboard-pulse me-2"></i>Clinical Notification</h5>
                
                <div class="mb-3">
                    <label asp-for="Case.ClinicalNotificationDate" class="form-label fw-bold">Clinical Notification Date</label>
                    <input asp-for="Case.ClinicalNotificationDate" class="form-control" type="date" />
                    <span asp-validation-for="Case.ClinicalNotificationDate" class="text-danger"></span>
                    <small class="form-text text-muted">Date when clinical notification was received</small>
                </div>

                <div class="mb-3">
                    <label asp-for="Case.ClinicalNotifierOrganisation" class="form-label fw-bold">Clinical Notifier Organisation</label>
                    <input asp-for="Case.ClinicalNotifierOrganisation" class="form-control organization-autocomplete" id="clinicalNotifierOrgAutocomplete" placeholder="Type to search organizations..." />
                    <span asp-validation-for="Case.ClinicalNotifierOrganisation" class="text-danger"></span>
                    <small class="form-text text-muted">Organisation that provided the clinical notification</small>
                </div>

                <div class="mb-3">
                    <label asp-for="Case.ClinicalNotificationNotes" class="form-label fw-bold">Clinical Notification Notes</label>
                    <textarea asp-for="Case.ClinicalNotificationNotes" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Case.ClinicalNotificationNotes" class="text-danger"></span>
                    <small class="form-text text-muted">Additional details about the clinical notification</small>
                </div>

                <div class="mb-3">
                    <label asp-for="Case.ConfirmationStatusId" class="form-label fw-bold">Confirmation Status</label>
                    <select asp-for="Case.ConfirmationStatusId" class="form-select" asp-items="ViewBag.ConfirmationStatusId">
                        <option value="">-- Select Status --</option>
                    </select>
                    <span asp-validation-for="Case.ConfirmationStatusId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Case.DiseaseId" class="form-label fw-bold">Disease</label>
                    <select asp-for="Case.DiseaseId" class="form-select disease-select" asp-items="ViewBag.DiseaseId" id="diseaseDropdown">
                        <option value="">-- Select Disease --</option>
                    </select>
                    <span asp-validation-for="Case.DiseaseId" class="text-danger"></span>
                    <small class="form-text text-muted">Type to search for a disease</small>
                </div>

                <hr class="my-4" />
                
                <h5 class="mb-3"><i class="bi bi-hospital me-2"></i>Hospitalization</h5>
                
                <div class="mb-3">
                    <label asp-for="Case.Hospitalised" class="form-label fw-bold">Hospitalised</label>
                    <select asp-for="Case.Hospitalised" class="form-select" id="hospitalisedSelect">
                        <option value="">-- Select --</option>
                        <option value="@((int)Sentinel.Models.YesNoUnknown.Yes)">Yes</option>
                        <option value="@((int)Sentinel.Models.YesNoUnknown.No)">No</option>
                        <option value="@((int)Sentinel.Models.YesNoUnknown.Unknown)">Unknown</option>
                    </select>
                    <span asp-validation-for="Case.Hospitalised" class="text-danger"></span>
                </div>

                <div id="hospitalizationDetails" style="display: none;">
                    <div class="mb-3">
                        <label asp-for="Case.HospitalId" class="form-label fw-bold">Hospital</label>
                        <select asp-for="Case.HospitalId" class="form-select hospital-select" asp-items="ViewBag.HospitalId">
                            <option value="">-- Select Hospital --</option>
                        </select>
                        <span asp-validation-for="Case.HospitalId" class="text-danger"></span>
                        <small class="form-text text-muted">Type to search for a hospital</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Case.DateOfAdmission" class="form-label fw-bold">Date of Admission</label>
                        <input asp-for="Case.DateOfAdmission" class="form-control" type="date" id="dateOfAdmission" />
                        <span asp-validation-for="Case.DateOfAdmission" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Case.DateOfDischarge" class="form-label fw-bold">Date of Discharge</label>
                        <input asp-for="Case.DateOfDischarge" class="form-control" type="date" id="dateOfDischarge" />
                        <span asp-validation-for="Case.DateOfDischarge" class="text-danger"></span>
                        <small class="form-text text-muted">Must be after date of admission</small>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="mb-3">
                    <label asp-for="Case.DiedDueToDisease" class="form-label fw-bold">Died due to disease?</label>
                    <select asp-for="Case.DiedDueToDisease" class="form-select">
                        <option value="">-- Select --</option>
                        <option value="@((int)Sentinel.Models.YesNoUnknown.Yes)">Yes</option>
                        <option value="@((int)Sentinel.Models.YesNoUnknown.No)">No</option>
                        <option value="@((int)Sentinel.Models.YesNoUnknown.Unknown)">Unknown</option>
                    </select>
                    <span asp-validation-for="Case.DiedDueToDisease" class="text-danger"></span>
                </div>

                <!-- Exposure Status Alert -->
                @if (Model.ShouldPromptForExposure && Model.DiseaseRequirements != null)
                {
                    @if (Model.HasIncompleteExposure)
                    {
                        <div style="background: #FBEDD1; border: 1px solid #EBD196; border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1rem; font-family: var(--f-sans); color: var(--forest);" role="alert">
                            <h6 style="font-weight: 600; margin-bottom: 0.5rem;">
                                <i class="bi bi-exclamation-triangle me-2" style="color: var(--status-watch);"></i>
                                @if (Model.DiseaseRequirements.ExposureTrackingMode == ExposureTrackingMode.LocalSpecificRegion ||
                                     Model.DiseaseRequirements.ExposureTrackingMode == ExposureTrackingMode.OverseasAcquired)
                                {
                                    <text>Exposure Data Required</text>
                                }
                                else
                                {
                                    <text>Exposure Data Recommended</text>
                                }
                            </h6>
                            @if (!string.IsNullOrWhiteSpace(Model.DiseaseRequirements.ExposureGuidanceText))
                            {
                                <p class="mb-2"><strong>Guidance:</strong> @Model.DiseaseRequirements.ExposureGuidanceText</p>
                            }
                            <p class="mb-2">
                                <strong>Current Status:</strong> 
                                @if (Model.ExposureCount == 0)
                                {
                                    <span class="chip" style="background: #FBE2D8; color: #7A2A15; border-color: #F2BBA4;">No exposure data recorded</span>
                                }
                                else
                                {
                                    <span class="chip" style="background: #FBEDD1; color: #6A4410; border-color: #EBD196;">@Model.ExposureCount exposure(s) recorded - may need more detail</span>
                                }
                            </p>
                            <hr style="border-color: #EBD196; margin: 0.75rem 0;" />
                            <div class="d-flex gap-2">
                                <a asp-page="./Details" asp-route-id="@Model.Case.Id" asp-fragment="exposures" class="btn-sentinel-secondary" style="font-size: 0.875rem; padding: 0.375rem 0.75rem;">
                                    <i class="bi bi-eye me-1"></i>View Exposures
                                </a>
                                <a asp-page="/Cases/Exposures/Create" asp-route-caseId="@Model.Case.Id" class="btn-sentinel-primary" style="font-size: 0.875rem; padding: 0.375rem 0.75rem;">
                                    <i class="bi bi-plus-circle me-1"></i>Add Exposure
                                </a>
                            </div>
                        </div>
                    }
                    else if (Model.ExposureCount > 0)
                    {
                        <div style="background: var(--signal-lt); border: 1px solid #9BE8C6; border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1rem; font-family: var(--f-sans); color: var(--forest);" role="alert">
                            <i class="bi bi-check-circle me-2" style="color: var(--signal-dk);"></i>
                            <strong>Exposure data complete</strong> - @Model.ExposureCount exposure(s) recorded
                            <a asp-page="./Details" asp-route-id="@Model.Case.Id" asp-fragment="exposures" style="color: var(--signal-dk); text-decoration: underline; margin-left: 0.5rem;">View exposures</a>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Column 2: Actions & Quick Info -->
        <div>
            <!-- Primary Actions Card -->
            <div class="sentinel-card mb-3">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--hairline);">
                    <h3 style="font-family: var(--f-sans); font-weight: 500; font-size: 1.25rem; color: var(--forest); margin: 0; display: flex; align-items: center; gap: 8px;">
                        <i class="bi bi-floppy" style="color: var(--signal-dk);"></i>
                        Actions
                    </h3>
                </div>
                <div class="sentinel-card-body">
                    <button type="submit" class="btn-sentinel-primary w-100 mb-2">
                        <i class="bi bi-save me-2"></i>Save Changes
                    </button>
                    <a asp-page="./Details" asp-route-id="@Model.Case.Id" class="btn-sentinel-secondary w-100 mb-3">
                        <i class="bi bi-x-circle me-2"></i>Cancel
                    </a>

                    <hr class="my-3" style="border-color: var(--hairline);" />

                    <!-- Delete Button -->
                    <button type="button" class="btn btn-outline-danger w-100" onclick="confirmDelete()">
                        <i class="bi bi-trash me-2"></i>Delete Case
                    </button>
                </div>
            </div>

            <!-- Quick Info Card -->
            <div class="sentinel-card" style="background: var(--paper);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--hairline);">
                    <h3 style="font-family: var(--f-sans); font-weight: 500; font-size: 1.25rem; color: var(--forest); margin: 0; display: flex; align-items: center; gap: 8px;">
                        <i class="bi bi-info-circle" style="color: var(--signal-dk);"></i>
                        Quick Info
                    </h3>
                </div>
                <div class="sentinel-card-body">
                    <ul class="small mb-0" style="list-style: none; padding-left: 0; font-family: var(--f-sans);">
                        <li class="mb-2" style="color: var(--graphite);"><i class="bi bi-hash me-1" style="color: var(--slate);"></i><strong style="color: var(--forest);">ID:</strong> @Model.Case.FriendlyId</li>
                        <li class="mb-2" style="color: var(--graphite);"><i class="bi bi-shield-check me-1" style="color: var(--slate);"></i>Changes are logged for audit</li>
                        <li style="color: var(--graphite);"><i class="bi bi-person-lock me-1" style="color: var(--slate);"></i>Patient cannot be reassigned</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Second Row: Jurisdictions and Address - 2 Column Grid -->
    <div class="case-grid" style="grid-template-columns: 1fr 1fr; margin-top: 1.5rem;">
        <!-- Column 1: Jurisdictions Section -->
        <div class="sentinel-card">
            @if (Model.ActiveJurisdictionTypes.Any())
            {
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--hairline);">
                    <h3 style="font-family: var(--f-sans); font-weight: 500; font-size: 1.25rem; color: var(--forest); margin: 0; display: flex; align-items: center; gap: 8px;">
                        <i class="bi bi-pin-map" style="color: var(--signal-dk);"></i>
                        Geographic Jurisdictions
                    </h3>
                </div>
                <div class="sentinel-card-body">
                    <div style="background: #E3E9FB; border: 1px solid #B7C4EE; border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1rem; font-size: 0.85rem; font-family: var(--f-sans); color: var(--forest);">
                        <i class="bi bi-info-circle me-1" style="color: var(--status-info);"></i>
                        Type to search and select jurisdictions for this case.
                    </div>
                    
                    @foreach (var jurisdictionType in Model.ActiveJurisdictionTypes.OrderBy(jt => jt.DisplayOrder))
                    {
                        var fieldProperty = $"Jurisdiction{jurisdictionType.FieldNumber}Id";
                        var fieldId = $"jurisdiction_{jurisdictionType.FieldNumber}";
                        
                        // Get current value and name from eager-loaded navigation properties
                        int? currentValue = jurisdictionType.FieldNumber switch
                        {
                            1 => Model.Case.Jurisdiction1Id,
                            2 => Model.Case.Jurisdiction2Id,
                            3 => Model.Case.Jurisdiction3Id,
                            4 => Model.Case.Jurisdiction4Id,
                            5 => Model.Case.Jurisdiction5Id,
                            _ => null
                        };

                        string? currentName = jurisdictionType.FieldNumber switch
                        {
                            1 => Model.Case.Jurisdiction1?.Name,
                            2 => Model.Case.Jurisdiction2?.Name,
                            3 => Model.Case.Jurisdiction3?.Name,
                            4 => Model.Case.Jurisdiction4?.Name,
                            5 => Model.Case.Jurisdiction5?.Name,
                            _ => null
                        };
                        
                        <div class="mb-3">
                            <label for="@fieldId" class="form-label small">
                                @jurisdictionType.Name
                                @if (!string.IsNullOrEmpty(jurisdictionType.Code))
                                {
                                    <span class="text-muted">(@jurisdictionType.Code)</span>
                                }
                            </label>
                            <input type="text" 
                                   id="@fieldId" 
                                   class="form-control form-control-sm jurisdiction-autocomplete"
                                   placeholder="Type to search for @jurisdictionType.Name..."
                                   data-jurisdiction-type-id="@jurisdictionType.Id"
                                   data-field-number="@jurisdictionType.FieldNumber"
                                   data-current-value="@currentValue"
                                   value="@currentName"
                                   autocomplete="off" />
                            <input type="hidden" 
                                   name="Case.@fieldProperty" 
                                   id="@fieldProperty" 
                                   value="@currentValue" />
                            <div class="autocomplete-dropdown" id="@(fieldId)_dropdown" style="display: none;"></div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--hairline);">
                    <h3 style="font-family: var(--f-sans); font-weight: 500; font-size: 1.25rem; color: var(--forest); margin: 0; display: flex; align-items: center; gap: 8px;">
                        <i class="bi bi-pin-map" style="color: var(--signal-dk);"></i>
                        Geographic Jurisdictions
                    </h3>
                </div>
                <div class="sentinel-card-body" style="text-align: center; padding: 2rem; color: var(--graphite);">
                    <i class="bi bi-info-circle me-1" style="color: var(--hairline); font-size: 2rem;"></i>
                    <div>No jurisdiction types configured</div>
                </div>
            }
        </div>

        <!-- Column 2: Case-Specific Address -->
        <div class="sentinel-card">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--hairline);">
                <h3 style="font-family: var(--f-sans); font-weight: 500; font-size: 1.25rem; color: var(--forest); margin: 0; display: flex; align-items: center; gap: 8px;">
                    <i class="bi bi-geo-alt" style="color: var(--signal-dk);"></i>
                    Case-Specific Address (Optional)
                </h3>
            </div>
            <div class="sentinel-card-body">
                <div style="background: #E3E9FB; border: 1px solid #B7C4EE; border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1rem; font-size: 0.85rem; font-family: var(--f-sans); color: var(--forest);">
                    <i class="bi bi-info-circle me-1" style="color: var(--status-info);"></i>
                    <strong>Note:</strong> This address is case-specific and does <strong>NOT</strong> update the patient's record. 
                    Use this to record where <strong>THIS case occurred</strong> if different from the patient's home address 
                    (e.g., workplace exposure, travel-related case, event location).
                </div>

                <div class="mb-3">
                    <label asp-for="Case.CaseAddressLine" class="form-label fw-bold">Street Address</label>
                    <input asp-for="Case.CaseAddressLine" class="form-control" placeholder="123 Main Street" />
                    <span asp-validation-for="Case.CaseAddressLine" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Case.CaseCity" class="form-label fw-bold">City</label>
                    <input asp-for="Case.CaseCity" class="form-control" placeholder="City name" />
                    <span asp-validation-for="Case.CaseCity" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Case.CaseStateId" class="form-label fw-bold">State</label>
                    <select asp-for="Case.CaseStateId" class="form-select" asp-items="@((SelectList)ViewData["CaseStateId"])">
                        <option value="">-- Select State --</option>
                    </select>
                    <span asp-validation-for="Case.CaseStateId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Case.CasePostalCode" class="form-label fw-bold">Postal Code</label>
                    <input asp-for="Case.CasePostalCode" class="form-control" placeholder="12345" />
                    <span asp-validation-for="Case.CasePostalCode" class="text-danger"></span>
                </div>

                <div style="background: var(--signal-lt); border: 1px solid #9BE8C6; border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.85rem; font-family: var(--f-sans); color: var(--forest);">
                    <i class="bi bi-lightning-charge me-1" style="color: var(--signal-dk);"></i>
                    <strong>Auto-Geocoding:</strong> When you save, the address will be automatically geocoded 
                    and jurisdictions will be detected (takes 1-2 minutes in the background).
                </div>
            </div>
        </div>
    </div>

    <!-- Third Row: Patient Information (Read-Only) - Full Width -->
    <div class="sentinel-card" style="margin-top: 1.5rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--hairline);">
            <h3 style="font-family: var(--f-sans); font-weight: 500; font-size: 1.25rem; color: var(--forest); margin: 0; display: flex; align-items: center; gap: 8px;">
                <i class="bi bi-person-badge" style="color: var(--signal-dk);"></i>
                Patient Information (Read-Only)
            </h3>
        </div>
        <div class="sentinel-card-body">
            @if (Model.Case.Patient != null)
            {
                <div style="background: #E3E9FB; border: 1px solid #B7C4EE; border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1rem; font-size: 0.875rem; font-family: var(--f-sans); color: var(--forest);">
                    <i class="bi bi-info-circle me-2" style="color: var(--status-info);"></i>
                    Patient cannot be changed after case creation. <a asp-page="/Patients/Details" asp-route-id="@Model.Case.PatientId" style="color: var(--status-info); text-decoration: underline;">View patient details <i class="bi bi-box-arrow-up-right"></i></a>
                </div>

                <div class="row g-3">
                    <div class="col-md-2">
                        <label class="form-label fw-bold small" style="color: var(--graphite);">Patient ID</label>
                        <div class="fw-bold" style="color: var(--forest);">@Model.Case.Patient.FriendlyId</div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold small" style="color: var(--graphite);">Full Name</label>
                        <div class="fw-bold" style="color: var(--forest);">@Model.Case.Patient.GivenName @Model.Case.Patient.FamilyName</div>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold small" style="color: var(--graphite);">Date of Birth</label>
                        <div style="color: var(--forest);">
                            @if (Model.Case.Patient.DateOfBirth.HasValue)
                            {
                                var age = DateTime.Now.Year - Model.Case.Patient.DateOfBirth.Value.Year;
                                <span>@Model.Case.Patient.DateOfBirth.Value.ToString("dd MMM yyyy") <small style="color: var(--graphite);">(@age yrs)</small></span>
                            }
                            else
                            {
                                <span style="color: var(--graphite);">-</span>
                            }
                        </div>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold small" style="color: var(--graphite);">Gender</label>
                        <div style="color: var(--forest);">@(Model.Case.Patient.Gender?.Name ?? "-")</div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold small" style="color: var(--graphite);">Contact</label>
                        <div>
                            @if (!string.IsNullOrWhiteSpace(Model.Case.Patient.MobilePhone))
                            {
                                <a href="tel:@Model.Case.Patient.MobilePhone" class="me-2" style="color: var(--signal-dk); text-decoration: none;">
                                    <i class="bi bi-phone"></i> @Model.Case.Patient.MobilePhone
                                </a>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.Case.Patient.EmailAddress))
                            {
                                <a href="mailto:@Model.Case.Patient.EmailAddress" style="color: var(--signal-dk); text-decoration: none;">
                                    <i class="bi bi-envelope"></i>
                                </a>
                            }
                            @if (string.IsNullOrWhiteSpace(Model.Case.Patient.MobilePhone) && string.IsNullOrWhiteSpace(Model.Case.Patient.EmailAddress))
                            {
                                <span style="color: var(--graphite);">-</span>
                            }
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div style="background: #FBEDD1; border: 1px solid #EBD196; border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 0; font-family: var(--f-sans); color: var(--forest);">
                    <i class="bi bi-exclamation-triangle me-2" style="color: var(--status-watch);"></i>
                    <strong>Warning:</strong> No patient assigned to this case.
                </div>
            }
        </div>
    </div>

    <!-- Third Row: Custom Fields - Full Width -->
    <div class="sentinel-card" style="margin-top: 1.5rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--hairline);">
            <h3 style="font-family: var(--f-sans); font-weight: 500; font-size: 1.25rem; color: var(--forest); margin: 0; display: flex; align-items: center; gap: 8px;">
                <i class="bi bi-ui-checks" style="color: var(--signal-dk);"></i>
                Custom Fields
            </h3>
        </div>
        <div class="sentinel-card-body">
            @if (Model.CustomFields.Any())
            {
                @foreach (var category in Model.CustomFields.GroupBy(f => f.Category))
                {
                    <div class="mb-4">
                        <h6 style="border-bottom: 1px solid var(--hairline); padding-bottom: 0.5rem; margin-bottom: 1rem; color: var(--forest); font-family: var(--f-sans); font-weight: 600;">@category.Key</h6>
                        <div class="row">
                            @foreach (var field in category.OrderBy(f => f.DisplayOrder))
                            {
                                var colSize = field.FieldType == CustomFieldType.TextArea ? "col-12" : "col-md-4";
                                var fieldName = $"customfield_{field.Id}";
                                var fieldValue = Model.CustomFieldValues.ContainsKey(field.Id) ? Model.CustomFieldValues[field.Id] : null;

                                <div class="@colSize mb-3">
                                    <label class="form-label fw-bold">
                                        @if (field.IsRequired)
                                        {
                                            <span class="text-danger">*</span>
                                        }
                                        @field.Label
                                    </label>

                                    @switch (field.FieldType)
                                    {
                                        case CustomFieldType.Text:
                                        case CustomFieldType.Email:
                                        case CustomFieldType.Phone:
                                            <input type="@field.FieldType.ToString().ToLower()" class="form-control" 
                                                   name="@fieldName" value="@fieldValue" 
                                                   required="@field.IsRequired" />
                                            break;

                                        case CustomFieldType.TextArea:
                                            <textarea class="form-control" name="@fieldName" rows="3" 
                                                      required="@field.IsRequired">@fieldValue</textarea>
                                            break;

                                        case CustomFieldType.Number:
                                            <input type="number" class="form-control" name="@fieldName" 
                                                   value="@fieldValue" step="any" 
                                                   required="@field.IsRequired" />
                                            break;

                                        case CustomFieldType.Date:
                                            var dateValue = fieldValue != null && DateTime.TryParse(fieldValue.ToString(), out var dt) 
                                                ? dt.ToString("yyyy-MM-dd") : "";
                                            <input type="date" class="form-control" name="@fieldName" 
                                                   value="@dateValue" 
                                                   required="@field.IsRequired" />
                                            break;

                                        case CustomFieldType.Checkbox:
                                            var isChecked = fieldValue != null && (bool)fieldValue;
                                            <div class="form-check">
                                                <input type="checkbox" class="form-check-input" name="@fieldName" 
                                                       value="true" checked="@isChecked" />
                                                <label class="form-check-label">@field.Label</label>
                                            </div>
                                            break;

                                        case CustomFieldType.Dropdown:
                                            if (field.LookupTable != null && field.LookupTable.Values != null && field.LookupTable.Values.Any())
                                            {
                                                <select class="form-select" name="@fieldName" 
                                                        required="@field.IsRequired">
                                                    <option value="">-- Select --</option>
                                                    @foreach (var value in field.LookupTable.Values.OrderBy(v => v.DisplayOrder))
                                                    {
                                                        var selected = fieldValue != null && fieldValue.ToString() == value.Id.ToString();
                                                        <option value="@value.Id" selected="@selected">@value.DisplayText</option>
                                                    }
                                                </select>
                                            }
                                            else
                                            {
                                                <div class="alert alert-warning">
                                                    <small>? Dropdown field "@field.Label" is missing lookup table data.</small>
                                                </div>
                                            }
                                            break;

                                        default:
                                            <input type="text" class="form-control" name="@fieldName" 
                                                   value="@fieldValue" 
                                                   required="@field.IsRequired" />
                                            break;
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="background: var(--paper); border: 1px solid var(--hairline); border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 0; font-family: var(--f-sans); color: var(--graphite);">
                    <i class="bi bi-info-circle me-2" style="color: var(--slate);"></i>
                    No custom fields configured for this case type. Custom fields can be added in <a asp-page="/Settings/CustomFields/Index" style="color: var(--signal-dk); text-decoration: underline;">Settings &gt; Custom Fields</a>.
                </div>
            }
        </div>
    </div>

    <!-- Fourth Row: Symptoms Section - Full Width -->
    <div class="sentinel-card" style="margin-top: 1.5rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--hairline); cursor: pointer;" data-bs-toggle="collapse" data-bs-target="#symptomsCollapse">
            <h3 style="font-family: var(--f-sans); font-weight: 500; font-size: 1.25rem; color: var(--forest); margin: 0; display: flex; align-items: center; gap: 8px;">
                <i class="bi bi-heart-pulse" style="color: var(--signal-dk);"></i>
                Symptoms
            </h3>
            <i class="bi bi-chevron-down" style="color: var(--graphite);"></i>
        </div>
        <div class="collapse show" id="symptomsCollapse">
            <div class="sentinel-card-body">
                @if (Model.CommonSymptoms.Any())
                {
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="mb-0" style="color: var(--forest); font-family: var(--f-sans); font-weight: 600;">Common Symptoms for @Model.Case.Disease?.Name</h6>
                        <button type="button" class="btn-sentinel-secondary" style="font-size: 0.875rem; padding: 0.375rem 0.75rem;" id="quickAddAllSymptoms">
                            <i class="bi bi-plus-circle me-1"></i>Quick Add All
                        </button>
                    </div>
                    <p style="color: var(--graphite); font-size: 0.875rem; margin-bottom: 1rem; font-family: var(--f-sans);">
                        <i class="bi bi-info-circle me-1" style="color: var(--status-info);"></i>Click symptoms to add them quickly, or use checkboxes for more control.
                    </p>
                    
                    <!-- Quick-Add Symptom Buttons -->
                    <div class="mb-3">
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var symptom in Model.CommonSymptoms)
                            {
                                var existing = Model.CaseSymptoms.FirstOrDefault(cs => cs.SymptomId == symptom.Id);
                                var isChecked = existing != null;
                                var buttonStyle = isChecked 
                                    ? "background: var(--signal); color: var(--forest); border: 1px solid var(--signal);" 
                                    : "background: var(--chalk); color: var(--graphite); border: 1px solid var(--hairline);";

                                <button type="button" 
                                        class="btn btn-sm symptom-quick-add" 
                                        data-symptom-id="@symptom.Id"
                                        data-symptom-name="@symptom.Name"
                                        style="@buttonStyle">
                                    @if (isChecked)
                                    {
                                        <i class="bi bi-check-circle-fill me-1"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-plus-circle me-1"></i>
                                    }
                                    @symptom.Name
                                </button>
                            }
                        </div>
                    </div>

                    <!-- Detailed Symptom Checkboxes (Collapsible) -->
                    <div class="accordion mb-3" id="detailedSymptomsAccordion">
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#detailedSymptoms">
                                    <i class="bi bi-calendar-date me-2"></i>Add Onset Dates & Details
                                </button>
                            </h2>
                            <div id="detailedSymptoms" class="accordion-collapse collapse">
                                <div class="accordion-body">
                                    <p class="text-muted small mb-3">Use this section to add specific onset dates for each symptom.</p>
                                    <div class="row">
                                        @foreach (var symptom in Model.CommonSymptoms)
                                        {
                                            var existing = Model.CaseSymptoms.FirstOrDefault(cs => cs.SymptomId == symptom.Id);
                                            var isChecked = existing != null;
                                            
                                            <div class="col-md-4 mb-3">
                                                <div class="d-flex align-items-start">
                                                    <div class="form-check me-3">
                                                        <input class="form-check-input symptom-checkbox-simple" 
                                                               type="checkbox" 
                                                               name="common_symptom_@symptom.Id" 
                                                               id="symptom_@symptom.Id" 
                                                               value="true"
                                                               checked="@isChecked"
                                                               data-symptom-id="@symptom.Id" />
                                                        <label class="form-check-label fw-bold" for="symptom_@symptom.Id">
                                                            @symptom.Name
                                                        </label>
                                                    </div>
                                                    <div class="flex-grow-1">
                                                        <input type="date" 
                                                               class="form-control form-control-sm onset-date-field" 
                                                               name="onset_date_@symptom.Id"
                                                               id="onset_@symptom.Id"
                                                               value="@(existing?.OnsetDate?.ToString("yyyy-MM-dd"))"
                                                               disabled="@(!isChecked)"
                                                               placeholder="Onset date" />
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <hr class="my-4" />
                }
                
                <!-- Search for Additional Symptoms -->
                <div class="mb-3">
                    <h6 class="mb-2">
                        @if (Model.CommonSymptoms.Any())
                        {
                            <i class="bi bi-search me-1"></i><span>Search for Additional Symptoms</span>
                        }
                        else
                        {
                            <i class="bi bi-search me-1"></i><span>Search for Symptoms</span>
                        }
                    </h6>
                    <p class="text-muted small mb-2">
                        @if (Model.CommonSymptoms.Any())
                        {
                            <span>Type to search for other symptoms not listed above.</span>
                        }
                        else
                        {
                            <span>No common symptoms configured for this disease. Type to search for any symptom.</span>
                        }
                    </p>
                    
                    <select class="form-select symptom-autocomplete" 
                            id="symptomAutocomplete" 
                            multiple="multiple" 
                            style="width: 100%;">
                        @foreach (var caseSymptom in Model.CaseSymptoms.Where(cs => !Model.CommonSymptoms.Any(common => common.Id == cs.SymptomId)))
                        {
                            if (caseSymptom.Symptom != null && caseSymptom.Symptom.Code != "OTHER")
                            {
                                <option value="@caseSymptom.SymptomId" selected="selected">@caseSymptom.Symptom.Name</option>
                            }
                        }
                    </select>
                    <input type="hidden" name="additional_symptom_ids" id="additionalSymptomIds" />
                    <small class="form-text text-muted">Start typing to search for symptoms</small>
                </div>
                
                <div id="additionalSymptomsOnset" class="mb-3" style="display: none;">
                    <label class="form-label fw-bold">Onset Dates for Additional Symptoms</label>
                    <div id="additionalSymptomDates"></div>
                </div>
            
                <hr class="my-3" />
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Other (Free Text)</label>
                    @{
                        var otherSymptom = Model.CaseSymptoms.FirstOrDefault(cs => cs.Symptom?.Code == "OTHER");
                    }
                    <input type="text" 
                           class="form-control" 
                           name="other_symptom_text"
                           id="otherSymptomText"
                           value="@otherSymptom?.OtherSymptomText"
                           placeholder="Enter any other symptoms not found above (e.g., night sweats, chest pain)" />
                    <small class="form-text text-muted">Use this field if a symptom couldn't be found in the search</small>
                </div>
                
                <div style="background: #E3E9FB; border: 1px solid #B7C4EE; border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.875rem; font-family: var(--f-sans); color: var(--forest); margin-bottom: 0;">
                    <i class="bi bi-lightbulb me-1" style="color: var(--status-info);"></i>
                    <strong>Tip:</strong> Symptom onset dates help track disease progression and are important for epidemiological analysis.
                </div>
            </div>
        </div>
    </div>
</form>
</div>

@section Scripts {
@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
<script>
    $(document).ready(function() {
        // Initialize Select2 on disease dropdown
        $('.disease-select').select2({
            theme: 'bootstrap-5',
            placeholder: '-- Select or search for a disease --',
            allowClear: true,
            width: '100%'
        });

        // Quick-add symptom button handling
        $('.symptom-quick-add').on('click', function() {
            var symptomId = $(this).data('symptom-id');
            var symptomName = $(this).data('symptom-name');
            var checkbox = $('#symptom_' + symptomId);
                
            // Toggle the checkbox
            checkbox.prop('checked', !checkbox.is(':checked'));
            checkbox.trigger('change');
                
            // Update button appearance
            if (checkbox.is(':checked')) {
                $(this).css({
                    'background': 'var(--signal)',
                    'color': 'var(--forest)',
                    'border-color': 'var(--signal)'
                });
                $(this).find('i').removeClass('bi-plus-circle').addClass('bi-check-circle-fill');
            } else {
                $(this).css({
                    'background': 'var(--chalk)',
                    'color': 'var(--graphite)',
                    'border-color': 'var(--hairline)'
                });
                $(this).find('i').removeClass('bi-check-circle-fill').addClass('bi-plus-circle');
            }

            // Update symptom count badge (removed - count no longer displayed)
                
            // Show brief toast notification
            showSymptomToast(symptomName, checkbox.is(':checked'));
        });

        // Quick add all symptoms
        $('#quickAddAllSymptoms').on('click', function() {
            var addedCount = 0;
            $('.symptom-quick-add').each(function() {
                var symptomId = $(this).data('symptom-id');
                var checkbox = $('#symptom_' + symptomId);
                    
                if (!checkbox.is(':checked')) {
                    checkbox.prop('checked', true);
                    checkbox.trigger('change');
                    $(this).css({
                        'background': 'var(--signal)',
                        'color': 'var(--forest)',
                        'border-color': 'var(--signal)'
                    });
                    $(this).find('i').removeClass('bi-plus-circle').addClass('bi-check-circle-fill');
                    addedCount++;
                }
            });

            if (addedCount > 0) {
                showSymptomToast(addedCount + ' symptoms', true);
            }
        });

        // Update symptom count badge
        function updateSymptomCountBadge() {
            var checkedCount = $('.symptom-checkbox-simple:checked').length;
            var additionalCount = $('.symptom-autocomplete').val()?.length || 0;
            var totalCount = checkedCount + additionalCount;
            $('#symptomCountBadge').text(totalCount);
        }

        // Show toast notification
        function showSymptomToast(symptomName, isAdded) {
            var message = isAdded ? 
                '<i class="bi bi-check-circle me-2"></i>' + symptomName + ' added' : 
                '<i class="bi bi-x-circle me-2"></i>' + symptomName + ' removed';
                
            // Create toast element
            var toast = $('<div class="toast-symptom-notification">' + message + '</div>');
            toast.css({
                'position': 'fixed',
                'top': '20px',
                'right': '20px',
                'background': isAdded ? '#159C6E' : '#6B7A78',
                'color': 'white',
                'padding': '12px 20px',
                'border-radius': '8px',
                'box-shadow': '0 4px 6px rgba(0,0,0,0.2)',
                'z-index': '9999',
                'animation': 'slideInRight 0.3s ease-out',
                'font-size': '14px',
                'font-family': 'var(--f-sans)'
            });
                
            $('body').append(toast);
                
            setTimeout(function() {
                toast.fadeOut(300, function() {
                    $(this).remove();
                });
            }, 2000);
        }

        // Common symptom checkbox handling - simpler version
        $('.symptom-checkbox-simple').on('change', function() {
            var symptomId = $(this).data('symptom-id');
            var onsetField = $('#onset_' + symptomId);
            var quickAddBtn = $('.symptom-quick-add[data-symptom-id="' + symptomId + '"]');
                
            if ($(this).is(':checked')) {
                onsetField.prop('disabled', false);
                quickAddBtn.css({
                    'background': 'var(--signal)',
                    'color': 'var(--forest)',
                    'border-color': 'var(--signal)'
                });
                quickAddBtn.find('i').removeClass('bi-plus-circle').addClass('bi-check-circle-fill');
            } else {
                onsetField.prop('disabled', true);
                onsetField.val('');
                quickAddBtn.css({
                    'background': 'var(--chalk)',
                    'color': 'var(--graphite)',
                    'border-color': 'var(--hairline)'
                });
                quickAddBtn.find('i').removeClass('bi-check-circle-fill').addClass('bi-plus-circle');
            }
        });

            // Initialize symptom autocomplete with Select2
            $('.symptom-autocomplete').select2({
                theme: 'bootstrap-5',
                placeholder: 'Type to search for symptoms...',
                allowClear: true,
                width: '100%',
                ajax: {
                    url: '?handler=SearchSymptoms',
                    dataType: 'json',
                    delay: 250,
                    data: function (params) {
                        return {
                            term: params.term
                        };
                    },
                    processResults: function (data) {
                        return {
                            results: data
                        };
                    },
                    cache: true
                },
                minimumInputLength: 2
            });

            // Initialize disease autocomplete with Select2
            $('#diseaseDropdown').select2({
                theme: 'bootstrap-5',
                placeholder: 'Type to search for diseases...',
                allowClear: true,
                width: '100%',
                ajax: {
                    url: '/api/diseases/search',
                    dataType: 'json',
                    delay: 250,
                    data: function (params) {
                        return {
                            term: params.term || ''
                        };
                    },
                    processResults: function (data) {
                        return {
                            results: data.map(function(disease) {
                                return {
                                    id: disease.id,
                                    text: disease.name + (disease.code ? ' (' + disease.code + ')' : '')
                                };
                            })
                        };
                    },
                    cache: true
                },
                minimumInputLength: 2
            });

            // Handle symptom autocomplete changes
            $('.symptom-autocomplete').on('change', function() {
                var selectedIds = $(this).val() || [];
                $('#additionalSymptomIds').val(selectedIds.join(','));
                
                if (selectedIds.length > 0) {
                    updateAdditionalSymptomDates(selectedIds);
                    $('#additionalSymptomsOnset').show();
                } else {
                    $('#additionalSymptomsOnset').hide();
                }
            });

            // Function to generate onset date fields for additional symptoms
            function updateAdditionalSymptomDates(symptomIds) {
                var container = $('#additionalSymptomDates');
                container.empty();
                
                symptomIds.forEach(function(symptomId) {
                    var symptomText = $('.symptom-autocomplete option[value="' + symptomId + '"]').text();
                    var existingValue = $('input[name="onset_date_' + symptomId + '"]').val() || '';
                    
                    var html = '<div class="row mb-2">' +
                        '<div class="col-md-6"><label class="form-label small">' + symptomText + '</label></div>' +
                        '<div class="col-md-6">' +
                        '<input type="date" class="form-control form-control-sm" ' +
                        'name="onset_date_' + symptomId + '" value="' + existingValue + '" />' +
                        '</div>' +
                        '</div>';
                    container.append(html);
                });
            }

            // Initialize additional symptoms on page load
            var initialSelectedIds = $('.symptom-autocomplete').val() || [];
            if (initialSelectedIds.length > 0) {
                $('#additionalSymptomIds').val(initialSelectedIds.join(','));
                updateAdditionalSymptomDates(initialSelectedIds);
                $('#additionalSymptomsOnset').show();
            }

            // Hospitalization toggle
            $('#hospitalisedSelect').on('change', function() {
                var value = $(this).val();
                if (value == '@((int)Sentinel.Models.YesNoUnknown.Yes)') {
                    $('#hospitalizationDetails').slideDown();
                } else {
                    $('#hospitalizationDetails').slideUp();
                    // Clear hospitalization fields
                    $('#Case_HospitalId').val('').trigger('change');
                    $('#dateOfAdmission').val('');
                    $('#dateOfDischarge').val('');
                }
            });

            // Initialize hospitalization display on page load
            if ($('#hospitalisedSelect').val() == '@((int)Sentinel.Models.YesNoUnknown.Yes)') {
                $('#hospitalizationDetails').show();
            }

            // Initialize Select2 on hospital dropdown
            $('.hospital-select').select2({
                theme: 'bootstrap-5',
                placeholder: '-- Select or search for a hospital --',
                allowClear: true,
                width: '100%',
                ajax: {
                    url: '/api/organizations/search',
                    dataType: 'json',
                    delay: 250,
                    data: function (params) {
                        return {
                            term: params.term || '',
                            type: 'Hospital'
                        };
                    },
                    processResults: function (data) {
                        return {
                            results: data.map(function(org) {
                                return {
                                    id: org.id,
                                    text: org.name + (org.address ? ' - ' + org.address : '')
                                };
                            })
                        };
                    },
                    cache: true
                },
                minimumInputLength: 2
            });

            // Date validation: discharge must be after admission
            $('#dateOfDischarge').on('change', function() {
                var admissionDate = $('#dateOfAdmission').val();
                var dischargeDate = $(this).val();
                
                if (admissionDate && dischargeDate && dischargeDate < admissionDate) {
                    alert('Date of discharge must be after date of admission.');
                    $(this).val('');
                }
            });

            // Jurisdiction Autocomplete
            $('.jurisdiction-autocomplete').each(function() {
                var $input = $(this);
                var $dropdown = $('#' + $input.attr('id') + '_dropdown');
                var typeId = $input.data('jurisdiction-type-id');
                var fieldNumber = $input.data('field-number');
                var $hiddenField = $('#Jurisdiction' + fieldNumber + 'Id');
                var currentValue = $input.data('current-value');
                
                // Load current jurisdiction name if value exists
                if (currentValue) {
                    $.get('/api/jurisdictions/search?typeId=' + typeId, function(data) {
                        var current = data.find(j => j.id == currentValue);
                        if (current) {
                            $input.val(current.name);
                        }
                    });
                }
                
                // Debounce function
                var debounceTimer;
                function debounceSearch(fn, delay) {
                    return function() {
                        var context = this, args = arguments;
                        clearTimeout(debounceTimer);
                        debounceTimer = setTimeout(function() {
                            fn.apply(context, args);
                        }, delay);
                    };
                }
                
                // Search function
                var searchJurisdictions = debounceSearch(function() {
                    var term = $input.val().trim();
                    
                    if (term.length < 2) {
                        $dropdown.hide().empty();
                        return;
                    }
                    
                    $.get('/api/jurisdictions/search', {
                        term: term,
                        typeId: typeId
                    }, function(data) {
                        if (data.length === 0) {
                            $dropdown.html('<div class="autocomplete-item disabled">No results found</div>').show();
                            return;
                        }
                        
                        $dropdown.empty();
                        data.forEach(function(j) {
                            var $item = $('<div class="autocomplete-item"></div>')
                                .text(j.name + (j.code ? ' (' + j.code + ')' : ''))
                                .data('id', j.id)
                                .data('name', j.name);
                            $dropdown.append($item);
                        });
                        $dropdown.show();
                    });
                }, 300);
                
                // Event listeners
                $input.on('input', searchJurisdictions);
                
                $input.on('focus', function() {
                    if ($dropdown.children().length > 0) {
                        $dropdown.show();
                    }
                });
                
                $(document).on('click', function(e) {
                    if (!$input.is(e.target) && !$dropdown.is(e.target) && $dropdown.has(e.target).length === 0) {
                        $dropdown.hide();
                    }
                });
                
                $dropdown.on('click', '.autocomplete-item:not(.disabled)', function() {
                    var id = $(this).data('id');
                    var name = $(this).data('name');
                    
                    $input.val(name);
                    $hiddenField.val(id);
                    $dropdown.hide();
                });
                
                // Clear hidden field if input is cleared
                $input.on('blur', function() {
                    setTimeout(function() {
                        if ($input.val().trim() === '') {
                            $hiddenField.val('');
                        }
                    }, 200);
                });
            });
        });

        // Initialize organization autocomplete for Clinical Notifier Organisation
        $('#clinicalNotifierOrgAutocomplete').autocomplete({
            source: function(request, response) {
                $.ajax({
                    url: '/api/organizations/search',
                    data: { term: request.term },
                    success: function(data) {
                        response($.map(data, function(item) {
                            var label = item.name;
                            if (item.contactPerson) {
                                label += ' (Contact: ' + item.contactPerson + ')';
                            }
                            return {
                                label: label,
                                value: item.name
                            };
                        }));
                    },
                    error: function(err) {                        response([]);
                    }
                });
            },
            minLength: 2,
            delay: 300
        });
        
        // Delete confirmation function
        function confirmDelete() {
            const caseId = '@Model.Case.FriendlyId';
            const patientName = '@(Model.Case.Patient?.GivenName) @(Model.Case.Patient?.FamilyName)';
            
            if (confirm(`Are you sure you want to delete case ${caseId}${patientName ? ' for ' + patientName : ''}?\n\nThis action cannot be undone. All associated data (tasks, exposures, lab results, etc.) will also be deleted.`)) {
                // Redirect to delete page
                window.location.href = '/Cases/Delete?id=@Model.Case.Id';
            }
        }
    </script>
