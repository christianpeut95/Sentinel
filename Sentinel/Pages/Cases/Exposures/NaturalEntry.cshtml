@page
@model Sentinel.Pages.Cases.Exposures.NaturalEntryModel

@{
    ViewData["Title"] = "Natural Language Exposure Entry";
    ViewData["Subtitle"] = "Timeline-based exposure tracking";
    Layout = "~/Pages/Shared/_LayoutSentinel.cshtml";
}

@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}

<nav aria-label="breadcrumb" class="mb-3" style="font-family: var(--f-sans);">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Cases/Index">Cases</a></li>
        <li class="breadcrumb-item"><a asp-page="/Cases/Details" asp-route-id="@Model.CaseId">Case @Model.CaseFriendlyId</a></li>
        <li class="breadcrumb-item active" aria-current="page">Natural Entry</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 style="font-size: 24px; font-weight: 600; color: var(--forest); font-family: var(--f-sans);">
            <i class="bi bi-calendar-week me-2" style="color: var(--signal-dk);"></i>Timeline Entry
        </h2>
        <p class="text-muted mb-0" style="font-family: var(--f-sans);">
            @Model.PatientName &mdash; @Model.DiseaseName
        </p>
    </div>
    <div>
        <a asp-page="./Create" asp-route-caseId="@Model.CaseId" class="btn btn-outline-secondary me-2">
            <i class="bi bi-ui-checks"></i> Traditional Form
        </a>
        <a asp-page="/Cases/Details" asp-route-id="@Model.CaseId" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Case
        </a>
    </div>
</div>

<!-- Instruction Alert -->
<div class="alert mb-4" style="background: var(--signal-lt); border: 1px solid var(--signal-dk); color: var(--forest); font-family: var(--f-sans);">
    <div class="d-flex">
        <div class="flex-shrink-0">
            <i class="bi bi-info-circle fs-4 me-2" style="color: var(--signal-dk);"></i>
        </div>
        <div>
            <h6 class="mb-2" style="font-weight: 600; color: var(--forest);">
                <i class="bi bi-keyboard me-1"></i>How to Use Natural Entry
            </h6>
            <ul class="mb-0 small">
                <li>Type naturally as if taking notes during a phone call</li>
                <li>Entities (people, places, transport) will be <strong>highlighted automatically</strong></li>
                <li>Click highlighted text to confirm or edit details</li>
                <li>Use shortcuts: "work", "home", "school" for familiar places</li>
                <li>Save drafts as you go - review and classify contacts later</li>
            </ul>
        </div>
    </div>
</div>

<!-- Main Timeline Interface -->
<div class="row">
    <!-- Left Panel: Timeline Entry -->
    <div class="col-lg-7">
        <div class="card mb-4" style="border: 1px solid var(--hairline); background: var(--chalk); border-radius: 10px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);">
            <div class="card-header" style="background: var(--bone); border-bottom: 2px solid var(--hairline); border-radius: 10px 10px 0 0; padding: 1rem 1.25rem;">
                <div class="d-flex justify-content-between align-items-center">
                    <span style="font-weight: 600; color: var(--forest); font-family: var(--f-sans); font-size: 16px;">
                        <i class="bi bi-calendar3 me-2" style="color: var(--signal-dk);"></i>Timeline Entries
                    </span>
                    <button type="button" id="addDayBtn" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-plus-circle"></i> Add Day
                    </button>
                </div>
            </div>
            <div class="card-body" style="font-family: var(--f-sans); max-height: 600px; overflow-y: auto;" id="timelineContainer">
                <p class="text-muted text-center py-4">
                    <i class="bi bi-calendar-plus fs-2 d-block mb-2"></i>
                    Click "Add Day" to start entering timeline data
                </p>
            </div>
            <div class="card-footer" style="background: var(--bone); border-top: 1px solid var(--hairline);">
                <div class="d-flex justify-content-between">
                    <button type="button" id="saveDraftBtn" class="btn btn-outline-secondary">
                        <i class="bi bi-save"></i> Save Draft
                    </button>
                    <div>
                        <button type="button" id="copyPreviousDayBtn" class="btn btn-outline-info me-2" disabled>
                            <i class="bi bi-files"></i> Copy Previous Day
                        </button>
                        <button type="button" id="saveAndReviewBtn" class="btn btn-success">
                            <i class="bi bi-check2-circle"></i> Save & Review
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Panel: Map & Entity Summary -->
    <div class="col-lg-5">
        <!-- Entity Summary -->
        <div class="card mb-3" style="border: 1px solid var(--hairline); background: var(--chalk); border-radius: 10px;">
            <div class="card-header" style="background: var(--bone); border-bottom: 2px solid var(--hairline); border-radius: 10px 10px 0 0; padding: 1rem 1.25rem;">
                <span style="font-weight: 600; color: var(--forest); font-family: var(--f-sans); font-size: 14px;">
                    <i class="bi bi-diagram-3 me-2"></i>Identified Entities
                </span>
            </div>
            <div class="card-body" style="font-family: var(--f-sans); font-size: 14px;" id="entitySummary">
                <div class="text-muted text-center py-3">
                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                    No entities detected yet
                </div>
            </div>
        </div>

        <!-- Map Visualization -->
        <div class="card" style="border: 1px solid var(--hairline); background: var(--chalk); border-radius: 10px;">
            <div class="card-header" style="background: var(--bone); border-bottom: 2px solid var(--hairline); border-radius: 10px 10px 0 0; padding: 1rem 1.25rem;">
                <span style="font-weight: 600; color: var(--forest); font-family: var(--f-sans); font-size: 14px;">
                    <i class="bi bi-geo-alt me-2"></i>Location Map
                </span>
            </div>
            <div class="card-body p-0">
                <div id="mapContainer" style="height: 400px; border-radius: 0 0 10px 10px;">
                    <!-- Map will be inserted here by JavaScript -->
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Hidden input to store case ID for JavaScript -->
<input type="hidden" id="caseId" value="@Model.CaseId" />

@section Scripts {
    <!-- Leaflet for mapping -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <!-- Timeline Entry CSS -->
    <link rel="stylesheet" href="~/css/timeline/timeline-entry.css" asp-append-version="true" />
    
    <!-- Timeline Entry JavaScript -->
    <script src="~/js/timeline/timeline-entry.js" asp-append-version="true" nonce="@GetCspNonce()"></script>
    <script src="~/js/timeline/entity-autocomplete.js" asp-append-version="true" nonce="@GetCspNonce()"></script>
    <script src="~/js/timeline/map-visualization.js" asp-append-version="true" nonce="@GetCspNonce()"></script>
    
    <script nonce="@GetCspNonce()">
        // Initialize timeline entry interface when page loads
        document.addEventListener('DOMContentLoaded', function() {
            const caseId = document.getElementById('caseId').value;
            window.timelineEntry = new TimelineEntry(caseId);
        });
    </script>
}
