@page
@model Sentinel.Pages.Cases.Exposures.CreateModel

@{
    ViewData["Title"] = "Add Exposure";
    Layout = "~/Pages/Shared/_LayoutSentinel.cshtml";
}
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}

<nav aria-label="breadcrumb" class="mb-3" style="font-family: var(--f-sans);">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Cases/Index">Cases</a></li>
        <li class="breadcrumb-item"><a asp-page="/Cases/Details" asp-route-id="@Model.CaseId">Case @Model.CaseFriendlyId</a></li>
        <li class="breadcrumb-item active" aria-current="page">Add Exposure</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 style="font-size: 24px; font-weight: 600; color: var(--forest); font-family: var(--f-sans);"><i class="bi bi-diagram-3 me-2" style="color: var(--signal-dk);"></i>Add Exposure</h2>
</div>

@* Display exposure guidance from disease settings *@
@if (!string.IsNullOrWhiteSpace(Model.ExposureGuidanceText))
{
    <div class="alert mb-4" style="background: var(--signal-lt); border: 1px solid var(--signal-dk); color: var(--forest); font-family: var(--f-sans);">
        <div class="d-flex">
            <div class="flex-shrink-0">
                <i class="bi bi-info-circle fs-4 me-2" style="color: var(--signal-dk);"></i>
            </div>
            <div>
                <h6 class="mb-2" style="font-weight: 600; color: var(--forest);">
                    <i class="bi bi-diagram-3 me-1"></i>Exposure Tracking Guidance
                </h6>
                <p class="mb-0" style="white-space: pre-wrap;">@Model.ExposureGuidanceText</p>
            </div>
        </div>
    </div>
}
else if (Model.ShouldPromptForExposure)
{
    <div class="alert mb-4" style="background: #FBE2D8; border: 1px solid var(--status-outbreak); color: var(--forest); font-family: var(--f-sans);">
        <div class="d-flex">
            <div class="flex-shrink-0">
                <i class="bi bi-exclamation-triangle fs-4 me-2" style="color: var(--status-outbreak);"></i>
            </div>
            <div>
                <h6 class="mb-2" style="font-weight: 600; color: var(--forest);">Exposure Information Required</h6>
                <p class="mb-0">This disease requires exposure tracking. Please provide details about where and when the exposure occurred.</p>
            </div>
        </div>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-dismissible fade show" role="alert" style="background: #FBE2D8; border: 1px solid var(--status-outbreak); color: var(--forest); font-family: var(--f-sans);">
        <i class="bi bi-exclamation-triangle me-2" style="color: var(--status-outbreak);"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form method="post">
<div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
<input type="hidden" asp-for="Exposure.ExposedCaseId" />

    <div class="card mb-4" style="border: 1px solid var(--hairline); background: var(--chalk); border-radius: 10px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);">
        <div class="card-header" style="background: var(--bone); border-bottom: 2px solid var(--hairline); border-radius: 10px 10px 0 0; padding: 1rem 1.25rem;">
            <span style="font-weight: 600; color: var(--forest); font-family: var(--f-sans); font-size: 16px;"><i class="bi bi-info-circle me-2" style="color: var(--signal-dk);"></i>Exposure Type</span>
        </div>
        <div class="card-body" style="font-family: var(--f-sans);">
            <div class="alert" style="background: var(--signal-lt); border: 1px solid var(--signal-dk); color: var(--forest);">
                <i class="bi bi-lightbulb me-2" style="color: var(--signal-dk);"></i>
                <strong>Select the type of exposure:</strong> The form will adapt to show relevant fields based on your selection.
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Exposure.ExposureType" class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        <span style="color: var(--status-outbreak);">*</span> Exposure Type
                    </label>
                    <select asp-for="Exposure.ExposureType" class="form-select" id="exposureTypeSelect" required style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);">
                        <option value="">-- Select Type --</option>
                        <option value="1">Event (at a recorded event)</option>
                        <option value="2">Location (at a specific place)</option>
                        <option value="3">Contact (person-to-person)</option>
                        <option value="4">Travel (international travel)</option>
                        <option value="5">Locally Acquired (at patient's residence)</option>
                    </select>
                    <span asp-validation-for="Exposure.ExposureType" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Event-based Exposure Fields -->
    <div class="card mb-4" id="eventFields" style="display: none; border: 1px solid var(--hairline); background: var(--chalk); border-radius: 10px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);">
        <div class="card-header" style="background: var(--forest); color: white; border-radius: 10px 10px 0 0; padding: 1rem 1.25rem;">
            <span style="font-weight: 600; font-family: var(--f-sans); font-size: 16px;"><i class="bi bi-calendar-event me-2"></i>Event Details</span>
        </div>
        <div class="card-body" style="font-family: var(--f-sans);">
            <div class="row">
                <div class="col-md-12 mb-3">
                    <label class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        <span style="color: var(--status-outbreak);">*</span> Event
                    </label>
                    <input type="text" class="form-control" id="eventAutocomplete" placeholder="Start typing event name..." style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);" />
                    <input type="hidden" asp-for="Exposure.EventId" id="eventIdHidden" />
                    <span asp-validation-for="Exposure.EventId" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                    <small class="form-text" style="color: var(--graphite); font-family: var(--f-sans);">
                        <i class="bi bi-info-circle me-1"></i>Don't see the event? <a asp-page="/Events/Create" target="_blank" style="color: var(--signal-dk);">Create a new event</a>
                    </small>
                    <div id="selectedEventInfo" class="alert mt-2" style="display: none; background: var(--signal-lt); border: 1px solid var(--signal-dk); color: var(--forest); font-family: var(--f-sans);">
                        <strong>Selected Event:</strong> <span id="selectedEventDisplay"></span><br/>
                        <small>
                            <strong>Date:</strong> <span id="selectedEventDate"></span> | 
                            <strong>Location:</strong> <span id="selectedEventLocation"></span>
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Location-based Exposure Fields -->
    <div class="card mb-4" id="locationFields" style="display: none; border: 1px solid var(--hairline); background: var(--chalk); border-radius: 10px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);">
        <div class="card-header" style="background: var(--signal-dk); color: white; border-radius: 10px 10px 0 0; padding: 1rem 1.25rem;">
            <span style="font-weight: 600; font-family: var(--f-sans); font-size: 16px;"><i class="bi bi-geo-alt me-2"></i>Location Details</span>
        </div>
        <div class="card-body" style="font-family: var(--f-sans);">
            <div class="row">
                <div class="col-md-12 mb-3">
                    <label class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        Location (from records)
                    </label>
                    <input type="text" class="form-control" id="locationAutocomplete" placeholder="Start typing location name..." style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);" />
                    <input type="hidden" asp-for="Exposure.LocationId" id="locationIdHidden" />
                    <small class="form-text" style="color: var(--graphite); font-family: var(--f-sans);">Select a recorded location, or enter address details below</small>
                    <div id="selectedLocationInfo" class="alert mt-2" style="display: none; background: var(--signal-lt); border: 1px solid var(--signal-dk); color: var(--forest); font-family: var(--f-sans);">
                        <strong>Selected Location:</strong> <span id="selectedLocationDisplay"></span><br/>
                        <small>
                            <strong>Address:</strong> <span id="selectedLocationAddress"></span> | 
                            <strong>Type:</strong> <span id="selectedLocationType"></span>
                        </small>
                    </div>
                </div>
            </div>

            <h6 class="pb-2 mb-3 mt-3" style="border-bottom: 2px solid var(--hairline); font-weight: 600; color: var(--forest); font-family: var(--f-sans);"><i class="bi bi-house me-2" style="color: var(--signal-dk);"></i>Structured Address</h6>

            <div class="row">
                <div class="col-md-12 mb-3">
                    <label asp-for="Exposure.AddressLine" class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        Street Address
                    </label>
                    <input asp-for="Exposure.AddressLine" class="form-control" placeholder="e.g., 45 Beach Road" maxlength="200" id="addressLineInput" style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);" />
                    <span asp-validation-for="Exposure.AddressLine" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                    <small class="form-text" style="color: var(--graphite); font-family: var(--f-sans);">
                        <i class="bi bi-info-circle me-1"></i>
                        Structured address enables reporting by suburb/postcode
                    </small>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Exposure.City" class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        Suburb / City
                    </label>
                    <input asp-for="Exposure.City" class="form-control" placeholder="e.g., Cairns" maxlength="100" id="cityInput" style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);" />
                    <span asp-validation-for="Exposure.City" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="Exposure.State" class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        State / Region
                    </label>
                    <input asp-for="Exposure.State" class="form-control" placeholder="e.g., Queensland" maxlength="100" id="stateInput" style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);" />
                    <span asp-validation-for="Exposure.State" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="Exposure.PostalCode" class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        Postcode
                    </label>
                    <input asp-for="Exposure.PostalCode" class="form-control" placeholder="e.g., 4870" maxlength="20" id="postalCodeInput" style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);" />
                    <span asp-validation-for="Exposure.PostalCode" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12 mb-3">
                    <label asp-for="Exposure.Country" class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        Country
                    </label>
                    <input asp-for="Exposure.Country" class="form-control" placeholder="e.g., Australia" maxlength="100" id="countryInput" value="Australia" style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);" />
                    <span asp-validation-for="Exposure.Country" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                </div>
            </div>

            <h6 class="pb-2 mb-3 mt-3" style="border-bottom: 2px solid var(--hairline); font-weight: 600; color: var(--forest); font-family: var(--f-sans);"><i class="bi bi-pin-map me-2" style="color: var(--signal-dk);"></i>Geocoding (Optional)</h6>

            <div class="row">
                <div class="col-md-5 mb-3">
                    <label asp-for="Exposure.Latitude" class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        Latitude
                    </label>
                    <input asp-for="Exposure.Latitude" class="form-control" placeholder="e.g., -16.9203" step="any" id="latitudeInput" readonly style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans); background: var(--bone);" />
                    <span asp-validation-for="Exposure.Latitude" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                </div>
                <div class="col-md-5 mb-3">
                    <label asp-for="Exposure.Longitude" class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        Longitude
                    </label>
                    <input asp-for="Exposure.Longitude" class="form-control" placeholder="e.g., 145.7781" step="any" id="longitudeInput" readonly style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans); background: var(--bone);" />
                    <span asp-validation-for="Exposure.Longitude" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                </div>
                <div class="col-md-2 mb-3">
                    <label class="form-label">&nbsp;</label>
                    <button type="button" class="btn w-100" id="geocodeButton" style="background: var(--chalk); border: 1px solid var(--signal-dk); color: var(--signal-dk); padding: 10px; border-radius: 8px; font-weight: 600; font-family: var(--f-sans); transition: all 0.2s;">
                        <i class="bi bi-compass me-1"></i>Geocode
                    </button>
                </div>
            </div>

            <div class="row" id="geocodingStatusRow" style="display: none;">
                <div class="col-md-12">
                    <div class="alert" style="background: var(--signal-lt); border: 1px solid var(--signal-dk); color: var(--forest); font-family: var(--f-sans);">
                        <i class="bi bi-check-circle me-2" style="color: var(--signal-dk);"></i>
                        <strong>Geocoded:</strong> <span id="geocodingAccuracyDisplay"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12 mb-3">
                    <label asp-for="Exposure.FreeTextLocation" class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        OR Free-text Location (Legacy)
                    </label>
                    <input asp-for="Exposure.FreeTextLocation" class="form-control" placeholder="e.g., Local supermarket, Friend's house" maxlength="500" style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);" />
                    <span asp-validation-for="Exposure.FreeTextLocation" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                    <small class="form-text" style="color: var(--graphite); font-family: var(--f-sans);">Use structured address above for better reporting</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Contact-based Exposure Fields -->
    <div class="card mb-4" id="contactFields" style="display: none; border: 1px solid var(--hairline); background: var(--chalk); border-radius: 10px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);">
        <div class="card-header" style="background: #F59E0B; color: white; border-radius: 10px 10px 0 0; padding: 1rem 1.25rem;">
            <span style="font-weight: 600; font-family: var(--f-sans); font-size: 16px;"><i class="bi bi-people me-2"></i>Contact Details</span>
        </div>
        <div class="card-body" style="font-family: var(--f-sans);">
            <div class="row">
                <div class="col-md-12 mb-3">
                    <label class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        Related Case
                    </label>
                    <div class="input-group">
                        <input type="text" class="form-control" id="caseAutocomplete" placeholder="Start typing case ID or patient name..." style="border: 1px solid var(--hairline); border-radius: 8px 0 0 8px; padding: 10px; font-family: var(--f-sans);" />
                        <button type="button" class="btn" onclick="openCreateContact()" title="Create New Contact" style="background: var(--signal-dk); color: white; border-radius: 0 8px 8px 0; padding: 10px 16px; font-weight: 600; border: none; font-family: var(--f-sans);">
                            <i class="bi bi-plus-circle me-1"></i>Create New Contact
                        </button>
                    </div>
                    <input type="hidden" asp-for="Exposure.SourceCaseId" id="sourceCaseIdHidden" />
                    <span asp-validation-for="Exposure.SourceCaseId" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                    <small class="form-text" style="color: var(--graphite); font-family: var(--f-sans);">Link to another case if this is a known contact, or create a new contact</small>
                    <div id="selectedCaseInfo" class="alert mt-2" style="display: none; background: var(--signal-lt); border: 1px solid var(--signal-dk); color: var(--forest); font-family: var(--f-sans);">
                        <strong>Selected Case:</strong> <span id="selectedCaseDisplay"></span><br/>
                        <small>
                            <strong>Notification Date:</strong> <span id="selectedCaseNotification"></span> | 
                            <strong>Disease:</strong> <span id="selectedCaseDisease"></span>
                        </small>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12 mb-3">
                    <label asp-for="Exposure.ContactClassificationId" class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        <span style="color: var(--status-outbreak);">*</span> Contact Classification
                    </label>
                    <select asp-for="Exposure.ContactClassificationId" asp-items="Model.ContactClassificationsList" class="form-select" style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);">
                        <option value="">-- Select Contact Type --</option>
                    </select>
                    <span asp-validation-for="Exposure.ContactClassificationId" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                    <small class="form-text" style="color: var(--graphite); font-family: var(--f-sans);">
                        <i class="bi bi-info-circle me-1"></i>Select how this person was exposed to the case
                    </small>
                </div>
            </div>
        </div>
    </div>

    <!-- Travel-based Exposure Fields -->
    <div class="card mb-4" id="travelFields" style="display: none; border: 1px solid var(--hairline); background: var(--chalk); border-radius: 10px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);">
        <div class="card-header" style="background: var(--signal-dk); color: white; border-radius: 10px 10px 0 0; padding: 1rem 1.25rem;">
            <span style="font-weight: 600; font-family: var(--f-sans); font-size: 16px;"><i class="bi bi-airplane me-2"></i>Travel Details</span>
        </div>
        <div class="card-body" style="font-family: var(--f-sans);">
            <div class="row">
                <div class="col-md-12 mb-3">
                    <label asp-for="Exposure.CountryCode" class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        <span style="color: var(--status-outbreak);">*</span> Country
                    </label>
                    <input type="text" class="form-control" id="countryAutocomplete" placeholder="Start typing country name..." style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);" />
                    <input type="hidden" asp-for="Exposure.CountryCode" />
                    <span asp-validation-for="Exposure.CountryCode" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                    <small class="form-text" style="color: var(--graphite); font-family: var(--f-sans);">Type to search for a country</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Locally Acquired Exposure Fields -->
    <div class="card mb-4" id="locallyAcquiredFields" style="display: none; border: 1px solid var(--hairline); background: var(--chalk); border-radius: 10px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);">
        <div class="card-header" style="background: var(--forest); color: white; border-radius: 10px 10px 0 0; padding: 1rem 1.25rem;">
            <span style="font-weight: 600; font-family: var(--f-sans); font-size: 16px;"><i class="bi bi-house me-2"></i>Locally Acquired (Patient's Residence)</span>
        </div>
        <div class="card-body" style="font-family: var(--f-sans);">
            <div class="alert" style="background: var(--signal-lt); border: 1px solid var(--signal-dk); color: var(--forest);">
                <i class="bi bi-info-circle me-2" style="color: var(--signal-dk);"></i>
                <strong>Patient's Residential Address:</strong> This exposure will be recorded at the patient's home address.
            </div>

            <div id="patientAddressDisplay" class="mb-3">
                <h6 class="pb-2 mb-3" style="border-bottom: 2px solid var(--hairline); font-weight: 600; color: var(--forest); font-family: var(--f-sans);">Patient Address</h6>
                <div class="row" style="font-family: var(--f-sans);">
                    <div class="col-md-12 mb-2">
                        <strong style="color: var(--graphite);">Street Address:</strong> <span id="displayAddressLine" style="color: var(--forest);"></span>
                    </div>
                    <div class="col-md-4 mb-2">
                        <strong style="color: var(--graphite);">Suburb/City:</strong> <span id="displayCity" style="color: var(--forest);"></span>
                    </div>
                    <div class="col-md-4 mb-2">
                        <strong style="color: var(--graphite);">State:</strong> <span id="displayState" style="color: var(--forest);"></span>
                    </div>
                    <div class="col-md-4 mb-2">
                        <strong style="color: var(--graphite);">Postcode:</strong> <span id="displayPostalCode" style="color: var(--forest);"></span>
                    </div>
                    <div class="col-md-12 mb-2">
                        <strong style="color: var(--graphite);">Country:</strong> <span id="displayCountry" style="color: var(--forest);"></span>
                    </div>
                </div>
            </div>

            <!-- Hidden fields to store patient address -->
            <input type="hidden" asp-for="Exposure.AddressLine" id="localAddressLine" />
            <input type="hidden" asp-for="Exposure.City" id="localCity" />
            <input type="hidden" asp-for="Exposure.State" id="localState" />
            <input type="hidden" asp-for="Exposure.PostalCode" id="localPostalCode" />
            <input type="hidden" asp-for="Exposure.Country" id="localCountry" />
            <input type="hidden" asp-for="Exposure.Latitude" id="localLatitude" />
            <input type="hidden" asp-for="Exposure.Longitude" id="localLongitude" />

            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="overridePatientAddress" style="cursor: pointer;" />
                <label class="form-check-label" for="overridePatientAddress" style="font-weight: 600; color: var(--forest); font-family: var(--f-sans); cursor: pointer;">
                    Override with different address
                </label>
            </div>

            <div id="overrideAddressFields" style="display: none;" class="mt-3">
                <h6 class="pb-2 mb-3" style="border-bottom: 2px solid var(--hairline); font-weight: 600; color: var(--forest); font-family: var(--f-sans);">Custom Address</h6>
                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">Street Address</label>
                        <input type="text" class="form-control" id="overrideAddressLine" placeholder="e.g., 45 Beach Road" style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">Suburb / City</label>
                        <input type="text" class="form-control" id="overrideCity" placeholder="e.g., Cairns" style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">State / Region</label>
                        <input type="text" class="form-control" id="overrideState" placeholder="e.g., Queensland" style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">Postcode</label>
                        <input type="text" class="form-control" id="overridePostalCode" placeholder="e.g., 4870" style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">Country</label>
                        <input type="text" class="form-control" id="overrideCountry" placeholder="e.g., Australia" value="Australia" style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Common Fields for All Types -->
    <div class="card mb-4" style="border: 1px solid var(--hairline); background: var(--chalk); border-radius: 10px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);">
        <div class="card-header" style="background: var(--bone); border-bottom: 2px solid var(--hairline); border-radius: 10px 10px 0 0; padding: 1rem 1.25rem;">
            <span style="font-weight: 600; color: var(--forest); font-family: var(--f-sans); font-size: 16px;"><i class="bi bi-calendar-range me-2" style="color: var(--signal-dk);"></i>Exposure Dates & Status</span>
        </div>
        <div class="card-body" style="font-family: var(--f-sans);">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Exposure.ExposureStartDate" class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        <span style="color: var(--status-outbreak);">*</span> Exposure Start Date/Time
                    </label>
                    <input asp-for="Exposure.ExposureStartDate" class="form-control" type="datetime-local" min="1900-01-01T00:00" required style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);" />
                    <span asp-validation-for="Exposure.ExposureStartDate" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                    @if (Model.Exposure.ExposureStartDate != default(DateTime))
                    {
                        <small class="form-text" style="color: var(--signal-dk); font-family: var(--f-sans);">
                            <i class="bi bi-info-circle me-1"></i>Auto-populated from earliest relevant date
                        </small>
                    }
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Exposure.ExposureEndDate" class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        Exposure End Date/Time
                    </label>
                    <input asp-for="Exposure.ExposureEndDate" class="form-control" type="datetime-local" min="1900-01-01T00:00" style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);" />
                    <span asp-validation-for="Exposure.ExposureEndDate" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                    <small class="form-text" style="color: var(--graphite); font-family: var(--f-sans);">Leave blank for single-point exposures</small>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Exposure.ExposureStatus" class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        Investigation Status
                    </label>
                    <select asp-for="Exposure.ExposureStatus" class="form-select" style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);">
                        <option value="0">Unknown</option>
                        <option value="1" selected>Potential Exposure</option>
                        <option value="2">Under Investigation</option>
                        <option value="3">Confirmed Exposure</option>
                        <option value="4">Ruled Out</option>
                    </select>
                    <span asp-validation-for="Exposure.ExposureStatus" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Exposure.ConfidenceLevel" class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        Confidence Level
                    </label>
                    <input asp-for="Exposure.ConfidenceLevel" class="form-control" placeholder="e.g., High, Medium, Low" maxlength="50" style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);" />
                    <span asp-validation-for="Exposure.ConfidenceLevel" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12 mb-3">
                    <div class="form-check form-switch">
                        <input asp-for="Exposure.IsReportingExposure" class="form-check-input" type="checkbox" id="isReportingExposureCheck" style="cursor: pointer;" />
                        <label asp-for="Exposure.IsReportingExposure" class="form-check-label" style="font-weight: 600; color: var(--forest); font-family: var(--f-sans); cursor: pointer;">
                            Primary Reporting Exposure
                        </label>
                    </div>
                    <small class="form-text" style="color: var(--graphite); font-family: var(--f-sans);">
                        <i class="bi bi-info-circle me-1"></i>
                        Mark this as the primary exposure to use for official reporting and statistics. Only one exposure per case should be marked as the reporting exposure.
                        @if (Model.Exposure.IsReportingExposure)
                        {
                            <br/>
                            <span style="color: var(--signal-dk);">
                                <i class="bi bi-check-circle me-1"></i>Auto-selected as this is the first exposure for this case.
                            </span>
                        }
                    </small>
                    <div id="reportingExposureWarning" class="alert mt-2" style="display: none; background: #FBE2D8; border: 1px solid var(--status-outbreak); color: var(--forest); font-family: var(--f-sans);">
                        <i class="bi bi-exclamation-triangle me-2" style="color: var(--status-outbreak);"></i>
                        <strong>Note:</strong> Another exposure is already marked as the reporting exposure for this case. Checking this will unmark the other one.
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12 mb-3">
                    <label asp-for="Exposure.Description" class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        Description
                    </label>
                    <textarea asp-for="Exposure.Description" class="form-control" rows="3" placeholder="Details about the exposure..." maxlength="2000" style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);"></textarea>
                    <span asp-validation-for="Exposure.Description" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12 mb-3">
                    <label asp-for="Exposure.InvestigationNotes" class="form-label" style="font-weight: 600; color: var(--graphite); font-size: 14px;">
                        Investigation Notes
                    </label>
                    <textarea asp-for="Exposure.InvestigationNotes" class="form-control" rows="3" placeholder="Notes from investigation..." maxlength="2000" style="border: 1px solid var(--hairline); border-radius: 8px; padding: 10px; font-family: var(--f-sans);"></textarea>
                    <span asp-validation-for="Exposure.InvestigationNotes" class="small" style="color: var(--status-outbreak); font-family: var(--f-sans);"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between">
        <a asp-page="/Cases/Details" asp-route-id="@Model.CaseId" class="btn" style="background: var(--chalk); border: 1px solid var(--hairline); color: var(--forest); padding: 10px 20px; border-radius: 8px; font-weight: 600; text-decoration: none; font-family: var(--f-sans); transition: all 0.2s;">
            <i class="bi bi-arrow-left me-1"></i>Cancel
        </a>
        <button type="submit" class="btn" style="background: var(--signal-dk); color: white; padding: 10px 20px; border-radius: 8px; font-weight: 600; border: none; font-family: var(--f-sans); transition: all 0.2s;">
            <i class="bi bi-check-circle me-1"></i>Add Exposure
        </button>
    </div>
</form>

@section Scripts {
@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
<script>
    // TEST: This should run immediately when script loads    // Wait for jQuery and jQuery UI to be ready
    $(function() {            const exposureTypeSelect = document.getElementById('exposureTypeSelect');
            const eventFields = document.getElementById('eventFields');
            const locationFields = document.getElementById('locationFields');
            const contactFields = document.getElementById('contactFields');
            const travelFields = document.getElementById('travelFields');
            const locallyAcquiredFields = document.getElementById('locallyAcquiredFields');

            // Debug: Check if elements exist            if (!exposureTypeSelect) {                return;
            }

            function updateFieldVisibility() {
                const selectedType = exposureTypeSelect.value;                // Hide all
                eventFields.style.display = 'none';
                locationFields.style.display = 'none';
                contactFields.style.display = 'none';
                travelFields.style.display = 'none';
                locallyAcquiredFields.style.display = 'none';

                // Show relevant fields
                switch(selectedType) {
                    case '1': // Event                        eventFields.style.display = 'block';
                        break;
                    case '2': // Location                        locationFields.style.display = 'block';
                        break;
                    case '3': // Contact                        contactFields.style.display = 'block';
                        break;
                    case '4': // Travel                        travelFields.style.display = 'block';
                        break;
                    case '5': // Locally Acquired                        locallyAcquiredFields.style.display = 'block';
                        loadPatientAddress();
                        break;
                    default:                }
            }

            exposureTypeSelect.addEventListener('change', updateFieldVisibility);
            updateFieldVisibility(); // Initial call

            // Handle override checkbox for locally acquired
            $('#overridePatientAddress').on('change', function() {
                if ($(this).is(':checked')) {
                    $('#overrideAddressFields').slideDown();
                } else {
                    $('#overrideAddressFields').slideUp();
                    // Reset to patient address
                    loadPatientAddress();
                }
            });

            // Update hidden fields when override fields change
            $('#overrideAddressLine, #overrideCity, #overrideState, #overridePostalCode, #overrideCountry').on('input', function() {
                if ($('#overridePatientAddress').is(':checked')) {
                    $('#localAddressLine').val($('#overrideAddressLine').val());
                    $('#localCity').val($('#overrideCity').val());
                    $('#localState').val($('#overrideState').val());
                    $('#localPostalCode').val($('#overridePostalCode').val());
                    $('#localCountry').val($('#overrideCountry').val());
                }
            });

            // Function to load patient address
            function loadPatientAddress() {                $.ajax({
                    url: '/api/patients/@Model.CaseId/address',
                    type: 'GET',
                    success: function(data) {                        // Populate display fields
                        $('#displayAddressLine').text(data.addressLine || 'Not specified');
                        $('#displayCity').text(data.city || 'Not specified');
                        $('#displayState').text(data.state || 'Not specified');
                        $('#displayPostalCode').text(data.postalCode || 'Not specified');
                        $('#displayCountry').text(data.country || 'Not specified');
                        
                        // Populate hidden form fields
                        $('#localAddressLine').val(data.addressLine || '');
                        $('#localCity').val(data.city || '');
                        $('#localState').val(data.state || '');
                        $('#localPostalCode').val(data.postalCode || '');
                        $('#localCountry').val(data.country || '');
                        $('#localLatitude').val(data.latitude || '');
                        $('#localLongitude').val(data.longitude || '');
                    },
                    error: function(xhr, status, error) {                        $('#displayAddressLine').text('Error loading address');
                    }
                });
            }

            // Initialize Country Autocomplete
            const countryInput = $("#countryAutocomplete");
            if (countryInput.length) {                countryInput.autocomplete({
                    source: function(request, response) {                        $.ajax({
                            url: "/api/countries/search",
                            data: { term: request.term },
                            success: function(data) {                                if (data && data.length > 0) {
                                    response($.map(data, function(item) {
                                        return {
                                            label: item.name,
                                            value: item.name,
                                            code: item.code
                                        };
                                    }));
                                } else {
                                    response([]);
                                }
                            },
                            error: function(xhr, status, error) {                                response([]);
                            }
                        });
                    },
                    minLength: 2,
                    select: function(event, ui) {                        $('#Exposure_CountryCode').val(ui.item.code);
                        return true;
                    }
                });            }

            // Initialize Case Autocomplete with disease filtering
            const caseInput = $("#caseAutocomplete");
            if (caseInput.length) {                caseInput.autocomplete({
                    source: function(request, response) {                        $.ajax({
                            url: "/api/cases/search",
                            data: { 
                                term: request.term,
                                excludeCaseId: '@Model.CaseId',
                                diseaseId: '@Model.CurrentDiseaseId',
                                contactsOnly: true
                            },
                            success: function(data) {                                if (data && data.length > 0) {
                                    response($.map(data, function(item) {
                                        // Create label with status and onset date
                                        var label = item.friendlyId + ' - ' + item.patientName;
                                        if (item.onsetDate) {
                                            label += ' - Onset: ' + item.onsetDate;
                                        }
                                        if (item.status) {
                                            label += ' (' + item.status + ')';
                                        }
                                        
                                        return {
                                            label: label,
                                            value: item.friendlyId + ' - ' + item.patientName,
                                            caseId: item.id,
                                            friendlyId: item.friendlyId,
                                            patientName: item.patientName,
                                            notificationDate: item.notificationDate,
                                            disease: item.disease,
                                            status: item.status,
                                            onsetDate: item.onsetDate
                                        };
                                    }));
                                } else {
                                    response([{ label: 'No matching contact cases found', value: '', disabled: true }]);
                                }
                            },
                            error: function(xhr, status, error) {                                response([]);
                            }
                        });
                    },
                    minLength: 2,
                    select: function(event, ui) {
                        // Prevent selection of disabled/placeholder items
                        if (ui.item.disabled || !ui.item.caseId) {
                            return false;
                        }                        $('#relatedCaseIdHidden').val(ui.item.caseId);
                        $('#selectedCaseDisplay').text(ui.item.friendlyId + ' - ' + ui.item.patientName);
                        $('#selectedCaseNotification').text(ui.item.notificationDate || 'Not set');
                        $('#selectedCaseDisease').text(ui.item.disease || 'Not specified');
                        $('#selectedCaseInfo').show();
                        return true;
                    }
                });            }

            // Function to open Patient Create popup for creating new contacts
            window.openCreateContact = function() {
                var diseaseId = '@Model.CurrentDiseaseId';
                var width = 1200;
                var height = 800;
                var left = (screen.width - width) / 2;
                var top = (screen.height - height) / 2;
                
                var popup = window.open(
                    '/Patients/Create?mode=popup&returnContext=exposure&diseaseId=' + diseaseId,
                    'CreateContact',
                    'width=' + width + ',height=' + height + ',left=' + left + ',top=' + top + ',resizable=yes,scrollbars=yes'
                );
                
                if (popup) {
                    popup.focus();
                } else {
                    alert('Please allow popups for this site to create contacts.');
                }
            };

            // Callback when contact is created in popup
            window.contactCreated = function(caseId, caseFriendlyId, patientName) {                // Update the autocomplete input
                $('#caseAutocomplete').val(caseFriendlyId + ' - ' + patientName);
                
                // Set the hidden field
                $('#relatedCaseIdHidden').val(caseId);
                
                // Update the selected case info display
                $('#selectedCaseDisplay').text(caseFriendlyId + ' - ' + patientName);
                $('#selectedCaseNotification').text('Just created');
                $('#selectedCaseDisease').text('Contact');
                $('#selectedCaseInfo').show();
                
                // Show success message
                alert('Contact created successfully: ' + patientName);
            };

            // Initialize Event Autocomplete
            const eventInput = $("#eventAutocomplete");
            if (eventInput.length) {                eventInput.autocomplete({
                    source: function(request, response) {                        $.ajax({
                            url: "/api/events/search",
                            data: { term: request.term },
                            success: function(data) {                                if (data && data.length > 0) {
                                    response($.map(data, function(item) {
                                        var label = item.name;
                                        if (item.startDate) {
                                            label += ' (' + item.startDate + ')';
                                        }
                                        if (item.location) {
                                            label += ' at ' + item.location;
                                        }
                                        
                                        return {
                                            label: label,
                                            value: item.name,
                                            eventId: item.id,
                                            name: item.name,
                                            startDate: item.startDate,
                                            location: item.location,
                                            eventType: item.eventType
                                        };
                                    }));
                                } else {
                                    response([{ label: 'No matching events found', value: '', disabled: true }]);
                                }
                            },
                            error: function(xhr, status, error) {                                response([]);
                            }
                        });
                    },
                    minLength: 2,
                    select: function(event, ui) {
                        if (ui.item.disabled || !ui.item.eventId) {
                            return false;
                        }                        $('#eventIdHidden').val(ui.item.eventId);
                        $('#selectedEventDisplay').text(ui.item.name);
                        $('#selectedEventDate').text(ui.item.startDate || 'Not set');
                        $('#selectedEventLocation').text(ui.item.location || 'Not specified');
                        $('#selectedEventInfo').show();
                        return true;
                    }
                });            }

            // Initialize Location Autocomplete
            const locationInput = $("#locationAutocomplete");
            if (locationInput.length) {                locationInput.autocomplete({
                    source: function(request, response) {                        $.ajax({
                            url: "/api/locations/search",
                            data: { term: request.term },
                            success: function(data) {                                if (data && data.length > 0) {
                                    response($.map(data, function(item) {
                                        var label = item.name;
                                        if (item.address) {
                                            label += ' - ' + item.address;
                                        }
                                        if (item.locationType) {
                                            label += ' [' + item.locationType + ']';
                                        }
                                        
                                        return {
                                            label: label,
                                            value: item.name,
                                            locationId: item.id,
                                            name: item.name,
                                            address: item.address,
                                            locationType: item.locationType
                                        };
                                    }));
                                } else {
                                    response([{ label: 'No matching locations found', value: '', disabled: true }]);
                                }
                            },
                            error: function(xhr, status, error) {                                response([]);
                            }
                        });
                    },
                    minLength: 2,
                    select: function(event, ui) {
                        if (ui.item.disabled || !ui.item.locationId) {
                            return false;
                        }                        $('#locationIdHidden').val(ui.item.locationId);
                        $('#selectedLocationDisplay').text(ui.item.name);
                        $('#selectedLocationAddress').text(ui.item.address || 'Not specified');
                        $('#selectedLocationType').text(ui.item.locationType || 'Not specified');
                        $('#selectedLocationInfo').show();
                        return true;
                    }
                });            }        });
    </script>
}
