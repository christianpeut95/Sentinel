@page "{id:guid}"
@model Sentinel.Pages.Cases.ClassificationHistoryModel
@{
    ViewData["Title"] = "Classification History";
    ViewData["Subtitle"] = $"Case {Model.Case.FriendlyId}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 style="color: var(--forest); font-weight: 600; font-size: 2rem; margin-bottom: 0.5rem;">
            <i class="bi bi-clock-history" style="color: var(--signal-dk);"></i>
            Classification History
        </h1>
        <div style="color: var(--graphite); font-size: 0.875rem;">
            <a asp-page="./Details" asp-route-id="@Model.Case.Id" style="color: var(--forest); text-decoration: none;">
                <i class="bi bi-arrow-left"></i> Back to Case @Model.Case.FriendlyId
            </a>
        </div>
    </div>
    <div class="d-flex gap-2">
        <form method="post" asp-page="/Cases/Details" asp-page-handler="EvaluateDefinitions" asp-route-id="@Model.Case.Id">
            <button type="submit" class="btn btn-sm" style="background: var(--signal-dk); color: white; border: none; font-weight: 600;">
                <i class="bi bi-check2-circle"></i> Evaluate Definitions
            </button>
        </form>
        <a asp-page="./Details" asp-route-id="@Model.Case.Id" class="btn btn-sentinel-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to Case
        </a>
    </div>
</div>

@if (Model.ClassificationHistory.Any())
{
    <div class="timeline" style="position: relative; padding-left: 3rem; max-width: 1200px;">
        @foreach (var history in Model.ClassificationHistory)
        {
            var isMatch = history.IsMatch;
            var wasApplied = history.WasApplied;
            var borderColor = wasApplied ? "var(--signal-dk)" : (isMatch ? "var(--status-info)" : "var(--slate)");
            var bgColor = wasApplied ? "var(--signal-lt)" : "white";
            var iconColor = wasApplied ? "var(--signal-dk)" : (isMatch ? "var(--status-info)" : "var(--slate)");
            var icon = wasApplied ? "check-circle-fill" : (isMatch ? "info-circle-fill" : "x-circle");

            <div style="position: relative; margin-bottom: 2rem; padding-left: 1.5rem;">
                @* Timeline dot *@
                <div style="position: absolute; left: -3rem; top: 0; width: 20px; height: 20px; background: @iconColor; border: 4px solid white; border-radius: 50%; box-shadow: 0 0 0 3px @iconColor;"></div>

                @* Timeline line *@
                @if (history != Model.ClassificationHistory.Last())
                {
                    <div style="position: absolute; left: calc(-3rem + 6px); top: 20px; width: 3px; height: calc(100% + 2rem); background: var(--hairline);"></div>
                }

                @* History Card *@
                <div class="sentinel-card" style="border: 3px solid @borderColor; background: @bgColor;">
                    <div class="sentinel-card-body">
                        @* Header *@
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div style="flex: 1;">
                                <h3 style="color: var(--forest); font-weight: 600; font-size: 1.25rem; margin-bottom: 0.75rem;">
                                    <i class="bi bi-@icon" style="color: @iconColor;"></i>
                                    @if (history.CaseDefinition != null)
                                    {
                                        <text>@history.CaseDefinition.Name</text>
                                    }
                                    else
                                    {
                                        <text>Unknown Definition</text>
                                    }
                                </h3>

                                <div class="d-flex gap-2 flex-wrap align-items-center">
                                    @if (wasApplied)
                                    {
                                        <span class="chip chip-success">
                                            <i class="bi bi-check-circle-fill"></i>
                                            Applied
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="chip chip-secondary">
                                            <i class="bi bi-eye-fill"></i>
                                            Evaluation Only
                                        </span>
                                    }

                                    @if (isMatch)
                                    {
                                        <span class="chip chip-success">
                                            <i class="bi bi-check-circle-fill"></i>
                                            Match
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="chip chip-secondary">
                                            <i class="bi bi-x-circle"></i>
                                            No Match
                                        </span>
                                    }

                                    @if (history.IsAutoClassified)
                                    {
                                        <span class="chip chip-info">
                                            <i class="bi bi-lightning-fill"></i>
                                            Auto-Classified
                                        </span>
                                    }

                                    @if (history.RecommendedAction != Sentinel.Models.CaseDefinitions.RecommendedAction.None)
                                    {
                                        var actionBadge = history.RecommendedAction switch
                                        {
                                            Sentinel.Models.CaseDefinitions.RecommendedAction.AutoClassify => ("chip-success", "Auto-Classify"),
                                            Sentinel.Models.CaseDefinitions.RecommendedAction.SuggestClassification => ("chip-warning", "Suggest"),
                                            Sentinel.Models.CaseDefinitions.RecommendedAction.FlagForReview => ("chip-info", "Review"),
                                            _ => ("chip-secondary", "No Action")
                                        };
                                        <span class="chip @actionBadge.Item1">
                                            <i class="bi bi-tag-fill"></i>
                                            @actionBadge.Item2
                                        </span>
                                    }
                                </div>
                            </div>

                            @* Timestamp *@
                            <div style="text-align: right; min-width: 160px;">
                                <div style="font-size: 0.875rem; color: var(--graphite); margin-bottom: 0.25rem;">
                                    <i class="bi bi-calendar-event"></i>
                                    @history.EvaluationDate.ToString("dd MMM yyyy")
                                </div>
                                <div style="font-size: 0.875rem; color: var(--graphite);">
                                    <i class="bi bi-clock"></i>
                                    @history.EvaluationDate.ToString("HH:mm:ss")
                                </div>
                            </div>
                        </div>

                        @* Status Change Info *@
                        @if (wasApplied && (history.FromConfirmationStatus != null || history.ToConfirmationStatus != null))
                        {
                            <div style="background: white; border-left: 4px solid var(--signal-dk); padding: 1rem; border-radius: 6px; margin-bottom: 1rem;">
                                <div style="font-size: 0.75rem; font-family: var(--f-mono); text-transform: uppercase; letter-spacing: 0.08em; color: var(--graphite); margin-bottom: 0.75rem; font-weight: 600;">
                                    Status Change
                                </div>
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    @if (history.FromConfirmationStatus != null)
                                    {
                                        <span class="chip chip-secondary" style="font-size: 0.9rem; padding: 0.5rem 1rem;">@history.FromConfirmationStatus.Name</span>
                                    }
                                    else
                                    {
                                        <span class="chip chip-neutral" style="font-size: 0.9rem; padding: 0.5rem 1rem;">Not Set</span>
                                    }
                                    <i class="bi bi-arrow-right" style="color: var(--signal-dk); font-size: 1.5rem;"></i>
                                    @if (history.ToConfirmationStatus != null)
                                    {
                                        <span class="chip chip-success" style="font-size: 0.9rem; padding: 0.5rem 1rem;">@history.ToConfirmationStatus.Name</span>
                                    }
                                    else
                                    {
                                        <span class="chip chip-neutral" style="font-size: 0.9rem; padding: 0.5rem 1rem;">Unknown</span>
                                    }
                                </div>
                                <div class="d-flex flex-column gap-2">
                                    @if (!string.IsNullOrWhiteSpace(history.ClassifiedByUserId))
                                    {
                                        var displayName = Model.UserDisplayNames.ContainsKey(history.ClassifiedByUserId) 
                                            ? Model.UserDisplayNames[history.ClassifiedByUserId] 
                                            : "Unknown User";

                                        <div style="font-size: 0.875rem; color: var(--forest-2);">
                                            <i class="bi bi-person-fill me-1"></i>
                                            Classified by: <strong>@displayName</strong>
                                        </div>
                                    }
                                    @if (history.ClassifiedDate.HasValue)
                                    {
                                        <div style="font-size: 0.875rem; color: var(--forest-2);">
                                            <i class="bi bi-calendar-check me-1"></i>
                                            Applied on: <strong>@history.ClassifiedDate.Value.ToString("dd MMM yyyy HH:mm:ss")</strong>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @* Rationale *@
                        @if (!string.IsNullOrWhiteSpace(history.Rationale))
                        {
                            <div style="background: var(--signal-lt); border-left: 4px solid var(--signal-dk); padding: 1rem; border-radius: 6px; margin-bottom: 1rem;">
                                <div style="font-size: 0.75rem; font-family: var(--f-mono); text-transform: uppercase; letter-spacing: 0.08em; color: var(--graphite); margin-bottom: 0.75rem; font-weight: 600;">
                                    Rationale
                                </div>
                                <div style="color: var(--forest); font-size: 0.95rem; line-height: 1.6; white-space: pre-wrap;">
                                    @history.Rationale
                                </div>
                            </div>
                        }

                        @* Criteria Details (Collapsible) *@
                        @if (!string.IsNullOrWhiteSpace(history.CriteriaResultJson))
                        {
                            <details style="margin-top: 1rem;">
                                <summary style="cursor: pointer; color: var(--forest); font-weight: 600; padding: 0.75rem; background: var(--chalk); border: 1px solid var(--hairline); border-radius: 6px; user-select: none;">
                                    <i class="bi bi-list-check me-2"></i>
                                    View Detailed Criteria Results
                                </summary>
                                <div style="margin-top: 0.75rem; padding: 1rem; background: white; border: 1px solid var(--hairline); border-radius: 6px; font-family: var(--f-mono); font-size: 0.875rem; max-height: 400px; overflow-y: auto;">
                                    <pre style="margin: 0; white-space: pre-wrap; word-wrap: break-word; color: var(--forest);">@history.CriteriaResultJson</pre>
                                </div>
                            </details>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="sentinel-card" style="text-align: center; padding: 5rem;">
        <i class="bi bi-clock-history" style="font-size: 5rem; display: block; margin-bottom: 1.5rem; color: var(--hairline);"></i>
        <h3 style="color: var(--graphite); font-size: 1.25rem; font-weight: 500; margin-bottom: 0.5rem;">
            No classification history found for this case
        </h3>
        <p style="color: var(--slate); font-size: 0.95rem; margin-bottom: 2rem;">
            Use the "Evaluate Definitions" button to run case definition evaluations.
        </p>
        <form method="post" asp-page="/Cases/Details" asp-page-handler="EvaluateDefinitions" asp-route-id="@Model.Case.Id">
            <button type="submit" class="btn-sentinel-primary">
                <i class="bi bi-check2-circle"></i> Evaluate Definitions Now
            </button>
        </form>
    </div>
}
