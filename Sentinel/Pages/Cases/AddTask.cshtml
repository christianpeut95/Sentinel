@page
@model Sentinel.Pages.Cases.AddTaskModel
@using Sentinel.Models
@{
    Layout = null;
    var caseData = Model.Case;
}
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Task - @caseData.FriendlyId</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
    <style>
        :root {
            --forest: #0C2A20;
            --signal-dk: #159C6E;
            --signal-lt: #D9F2E5;
            --chalk: #FBFAF5;
            --bone: #F5F3EC;
            --hairline: #D8D4C4;
            --graphite: #4A5A55;
            --slate: #6B7A78;
            --status-outbreak: #E04D2B;
            --f-sans: "Geist", ui-sans-serif, system-ui, -apple-system, sans-serif;
            --radius-sm: 10px;
        }
        body {
            background: var(--bone);
            padding: 0.75rem;
            font-family: var(--f-sans);
            font-size: 0.875rem;
        }
        .add-container {
            background: var(--chalk);
            border-radius: var(--radius-sm);
            padding: 1rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
            max-height: calc(100vh - 1.5rem);
            overflow-y: auto;
            border: 1px solid var(--hairline);
        }
        .header {
            border-bottom: 2px solid var(--hairline);
            padding-bottom: 0.6rem;
            margin-bottom: 0.75rem;
            position: sticky;
            top: 0;
            background: var(--chalk);
            z-index: 10;
        }
        .header h1 {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--forest);
            margin-bottom: 0.25rem;
        }
        .case-context {
            background: var(--signal-lt);
            border-radius: var(--radius-sm);
            padding: 0.6rem;
            margin-bottom: 0.75rem;
            font-size: 0.8rem;
            border: 1px solid var(--signal-dk);
        }
        .nav-tabs {
            border-bottom: 2px solid var(--hairline);
            margin-bottom: 1rem;
        }
        .nav-tabs .nav-link {
            color: var(--slate);
            border: none;
            padding: 0.5rem 1rem;
            font-weight: 600;
            font-size: 0.85rem;
        }
        .nav-tabs .nav-link:hover {
            color: var(--forest);
            border: none;
        }
        .nav-tabs .nav-link.active {
            color: var(--forest);
            background: transparent;
            border: none;
            border-bottom: 3px solid var(--signal-dk);
        }
        .form-label {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--graphite);
            margin-bottom: 0.25rem;
        }
        .form-label .required {
            color: var(--status-outbreak);
        }
        .form-control, .form-select {
            font-size: 0.85rem;
            padding: 0.4rem 0.6rem;
            border: 1px solid var(--hairline);
            border-radius: var(--radius-sm);
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--signal-dk);
            box-shadow: 0 0 0 3px rgba(61, 213, 152, 0.1);
        }
        .btn {
            font-size: 0.8rem;
            padding: 0.4rem 0.85rem;
            border-radius: var(--radius-sm);
            font-weight: 600;
        }
        .btn-success {
            background: var(--signal-dk);
            border-color: var(--signal-dk);
            color: white;
        }
        .btn-success:hover {
            background: #0F7C56;
            border-color: #0F7C56;
        }
        .btn-secondary {
            background: var(--chalk);
            border-color: var(--hairline);
            color: var(--forest);
        }
        .btn-secondary:hover {
            background: var(--bone);
            border-color: var(--signal-dk);
        }
        .btn-toolbar {
            margin-top: 0.75rem;
            padding-top: 0.75rem;
            border-top: 1px solid var(--hairline);
            display: flex;
            gap: 0.4rem;
            justify-content: space-between;
            position: sticky;
            bottom: 0;
            background: var(--chalk);
            z-index: 10;
        }
        .list-group-item {
            font-size: 0.85rem;
            padding: 0.6rem;
            margin-bottom: 0.5rem;
            border-radius: var(--radius-sm);
            border: 1px solid var(--hairline);
        }
        .list-group-item:hover {
            background: var(--signal-lt);
        }
        .badge {
            font-size: 0.7rem;
            padding: 0.25rem 0.5rem;
        }
        .alert {
            font-size: 0.8rem;
            padding: 0.5rem;
            margin-bottom: 0.75rem;
        }
        .survey-section {
            background: var(--bone);
            border-radius: var(--radius-sm);
            padding: 0.75rem;
            margin-top: 0.75rem;
            border: 1px solid var(--hairline);
        }
        .form-text {
            font-size: 0.7rem;
            color: var(--graphite);
        }
        .text-muted {
            color: var(--slate) !important;
        }
        /* Priority badge colors - map to Sentinel palette */
        .badge.bg-danger {
            background: var(--status-outbreak) !important;
        }
        .badge.bg-warning {
            background: #F59E0B !important;
            color: var(--forest) !important;
        }
        .badge.bg-secondary {
            background: var(--graphite) !important;
        }
        .badge.bg-info {
            background: var(--signal-dk) !important;
        }
    </style>
</head>
<body>
    <div class="add-container">
        <div class="header">
            <h1><i class="bi bi-plus-circle me-2"></i>Add Task</h1>
            <small class="text-muted">Case: <strong>@caseData.FriendlyId</strong></small>
        </div>

        <!-- Case Context -->
        <div class="case-context">
            <div class="row g-2">
                <div class="col-md-6">
                    <strong>Patient:</strong> @caseData.Patient?.GivenName @caseData.Patient?.FamilyName
                </div>
                <div class="col-md-6">
                    <strong>Disease:</strong> @caseData.Disease?.Name
                </div>
            </div>
        </div>

        <!-- Tab Navigation -->
        <ul class="nav nav-tabs" id="taskTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="template-tab" data-bs-toggle="tab" data-bs-target="#template-pane" type="button" role="tab">
                    <i class="bi bi-layout-text-sidebar me-1"></i>From Template
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="manual-tab" data-bs-toggle="tab" data-bs-target="#manual-pane" type="button" role="tab">
                    <i class="bi bi-pencil me-1"></i>Manual Entry
                </button>
            </li>
        </ul>

        <!-- Tab Content -->
        <div class="tab-content" id="taskTabContent">
            <!-- Template Tab -->
            <div class="tab-pane fade show active" id="template-pane" role="tabpanel">
                @if (Model.AvailableTaskTemplates.Any())
                {
                    <p class="text-muted mb-3">
                        <i class="bi bi-info-circle me-1"></i>
                        Select a task template. The task will be assigned to you by default.
                    </p>
                    <form method="post" asp-page-handler="Template" asp-route-caseId="@Model.CaseId">
                        <div class="list-group">
                            @foreach (var template in Model.AvailableTaskTemplates)
                            {
                                <label class="list-group-item">
                                    <div class="d-flex w-100 justify-content-between align-items-start">
                                        <div class="form-check">
                                            <input asp-for="SelectedTaskTemplateId" value="@template.Id" class="form-check-input" type="radio" required />
                                            <label class="form-check-label fw-bold">
                                                @template.Name
                                            </label>
                                        </div>
                                        <div>
                                            @{
                                                var priorityClass = template.DefaultPriority switch
                                                {
                                                    TaskPriority.Urgent => "bg-danger",
                                                    TaskPriority.High => "bg-warning text-dark",
                                                    TaskPriority.Medium => "bg-secondary",
                                                    TaskPriority.Low => "bg-info",
                                                    _ => "bg-secondary"
                                                };
                                            }
                                            <span class="badge @priorityClass">@template.DefaultPriority</span>
                                            @if (template.TaskType != null)
                                            {
                                                <span class="badge bg-secondary">@template.TaskType.Name</span>
                                            }
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(template.Description))
                                    {
                                        <small class="text-muted d-block mt-2">@template.Description</small>
                                    }
                                    @if (!string.IsNullOrEmpty(template.Instructions))
                                    {
                                        <small class="text-muted d-block mt-1">
                                            <i class="bi bi-info-circle"></i> @template.Instructions
                                        </small>
                                    }
                                </label>
                            }
                        </div>
                        
                        <!-- User Assignment Section -->
                        <div class="mt-3 p-3" style="background: #f7fafc; border-radius: 6px;">
                            <h6 style="font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem;">
                                <i class="bi bi-person me-1"></i>Assignment
                            </h6>
                            <label for="templateAssignedToUserSearch" class="form-label" style="font-size: 0.75rem; font-weight: 600;">Assign To User</label>
                            <input type="text" id="templateAssignedToUserSearch" class="form-control" 
                                   placeholder="Type to search users..." autocomplete="off" />
                            <input type="hidden" asp-for="AssignedToUserId" id="templateAssignedToUserId" />
                            <small class="form-text text-muted">Leave blank to assign to yourself</small>
                        </div>

                        <div class="btn-toolbar">
                            <button type="button" class="btn btn-secondary" onclick="window.close()">
                                <i class="bi bi-x-circle me-1"></i>Cancel
                            </button>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-plus-circle me-1"></i>Add Selected Task
                            </button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        No task templates available for this disease. Use Manual Entry to create a custom task.
                    </div>
                }
            </div>

            <!-- Manual Tab -->
            <div class="tab-pane fade" id="manual-pane" role="tabpanel">
                <p class="text-muted mb-3">
                    <i class="bi bi-info-circle me-1"></i>
                    Create a custom task. The task will be assigned to you by default.
                </p>
                <form method="post" asp-page-handler="Manual" asp-route-caseId="@Model.CaseId">
                    <div class="mb-3">
                        <label asp-for="ManualTitle" class="form-label">
                            Task Title <span class="required">*</span>
                        </label>
                        <input asp-for="ManualTitle" class="form-control" required placeholder="e.g., Follow-up phone call" maxlength="200" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="ManualDescription" class="form-label">Description</label>
                        <textarea asp-for="ManualDescription" class="form-control" rows="2" placeholder="Details about what needs to be done..."></textarea>
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label asp-for="ManualTaskTypeId" class="form-label">
                                Task Type <span class="required">*</span>
                            </label>
                            <select asp-for="ManualTaskTypeId" asp-items="Model.TaskTypesList" class="form-select" required>
                                <option value="">Select Type</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ManualPriority" class="form-label">
                                Priority <span class="required">*</span>
                            </label>
                            <select asp-for="ManualPriority" class="form-select" required>
                                <option value="1">Medium</option>
                                <option value="0">Low</option>
                                <option value="2">High</option>
                                <option value="3">Urgent</option>
                            </select>
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label asp-for="ManualDueDate" class="form-label">Due Date</label>
                            <input asp-for="ManualDueDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label for="assignedToUserSearch" class="form-label">Assign To User</label>
                            <input type="text" id="assignedToUserSearch" class="form-control" 
                                   placeholder="Type to search users..." autocomplete="off" />
                            <input type="hidden" asp-for="AssignedToUserId" id="assignedToUserId" />
                            <small class="form-text text-muted">Leave blank to assign to yourself</small>
                        </div>
                    </div>

                    <!-- Survey Configuration -->
                    <div class="survey-section">
                        <h6 class="mb-2" style="font-size: 0.85rem; font-weight: 600;">
                            <i class="bi bi-clipboard-check me-1"></i>Survey (Optional)
                        </h6>
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="includeSurvey" />
                            <label class="form-check-label" for="includeSurvey" style="font-size: 0.8rem;">
                                Include a survey with this task
                            </label>
                        </div>

                        <div id="surveyOptions" style="display: none;">
                            <div class="mb-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="surveySource" id="useLibrary" value="library" checked />
                                    <label class="form-check-label" for="useLibrary" style="font-size: 0.8rem;">
                                        Use Survey Library
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="surveySource" id="useCustom" value="custom" />
                                    <label class="form-check-label" for="useCustom" style="font-size: 0.8rem;">
                                        Custom Survey JSON
                                    </label>
                                </div>
                            </div>

                            <div id="librarySection">
                                <label asp-for="SurveyTemplateId" class="form-label">Survey Template</label>
                                <select asp-for="SurveyTemplateId" asp-items="Model.SurveyTemplatesList" class="form-select">
                                    <option value="">Select Template</option>
                                </select>
                            </div>

                            <div id="customSection" style="display: none;">
                                <label asp-for="CustomSurveyJson" class="form-label">Survey JSON</label>
                                <textarea asp-for="CustomSurveyJson" class="form-control font-monospace" rows="4" placeholder='{"title": "My Survey", "elements": [...]}'></textarea>
                                <small class="form-text text-muted">
                                    <a href="https://surveyjs.io/form-library/examples/overview/reactjs" target="_blank">SurveyJS Examples</a>
                                </small>
                            </div>
                        </div>
                    </div>

                    <div class="btn-toolbar">
                        <button type="button" class="btn btn-secondary" onclick="window.close()">
                            <i class="bi bi-x-circle me-1"></i>Cancel
                        </button>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-plus-circle me-1"></i>Create Task
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
    <style>
        /* jQuery UI Autocomplete styling */
        .ui-autocomplete {
            max-height: 200px;
            overflow-y: auto;
            overflow-x: hidden;
            font-size: 0.85rem;
            z-index: 9999 !important;
        }
        .ui-menu-item {
            padding: 0.4rem 0.6rem;
        }
    </style>
    <script>
        // User autocomplete for assignment
        $(document).ready(function() {
            // Manual task user autocomplete
            $("#assignedToUserSearch").autocomplete({
                source: function(request, response) {
                    $.ajax({
                        url: '/api/Patients/SearchUsers',
                        data: { term: request.term },
                        dataType: 'json',
                        success: function(data) {
                            response(data.map(function(item) {
                                return {
                                    label: item.text,
                                    value: item.text,
                                    id: item.id
                                };
                            }));
                        },
                        error: function(xhr, status, error) {                            response([]);
                        }
                    });
                },
                minLength: 2,
                select: function(event, ui) {
                    $("#assignedToUserId").val(ui.item.id);
                    return true;
                },
                change: function(event, ui) {
                    // If field is cleared, clear the hidden ID field
                    if (!ui.item) {
                        $("#assignedToUserId").val('');
                    }
                }
            });

            // Template task user autocomplete
            $("#templateAssignedToUserSearch").autocomplete({
                source: function(request, response) {
                    $.ajax({
                        url: '/api/Patients/SearchUsers',
                        data: { term: request.term },
                        dataType: 'json',
                        success: function(data) {
                            response(data.map(function(item) {
                                return {
                                    label: item.text,
                                    value: item.text,
                                    id: item.id
                                };
                            }));
                        },
                        error: function(xhr, status, error) {                            response([]);
                        }
                    });
                },
                minLength: 2,
                select: function(event, ui) {
                    $("#templateAssignedToUserId").val(ui.item.id);
                    return true;
                },
                change: function(event, ui) {
                    // If field is cleared, clear the hidden ID field
                    if (!ui.item) {
                        $("#templateAssignedToUserId").val('');
                    }
                }
            });
        });

        // Survey toggle
        document.getElementById('includeSurvey').addEventListener('change', function() {
            document.getElementById('surveyOptions').style.display = this.checked ? 'block' : 'none';
        });

        // Survey source toggle
        document.querySelectorAll('input[name="surveySource"]').forEach(radio => {
            radio.addEventListener('change', function() {
                if (this.value === 'library') {
                    document.getElementById('librarySection').style.display = 'block';
                    document.getElementById('customSection').style.display = 'none';
                } else {
                    document.getElementById('librarySection').style.display = 'none';
                    document.getElementById('customSection').style.display = 'block';
                }
            });
        });
    </script>
</body>
</html>
