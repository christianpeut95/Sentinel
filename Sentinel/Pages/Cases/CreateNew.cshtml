@page
@model Sentinel.Pages.Cases.CreateNewModel

@{
    ViewData["Title"] = "Create Case";
    Layout = "~/Pages/Shared/_LayoutSentinel.cshtml";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Cases</a></li>
        <li class="breadcrumb-item active">Create Case</li>
    </ol>
</nav>

<div class="create-case-container">
    <h1 style="font-size: 28px; font-weight: 600; color: var(--forest); margin-bottom: 2rem; font-family: var(--f-sans);">
        <i class="bi bi-plus-circle me-2"></i>Create New Case
    </h1>

    <!-- Progress Steps -->
    <div class="progress-steps">
        <div class="step active" data-step="1">
            <div class="step-circle">1</div>
            <div class="step-label">Patient</div>
        </div>
        <div class="step" data-step="2">
            <div class="step-circle">2</div>
            <div class="step-label">Case Details</div>
        </div>
        <div class="step" data-step="3">
            <div class="step-circle">3</div>
            <div class="step-label">Lab Results</div>
        </div>
        <div class="step" data-step="4">
            <div class="step-circle">4</div>
            <div class="step-label">Exposures</div>
        </div>
        <div class="step" data-step="5">
            <div class="step-circle">5</div>
            <div class="step-label">Review</div>
        </div>
    </div>

    <form id="createCaseForm" method="post">
        <!-- Step 1: Patient Selection -->
        <div class="step-content active" data-step="1">
            <h2 style="font-size: 20px; font-weight: 600; margin-bottom: 1.5rem; color: var(--forest); font-family: var(--f-sans);">Select or Create Patient</h2>
            
            <div id="patientSearchSection">
                <div class="search-box">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" 
                           id="patientSearch" 
                           class="search-input" 
                           placeholder="Search by name, date of birth, or ID..." 
                           autocomplete="off">
                    <div id="searchResults" class="search-results"></div>
                </div>

                <div class="create-patient-prompt">
                    <p>Can't find the patient?</p>
                    <a asp-page="/Patients/Create" asp-route-returnUrl="@Url.Page("/Cases/CreateNew")" class="btn-modern btn-secondary">
                        <i class="bi bi-person-plus"></i>
                        Create New Patient
                    </a>
                </div>
            </div>

            <div id="selectedPatientSection" style="display: none;">
                <div class="selected-patient-card">
                    <div class="patient-info">
                        <h4 id="selectedPatientName"></h4>
                        <p id="selectedPatientDetails"></p>
                    </div>
                    <button type="button" class="btn-change" onclick="changePatient()">
                        <i class="bi bi-arrow-left-right"></i>
                        Change
                    </button>
                </div>

                <!-- Patient Details Review Section -->
                <div id="patientReviewSection" class="mt-3" style="display: none;">
                    <div class="card border-primary">
                        <div class="card-header bg-primary bg-opacity-10">
                            <div class="d-flex justify-content-between align-items-center">
                                <h6 class="mb-0">
                                    <i class="bi bi-person-check me-2"></i>Review Patient Details
                                </h6>
                                <button type="button" class="btn btn-sm btn-outline-primary" id="editPatientDetailsBtn">
                                    <i class="bi bi-pencil me-1"></i>Edit Details
                                </button>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="alert alert-info mb-3">
                                <i class="bi bi-info-circle me-2"></i>
                                Please review the patient details below. You can edit them if needed before creating the case.
                            </div>

                            <!-- Patient Details Display -->
                            <div id="patientDetailsDisplay">
                                <!-- Basic Information -->
                                <div class="mb-4">
                                    <h6 class="text-uppercase text-muted mb-3" style="font-size: 12px; font-weight: 600; letter-spacing: 0.5px;">
                                        <i class="bi bi-person-badge me-2"></i>Basic Information
                                    </h6>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label text-muted small">Name</label>
                                            <div id="patientNameDisplay" class="fw-semibold">-</div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label text-muted small">Date of Birth</label>
                                            <div id="patientDOBDisplay" class="fw-semibold">-</div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label text-muted small">Gender</label>
                                            <div id="patientGenderDisplay" class="fw-semibold">-</div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label text-muted small">Sex at Birth</label>
                                            <div id="patientSexAtBirthDisplay" class="fw-semibold">-</div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Contact Information -->
                                <div class="mb-4">
                                    <h6 class="text-uppercase text-muted mb-3" style="font-size: 12px; font-weight: 600; letter-spacing: 0.5px;">
                                        <i class="bi bi-telephone me-2"></i>Contact Information
                                    </h6>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label text-muted small">Email</label>
                                            <div id="patientEmailDisplay" class="fw-semibold">-</div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label text-muted small">Mobile Phone</label>
                                            <div id="patientMobileDisplay" class="fw-semibold">-</div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label text-muted small">Home Phone</label>
                                            <div id="patientHomePhoneDisplay" class="fw-semibold">-</div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Address -->
                                <div class="mb-4">
                                    <h6 class="text-uppercase text-muted mb-3" style="font-size: 12px; font-weight: 600; letter-spacing: 0.5px;">
                                        <i class="bi bi-geo-alt me-2"></i>Address
                                    </h6>
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label class="form-label text-muted small">Home Address</label>
                                            <div id="patientAddressDisplay" class="fw-semibold">-</div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Demographics -->
                                <div class="mb-4">
                                    <h6 class="text-uppercase text-muted mb-3" style="font-size: 12px; font-weight: 600; letter-spacing: 0.5px;">
                                        <i class="bi bi-globe me-2"></i>Demographics
                                    </h6>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label text-muted small">Country of Birth</label>
                                            <div id="patientCountryOfBirthDisplay" class="fw-semibold">-</div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label text-muted small">Language Spoken at Home</label>
                                            <div id="patientLanguageDisplay" class="fw-semibold">-</div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label text-muted small">Ethnicity</label>
                                            <div id="patientEthnicityDisplay" class="fw-semibold">-</div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label text-muted small">Aboriginal & Torres Strait Islander Status</label>
                                            <div id="patientAtsiStatusDisplay" class="fw-semibold">-</div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label text-muted small">Occupation</label>
                                            <div id="patientOccupationDisplay" class="fw-semibold">-</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Patient Details Edit Form (Hidden by default) -->
                            <div id="patientDetailsEdit" style="display: none;">
                                <!-- Basic Information Section -->
                                <div class="mb-4">
                                    <h6 class="text-uppercase text-muted mb-3" style="font-size: 12px; font-weight: 600; letter-spacing: 0.5px;">
                                        <i class="bi bi-person-badge me-2"></i>Basic Information
                                    </h6>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label for="editGivenName" class="form-label">Given Name <span class="text-danger">*</span></label>
                                            <input type="text" id="editGivenName" class="form-control" required />
                                        </div>
                                        <div class="col-md-6">
                                            <label for="editFamilyName" class="form-label">Family Name <span class="text-danger">*</span></label>
                                            <input type="text" id="editFamilyName" class="form-control" required />
                                        </div>
                                        <div class="col-md-6">
                                            <label for="editDateOfBirth" class="form-label">Date of Birth</label>
                                            <input type="date" id="editDateOfBirth" class="form-control" />
                                        </div>
                                        <div class="col-md-6">
                                            <label for="editGender" class="form-label">Gender</label>
                                            <select id="editGender" class="form-select">
                                                <option value="">-- Select --</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="editSexAtBirth" class="form-label">Sex at Birth</label>
                                            <select id="editSexAtBirth" class="form-select">
                                                <option value="">-- Select --</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <!-- Contact Information Section -->
                                <div class="mb-4">
                                    <h6 class="text-uppercase text-muted mb-3" style="font-size: 12px; font-weight: 600; letter-spacing: 0.5px;">
                                        <i class="bi bi-telephone me-2"></i>Contact Information
                                    </h6>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label for="editEmailAddress" class="form-label">Email</label>
                                            <input type="email" id="editEmailAddress" class="form-control" />
                                        </div>
                                        <div class="col-md-6">
                                            <label for="editMobilePhone" class="form-label">Mobile Phone</label>
                                            <input type="tel" id="editMobilePhone" class="form-control" />
                                        </div>
                                        <div class="col-md-6">
                                            <label for="editHomePhone" class="form-label">Home Phone</label>
                                            <input type="tel" id="editHomePhone" class="form-control" />
                                        </div>
                                    </div>
                                </div>

                                <!-- Address Section -->
                                <div class="mb-4">
                                    <h6 class="text-uppercase text-muted mb-3" style="font-size: 12px; font-weight: 600; letter-spacing: 0.5px;">
                                        <i class="bi bi-geo-alt me-2"></i>Address
                                    </h6>
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label for="editAddress" class="form-label">Street Address</label>
                                            <input type="text" id="editAddress" class="form-control" placeholder="Type address or use autocomplete..." autocomplete="off" />
                                            <small class="form-text text-muted">Start typing to use address autocomplete</small>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="editCity" class="form-label">City/Suburb</label>
                                            <input type="text" id="editCity" class="form-control" />
                                        </div>
                                        <div class="col-md-3">
                                            <label for="editState" class="form-label">State</label>
                                            <select id="editState" class="form-select">
                                                <option value="">-- Select --</option>
                                                <option value="NSW">NSW</option>
                                                <option value="VIC">VIC</option>
                                                <option value="QLD">QLD</option>
                                                <option value="SA">SA</option>
                                                <option value="WA">WA</option>
                                                <option value="TAS">TAS</option>
                                                <option value="NT">NT</option>
                                                <option value="ACT">ACT</option>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label for="editPostcode" class="form-label">Postcode</label>
                                            <input type="text" id="editPostcode" class="form-control" maxlength="4" />
                                        </div>
                                    </div>
                                </div>

                                <!-- Demographics Section -->
                                <div class="mb-4">
                                    <h6 class="text-uppercase text-muted mb-3" style="font-size: 12px; font-weight: 600; letter-spacing: 0.5px;">
                                        <i class="bi bi-globe me-2"></i>Demographics
                                    </h6>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label for="editCountryOfBirth" class="form-label">Country of Birth</label>
                                            <select id="editCountryOfBirth" class="form-select">
                                                <option value="">-- Select --</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="editLanguageSpokenAtHome" class="form-label">Language Spoken at Home</label>
                                            <select id="editLanguageSpokenAtHome" class="form-select">
                                                <option value="">-- Select --</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="editEthnicity" class="form-label">Ethnicity</label>
                                            <select id="editEthnicity" class="form-select">
                                                <option value="">-- Select --</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="editAtsiStatus" class="form-label">Aboriginal & Torres Strait Islander Status</label>
                                            <select id="editAtsiStatus" class="form-select">
                                                <option value="">-- Select --</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="editOccupation" class="form-label">Occupation</label>
                                            <input type="text" id="editOccupation" class="form-control" placeholder="Type to search..." autocomplete="off" />
                                            <input type="hidden" id="editOccupationId" />
                                            <small class="form-text text-muted">Start typing to search for an occupation</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex gap-2 mt-3">
                                    <button type="button" class="btn btn-primary" id="savePatientDetailsBtn">
                                        <i class="bi bi-save me-1"></i>Save Changes
                                    </button>
                                    <button type="button" class="btn btn-secondary" id="cancelPatientEditBtn">
                                        <i class="bi bi-x me-1"></i>Cancel
                                    </button>
                                </div>
                            </div>

                            <div class="alert alert-success mt-3 mb-0" id="patientDetailsConfirmed" style="display: none;">
                                <i class="bi bi-check-circle me-2"></i>
                                Patient details confirmed. You can proceed with creating the case.
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <input type="hidden" id="selectedPatientId" name="PatientId" />

            <div class="step-actions">
                <div></div>
                <button type="button" class="btn-modern btn-primary" onclick="nextStep()" id="step1Next" disabled>
                    Next
                    <i class="bi bi-arrow-right"></i>
                </button>
            </div>
        </div>

        <!-- Step 2: Case Details -->
        <div class="step-content" data-step="2">
            <h2 style="font-size: 20px; font-weight: 600; margin-bottom: 1.5rem; color: var(--forest); font-family: var(--f-sans);">Case Information</h2>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Disease<span class="required">*</span></label>
                        <select id="diseaseSelect" name="DiseaseId" class="form-control-modern" required>
                            <option value="">-- Select Disease --</option>
                            @if (Model.Diseases != null)
                            {
                                @foreach (var disease in Model.Diseases)
                                {
                                    <option value="@disease.Id">@disease.Name</option>
                                }
                            }
                        </select>
                        <div class="form-hint">Select the disease associated with this case</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Confirmation Status</label>
                        <select name="ConfirmationStatusId" class="form-control-modern">
                            <option value="">-- Select Status --</option>
                            @if (Model.CaseStatuses != null)
                            {
                                @foreach (var status in Model.CaseStatuses)
                                {
                                    <option value="@status.Id">@status.Name</option>
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Date of Onset</label>
                        <input type="date" name="DateOfOnset" class="form-control-modern">
                        <div class="form-hint">When did symptoms first appear?</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Date of Notification</label>
                        <input type="date" name="DateOfNotification" class="form-control-modern" value="@DateTime.Today.ToString("yyyy-MM-dd")">
                        <div class="form-hint">When was this case reported?</div>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Clinical Notes</label>
                <textarea name="ClinicalNotes" class="form-control-modern" rows="4" placeholder="Enter any relevant clinical information..."></textarea>
            </div>

            <div class="step-actions">
                <button type="button" class="btn-modern btn-secondary" onclick="prevStep()">
                    <i class="bi bi-arrow-left"></i>
                    Back
                </button>
                <button type="button" class="btn-modern btn-primary" onclick="nextStep()">
                    Next
                    <i class="bi bi-arrow-right"></i>
                </button>
            </div>
        </div>

        <!-- Step 3: Lab Results (Optional) -->
        <div class="step-content" data-step="3">
            <h2 style="font-size: 20px; font-weight: 600; margin-bottom: 1.5rem; color: var(--forest); font-family: var(--f-sans);">Laboratory Results (Optional)</h2>
            
            <button type="button" class="btn-add" onclick="addLabResult()">
                <i class="bi bi-plus-circle"></i>
                Add Lab Result
            </button>

            <div id="labResultsContainer">
                <!-- Lab results will be added here -->
            </div>

            <div class="step-actions">
                <button type="button" class="btn-modern btn-secondary" onclick="prevStep()">
                    <i class="bi bi-arrow-left"></i>
                    Back
                </button>
                <button type="button" class="btn-modern btn-primary" onclick="nextStep()">
                    Next
                    <i class="bi bi-arrow-right"></i>
                </button>
            </div>
        </div>

    <!-- Step 4: Exposures (Optional) -->
        <div class="step-content" data-step="4">
            <h2 style="font-size: 20px; font-weight: 600; margin-bottom: 1.5rem; color: var(--forest); font-family: var(--f-sans);">Exposure Tracking (Optional)</h2>
            
            <!-- Exposure Guidance Alert (loaded dynamically) -->
            <div id="exposureGuidanceAlert" style="display: none;" class="alert alert-info mb-4">
                <div class="d-flex">
                    <div class="flex-shrink-0">
                        <i class="bi bi-info-circle fs-4 me-2"></i>
                    </div>
                    <div>
                        <h6 class="alert-heading mb-2">
                            <i class="bi bi-diagram-3 me-1"></i>Exposure Tracking Guidance
                        </h6>
                        <p id="exposureGuidanceText" class="mb-0" style="white-space: pre-wrap;"></p>
                    </div>
                </div>
            </div>

            <div id="exposureRequiredAlert" style="display: none;" class="alert alert-warning mb-4">
                <div class="d-flex">
                    <div class="flex-shrink-0">
                        <i class="bi bi-exclamation-triangle fs-4 me-2"></i>
                    </div>
                    <div>
                        <h6 class="alert-heading mb-2">Exposure Information Required</h6>
                        <p class="mb-0">This disease requires exposure tracking. Please provide details about where and when the exposure occurred.</p>
                    </div>
                </div>
            </div>
            
            <button type="button" class="btn-add" onclick="addExposure()">
                <i class="bi bi-plus-circle"></i>
                Add Exposure
            </button>

            <div id="exposuresContainer">
                <!-- Exposures will be added here -->
            </div>

            <div class="step-actions">
                <button type="button" class="btn-modern btn-secondary" onclick="prevStep()">
                    <i class="bi bi-arrow-left"></i>
                    Back
                </button>
                <button type="button" class="btn-modern btn-primary" onclick="nextStep()">
                    Next
                    <i class="bi bi-arrow-right"></i>
                </button>
            </div>
        </div>

        <!-- Step 5: Review & Submit -->
        <div class="step-content" data-step="5">
            <h2 style="font-size: 20px; font-weight: 600; margin-bottom: 1.5rem; color: var(--forest); font-family: var(--f-sans);">Review & Submit</h2>

            <div id="reviewSummary" style="background: var(--bone); padding: 2rem; border-radius: 10px; border: 1px solid var(--hairline);">
                <!-- Summary will be populated by JavaScript -->
            </div>

            <div class="step-actions">
                <button type="button" class="btn-modern btn-secondary" onclick="prevStep()">
                    <i class="bi bi-arrow-left"></i>
                    Back
                </button>
                <button type="submit" class="btn-modern btn-success">
                    <i class="bi bi-check-circle"></i>
                    Create Case
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
    
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-ui/dist/jquery-ui.min.js"></script>
<link rel="stylesheet" href="~/lib/jquery-ui/dist/themes/base/jquery-ui.min.css" />
<link href="~/lib/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/lib/select2/dist/js/select2.min.js"></script>
<script nonce="@GetCspNonce()">
    let currentStep = 1;
    let selectedPatient = null;
    let labResults = [];
    let exposures = [];
    let createdCaseId = null; // Store the created case ID

    $(document).ready(function() {
        // Populate dropdowns from Model
        var genders = @Html.Raw(Json.Serialize(Model.Genders));
        var sexAtBirths = @Html.Raw(Json.Serialize(Model.SexAtBirths));
        var countries = @Html.Raw(Json.Serialize(Model.Countries));
        var languages = @Html.Raw(Json.Serialize(Model.Languages));
        var Ancestries = @Html.Raw(Json.Serialize(Model.Ancestries));
        var atsiStatuses = @Html.Raw(Json.Serialize(Model.AtsiStatuses));
        
        // Populate Gender dropdown
        if (genders && genders.length > 0) {
            var $genderSelect = $('#editGender');
            $genderSelect.empty();
            $genderSelect.append('<option value="">-- Select --</option>');
            genders.forEach(function(gender) {
                $genderSelect.append('<option value="' + gender.id + '">' + gender.name + '</option>');
            });
        }

        // Populate Sex at Birth dropdown
        if (sexAtBirths && sexAtBirths.length > 0) {
            var $sexSelect = $('#editSexAtBirth');
            $sexSelect.empty();
            $sexSelect.append('<option value="">-- Select --</option>');
            sexAtBirths.forEach(function(sex) {
                $sexSelect.append('<option value="' + sex.id + '">' + sex.name + '</option>');
            });
        }

        // Populate Country of Birth dropdown
        if (countries && countries.length > 0) {
            var $countrySelect = $('#editCountryOfBirth');
            $countrySelect.empty();
            $countrySelect.append('<option value="">-- Select --</option>');
            countries.forEach(function(country) {
                $countrySelect.append('<option value="' + country.id + '">' + country.name + '</option>');
            });
        }

        // Populate Language dropdown
        if (languages && languages.length > 0) {
            var $languageSelect = $('#editLanguageSpokenAtHome');
            $languageSelect.empty();
            $languageSelect.append('<option value="">-- Select --</option>');
            languages.forEach(function(language) {
                $languageSelect.append('<option value="' + language.id + '">' + language.name + '</option>');
            });
        }

        // Populate Ethnicity dropdown
        if (Ancestries && Ancestries.length > 0) {
            var $ethnicitySelect = $('#editEthnicity');
            $ethnicitySelect.empty();
            $ethnicitySelect.append('<option value="">-- Select --</option>');
            Ancestries.forEach(function(ethnicity) {
                $ethnicitySelect.append('<option value="' + ethnicity.id + '">' + ethnicity.name + '</option>');
            });
        }

        // Populate ATSI Status dropdown
