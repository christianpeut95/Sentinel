                                                <span class="visually-hidden">Loading...</span>
                                            </div>
                                        </div>
                                        <iframe id="exposureFrame" style="width:100%; height:600px; border:none; display:block;"></iframe>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `);
                }
                
                // Get the iframe element
                const $iframe = $('#exposureFrame');
                const $loader = $('#exposureIframeLoader');
                
                // Show loader, hide iframe
                $loader.show();
                $iframe.hide();
                
                // Clear the iframe src first to force a clean reload
                $iframe.attr('src', 'about:blank');
                
                // Wait a moment, then load the new URL
                setTimeout(function() {
                    $iframe.attr('src', url);
                    
                    // Hide loader and show iframe when loaded
                    $iframe.on('load', function() {
                        $loader.hide();
                        $iframe.show();
                    });
                }, 100);
                
                // Show modal
                const modalElement = document.getElementById('exposureModal');
                const modal = new bootstrap.Modal(modalElement);
                modal.show();
                
                // Remove old listener if exists
                window.removeEventListener('message', handleExposureSaved);
                
                // Listen for success message from iframe
                window.addEventListener('message', handleExposureSaved);
                
                // Store modal reference for the handler
                window.currentExposureModal = modal;
                
                // Reset iframe when modal is closed manually
                modalElement.addEventListener('hidden.bs.modal', function() {
                    $iframe.attr('src', 'about:blank');
                }, { once: true });
            } else {
                // Fallback: open in new window
                window.open(url, 'AddExposure', 'width=800,height=600');
            }
        }

        // Separate function to handle exposure saved message
        function handleExposureSaved(event) {            if (event.data === 'exposureSaved') {                // Hide modal
                if (window.currentExposureModal) {
                    window.currentExposureModal.hide();
                }
                
                // Clear the iframe to prevent layout issues on next open
                setTimeout(function() {
                    $('#exposureFrame').attr('src', 'about:blank');
                }, 300);
                
                // Refresh the list
                loadExposures();
                
                // Show success toast
                showToast('Exposure added successfully!', 'success');
            }
        }

        function loadExposures() {
            if (!createdCaseId) return;
            
            $.ajax({
                url: `/api/cases/${createdCaseId}/exposures`,
                type: 'GET',
                success: function(results) {
                    exposures = results || [];
                    displayExposures();
                },
                error: function() {                }
            });
        }

        function displayExposures() {
            const $container = $('#exposuresContainer');
            
            if (exposures.length === 0) {
                $container.html('<p class="text-muted">No exposures added yet.</p>');
                return;
            }
            
            let html = '<div class="list-group mt-3">';
            exposures.forEach(exposure => {
                const startDate = exposure.exposureStartDate ? new Date(exposure.exposureStartDate).toLocaleDateString() : 'N/A';
                const endDate = exposure.exposureEndDate ? new Date(exposure.exposureEndDate).toLocaleDateString() : 'N/A';
                const location = exposure.locationName || exposure.eventName || 'Unknown location';
                
                html += `
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="mb-1">${location}</h6>
                                <p class="mb-1"><strong>Type:</strong> ${exposure.exposureType}</p>
                                <small class="text-muted">Period: ${startDate} - ${endDate}</small>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteExposure('${exposure.id}')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                `;
            });
            html += '</div>';
            
            $container.html(html);
        }

        function deleteExposure(exposureId) {
            if (!confirm('Are you sure you want to delete this exposure?')) return;
            
            $.ajax({
                url: `/api/exposures/${exposureId}`,
                type: 'DELETE',
                success: function() {
                    loadExposures(); // Refresh list
                },
                error: function() {
                    alert('Failed to delete exposure');
                }
            });
        }

        function populateReviewSummary() {
            let html = `
                <h3 style="font-weight: 600; margin-bottom: 1rem; color: var(--forest); font-family: var(--f-sans);">Patient Information</h3>
                <p style="font-family: var(--f-sans);"><strong>Name:</strong> ${selectedPatient.name}</p>
                <p style="font-family: var(--f-sans);"><strong>DOB:</strong> ${selectedPatient.dob || 'N/A'}</p>
                <p style="font-family: var(--f-sans);"><strong>ID:</strong> ${selectedPatient.friendlyId}</p>
                <hr style="margin: 1.5rem 0; border-color: var(--hairline);">
                <h3 style="font-weight: 600; margin-bottom: 1rem; color: var(--forest); font-family: var(--f-sans);">Case Details</h3>
                <p style="font-family: var(--f-sans);"><strong>Disease:</strong> ${$('#diseaseSelect option:selected').text()}</p>
                <p style="font-family: var(--f-sans);"><strong>Status:</strong> ${$('select[name="ConfirmationStatusId"] option:selected').text() || 'Not specified'}</p>
                <p style="font-family: var(--f-sans);"><strong>Date of Onset:</strong> ${$('input[name="DateOfOnset"]').val() || 'Not specified'}</p>
                <p style="font-family: var(--f-sans);"><strong>Date of Notification:</strong> ${$('input[name="DateOfNotification"]').val()}</p>
            `;

            if (labResults.length > 0 || exposures.length > 0) {
                html += `<hr style="margin: 1.5rem 0; border-color: var(--hairline);">`;
                html += `<p style="font-family: var(--f-sans);"><strong>Lab Results:</strong> ${labResults.length}</p>`;
                html += `<p style="font-family: var(--f-sans);"><strong>Exposures:</strong> ${exposures.length}</p>`;
            }

            $('#reviewSummary').html(html);
        }

        // Close search results when clicking outside
        $(document).on('click', function(e) {
            if (!$(e.target).closest('.search-box').length) {
                $('#searchResults').removeClass('show');
            }
        });


        // Prevent form submission in Step 5 - just redirect to existing case
$('form').on('submit', function(e) {
    if (currentStep === 5 && createdCaseId) {
        e.preventDefault();        window.location.href = `/Cases/Details?id=${createdCaseId}`;
        return false;
    }
});

        // Global function for Step 5 completion button
        window.completeCase = function() {
            if (!createdCaseId) {
                alert('Error: Case was not created properly. Please try again.');
                location.reload();
                return;
            }
            window.location.href = `/Cases/Details?id=${createdCaseId}`;
        };
    </script>

    <style>
        /* Sentinel Design - Multi-Step Case Creation */
        .create-case-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Progress Steps */
        .progress-steps {
            display: flex;
            justify-content: space-between;
            margin-bottom: 3rem;
            position: relative;
        }

        .progress-steps::before {
            content: '';
            position: absolute;
            top: 20px;
            left: 10%;
            right: 10%;
            height: 2px;
            background: var(--hairline);
            z-index: 0;
        }

        .step {
            flex: 1;
            text-align: center;
            position: relative;
            z-index: 1;
        }

        .step-circle {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--chalk);
            border: 2px solid var(--hairline);
            color: var(--slate);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            margin-bottom: 0.5rem;
            transition: all 0.3s;
            font-family: var(--f-sans);
        }

        .step.active .step-circle {
            background: var(--forest);
            border-color: var(--forest);
            color: white;
        }

        .step.completed .step-circle {
            background: var(--signal-dk);
            border-color: var(--signal-dk);
            color: white;
        }

        .step-label {
            font-size: 14px;
            color: var(--graphite);
            font-weight: 500;
            font-family: var(--f-sans);
        }

        .step.active .step-label {
            color: var(--forest);
            font-weight: 600;
        }

        /* Step Content Card */
        .step-content {
            background: var(--chalk);
            border-radius: 12px;
            padding: 2rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
            border: 1px solid var(--hairline);
            display: none;
        }

        .step-content.active {
            display: block;
            animation: fadeIn 0.3s;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Patient Search */
        .search-box {
            position: relative;
            margin-bottom: 1.5rem;
        }

        .search-input {
            width: 100%;
            padding: 14px 16px 14px 45px;
            border: 1px solid var(--hairline);
            border-radius: 10px;
            font-size: 16px;
            transition: all 0.2s;
            background: var(--chalk);
            font-family: var(--f-sans);
            color: var(--forest);
        }

        .search-input:focus {
            outline: none;
            border-color: var(--signal-dk);
            box-shadow: 0 0 0 3px rgba(61, 213, 152, 0.1);
        }

        .search-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--slate);
            font-size: 18px;
        }

        .search-results {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: white;
            border: 1px solid var(--hairline);
            border-radius: 10px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
            max-height: 400px;
            overflow-y: auto;
            z-index: 100;
            display: none;
        }

        .search-results.show {
            display: block;
        }

        .search-result-item {
            padding: 12px 16px;
            cursor: pointer;
            transition: background 0.15s;
            border-bottom: 1px solid var(--hairline);
            font-family: var(--f-sans);
        }

        .search-result-item:last-child {
            border-bottom: none;
        }

        .search-result-item:hover {
            background: var(--signal-lt);
        }

        .search-result-name {
            font-weight: 600;
            color: var(--forest);
            margin-bottom: 4px;
        }

        .search-result-meta {
            font-size: 13px;
            color: var(--graphite);
        }

        .duplicate-badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            background: #FBE2D8;
            color: var(--status-outbreak);
            margin-left: 8px;
        }

        /* Selected Patient Card */
        .selected-patient-card {
            background: var(--bone);
            border: 1px solid var(--hairline);
            border-radius: 10px;
            padding: 1.25rem;
            margin-bottom: 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .patient-info h4 {
            font-size: 18px;
            font-weight: 600;
            color: var(--forest);
            margin-bottom: 4px;
            font-family: var(--f-sans);
        }

        .patient-info p {
            font-size: 14px;
            color: var(--graphite);
            margin: 0;
            font-family: var(--f-sans);
        }

        .btn-change {
            background: var(--chalk);
            border: 1px solid var(--hairline);
            color: var(--forest);
            padding: 8px 16px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            font-family: var(--f-sans);
        }

        .btn-change:hover {
            background: var(--signal-lt);
            border-color: var(--signal-dk);
        }

        /* Form Elements */
        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: var(--forest);
            margin-bottom: 8px;
            font-family: var(--f-sans);
        }

        .form-label .required {
            color: var(--status-outbreak);
            margin-left: 4px;
        }

        .form-control-modern {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid var(--hairline);
            border-radius: 10px;
            font-size: 15px;
            transition: all 0.2s;
            background: var(--chalk);
            font-family: var(--f-sans);
            color: var(--forest);
        }

        .form-control-modern:focus {
            outline: none;
            border-color: var(--signal-dk);
            box-shadow: 0 0 0 3px rgba(61, 213, 152, 0.1);
        }

        .form-hint {
            font-size: 13px;
            color: var(--graphite);
            margin-top: 6px;
            font-family: var(--f-sans);
        }

        /* Lab Results & Exposures Tables */
        .item-table {
            width: 100%;
            margin-top: 1rem;
        }

        .item-table thead {
            background: var(--bone);
        }

        .item-table th {
            padding: 12px;
            text-align: left;
            font-weight: 600;
            font-size: 13px;
            color: var(--graphite);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-family: var(--f-sans);
        }

        .item-table td {
            padding: 12px;
            border-top: 1px solid var(--hairline);
            font-size: 15px;
            font-family: var(--f-sans);
            color: var(--forest);
        }

        .btn-remove {
            color: var(--status-outbreak);
            background: none;
            border: none;
            cursor: pointer;
            font-size: 18px;
            padding: 0;
        }

        .btn-remove:hover {
            color: #b91c1c;
        }

        /* Action Buttons */
        .step-actions {
            display: flex;
            justify-content: space-between;
            margin-top: 2rem;
            padding-top: 2rem;
            border-top: 1px solid var(--hairline);
        }

        .btn-modern {
            padding: 12px 24px;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-family: var(--f-sans);
        }

        .btn-primary {
            background: var(--forest);
            color: white;
        }

        .btn-primary:hover {
            background: #081612;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(12, 42, 32, 0.3);
        }

        .btn-secondary {
            background: var(--chalk);
            color: var(--forest);
            border: 1px solid var(--hairline);
        }

        .btn-secondary:hover {
            background: var(--bone);
            border-color: var(--signal-dk);
        }

        .btn-success {
            background: var(--signal-dk);
            color: white;
        }

        .btn-success:hover {
            background: #0F7C56;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(21, 156, 110, 0.3);
        }

        .btn-add {
            background: var(--chalk);
            color: var(--forest);
            border: 1px solid var(--hairline);
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-family: var(--f-sans);
        }

        .btn-add:hover {
            background: var(--signal-lt);
            border-color: var(--signal-dk);
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 3rem 2rem;
            color: var(--slate);
            font-family: var(--f-sans);
        }

        .empty-state i {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .empty-state p {
            margin: 0;
        }

        /* Create New Patient Link */
        .create-patient-prompt {
            text-align: center;
            padding: 2rem;
            background: var(--bone);
            border-radius: 10px;
            margin-top: 1rem;
        }

        .create-patient-prompt p {
            color: var(--graphite);
            margin-bottom: 1rem;
            font-family: var(--f-sans);
        }

        /* Breadcrumb */
        .breadcrumb {
            background: transparent;
            padding: 0;
            margin-bottom: 1.5rem;
            font-size: 14px;
            font-family: var(--f-sans);
        }

        .breadcrumb-item a {
            color: var(--graphite);
            text-decoration: none;
        }

        .breadcrumb-item a:hover {
            color: var(--forest);
        }

        .breadcrumb-item.active {
            color: var(--forest);
        }

        /* Select2 Dropdown Fixes */
        .select2-container {
            width: 100% !important;
        }

        /* Single select (Disease dropdown) */
        .select2-container .select2-selection--single {
            height: calc(1.5em + 0.75rem + 2px) !important;
            border: 1px solid var(--hairline) !important;
            border-radius: var(--radius-sm) !important;
            background: var(--chalk) !important;
            display: flex !important;  /* Use flexbox */
            align-items: center !important;  /* Center vertically */
        }

        .select2-container .select2-selection--single .select2-selection__rendered {
            padding-left: 0.75rem !important;
            padding-right: 2.5rem !important;  /* Space for arrow */
            line-height: 1.5 !important;
            color: var(--forest) !important;
            overflow: hidden !important;  /* Hide overflow text */
            text-overflow: ellipsis !important;  /* Show ... for long text */
            white-space: nowrap !important;  /* Don't wrap */
            flex: 1 !important;  /* Take available space */
            min-width: 0 !important;  /* Allow flex item to shrink below content size */
        }

        .select2-container .select2-selection--single .select2-selection__arrow {
            height: calc(1.5em + 0.75rem) !important;
            top: 1px !important;
            right: 1px !important;
        }

        /* Focus states for single select */
        .select2-container--bootstrap-5.select2-container--focus .select2-selection--single,
        .select2-container--bootstrap-5.select2-container--open .select2-selection--single {
            border-color: var(--signal-dk) !important;
            box-shadow: 0 0 0 0.2rem rgba(61, 213, 152, 0.25) !important;
        }
    </style>
}

@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}
