        function handleLabResultSaved(event) {            if (event.data === 'labResultSaved') {                // Hide modal
                if (window.currentLabResultModal) {
                    window.currentLabResultModal.hide();
                }
                
                // Clear the iframe to prevent layout issues on next open
                setTimeout(function() {
                    $('#labResultFrame').attr('src', 'about:blank');
