        // Save case after Step 2 and proceed to Step 3 (Lab Results)
        function saveCaseAndContinue() {
            const patientId = $('#selectedPatientId').val();
            const diseaseId = $('#diseaseSelect').val();
            const confirmationStatusId = $('select[name="ConfirmationStatusId"]').val();
            const dateOfOnset = $('input[name="DateOfOnset"]').val();
            const dateOfNotification = $('input[name="DateOfNotification"]').val();
            const clinicalNotes = $('textarea[name="ClinicalNotes"]').val();

            if (!diseaseId) {
                alert('Please select a disease before continuing.');
                return;
            }

            // Show loading indicator
            const $nextBtn = $('.step-content[data-step="2"] .btn-primary');
            const originalText = $nextBtn.html();
            $nextBtn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Creating case...');

            $.ajax({
                url: '/Cases/CreateNew?handler=SaveInitialCase',
                type: 'POST',
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                contentType: 'application/json',
                data: JSON.stringify({
                    patientId: patientId,
                    diseaseId: diseaseId,
                    confirmationStatusId: confirmationStatusId || null,
                    dateOfOnset: dateOfOnset || null,
                    dateOfNotification: dateOfNotification,
                    clinicalNotes: clinicalNotes || null
                }),
                success: function(response) {
                    if (response.success && response.caseId) {
                        createdCaseId = response.caseId;                        // Restore button and proceed to next step
                        $nextBtn.prop('disabled', false).html(originalText);
                        
                        // Move to Step 3
                        $(`.step-content[data-step="2"]`).removeClass('active');
                        $(`.step[data-step="2"]`).removeClass('active').addClass('completed');
                        currentStep = 3;
                        $(`.step-content[data-step="3"]`).addClass('active');
                        $(`.step[data-step="3"]`).addClass('active');
                        $('html, body').animate({ scrollTop: 0 }, 300);
                    } else {
                        alert('Error creating case: ' + (response.message || 'Unknown error'));
                        $nextBtn.prop('disabled', false).html(originalText);
                    }
                },
                error: function(xhr) {
                    alert('Error creating case. Please try again.');                    $nextBtn.prop('disabled', false).html(originalText);
                }
            });
        }

        function prevStep() {
            if (currentStep > 1) {
                $(`.step-content[data-step="${currentStep}"]`).removeClass('active');
                $(`.step[data-step="${currentStep}"]`).removeClass('active');
                
                currentStep--;
                
                $(`.step-content[data-step="${currentStep}"]`).addClass('active');
                $(`.step[data-step="${currentStep}"]`).removeClass('completed').addClass('active');
                
                $('html, body').animate({ scrollTop: 0 }, 300);
            }
        }

        function addLabResult() {
            if (!createdCaseId) {
                alert('Please complete the case details first.');
                return;
            }
            
            // Open the lab result modal with iframe=true parameter
            const url = `/Cases/AddLabResult?caseId=${createdCaseId}&iframe=true`;
            
            // Use Bootstrap modal if available
            if (typeof bootstrap !== 'undefined') {
                // Create modal container if it doesn't exist
                if ($('#labResultModal').length === 0) {
                    $('body').append(`
                        <div class="modal fade" id="labResultModal" tabindex="-1" aria-labelledby="labResultModalLabel" aria-hidden="true">
                            <div class="modal-dialog modal-lg">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="labResultModalLabel">Add Laboratory Result</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body" style="padding: 0; position: relative;">
                                        <div id="iframeLoader" style="display: none; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1000;">
                                            <div class="spinner-border text-primary" role="status">
                                                <span class="visually-hidden">Loading...</span>
                                            </div>
                                        </div>
                                        <iframe id="labResultFrame" style="width:100%; height:600px; border:none; display:block;"></iframe>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `);
                }
                
                // Get the iframe element
                const $iframe = $('#labResultFrame');
                const $loader = $('#iframeLoader');
                
                // Show loader, hide iframe
                $loader.show();
                $iframe.hide();
                
                // IMPORTANT: Clear the iframe src first to force a clean reload
                $iframe.attr('src', 'about:blank');
                
                // Wait a moment, then load the new URL
                setTimeout(function() {
                    $iframe.attr('src', url);
                    
                    // Hide loader and show iframe when loaded
                    $iframe.on('load', function() {
                        $loader.hide();
                        $iframe.show();
                    });
                }, 100);
                
                // Show modal
                const modalElement = document.getElementById('labResultModal');
                const modal = new bootstrap.Modal(modalElement);
                modal.show();
                
                // Remove old listener if exists
                window.removeEventListener('message', handleLabResultSaved);
                
                // Listen for success message from iframe
                window.addEventListener('message', handleLabResultSaved);
                
                // Store modal reference for the handler
                window.currentLabResultModal = modal;
                
                // Reset iframe when modal is closed manually
                modalElement.addEventListener('hidden.bs.modal', function() {
                    // Clear iframe to free memory
                    $iframe.attr('src', 'about:blank');
                }, { once: true });
            } else {
                // Fallback: open in new window
                window.open(url, 'AddLabResult', 'width=800,height=600');
            }
        }

