@page
@model Sentinel.Pages.Cases.DetailsModel
@using Sentinel.Models
@using Sentinel.Models.Lookups

@{
    ViewData["Title"] = "Case Details";
    ViewData["Subtitle"] = Model.Case.FriendlyId ?? "Case Information";
}

@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}

<style nonce="@GetCspNonce()">
    /* Responsive Grid - 3 column layout using Sentinel spacing */
    .case-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: var(--spacing-4);
        grid-auto-rows: auto;
    }

    /* Tablet view - 2 columns */
    @@media (max-width: 1200px) {
        .case-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    /* Mobile view - 1 column */
    @@media (max-width: 768px) {
        .case-grid {
            grid-template-columns: 1fr;
        }
    }

    /* Card positioning */
    .case-info-card { grid-column: 1; grid-row: 1; }
    .patient-info-card { grid-column: 1; grid-row: 2; }
    .symptoms-card { grid-column: 1; grid-row: 3; }
    .lab-results-card { grid-column: 2 / span 2; grid-row: 1; }
    .acquisitions-card { grid-column: 2; grid-row: 2; }
    .transmissions-card { grid-column: 3; grid-row: 2; }
    .tasks-card { grid-column: 2 / span 2; grid-row: 3; }

    @@media (max-width: 1200px) {
        .case-info-card, .patient-info-card, .symptoms-card,
        .lab-results-card, .acquisitions-card, .transmissions-card,
        .tasks-card {
            grid-column: auto;
            grid-row: auto;
        }
    }

    /* Info rows using Sentinel colors */
    .info-row {
        display: grid;
        grid-template-columns: 140px 1fr;
        gap: var(--spacing-3);
        padding: var(--spacing-2) 0;
        border-bottom: 1px solid var(--hairline);
        font-size: 0.875rem;
    }
    .info-row:last-child { border-bottom: none; }
    .info-label { color: var(--graphite); font-weight: 500; }
    .info-value { color: var(--forest); font-weight: 600; }

    /* Note items using Sentinel signal */
    .note-item {
        background: var(--signal-lt);
        border-left: 3px solid var(--signal-dk);
        padding: var(--spacing-3);
        margin-bottom: var(--spacing-3);
        border-radius: 8px;
        font-size: 0.875rem;
    }
    .note-item .note-header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        margin-bottom: var(--spacing-2);
    }
    .note-item .note-meta {
        font-size: 0.75rem;
        color: var(--forest-2);
    }

    /* Half-height cards with scroll */
    .half-height {
        max-height: 400px;
    }
    .half-height .table-responsive {
        max-height: 280px;
        overflow-y: auto;
    }

    /* Modal z-index fixes - CRITICAL FOR MODAL VISIBILITY */
    .modal { z-index: 1055 !important; }
    .modal-backdrop { z-index: 1050 !important; }
    .modal-dialog { z-index: 1056 !important; position: relative; }
    .modal.show { display: block !important; opacity: 1 !important; }
    .modal.show .modal-dialog { transform: none !important; }
    #viewLabResultModal.show { display: block !important; visibility: visible !important; }
    #viewLabResultModal .modal-dialog { pointer-events: auto !important; opacity: 1 !important; transform: translateY(0) !important; }
    #viewLabResultModal.show .modal-content { visibility: visible !important; opacity: 1 !important; }

    /* Custom Field Category Accordion using Sentinel colors */
    .custom-field-category {
        margin-top: var(--spacing-4);
        border-top: 1px solid var(--hairline);
        padding-top: var(--spacing-3);
    }
    .custom-field-category:first-of-type { margin-top: var(--spacing-2); }

    .category-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        padding: var(--spacing-2) var(--spacing-3);
        background: var(--signal-lt);
        border-radius: 8px;
        margin-bottom: var(--spacing-2);
        transition: all 0.2s;
        user-select: none;
    }
    .category-header:hover { background: var(--bone); }

    .category-title {
        display: flex;
        align-items: center;
        gap: var(--spacing-2);
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--forest);
        margin: 0;
    }

    .category-count {
        background: var(--signal-dk);
        color: white;
        padding: 0.15rem 0.5rem;
        border-radius: 12px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .category-chevron {
        color: var(--signal-dk);
        transition: transform 0.2s;
        font-size: 1rem;
    }
    .category-chevron.collapsed { transform: rotate(-90deg); }

    .category-fields {
        max-height: 1000px;
        overflow: hidden;
        transition: max-height 0.3s ease-out, opacity 0.2s;
        opacity: 1;
    }
    .category-fields.collapsed { max-height: 0; opacity: 0; }
</style>


<nav aria-label="breadcrumb" class="mb-3" style="font-size: 0.875rem;">
    <ol class="breadcrumb" style="background: transparent; padding: 0; margin-bottom: var(--spacing-3);">
        <li class="breadcrumb-item"><a asp-page="/Index" style="color: var(--graphite); text-decoration: none;">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index" style="color: var(--graphite); text-decoration: none;">Cases</a></li>
        <li class="breadcrumb-item active" aria-current="page" style="color: var(--forest);">@Model.Case.FriendlyId</li>
    </ol>
</nav>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 10px; border-left: 3px solid var(--signal-dk); background: var(--signal-lt); color: var(--forest); margin-bottom: var(--spacing-4);">
        <i class="bi bi-check-circle-fill me-2" style="color: var(--signal-dk);"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ExposureInfo"] != null)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert" style="border-radius: 10px; border-left: 3px solid var(--status-info); background: #E3E9FB; color: var(--forest); margin-bottom: var(--spacing-4);">
        <i class="bi bi-info-circle-fill me-2" style="color: var(--status-info);"></i>@TempData["ExposureInfo"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ExposureWarning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert" style="border-radius: 10px; border-left: 3px solid var(--status-watch); background: #FBEDD1; color: var(--forest); margin-bottom: var(--spacing-4);">
        <i class="bi bi-exclamation-triangle-fill me-2" style="color: var(--status-watch);"></i>@TempData["ExposureWarning"]
        <a asp-page="/Cases/Exposures/Create" asp-route-caseId="@Model.Case.Id" class="alert-link ms-2" style="color: var(--forest); font-weight: 600;">Add exposure now</a>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 10px; border-left: 3px solid var(--status-outbreak); background: #FBE2D8; color: var(--forest); margin-bottom: var(--spacing-4);">
        <i class="bi bi-exclamation-triangle-fill me-2" style="color: var(--status-outbreak);"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="case-details-container">
    <!-- Header Section with Sentinel styling -->
    <div style="background: var(--chalk); border: 1px solid var(--hairline); border-radius: 10px; padding: var(--spacing-5); margin-bottom: var(--spacing-4);">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h1 style="color: var(--forest); font-weight: 600; font-size: 2rem; margin-bottom: var(--spacing-2); font-family: var(--f-sans);">
                    <i class="bi bi-virus2" style="color: var(--signal-dk);"></i>
                    Case @Model.Case.FriendlyId
                </h1>
                @if (Model.Case.Patient != null)
                {
                    <p class="mb-0" style="color: var(--graphite); font-size: 1rem;">
                        <strong style="color: var(--forest);">@Model.Case.Patient.GivenName @Model.Case.Patient.FamilyName</strong>
                        @if (Model.Case.Disease != null)
                        {
                            <span class="mx-2">•</span>
                            <span>@Model.Case.Disease.Name</span>
                        }
                        @if (Model.Case.ConfirmationStatus != null)
                        {
                            <span class="mx-2">•</span>
                            <span class="chip chip-success">@Model.Case.ConfirmationStatus.Name</span>
                        }
                    </p>

                    @* Address and Jurisdictions on second line *@
                    var hasAddress = !string.IsNullOrWhiteSpace(Model.Case.CaseAddressLine) || !string.IsNullOrWhiteSpace(Model.Case.CaseCity);
                    var hasJurisdictions = Model.Case.Jurisdiction1Id.HasValue ||
                                         Model.Case.Jurisdiction2Id.HasValue ||
                                         Model.Case.Jurisdiction3Id.HasValue ||
                                         Model.Case.Jurisdiction4Id.HasValue ||
                                         Model.Case.Jurisdiction5Id.HasValue;
                    <p class="mb-0 mt-1" style="font-size: 0.875rem; color: var(--graphite);">
                        @if (hasAddress || hasJurisdictions)
                        {
                            @if (hasAddress)
                            {
                                var jurisdictions = new List<string>();
                                foreach (var jurisdictionType in Model.ActiveJurisdictionTypes.OrderBy(jt => jt.DisplayOrder))
                                {
                                    var jurisdiction = jurisdictionType.FieldNumber switch
                                    {
                                        1 => Model.Case.Jurisdiction1,
                                        2 => Model.Case.Jurisdiction2,
                                        3 => Model.Case.Jurisdiction3,
                                        4 => Model.Case.Jurisdiction4,
                                        5 => Model.Case.Jurisdiction5,
                                        _ => null
                                    };

                                    if (jurisdiction != null)
                                    {
                                        var label = !string.IsNullOrEmpty(jurisdictionType.Code) 
                                            ? jurisdictionType.Code 
                                            : jurisdictionType.Name;
                                        jurisdictions.Add($"{label}: {jurisdiction.Name}");
                                    }
                                }

                                <i class="bi bi-geo-alt-fill me-1" style="color: var(--signal-dk);"></i>
                                if (!string.IsNullOrWhiteSpace(Model.Case.CaseAddressLine))
                                {
                                    <span>@Model.Case.CaseAddressLine, </span>
                                }
                                if (!string.IsNullOrWhiteSpace(Model.Case.CaseCity))
                                {
                                    <span>@Model.Case.CaseCity</span>
                                }
                                if (Model.Case.CaseState != null)
                                {
                                    <span>, @Model.Case.CaseState.Code</span>
                                }
                                if (!string.IsNullOrWhiteSpace(Model.Case.CasePostalCode))
                                {
                                    <span> @Model.Case.CasePostalCode</span>
                                }

                                if (jurisdictions.Any())
                                {
                                    <span class="mx-2">•</span>
                                    @string.Join(" • ", jurisdictions)
                                }
                            }
                            else
                            {
                                var jurisdictionsOnly = new List<string>();
                                foreach (var jurisdictionType in Model.ActiveJurisdictionTypes.OrderBy(jt => jt.DisplayOrder))
                                {
                                    var jurisdiction = jurisdictionType.FieldNumber switch
                                    {
                                        1 => Model.Case.Jurisdiction1,
                                        2 => Model.Case.Jurisdiction2,
                                        3 => Model.Case.Jurisdiction3,
                                        4 => Model.Case.Jurisdiction4,
                                        5 => Model.Case.Jurisdiction5,
                                        _ => null
                                    };

                                    if (jurisdiction != null)
                                    {
                                        var label = !string.IsNullOrEmpty(jurisdictionType.Code) 
                                            ? jurisdictionType.Code 
                                            : jurisdictionType.Name;
                                        jurisdictionsOnly.Add($"{label}: {jurisdiction.Name}");
                                    }
                                }

                                if (jurisdictionsOnly.Any())
                                {
                                    <i class="bi bi-pin-map me-1" style="color: var(--signal-dk);"></i>
                                    @string.Join(" • ", jurisdictionsOnly)
                                }
                            }

                            @if (Model.Case.CaseAddressManualOverride)
                            {
                                <span class="mx-2">•</span>
                                <span class="chip chip-info" style="font-size: 0.65rem;" title="Address manually set">Manual Override</span>
                            }
                        }
                        else
                        {
                            <i class="bi bi-geo-alt text-muted me-1"></i>
                            <span class="text-muted">No address or jurisdiction recorded</span>
                            @if (Model.PatientHasDifferentAddress)
                            {
                                <span class="mx-2">•</span>
                                <i class="bi bi-info-circle me-1" style="color: var(--status-watch);" title="Patient has address data"></i>
                                <span style="color: var(--status-watch);">Patient has address available</span>
                            }
                        }
                    </p>
                }
            </div>
            <div class="text-end">
                <a asp-page="./Index" class="btn btn-sentinel-secondary btn-sm">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>

        <!-- Quick Actions with Sentinel button styling -->
        <div style="display: flex; flex-wrap: wrap; gap: var(--spacing-2); margin-top: var(--spacing-4); padding-top: var(--spacing-4); border-top: 1px solid var(--hairline);">
            <a asp-page="./Edit" asp-route-id="@Model.Case.Id" class="btn btn-sentinel-primary btn-sm">
                <i class="bi bi-pencil"></i> Edit Case
            </a>
            @if (Model.PatientHasDifferentAddress)
            {
                <button type="button" class="btn btn-sm" style="background: var(--status-watch); color: white; border: none; font-weight: 600;" onclick="copyAddressFromPatient()" title="Copy address and jurisdiction data from patient record">
                    <i class="bi bi-arrow-down-circle"></i> Copy Address from Patient
                    @if (Model.PatientJurisdictionMappingInProgress)
                    {
                        <i class="bi bi-hourglass-split ms-1" title="Jurisdiction mapping in progress"></i>
                    }
                </button>
            }
            <button type="button" class="btn btn-sentinel-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addNoteModal">
                <i class="bi bi-plus-circle"></i> Add Note
            </button>
            <button type="button" class="btn btn-sentinel-primary btn-sm" onclick="openAddLabResult()">
                <i class="bi bi-plus-circle"></i> Add Lab Result
            </button>
            <button type="button" class="btn btn-sentinel-primary btn-sm" onclick="openAddExposure()">
                <i class="bi bi-plus-circle"></i> Add Exposure
            </button>
            <a asp-page="/Cases/Contacts/BulkCreate" asp-route-caseId="@Model.Case.Id" class="btn btn-sentinel-primary btn-sm">
                <i class="bi bi-people-fill"></i> Bulk Create Contacts
            </a>
            <button type="button" class="btn btn-sentinel-primary btn-sm" onclick="openAddTask()">
                <i class="bi bi-plus-circle"></i> Add Task
            </button>
            @if (Model.Case.Patient != null)
            {
                <a asp-page="/Patients/Details" asp-route-id="@Model.Case.PatientId" class="btn btn-sentinel-secondary btn-sm">
                    <i class="bi bi-person"></i> View Patient
                </a>
            }
            <a asp-page="./AuditHistory" asp-route-id="@Model.Case.Id" class="btn btn-sentinel-secondary btn-sm">
                <i class="bi bi-clock-history"></i> Audit Log
            </a>
        </div>
    </div>

    <!-- Main Content Grid -->
    <!-- 3-Column Layout: Left = Case/Patient/Symptoms stacked | Right = Lab Results/Tasks/Exposures+Notes -->
    <div class="case-grid">
        <!-- LEFT COLUMN: Case Information -->
        <div class="sentinel-card case-info-card">
            <div class="sentinel-card-header" style="display: flex; justify-content: space-between; align-items: center;">
                <h3 style="color: var(--forest); font-weight: 600; font-size: 1.125rem; margin: 0; font-family: var(--f-sans);">
                    <i class="bi bi-clipboard-data" style="color: var(--signal-dk);"></i>
                    Case Information
                </h3>
                <a asp-page="./Edit" asp-route-id="@Model.Case.Id" class="btn btn-sentinel-secondary btn-sm">
                    <i class="bi bi-pencil"></i> Edit
                </a>
            </div>
            <div class="sentinel-card-body">
            @if (Model.Case.Disease != null)
            {
                <div class="info-row">
                    <div class="info-label">Disease</div>
                    <div class="info-value">
                        <strong>@Model.Case.Disease.Name</strong>
                        <br /><small class="text-muted">@Model.Case.Disease.Code (@Model.Case.Disease.ExportCode)</small>
                    </div>
                </div>
            }
            <div class="info-row">
                <div class="info-label">Confirmation Status</div>
                <div class="info-value">
                    @if (Model.Case.ConfirmationStatus != null)
                    {
                        <span class="chip chip-success">@Model.Case.ConfirmationStatus.Name</span>
                    }
                    else
                    {
                        <span class="text-muted">Not set</span>
                    }
                </div>
            </div>
            <div class="info-row">
                <div class="info-label">Date of Onset</div>
                <div class="info-value">
                    @if (Model.Case.DateOfOnset.HasValue)
                    {
                        <i class="bi bi-calendar-event me-1" style="color: var(--signal-dk);"></i>
                        @Model.Case.DateOfOnset.Value.ToString("dd MMM yyyy")
                    }
                    else
                    {
                        <span class="text-muted">Not specified</span>
                    }
                </div>
            </div>
            <div class="info-row">
                <div class="info-label">Date of Notification</div>
                <div class="info-value">
                    @if (Model.Case.DateOfNotification.HasValue)
                    {
                        <i class="bi bi-calendar-check me-1" style="color: var(--signal-dk);"></i>
                        @Model.Case.DateOfNotification.Value.ToString("dd MMM yyyy")
                    }
                    else
                    {
                        <span class="text-muted">Not specified</span>
                    }
                </div>
            </div>
            @if (Model.Case.ClinicalNotificationDate.HasValue || !string.IsNullOrWhiteSpace(Model.Case.ClinicalNotifierOrganisation) || !string.IsNullOrWhiteSpace(Model.Case.ClinicalNotificationNotes))
            {
                <div class="info-row">
                    <div class="info-label">Clinical Notification Date</div>
                    <div class="info-value">
                        @if (Model.Case.ClinicalNotificationDate.HasValue)
                        {
                            <i class="bi bi-calendar-plus me-1" style="color: var(--status-info);"></i>
                            @Model.Case.ClinicalNotificationDate.Value.ToString("dd MMM yyyy")
                        }
                        else
                        {
                            <span class="text-muted">Not specified</span>
                        }
                    </div>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Case.ClinicalNotifierOrganisation))
            {
                <div class="info-row">
                    <div class="info-label">Clinical Notifier Organisation</div>
                    <div class="info-value">
                        <i class="bi bi-building me-1" style="color: var(--status-info);"></i>
                        @Model.Case.ClinicalNotifierOrganisation
                    </div>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Case.ClinicalNotificationNotes))
            {
                <div class="info-row">
                    <div class="info-label">Clinical Notification Notes</div>
                    <div class="info-value">
                        <i class="bi bi-sticky me-1" style="color: var(--status-info);"></i>
                        @Model.Case.ClinicalNotificationNotes
                    </div>
                </div>
            }
            <div class="info-row">
                <div class="info-label">Hospitalised</div>
                <div class="info-value">
                    @if (Model.Case.Hospitalised.HasValue)
                    {
                        switch (Model.Case.Hospitalised.Value)
                        {
                            case Sentinel.Models.YesNoUnknown.Yes:
                                <span class="chip" style="background: var(--status-outbreak); color: white;">Yes</span>
                                break;
                            case Sentinel.Models.YesNoUnknown.No:
                                <span class="chip chip-success">No</span>
                                break;
                            case Sentinel.Models.YesNoUnknown.Unknown:
                                <span class="chip chip-neutral">Unknown</span>
                                break;
                        }
                    }
                    else
                    {
                        <span class="text-muted">Not specified</span>
                    }
                </div>
            </div>
            @if (Model.Case.Hospitalised == Sentinel.Models.YesNoUnknown.Yes)
            {
                if (Model.Case.Hospital != null)
                {
                    <div class="info-row">
                        <div class="info-label">Hospital</div>
                        <div class="info-value">
                            <i class="bi bi-hospital me-1" style="color: var(--status-outbreak);"></i>
                            @Model.Case.Hospital.Name
                        </div>
                    </div>
                }
                if (Model.Case.DateOfAdmission.HasValue)
                {
                    <div class="info-row">
                        <div class="info-label">Date of Admission</div>
                        <div class="info-value">
                            <i class="bi bi-calendar-plus me-1" style="color: var(--status-outbreak);"></i>
                            @Model.Case.DateOfAdmission.Value.ToString("dd MMM yyyy")
                        </div>
                    </div>
                }
                if (Model.Case.DateOfDischarge.HasValue)
                {
                    <div class="info-row">
                        <div class="info-label">Date of Discharge</div>
                        <div class="info-value">
                            <i class="bi bi-calendar-minus me-1" style="color: var(--signal-dk);"></i>
                            @Model.Case.DateOfDischarge.Value.ToString("dd MMM yyyy")
                        </div>
                    </div>
                }
            }
            <div class="info-row">
                <div class="info-label">Died due to disease?</div>
                <div class="info-value">
                    @if (Model.Case.DiedDueToDisease.HasValue)
                    {
                        switch (Model.Case.DiedDueToDisease.Value)
                        {
                            case Sentinel.Models.YesNoUnknown.Yes:
                                <span class="chip" style="background: var(--forest); color: white;">Yes</span>
                                break;
                            case Sentinel.Models.YesNoUnknown.No:
                                <span class="chip chip-success">No</span>
                                break;
                            case Sentinel.Models.YesNoUnknown.Unknown:
                                <span class="chip chip-neutral">Unknown</span>
                                break;
                        }
                    }
                    else
                    {
                        <span class="text-muted">Not specified</span>
                    }
                </div>
            </div>

            @* Integrate Custom Fields into Case Information Card *@
            @if (Model.CustomFields.Any())
            {
                var fieldsByCategory = Model.CustomFields
                .OrderBy(f => f.Category ?? "Other")
                .ThenBy(f => f.DisplayOrder)
                .GroupBy(f => f.Category ?? "Additional Details")
                .ToList();

                int categoryIndex = 0;
                foreach (var categoryGroup in fieldsByCategory)
                {
                    var isFirstCategory = categoryIndex == 0;
                    var categoryId = $"category-{categoryIndex}";
                    var fieldsWithValues = categoryGroup.Where(f => Model.CustomFieldValues.ContainsKey(f.Id) || f.ShowOnCaseForm).ToList();

                    if (fieldsWithValues.Any())
                    {
                        <div class="custom-field-category">
                            <div class="category-header" onclick="toggleCategory('@categoryId')">
                                <div class="category-title">
                                    <i class="bi bi-file-text"></i>
                                    <span>@categoryGroup.Key</span>
                                    <span class="category-count">@fieldsWithValues.Count</span>
                                </div>
                                <i class="bi bi-chevron-down category-chevron @(isFirstCategory ? "" : "collapsed")" id="chevron-@categoryId"></i>
                            </div>
                            <div class="category-fields @(isFirstCategory ? "" : "collapsed")" id="@categoryId">
                                @foreach (var field in fieldsWithValues)
                                {
                                    var fieldValue = Model.CustomFieldValues.ContainsKey(field.Id) ? Model.CustomFieldValues[field.Id] : null;

                                    <div class="info-row">
                                        <div class="info-label">
                                            @field.Label
                                            @if (field.IsRequired)
                                            {
                                                <span class="text-danger">*</span>
                                            }
                                        </div>
                                        <div class="info-value">
                                            @switch (field.FieldType)
                                            {
                                                case Sentinel.Models.CustomFieldType.Text:
                                                case Sentinel.Models.CustomFieldType.TextArea:
                                                    if (fieldValue != null && !string.IsNullOrWhiteSpace(fieldValue.ToString()))
                                                    {
                                                        <text>@fieldValue</text>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                    break;

                                                case Sentinel.Models.CustomFieldType.Number:
                                                    if (fieldValue != null)
                                                    {
                                                        <text>@fieldValue</text>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                    break;

                                                case Sentinel.Models.CustomFieldType.Date:
                                                    if (fieldValue != null && DateTime.TryParse(fieldValue.ToString(), out var dateVal))
                                                    {
                                                        <i class="bi bi-calendar me-1"></i>
                                                        <text>@dateVal.ToString("dd MMM yyyy")</text>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                    break;

                                                case Sentinel.Models.CustomFieldType.Checkbox:
                                                    if (fieldValue != null && bool.TryParse(fieldValue.ToString(), out var boolVal))
                                                    {
                                                        if (boolVal)
                                                        {
                                                            <span class="chip chip-success"><i class="bi bi-check-circle"></i> Yes</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="chip chip-neutral"><i class="bi bi-x-circle"></i> No</span>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                    break;

                                                case Sentinel.Models.CustomFieldType.Dropdown:
                                                    if (fieldValue != null && !string.IsNullOrWhiteSpace(fieldValue.ToString()))
                                                    {
                                                        <text>@fieldValue</text>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                    break;

                                                default:
                                                    if (fieldValue != null)
                                                    {
                                                        <text>@fieldValue</text>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                    break;
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                        categoryIndex++;
                    }
                }
            }
            </div>
        </div>

        <!-- LEFT COLUMN: Patient Information (stacked below Case) -->
        @if (Model.Case.Patient != null)
        {
            <div class="sentinel-card patient-info-card">
                <div class="sentinel-card-header" style="display: flex; justify-content: space-between; align-items: center;">
                    <h3 style="color: var(--forest); font-weight: 600; font-size: 1.125rem; margin: 0; font-family: var(--f-sans);">
                        <i class="bi bi-person-badge" style="color: var(--signal-dk);"></i>
                        Patient Information
                    </h3>
                    <a asp-page="/Patients/Details" asp-route-id="@Model.Case.PatientId" class="btn btn-sentinel-secondary btn-sm">
                        <i class="bi bi-eye"></i> View
                    </a>
                </div>
                <div class="sentinel-card-body">
                <div class="info-row">
                    <div class="info-label">Patient ID</div>
                    <div class="info-value">
                        <a asp-page="/Patients/Details" asp-route-id="@Model.Case.PatientId" style="color: var(--signal-dk); text-decoration: none; font-weight: 600;">
                            @Model.Case.Patient.FriendlyId
                        </a>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-label">Name</div>
                    <div class="info-value">@Model.Case.Patient.GivenName @Model.Case.Patient.FamilyName</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Date of Birth</div>
                    <div class="info-value">
                        @if (Model.Case.Patient.DateOfBirth.HasValue)
                        {
                            var age = DateTime.Now.Year - Model.Case.Patient.DateOfBirth.Value.Year;
                            <span>@Model.Case.Patient.DateOfBirth.Value.ToString("dd MMM yyyy") <small class="text-muted">(@age yrs)</small></span>
                        }
                        else
                        {
                            <span class="text-muted">Not specified</span>
                        }
                    </div>
                </div>
                @if (Model.Case.Patient.DateOfBirth.HasValue && Model.Case.DateOfNotification.HasValue)
                {
                    var dob = Model.Case.Patient.DateOfBirth.Value;
                    var notificationDate = Model.Case.DateOfNotification.Value;
                    var totalMonths = ((notificationDate.Year - dob.Year) * 12) + notificationDate.Month - dob.Month;
                    var years = totalMonths / 12;
                    var months = totalMonths % 12;
                    var weeks = (int)((notificationDate - dob).TotalDays / 7);

                    string ageDisplay;
                    string ageColor = "var(--forest)";

                    if (totalMonths < 4)
                    {
                        ageDisplay = $"{weeks} weeks";
                        ageColor = "var(--signal-dk)";
                    }
                    else if (totalMonths < 24)
                    {
                        ageDisplay = $"{totalMonths} months";
                        ageColor = "var(--signal-dk)";
                    }
                    else if (years < 5)
                    {
                        ageDisplay = months > 0 ? $"{years} years, {months} months" : $"{years} years";
                        ageColor = "var(--signal-dk)";
                    }
                    else
                    {
                        ageDisplay = $"{years} years";
                        if (years < 18) ageColor = "var(--status-info)";
                        else if (years > 65) ageColor = "var(--status-watch)";
                    }

                    <div class="info-row">
                        <div class="info-label">Age at Notification</div>
                        <div class="info-value">
                            <i class="bi bi-cake2 me-1" style="color: var(--signal-dk);"></i>
                            <span style="color: @ageColor; font-weight: 600;">@ageDisplay</span>
                            @if (years < 18)
                            {
                                <span class="chip chip-info ms-2" style="font-size: 0.65rem;">Child</span>
                            }
                            else if (years > 65)
                            {
                                <span class="chip ms-2" style="background: var(--status-watch); color: var(--forest); font-size: 0.65rem;">Elderly</span>
                            }
                        </div>
                    </div>
                }
                <div class="info-row">
                    <div class="info-label">Gender</div>
                    <div class="info-value">@(Model.Case.Patient.Gender?.Name ?? "-")</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Email</div>
                    <div class="info-value">
                        @if (!string.IsNullOrWhiteSpace(Model.Case.Patient.EmailAddress))
                        {
                            <a href="mailto:@Model.Case.Patient.EmailAddress" style="color: var(--signal-dk); text-decoration: none;">
                                <i class="bi bi-envelope me-1"></i>@Model.Case.Patient.EmailAddress
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">Not provided</span>
                        }
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-label">Mobile Phone</div>
                    <div class="info-value">
                        @if (!string.IsNullOrWhiteSpace(Model.Case.Patient.MobilePhone))
                        {
                            <a href="tel:@Model.Case.Patient.MobilePhone" style="color: var(--signal-dk); text-decoration: none;">
                                <i class="bi bi-phone me-1"></i>@Model.Case.Patient.MobilePhone
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">Not provided</span>
                        }
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-label">Deceased</div>
                    <div class="info-value">
                        @if (Model.Case.Patient.IsDeceased)
                        {
                            <span class="chip" style="background: var(--forest); color: white;">Yes</span>
                            if (Model.Case.Patient.DateOfDeath.HasValue)
                            {
                                <br />

                                <small class="text-muted">@Model.Case.Patient.DateOfDeath.Value.ToString("dd MMM yyyy")</small>
                            }
                        }
                        else
                        {
                            <span class="chip chip-success">No</span>
                        }
                    </div>
                </div>
            </div>
            </div>
        }

        <!-- LEFT COLUMN: Symptoms (stacked below Patient) -->
        <div class="sentinel-card symptoms-card">
            <div class="sentinel-card-header" style="display: flex; justify-content: space-between; align-items: center;">
                <h3 style="color: var(--forest); font-weight: 600; font-size: 1.125rem; margin: 0; font-family: var(--f-sans);">
                    <i class="bi bi-heart-pulse" style="color: var(--signal-dk);"></i>
                    Symptoms (@Model.CaseSymptoms.Count)
                </h3>
                <a asp-page="./Edit" asp-route-id="@Model.Case.Id" class="btn btn-sentinel-secondary btn-sm">
                    <i class="bi bi-pencil"></i> Edit
                </a>
            </div>
            <div class="sentinel-card-body">
            @if (Model.CaseSymptoms.Any())
            {
                <div class="table-responsive">
                <table class="patient-table w-100">
                    <thead>
                        <tr>
                            <th>Symptom</th>
                            <th>Onset</th>
                            <th>Severity</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var symptom in Model.CaseSymptoms)
                        {
                            <tr>
                                <td>
                                    <strong>@symptom.Symptom?.Name</strong>
                                    @if (symptom.Symptom?.Code == "OTHER" && !string.IsNullOrEmpty(symptom.OtherSymptomText))
                                    {
                                        <br />

                                        <small class="text-muted">(@symptom.OtherSymptomText)</small>
                                    }
                                </td>
                                <td>
                                    @if (symptom.OnsetDate.HasValue)
                                    {
                                        <span>@symptom.OnsetDate.Value.ToString("dd MMM")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(symptom.Severity))
                                    {
                                        var severityChip = symptom.Severity.ToLower() switch
                                        {
                                            "mild" => "chip-success",
                                            "moderate" => "chip" + " style=\"background: var(--status-watch); color: var(--forest);\"",
                                            "severe" => "chip" + " style=\"background: var(--status-outbreak); color: white;\"",
                                            _ => "chip-neutral"
                                        };
                                        <span class="@severityChip">@symptom.Severity</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>

                @if (Model.CaseSymptoms.Any(cs => cs.OnsetDate.HasValue))
                {
                    var earliestOnset = Model.CaseSymptoms.Where(cs => cs.OnsetDate.HasValue).Min(cs => cs.OnsetDate!.Value);
                    <div style="margin-top: var(--spacing-3); padding: var(--spacing-2) var(--spacing-3); background: var(--signal-lt); border-left: 3px solid var(--status-info); border-radius: 6px; font-size: 0.75rem;">
                        <i class="bi bi-info-circle me-1" style="color: var(--status-info);"></i>
                        <strong>Earliest onset:</strong> @earliestOnset.ToString("dd MMM yyyy")
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: var(--spacing-5) var(--spacing-3); color: var(--graphite);">
                    <i class="bi bi-heart-pulse" style="font-size: 2.5rem; color: var(--hairline); margin-bottom: var(--spacing-3); display: block;"></i>
                    <p style="margin: var(--spacing-2) 0; font-size: 0.875rem;">No symptoms recorded</p>
                    <a asp-page="./Edit" asp-route-id="@Model.Case.Id" class="btn btn-sentinel-secondary btn-sm" style="margin-top: var(--spacing-2);">Add Symptoms</a>
                </div>
            }
            </div>
        </div>

        <!-- RIGHT SIDE (2 columns): Lab Results - Wide and Half Height -->
        <div class="sentinel-card wide half-height lab-results-card">
            <div class="sentinel-card-header" style="display: flex; justify-content: space-between; align-items: center;">
                <h3 style="color: var(--forest); font-weight: 600; font-size: 1.125rem; margin: 0; font-family: var(--f-sans);">
                    <i class="bi bi-clipboard-pulse" style="color: var(--signal-dk);"></i>
                    Lab Results (@Model.LabResults.Count)
                </h3>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sentinel-primary btn-sm" data-bs-toggle="modal" data-bs-target="#viewAllLabResultsModal">
                        <i class="bi bi-list-ul"></i> View All
                    </button>
                    <button type="button" class="btn btn-sentinel-secondary btn-sm" onclick="openAddLabResult()">
                        <i class="bi bi-plus-circle"></i> Add
                    </button>
                </div>
            </div>
            <div class="sentinel-card-body">
            @if (Model.LabResults.Any())
            {
                <div class="table-responsive">
                <table class="patient-table w-100">
                    <thead>
                        <tr>
                            <th style="width: 25%;">Test / Specimen</th>
                            <th style="width: 20%;">Tested For</th>
                            <th style="width: 15%;">Result</th>
                            <th style="width: 15%;">Collected</th>
                            <th style="width: 15%;">Reported</th>
                            <th style="width: 10%;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var labResult in Model.LabResults.Take(5))
                        {
                            <tr>
                                <td>
                                    <strong style="font-size: 0.85rem;">@(labResult.TestType?.Name ?? "-")</strong>
                                    <br /><small class="text-muted" style="font-size: 0.75rem;">@(labResult.SpecimenType?.Name ?? "-")</small>
                                    @if (labResult.IsAmended)
                                    {
                                        <br />

                                        <span class="chip" style="background: var(--status-watch); color: var(--forest); font-size: 0.6rem; padding: 0.15rem 0.4rem;"><i class="bi bi-pencil-square"></i> Amended</span>
                                    }
                                </td>
                                <td>
                                    @if (labResult.TestedDisease != null)
                                    {
                                        <span style="font-size: 0.8rem;">@labResult.TestedDisease.Name</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (labResult.TestResult != null)
                                    {
                                        var resultStyle = labResult.TestResult.Name?.ToLower() switch
                                        {
                                            "positive" => "background: var(--status-outbreak); color: white;",
                                            "negative" => "background: var(--status-clear); color: var(--forest);",
                                            "indeterminate" or "equivocal" => "background: var(--status-watch); color: var(--forest);",
                                            _ => "background: var(--slate); color: white;"
                                        };
                                        <span class="chip" style="@resultStyle font-size: 0.7rem;">@labResult.TestResult.Name</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (labResult.SpecimenCollectionDate.HasValue)
                                    {
                                        <span style="font-size: 0.8rem;">@labResult.SpecimenCollectionDate.Value.ToString("dd MMM yyyy")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (labResult.ResultDate.HasValue)
                                    {
                                        <span style="font-size: 0.8rem;">@labResult.ResultDate.Value.ToString("dd MMM yyyy")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-link p-0" onclick="window.viewLabResult('@labResult.Id')" title="View Details" style="color: var(--signal-dk);">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
                @if (Model.LabResults.Count > 5)
                {
                    <div class="text-center" style="margin-top: var(--spacing-2);">
                        <small class="text-muted">Showing 5 of @Model.LabResults.Count lab results</small>
                        <button type="button" class="btn btn-sm btn-link p-0 ms-2" data-bs-toggle="modal" data-bs-target="#viewAllLabResultsModal" style="color: var(--signal-dk);">
                            <i class="bi bi-arrows-angle-expand"></i> View All
                        </button>
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: var(--spacing-6) var(--spacing-4);">
                    <i class="bi bi-clipboard-pulse" style="font-size: 3rem; color: var(--hairline); display: block; margin-bottom: var(--spacing-3);"></i>
                    <p style="color: var(--graphite); margin-bottom: var(--spacing-3);">No lab results yet</p>
                    <button type="button" class="btn btn-sentinel-secondary btn-sm" onclick="openAddLabResult()">Add Lab Result</button>
                </div>
            }
            </div>
        </div>

        <!-- RIGHT SIDE: Acquisitions (How THIS case was exposed) -->
        <div class="sentinel-card acquisitions-card">
            <div class="sentinel-card-header" style="display: flex; justify-content: space-between; align-items: center;">
                <h3 style="color: var(--forest); font-weight: 600; font-size: 1.125rem; margin: 0; font-family: var(--f-sans);">
                    <i class="bi bi-arrow-down-circle" style="color: var(--signal-dk);"></i>
                    Acquisitions (@Model.Acquisitions.Count)
                </h3>
                <div class="d-flex gap-2">
                    @if (Model.Acquisitions.Any(e => e.LocationId.HasValue || e.EventId.HasValue))
                    {
                        var firstExposure = Model.Acquisitions.FirstOrDefault(e => e.LocationId.HasValue || e.EventId.HasValue);
                        <a asp-page="/Outbreaks/CreateFromExposure"
                           asp-route-caseId="@Model.Case.Id"
                           asp-route-exposureId="@firstExposure!.Id"
                           asp-route-locationId="@firstExposure.LocationId"
                           asp-route-eventId="@firstExposure.EventId"
                           class="btn btn-sentinel-primary btn-sm" title="Create Outbreak from this exposure">
                            <i class="bi bi-diagram-3"></i> Create Outbreak
                        </a>
                    }
                    <button type="button" class="btn btn-sentinel-secondary btn-sm" onclick="openAddExposure()">
                        <i class="bi bi-plus-circle"></i> Add
                    </button>
                </div>
            </div>
            <div class="sentinel-card-body">
            @if (Model.Acquisitions.Any())
            {
                <div class="table-responsive">
                <table class="patient-table w-100">
                    <thead>
                        <tr>
                            <th style="width: 120px;">Type</th>
                            <th>Source/Location</th>
                            <th style="width: 90px;">Date</th>
                            <th style="width: 100px;">Status</th>
                            <th style="width: 80px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exposure in Model.Acquisitions.OrderByDescending(e => e.ExposureStartDate).Take(5))
                        {
                            <tr>
                                <td>
                                    @switch (exposure.ExposureType)
                                    {
                                        case Sentinel.Models.ExposureType.Event:
                                            <span class="chip chip-success"><i class="bi bi-calendar-event"></i> Event</span>
                                            break;
                                        case Sentinel.Models.ExposureType.Location:
                                            <span class="chip" style="background: var(--slate); color: white;"><i class="bi bi-geo-alt"></i> Location</span>
                                            break;
                                        case Sentinel.Models.ExposureType.Contact:
                                            <span class="chip" style="background: var(--status-watch); color: var(--forest);"><i class="bi bi-people"></i> Contact</span>
                                            break;
                                        case Sentinel.Models.ExposureType.Travel:
                                            <span class="chip" style="background: var(--graphite); color: white;"><i class="bi bi-airplane"></i> Travel</span>
                                            break;
                                        case Sentinel.Models.ExposureType.LocallyAcquired:
                                            <span class="chip chip-success"><i class="bi bi-house"></i> Locally Acquired</span>
                                            break;
                                        default:
                                            <span class="chip chip-neutral">Unknown</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <small>
                                        @* For Contact exposures, show the SOURCE person *@
                                        @if (exposure.ExposureType == Sentinel.Models.ExposureType.Contact && exposure.SourceCase != null)
                                        {
                                            <div>
                                                <strong>
                                                    <i class="bi bi-person"></i>
                                                    <a asp-page="/Cases/Details" asp-route-id="@exposure.SourceCase.Id">
                                                        @if (exposure.SourceCase.Patient != null)
                                                        {
                                                            <text>@exposure.SourceCase.Patient.GivenName @exposure.SourceCase.Patient.FamilyName</text>
                                                        }
                                                        else
                                                        {
                                                            <text>Case @exposure.SourceCase.FriendlyId</text>
                                                        }
                                                    </a>
                                                </strong>
                                            </div>
                                            @if (exposure.Location != null)
                                            {
                                                <div class="text-muted">
                                                    <i class="bi bi-geo-alt"></i> At: <a asp-page="/Locations/Details" asp-route-id="@exposure.Location.Id">@exposure.Location.Name</a>
                                                </div>
                                            }
                                            @if (exposure.Event != null)
                                            {
                                                <div class="text-muted">
                                                    <i class="bi bi-calendar-event"></i> At: <a asp-page="/Events/Details" asp-route-id="@exposure.Event.Id">@exposure.Event.Name</a>
                                                </div>
                                            }
                                        }
                                        @* For Location/Event exposures without a contact person *@
                                        else if (exposure.Event != null)
                                        {
                                            <a asp-page="/Events/Details" asp-route-id="@exposure.Event.Id">@exposure.Event.Name</a>
                                        }
                                        else if (exposure.Location != null)
                                        {
                                            <a asp-page="/Locations/Details" asp-route-id="@exposure.Location.Id">@exposure.Location.Name</a>
                                        }
                                        @* For Travel exposures, show country *@
                                        else if (exposure.ExposureType == Sentinel.Models.ExposureType.Travel)
                                        {
                                            @if (!string.IsNullOrEmpty(exposure.Country))
                                            {
                                                <div><i class="bi bi-airplane"></i> @exposure.Country</div>
                                            }
                                            else if (!string.IsNullOrEmpty(exposure.CountryCode))
                                            {
                                                <div><i class="bi bi-airplane"></i> @exposure.CountryCode</div>
                                            }
                                            else if (!string.IsNullOrEmpty(exposure.FreeTextLocation))
                                            {
                                                <text>@exposure.FreeTextLocation</text>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        }
                                        @* Fallback for other exposure types *@
                                        else if (exposure.ExposureType == Sentinel.Models.ExposureType.LocallyAcquired)
                                        {
                                            @if (!string.IsNullOrEmpty(exposure.AddressLine))
                                            {
                                                <text>@exposure.AddressLine, @exposure.City</text>
                                            }
                                            else
                                            {
                                                <text>Patient's Residence</text>
                                            }
                                        }
                                        else if (!string.IsNullOrEmpty(exposure.FreeTextLocation))
                                        {
                                            <text>@exposure.FreeTextLocation</text>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </small>
                                </td>
                                <td><small>@exposure.ExposureStartDate.ToString("dd MMM")</small></td>
                                <td>
                                    @switch (exposure.ExposureStatus)
                                    {
                                        case Sentinel.Models.ExposureStatus.ConfirmedExposure:
                                            <span class="chip" style="background: var(--status-outbreak); color: white;">Confirmed</span>
                                            break;
                                        case Sentinel.Models.ExposureStatus.UnderInvestigation:
                                            <span class="chip" style="background: var(--status-watch); color: var(--forest);">Investigating</span>
                                            break;
                                        case Sentinel.Models.ExposureStatus.PotentialExposure:
                                            <span class="chip" style="background: var(--status-info); color: white;">Potential</span>
                                            break;
                                        case Sentinel.Models.ExposureStatus.RuledOut:
                                            <span class="chip" style="background: var(--status-clear); color: var(--forest);">Ruled Out</span>
                                            break;
                                        default:
                                            <span class="chip chip-neutral">Unknown</span>
                                            break;
                                    }
                                </td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-link p-0" onclick="openEditExposure('@exposure.Id')" title="Edit Exposure" style="color: var(--signal-dk);">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <form method="post" asp-page-handler="DeleteExposure" asp-route-id="@Model.Case.Id" asp-route-exposureId="@exposure.Id" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this exposure?');">
                                        <button type="submit" class="btn btn-sm btn-link p-0" title="Delete Exposure" style="color: var(--status-outbreak);">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
                @if (Model.Acquisitions.Count > 5)
                {
                    <div class="text-center" style="margin-top: var(--spacing-2);">
                        <small class="text-muted">Showing 5 of @Model.Acquisitions.Count exposures</small>
                        <button type="button" class="btn btn-sm btn-link p-0 ms-2" data-bs-toggle="modal" data-bs-target="#viewAllExposuresModal" style="color: var(--signal-dk);">
                            <i class="bi bi-arrows-angle-expand"></i> View All
                        </button>
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: var(--spacing-6) var(--spacing-4);">
                    <i class="bi bi-diagram-3" style="font-size: 3rem; color: var(--hairline); display: block; margin-bottom: var(--spacing-3);"></i>
                    <p style="color: var(--graphite); margin-bottom: var(--spacing-3);">No exposures recorded</p>
                    <button type="button" class="btn btn-sentinel-secondary btn-sm" onclick="openAddExposure()">Add Exposure</button>
                </div>
            }
            </div>
        </div>

        <!-- RIGHT SIDE: Transmissions (Who THIS case exposed) -->
        <div class="sentinel-card transmissions-card">
            <div class="sentinel-card-header" style="display: flex; justify-content: space-between; align-items: center;">
                <h3 style="color: var(--forest); font-weight: 600; font-size: 1.125rem; margin: 0; font-family: var(--f-sans);">
                    <i class="bi bi-arrow-up-circle" style="color: var(--signal-dk);"></i>
                    Transmissions (@Model.Transmissions.Count)
                </h3>
                <div class="d-flex gap-1">
                    <a asp-page="/Outbreaks/CreateFromExposure"
                       asp-route-caseId="@Model.Case.Id"
                       class="btn btn-sentinel-primary btn-sm"
                       title="Create Contact Tracing Event">
                        <i class="bi bi-diagram-3"></i>
                    </a>
                    <a asp-page="/Cases/Contacts/BulkCreate"
                       asp-route-caseId="@Model.Case.Id"
                       class="btn btn-sentinel-primary btn-sm"
                       title="Bulk Add Contacts">
                        <i class="bi bi-people-fill"></i>
                    </a>
                    @if (Model.Transmissions.Count > 5)
                    {
                        <button type="button" class="btn btn-sentinel-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#viewAllTransmissionsModal" title="View All">
                            <i class="bi bi-list-ul"></i>
                        </button>
                    }
                    <button type="button" class="btn btn-sentinel-secondary btn-sm" onclick="openAddExposure()" title="Add Exposure">
                        <i class="bi bi-plus-circle"></i>
                    </button>
                </div>
            </div>
            <div class="sentinel-card-body">
            @if (Model.Transmissions.Any())
            {
                <div class="table-responsive">
                <table class="patient-table w-100">
                    <thead>
                        <tr>
                            <th style="width: 120px;">Type</th>
                            <th>Exposed Person</th>
                            <th style="width: 90px;">Date</th>
                            <th style="width: 100px;">Status</th>
                            <th style="width: 80px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exposure in Model.Transmissions.OrderByDescending(e => e.ExposureStartDate).Take(5))
                        {
                            <tr>
                                <td>
                                    @switch (exposure.ExposureType)
                                    {
                                        case Sentinel.Models.ExposureType.Event:
                                            <span class="chip chip-success"><i class="bi bi-calendar-event"></i> Event</span>
                                            break;
                                        case Sentinel.Models.ExposureType.Location:
                                            <span class="chip" style="background: var(--slate); color: white;"><i class="bi bi-geo-alt"></i> Location</span>
                                            break;
                                        case Sentinel.Models.ExposureType.Contact:
                                            <span class="chip" style="background: var(--status-watch); color: var(--forest);"><i class="bi bi-people"></i> Contact</span>
                                            break;
                                        case Sentinel.Models.ExposureType.Travel:
                                            <span class="chip" style="background: var(--graphite); color: white;"><i class="bi bi-airplane"></i> Travel</span>
                                            break;
                                        case Sentinel.Models.ExposureType.LocallyAcquired:
                                            <span class="chip chip-success"><i class="bi bi-house"></i> Locally Acquired</span>
                                            break;
                                        default:
                                            <span class="chip chip-neutral">Unknown</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <small>
                                        @* For Contact exposures, show the EXPOSED person *@
                                        @if (exposure.ExposureType == Sentinel.Models.ExposureType.Contact && exposure.ExposedCase != null)
                                        {
                                            <div>
                                                <strong>
                                                    <i class="bi bi-person"></i>
                                                    <a asp-page="/Cases/Details" asp-route-id="@exposure.ExposedCase.Id">
                                                        @if (exposure.ExposedCase.Patient != null)
                                                        {
                                                            <text>@exposure.ExposedCase.Patient.GivenName @exposure.ExposedCase.Patient.FamilyName</text>
                                                        }
                                                        else
                                                        {
                                                            <text>Case @exposure.ExposedCase.FriendlyId</text>
                                                        }
                                                    </a>
                                                </strong>
                                            </div>
                                            @if (exposure.Location != null)
                                            {
                                                <div class="text-muted">
                                                    <i class="bi bi-geo-alt"></i> At: <a asp-page="/Locations/Details" asp-route-id="@exposure.Location.Id">@exposure.Location?.Name</a>
                                                </div>
                                            }
                                            @if (exposure.Event != null)
                                            {
                                                <div class="text-muted">
                                                    <i class="bi bi-calendar-event"></i> At: <a asp-page="/Events/Details" asp-route-id="@exposure.Event.Id">@exposure.Event?.Name</a>
                                                </div>
                                            }
                                        }
                                        @* For Event exposures *@
                                        else if (exposure.ExposureType == Sentinel.Models.ExposureType.Event && exposure.Event != null)
                                        {
                                            <div>
                                                <i class="bi bi-calendar-event"></i>
                                                <a asp-page="/Events/Details" asp-route-id="@exposure.Event.Id">@exposure.Event.Name</a>
                                            </div>
                                            @if (exposure.Event.Location != null)
                                            {
                                                <div class="text-muted">
                                                    <i class="bi bi-geo-alt"></i> At: @exposure.Event.Location.Name
                                                </div>
                                            }
                                        }
                                        @* For Location exposures *@
                                        else if (exposure.ExposureType == Sentinel.Models.ExposureType.Location && exposure.Location != null)
                                        {
                                            <div>
                                                <i class="bi bi-geo-alt"></i>
                                                <a asp-page="/Locations/Details" asp-route-id="@exposure.Location.Id">@exposure.Location.Name</a>
                                            </div>
                                        }
                                        @* For Travel exposures *@
                                        else if (exposure.ExposureType == Sentinel.Models.ExposureType.Travel)
                                        {
                                            @if (!string.IsNullOrEmpty(exposure.Country))
                                            {
                                                <div><i class="bi bi-airplane"></i> @exposure.Country</div>
                                            }
                                            else if (!string.IsNullOrEmpty(exposure.CountryCode))
                                            {
                                                <div><i class="bi bi-airplane"></i> @exposure.CountryCode</div>
                                            }
                                            else if (!string.IsNullOrEmpty(exposure.FreeTextLocation))
                                            {
                                                <text>@exposure.FreeTextLocation</text>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </small>
                                </td>
                                <td><small>@exposure.ExposureStartDate.ToString("dd MMM")</small></td>
                                <td>
                                    @switch (exposure.ExposureStatus)
                                    {
                                        case Sentinel.Models.ExposureStatus.ConfirmedExposure:
                                            <span class="chip" style="background: var(--status-outbreak); color: white;">Confirmed</span>
                                            break;
                                        case Sentinel.Models.ExposureStatus.UnderInvestigation:
                                            <span class="chip" style="background: var(--status-watch); color: var(--forest);">Investigating</span>
                                            break;
                                        case Sentinel.Models.ExposureStatus.PotentialExposure:
                                            <span class="chip" style="background: var(--status-info); color: white;">Potential</span>
                                            break;
                                        case Sentinel.Models.ExposureStatus.RuledOut:
                                            <span class="chip" style="background: var(--status-clear); color: var(--forest);">Ruled Out</span>
                                            break;
                                        default:
                                            <span class="chip chip-neutral">Unknown</span>
                                            break;
                                    }
                                </td>
                                <td class="text-end">
                                    @if (exposure.ExposureType == Sentinel.Models.ExposureType.Location || exposure.ExposureType == Sentinel.Models.ExposureType.Event)
                                    {
                                        <a asp-page="/Cases/Contacts/BulkCreate"
                                           asp-route-caseId="@Model.Case.Id"
                                           asp-route-locationId="@exposure.LocationId"
                                           asp-route-eventId="@exposure.EventId"
                                           asp-route-exposureStartDate="@exposure.ExposureStartDate.ToString("o")"
                                           asp-route-exposureEndDate="@exposure.ExposureEndDate?.ToString("o")"
                                           class="btn btn-sm btn-link p-0 me-1"
                                           style="color: var(--status-info);"
                                           title="Bulk Add Contacts for this exposure">
                                            <i class="bi bi-people-fill"></i>
                                        </a>
                                    }
                                    <button type="button" class="btn btn-sm btn-link p-0" style="color: var(--signal-dk);" onclick="openEditExposure('@exposure.Id')" title="Edit Exposure">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <form method="post" asp-page-handler="DeleteExposure" asp-route-id="@Model.Case.Id" asp-route-exposureId="@exposure.Id" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this exposure?');">
                                        <button type="submit" class="btn btn-sm btn-link p-0" style="color: var(--status-outbreak);" title="Delete Exposure">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
                @if (Model.Transmissions.Count > 5)
                {
                    <div class="text-center" style="margin-top: var(--spacing-2);">
                        <small class="text-muted">Showing 5 of @Model.Transmissions.Count transmissions</small>
                        <button type="button" class="btn btn-sm btn-link p-0 ms-2" style="color: var(--signal-dk);" data-bs-toggle="modal" data-bs-target="#viewAllTransmissionsModal">
                            <i class="bi bi-arrows-angle-expand"></i> View All
                        </button>
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: var(--spacing-6) var(--spacing-4);">
                    <i class="bi bi-diagram-3" style="font-size: 3rem; color: var(--hairline); display: block; margin-bottom: var(--spacing-3);"></i>
                    <p style="color: var(--graphite); margin-bottom: var(--spacing-2);">No transmissions recorded</p>
                    <small class="text-muted d-block" style="margin-top: var(--spacing-2);">
                        <i class="bi bi-lightbulb"></i> Tip: After adding exposures with contacts, use "Create Contact Tracing Event" to manage multiple contacts as a unified investigation
                    </small>
                </div>
            }
            </div>
        </div>

        <!-- Tasks Section - Wide -->
        <div class="sentinel-card wide tasks-card">
            <div class="sentinel-card-header" style="display: flex; justify-content: space-between; align-items: center;">
                <h3 style="color: var(--forest); font-weight: 600; font-size: 1.125rem; margin: 0; font-family: var(--f-sans);">
                    <i class="bi bi-list-check" style="color: var(--signal-dk);"></i>
                    Tasks (@Model.Tasks.Count)
                </h3>
                <div class="d-flex gap-2">
                    @if (Model.Tasks.Count > 5)
                    {
                        <button type="button" class="btn btn-sentinel-primary btn-sm" data-bs-toggle="modal" data-bs-target="#viewAllTasksModal">
                            <i class="bi bi-list-ul"></i> View All
                        </button>
                    }
                    <button type="button" class="btn btn-sentinel-secondary btn-sm" onclick="openAddTask()">
                        <i class="bi bi-plus-circle"></i> Add
                    </button>
                </div>
            </div>
            <div class="sentinel-card-body">
            @if (Model.Tasks.Any())
            {
                <div class="table-responsive">
                <table class="patient-table w-100">
                    <thead>
                        <tr>
                            <th>Task</th>
                            <th>Assigned To</th>
                            <th>Survey</th>
                            <th>Priority</th>
                            <th>Due</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in Model.Tasks.OrderBy(t => t.DueDate ?? DateTime.MaxValue).Take(5))
                        {
                            <tr>
                                <td>
                                    <strong>@(task.TaskTemplate?.Name ?? task.Title)</strong>
                                    @if (task.TaskType != null)
                                    {
                                        <br />

                                        <small class="text-muted">@task.TaskType.Name</small>
                                    }
                                    @if (task.CallAttempts?.Any() == true)
                                    {
                                        <br />
                                        <span class="chip" style="background: var(--status-info); color: white; font-size: 0.65rem;">
                                            <i class="bi bi-telephone"></i> @task.CallAttempts.Count call(s)
                                        </span>
                                        <button type="button" class="btn btn-sm btn-link p-0 ms-1"
                                                onclick="showCallHistory('@task.Id')"
                                                title="View Call History"
                                                style="font-size: 0.7rem; color: var(--signal-dk);">
                                            <i class="bi bi-clock-history"></i>
                                        </button>
                                    }
                                </td>
                                <td>
                                    @if (task.AssignedToUser != null)
                                    {
                                        <small>@task.AssignedToUser.UserName</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Unassigned</span>
                                    }
                                </td>
                                <td>
                                    @if (task.TaskTemplate?.SurveyTemplate != null)
                                    {
                                        <small class="text-muted">
                                            <i class="bi bi-clipboard-check"></i>
                                            @task.TaskTemplate.SurveyTemplate.Name
                                        </small>
                                    }
                                    else if (!string.IsNullOrEmpty(task.TaskTemplate?.SurveyDefinitionJson))
                                    {
                                        <small class="text-muted">
                                            <i class="bi bi-clipboard-check"></i>
                                            <text>Custom Survey</text>
                                        </small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var priorityStyle = task.Priority switch
                                        {
                                            TaskPriority.Low => "background: var(--graphite); color: white;",
                                            TaskPriority.Medium => "background: var(--slate); color: white;",
                                            TaskPriority.High => "background: var(--status-watch); color: var(--forest);",
                                            TaskPriority.Urgent => "background: var(--status-outbreak); color: white;",
                                            _ => "background: var(--graphite); color: white;"
                                        };
                                    }
                                    <span class="chip" style="@priorityStyle">@task.Priority</span>
                                </td>
                                <td>
                                    @if (task.DueDate.HasValue)
                                    {
                                        <small>@task.DueDate.Value.ToString("dd MMM")</small>
                                        @if (task.Status == CaseTaskStatus.Overdue)
                                        {
                                            <br />

                                            <span class="chip" style="background: var(--status-outbreak); color: white; font-size: 0.65rem;">Overdue</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var statusStyle = task.Status switch
                                        {
                                            CaseTaskStatus.Pending => "background: var(--graphite); color: white;",
                                            CaseTaskStatus.InProgress => "background: var(--signal); color: var(--forest);",
                                            CaseTaskStatus.Completed => "background: var(--status-clear); color: var(--forest);",
                                            CaseTaskStatus.Cancelled => "background: var(--graphite); color: white;",
                                            CaseTaskStatus.Overdue => "background: var(--status-outbreak); color: white;",
                                            CaseTaskStatus.WaitingForPatient => "background: var(--status-watch); color: var(--forest);",
                                            _ => "background: var(--graphite); color: white;"
                                        };
                                    }
                                    <span class="chip" style="@statusStyle">@task.Status</span>
                                </td>
                                <td class="text-end">
                                    @{
                                        var hasSurvey = (task.TaskTemplate?.SurveyTemplateId.HasValue == true) ||
                                        !string.IsNullOrEmpty(task.TaskTemplate?.SurveyDefinitionJson);
                                        var isCompletedWithSurvey = task.Status == CaseTaskStatus.Completed && hasSurvey && !string.IsNullOrEmpty(task.SurveyResponseJson);
                                    }

                                    @if (isCompletedWithSurvey)
                                    {
                                        <a asp-page="/Tasks/ViewSurveyResult" asp-route-id="@task.Id" class="btn btn-sm btn-link p-0 me-1" title="View Survey Results">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    }
                                    else if (task.Status != CaseTaskStatus.Completed && task.Status != CaseTaskStatus.Cancelled)
                                    {
                                        @if (hasSurvey)
                                        {
                                            <a asp-page="/Tasks/CompleteSurvey" asp-route-id="@task.Id" class="btn btn-sm btn-link p-0 me-1" title="Complete Survey">
                                                <i class="bi bi-clipboard-check"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-link p-0 me-1" onclick="openCompleteTaskModal('@task.Id', '@task.TaskTemplate?.Name')" title="Complete">
                                                <i class="bi bi-check-circle"></i>
                                            </button>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
                @if (Model.Tasks.Count > 5)
                {
                    <div class="text-center" style="margin-top: var(--spacing-2);">
                        <small class="text-muted">Showing 5 of @Model.Tasks.Count tasks</small>
                        <button type="button" class="btn btn-sm btn-link p-0 ms-2" style="color: var(--signal-dk);" data-bs-toggle="modal" data-bs-target="#viewAllTasksModal">
                            <i class="bi bi-arrows-angle-expand"></i> View All
                        </button>
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: var(--spacing-6) var(--spacing-4);">
                    <i class="bi bi-list-check" style="font-size: 3rem; color: var(--hairline); display: block; margin-bottom: var(--spacing-3);"></i>
                    <p style="color: var(--graphite); margin-bottom: var(--spacing-3);">No tasks yet</p>
                    <button type="button" class="btn btn-sentinel-secondary btn-sm" onclick="openAddTask()">Add Task</button>
                </div>
            }
            </div>
        </div>

    <!-- Notes Card -->
    <div class="sentinel-card notes-card">
        <div class="sentinel-card-header" style="display: flex; justify-content: space-between; align-items: center;">
            <h3 style="color: var(--forest); font-weight: 600; font-size: 1.125rem; margin: 0; font-family: var(--f-sans);">
                <i class="bi bi-chat-left-text" style="color: var(--signal-dk);"></i>
                Notes (@Model.Notes.Count)
            </h3>
            <button type="button" class="btn btn-sentinel-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#addNoteModal">
                <i class="bi bi-plus-circle me-1"></i>Add
            </button>
        </div>
        <div class="sentinel-card-body">

        @if (Model.Notes.Any())
        {
            <div class="scroll-container">
                @foreach (var note in Model.Notes.OrderByDescending(n => n.CreatedAt).Take(3))
                {
                    <div class="note-item">
                        <div class="note-header">
                            <strong>@note.Subject</strong>
                            <div class="note-meta">
                                @note.CreatedAt.ToString("dd MMM yyyy HH:mm") by @note.CreatedBy
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(note.Content))
                        {
                            <p class="mb-1">@note.Content</p>
                        }
                        @if (!string.IsNullOrEmpty(note.AttachmentFileName))
                        {
                            <div class="mt-1">
                                <a href="@note.AttachmentPath" class="btn btn-sentinel-secondary btn-sm" target="_blank">
                                    <i class="bi bi-paperclip"></i> @note.AttachmentFileName
                                </a>
                            </div>
                        }
                        <div class="text-end" style="margin-top: var(--spacing-2);">
                            <form method="post" asp-page-handler="DeleteNote" asp-route-id="@Model.Case.Id" asp-route-noteId="@note.Id"
                                  onsubmit="return confirm('Are you sure you want to delete this note?');" style="display: inline;">
                                <button type="submit" class="btn btn-sm btn-link p-0" style="color: var(--status-outbreak);">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>

            @if (Model.Notes.Count > 3)
            {
                <div class="text-center" style="margin-top: var(--spacing-2);">
                    <small class="text-muted">Showing 3 of @Model.Notes.Count notes</small>
                </div>
            }
        }
        else
        {
            <div style="text-align: center; padding: var(--spacing-6) var(--spacing-4);">
                <i class="bi bi-chat-left-text" style="font-size: 3rem; color: var(--hairline); display: block; margin-bottom: var(--spacing-3);"></i>
                <p style="color: var(--graphite); margin-bottom: var(--spacing-3);">No notes yet</p>
                <button type="button" class="btn btn-sentinel-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#addNoteModal">Add Note</button>
            </div>
        }
        </div>
    </div>
</div>

<!-- Add Note Modal -->
<div class="modal fade" id="addNoteModal" tabindex="-1" aria-labelledby="addNoteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addNoteModalLabel">
                    <i class="bi bi-chat-left-text me-2"></i>Add Note
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="AddNote" asp-route-id="@Model.Case.Id" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Subject <span class="required">*</span></label>
                        <input type="text" name="NewNote.Subject" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Content</label>
                        <textarea name="NewNote.Content" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Attachment</label>
                        <input type="file" name="Attachment" class="form-control" />
                        <small class="form-text text-muted">Optional file attachment (PDF, Word, Excel, Image)</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-sentinel-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-sentinel-primary">
                        <i class="bi bi-check-circle me-1"></i>Add Note
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- View All Tasks Modal -->
<div class="modal fade" id="viewAllTasksModal" tabindex="-1" aria-labelledby="viewAllTasksModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewAllTasksModalLabel">
                    <i class="bi bi-list-check me-2"></i>All Tasks (@Model.Tasks.Count)
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @if (Model.Tasks.Any())
                {
                    <div class="table-responsive">
                        <table class="patient-table">
                            <thead>
                                <tr>
                                    <th>Task</th>
                                    <th>Assigned To</th>
                                    <th>Survey</th>
                                    <th>Priority</th>
                                    <th>Due</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                        <tbody>
                            @foreach (var task in Model.Tasks.OrderBy(t => t.DueDate ?? DateTime.MaxValue))
                            {
                                <tr>
                                    <td>
                                        <strong>@(task.TaskTemplate?.Name ?? task.Title)</strong>
                                        @if (task.TaskType != null)
                                        {
                                            <br />

                                            <small class="text-muted">@task.TaskType.Name</small>
                                        }
                                    </td>
                                    <td>
                                        @if (task.AssignedToUser != null)
                                        {
                                            @task.AssignedToUser.UserName
                                        }
                                        else
                                        {
                                            <span class="text-muted">Unassigned</span>
                                        }
                                    </td>
                                    <td>
                                        @if (task.TaskTemplate?.SurveyTemplate != null)
                                        {
                                            <i class="bi bi-clipboard-check"></i>
                                            @task.TaskTemplate.SurveyTemplate.Name
                                        }
                                        else if (!string.IsNullOrEmpty(task.TaskTemplate?.SurveyDefinitionJson))
                                        {
                                            <i class="bi bi-clipboard-check"></i>
                                            <text>Custom Survey</text>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @{
                                            var priorityColor = task.Priority switch
                                            {
                                                TaskPriority.Low => "var(--graphite)",
                                                TaskPriority.Medium => "var(--slate)",
                                                TaskPriority.High => "var(--status-watch)",
                                                TaskPriority.Urgent => "var(--status-outbreak)",
                                                _ => "var(--graphite)"
                                            };
                                        }
                                        <span class="chip" style="background: @priorityColor; color: white; border-color: @priorityColor;">@task.Priority</span>
                                    </td>
                                    <td>
                                        @if (task.DueDate.HasValue)
                                        {
                                            @task.DueDate.Value.ToString("dd MMM yyyy")
                                            @if (task.Status == CaseTaskStatus.Overdue)
                                            {
                                                <br />

                                                <span class="chip" style="background: var(--status-outbreak); color: white; border-color: var(--status-outbreak); font-size: 0.65rem;">Overdue</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @{
                                            var statusColor = task.Status switch
                                            {
                                                CaseTaskStatus.Pending => "var(--graphite)",
                                                CaseTaskStatus.InProgress => "var(--signal)",
                                                CaseTaskStatus.Completed => "var(--signal-dk)",
                                                CaseTaskStatus.Cancelled => "var(--slate-2)",
                                                CaseTaskStatus.Overdue => "var(--status-outbreak)",
                                                CaseTaskStatus.WaitingForPatient => "var(--status-watch)",
                                                _ => "var(--graphite)"
                                            };
                                        }
                                        <span class="chip" style="background: @statusColor; color: white; border-color: @statusColor;">@task.Status</span>
                                    </td>
                                    <td class="text-end">
                                        @{
                                            var hasSurvey = (task.TaskTemplate?.SurveyTemplateId.HasValue == true) ||
                                            !string.IsNullOrEmpty(task.TaskTemplate?.SurveyDefinitionJson);
                                            var isCompletedWithSurvey = task.Status == CaseTaskStatus.Completed && hasSurvey && !string.IsNullOrEmpty(task.SurveyResponseJson);
                                        }

                                        @if (isCompletedWithSurvey)
                                        {
                                            <a asp-page="/Tasks/ViewSurveyResult" asp-route-id="@task.Id" class="btn btn-sm btn-link p-0 me-1" title="View Survey Results">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        }
                                        else if (task.Status != CaseTaskStatus.Completed && task.Status != CaseTaskStatus.Cancelled)
                                        {
                                            @if (hasSurvey)
                                            {
                                                <a asp-page="/Tasks/CompleteSurvey" asp-route-id="@task.Id" class="btn btn-sm btn-link p-0 me-1" title="Complete Survey">
                                                    <i class="bi bi-clipboard-check"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-sm btn-link p-0 me-1" onclick="openCompleteTaskModal('@task.Id', '@task.TaskTemplate?.Name')" title="Complete">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    </div>
                }
                else
                {
                    <div style="text-align: center; padding: 3rem; color: var(--hairline);">
                        <i class="bi bi-list-check" style="font-size: 3rem; display: block; margin-bottom: 1rem;"></i>
                        <div style="color: var(--graphite);">No tasks have been created for this case.</div>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-sentinel-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn-sentinel-primary" onclick="openAddTask(); $('#viewAllTasksModal').modal('hide');">
                    <i class="bi bi-plus-circle me-1"></i>Add New Task
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Add Exposure Modal -->
<div class="modal fade" id="addExposureModal" tabindex="-1" aria-labelledby="addExposureModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addExposureModalLabel">
                    <i class="bi bi-diagram-3 me-2"></i>Add Exposure
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="AddExposure">
                <div class="modal-body">
                    <input type="hidden" name="CaseId" value="@Model.Case.Id" />

                    <div style="background: var(--signal-lt); border: 1px solid var(--signal); border-radius: 4px; padding: 1rem; margin-bottom: 1rem; color: var(--forest);">
                        <i class="bi bi-info-circle me-2" style="color: var(--signal-dk);"></i>
                        <strong>Case:</strong> @Model.Case.FriendlyId - @Model.Case.Patient?.GivenName @Model.Case.Patient?.FamilyName
                    </div>

                    <!-- Exposure Direction Toggle -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            <i class="bi bi-arrow-left-right me-1"></i>Exposure Direction <span class="text-danger">*</span>
                        </label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check" name="ExposureDirection" id="modalDirectionAcquisition" value="Acquisition" checked />
                            <label class="btn btn-outline-primary" for="modalDirectionAcquisition">
                                <i class="bi bi-arrow-down-circle me-1"></i>
                                <strong>Acquisition</strong> <small class="d-block text-muted">This case got exposed</small>
                            </label>

                            <input type="radio" class="btn-check" name="ExposureDirection" id="modalDirectionTransmission" value="Transmission" />
                            <label class="btn btn-outline-danger" for="modalDirectionTransmission">
                                <i class="bi bi-arrow-up-circle me-1"></i>
                                <strong>Transmission</strong> <small class="d-block text-muted">This case exposed others</small>
                            </label>
                        </div>
                        <small class="form-text text-muted">
                            ?? <strong>Acquisition:</strong> Track where patient got infected | <strong>Transmission:</strong> Contact tracing from this case
                        </small>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">
                                Exposure Type <span class="text-danger">*</span>
                            </label>
                            <select name="ExposureType" class="form-select" id="modalExposureTypeSelect" required>
                                <option value="">Select Type</option>
                                <option value="@((int)ExposureType.Event)">Event</option>
                                <option value="@((int)ExposureType.Location)">Location</option>
                                <option value="@((int)ExposureType.Contact)">Contact (Person-to-Person)</option>
                                <option value="@((int)ExposureType.Travel)">Travel</option>
                                <option value="@((int)ExposureType.LocallyAcquired)">Locally Acquired</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">
                                Status <span class="text-danger">*</span>
                            </label>
                            <select name="ExposureStatus" class="form-select">
                                <option value="@((int)ExposureStatus.PotentialExposure)">Potential Exposure</option>
                                <option value="@((int)ExposureStatus.UnderInvestigation)">Under Investigation</option>
                                <option value="@((int)ExposureStatus.ConfirmedExposure)">Confirmed Exposure</option>
                                <option value="@((int)ExposureStatus.RuledOut)">Ruled Out</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mt-2">
                        <div class="col-md-6">
                            <label class="form-label">
                                Start Date <span class="text-danger">*</span>
                            </label>
                            <input name="ExposureStartDate" type="datetime-local" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">
                                End Date
                            </label>
                            <input name="ExposureEndDate" type="datetime-local" class="form-control" />
                        </div>
                    </div>

                    <!-- Type-Specific Sections -->
                    <div id="modalEventSection" class="mt-3" style="display: none;">
                        <label class="form-label">
                            Event <span class="text-danger">*</span>
                        </label>
                        <select name="EventId" class="form-select select2-modal-event">
                            <option value="">Type to search for event...</option>
                        </select>
                    </div>

                    <div id="modalLocationSection" class="mt-3" style="display: none;">
                        <label class="form-label">
                            Location <span class="text-danger">*</span>
                        </label>
                        <select name="LocationId" class="form-select select2-modal-location">
                            <option value="">Type to search for location...</option>
                        </select>
                    </div>

                    <div id="modalContactSection" class="mt-3" style="display: none;">
                        <label class="form-label">
                            Source Case (Person who transmitted)
                        </label>
                        <select name="SourceCaseId" class="form-select select2-modal-case">
                            <option value="">Type to search for case...</option>
                        </select>
                        <small class="form-text text-muted">Search for the person who may have transmitted disease to this case</small>
                    </div>

                    <div id="modalTravelSection" class="mt-3" style="display: none;">
                        <label class="form-label">
                            Country <span class="text-danger">*</span>
                        </label>
                        <select name="CountryCode" class="form-select select2-modal-country">
                            <option value="">Type to search for country...</option>
                        </select>
                    </div>

                    <div class="mt-3">
                        <label class="form-label">Description</label>
                        <textarea name="Description" class="form-control" rows="3" placeholder="Additional details about this exposure..."></textarea>
                    </div>

                    <div class="mt-3">
                        <div class="form-check">
                            <input name="IsReportingExposure" class="form-check-input" type="checkbox" />
                            <label class="form-check-label">
                                Primary Reporting Exposure
                            </label>
                            <small class="form-text text-muted d-block">
                                <i class="bi bi-info-circle me-1"></i>
                                Mark this as the main exposure for reporting purposes
                            </small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-sentinel-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn-sentinel-primary">
                        <i class="bi bi-save me-1"></i>Save Exposure
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- View All Transmissions Modal -->
<div class="modal fade" id="viewAllTransmissionsModal" tabindex="-1" aria-labelledby="viewAllTransmissionsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewAllTransmissionsModalLabel">
                    <i class="bi bi-arrow-up-circle me-2"></i>All Transmissions (@Model.Transmissions.Count)
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @if (Model.Transmissions.Any())
                {
                    <div class="table-responsive">
                        <table class="patient-table">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Exposed Person</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                        <tbody>
                            @foreach (var exposure in Model.Transmissions.OrderByDescending(e => e.ExposureStartDate))
                            {
                                <tr>
                                    <td>
                                        @switch (exposure.ExposureType)
                                        {
                                            case Sentinel.Models.ExposureType.Event:
                                                <span class="chip" style="background: var(--signal); color: var(--forest); border-color: var(--signal);"><i class="bi bi-calendar-event"></i> Event</span>
                                                break;
                                            case Sentinel.Models.ExposureType.Location:
                                                <span class="chip" style="background: var(--slate); color: white; border-color: var(--slate);"><i class="bi bi-geo-alt"></i> Location</span>
                                                break;
                                            case Sentinel.Models.ExposureType.Contact:
                                                <span class="chip" style="background: var(--status-watch); color: var(--forest); border-color: var(--status-watch);"><i class="bi bi-people"></i> Contact</span>
                                                break;
                                            case Sentinel.Models.ExposureType.Travel:
                                                <span class="chip" style="background: var(--graphite); color: white; border-color: var(--graphite);"><i class="bi bi-airplane"></i> Travel</span>
                                                break;
                                            case Sentinel.Models.ExposureType.LocallyAcquired:
                                                <span class="chip" style="background: var(--signal); color: var(--forest); border-color: var(--signal);"><i class="bi bi-house"></i> Locally Acquired</span>
                                                break;
                                            default:
                                                <span class="chip" style="background: var(--graphite); color: white; border-color: var(--graphite);">Unknown</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (exposure.ExposureType == Sentinel.Models.ExposureType.Contact && exposure.ExposedCase != null)
                                        {
                                            <div>
                                                <strong>
                                                    <a asp-page="/Cases/Details" asp-route-id="@exposure.ExposedCase.Id">
                                                        @if (exposure.ExposedCase.Patient != null)
                                                        {
                                                            <text>@exposure.ExposedCase.Patient.GivenName @exposure.ExposedCase.Patient.FamilyName</text>
                                                        }
                                                        else
                                                        {
                                                            <text>Case @exposure.ExposedCase.FriendlyId</text>
                                                        }
                                                    </a>
                                                </strong>
                                            </div>
                                            @if (exposure.Location != null)
                                            {
                                                <div class="text-muted small">
                                                    <i class="bi bi-geo-alt"></i> At: <a asp-page="/Locations/Details" asp-route-id="@exposure.Location.Id">@exposure.Location.Name</a>
                                                </div>
                                            }
                                            @if (exposure.Event != null)
                                            {
                                                <div class="text-muted small">
                                                    <i class="bi bi-calendar-event"></i> At: <a asp-page="/Events/Details" asp-route-id="@exposure.Event.Id">@exposure.Event.Name</a>
                                                </div>
                                            }
                                        }
                                        @* For Event exposures *@
                                        else if (exposure.ExposureType == Sentinel.Models.ExposureType.Event && exposure.Event != null)
                                        {
                                            <div>
                                                <i class="bi bi-calendar-event"></i>
                                                <a asp-page="/Events/Details" asp-route-id="@exposure.Event.Id">@exposure.Event.Name</a>
                                            </div>
                                            @if (exposure.Event.Location != null)
                                            {
                                                <div class="text-muted small">
                                                    <i class="bi bi-geo-alt"></i> At: @exposure.Event.Location.Name
                                                </div>
                                            }
                                        }
                                        @* For Location exposures *@
                                        else if (exposure.ExposureType == Sentinel.Models.ExposureType.Location && exposure.Location != null)
                                        {
                                            <div>
                                                <i class="bi bi-geo-alt"></i>
                                                <a asp-page="/Locations/Details" asp-route-id="@exposure.Location.Id">@exposure.Location.Name</a>
                                            </div>
                                        }
                                        @* For Travel exposures *@
                                        else if (exposure.ExposureType == Sentinel.Models.ExposureType.Travel)
                                        {
                                            @if (!string.IsNullOrEmpty(exposure.Country))
                                            {
                                                <div><i class="bi bi-airplane"></i> @exposure.Country</div>
                                            }
                                            else if (!string.IsNullOrEmpty(exposure.CountryCode))
                                            {
                                                <div><i class="bi bi-airplane"></i> @exposure.CountryCode</div>
                                            }
                                            else if (!string.IsNullOrEmpty(exposure.FreeTextLocation))
                                            {
                                                <text>@exposure.FreeTextLocation</text>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>@exposure.ExposureStartDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @switch (exposure.ExposureStatus)
                                        {
                                            case Sentinel.Models.ExposureStatus.ConfirmedExposure:
                                                <span class="chip" style="background: var(--status-outbreak); color: white; border-color: var(--status-outbreak);">Confirmed</span>
                                                break;
                                            case Sentinel.Models.ExposureStatus.UnderInvestigation:
                                                <span class="chip" style="background: var(--status-watch); color: var(--forest); border-color: var(--status-watch);">Investigating</span>
                                                break;
                                            case Sentinel.Models.ExposureStatus.PotentialExposure:
                                                <span class="chip" style="background: var(--status-info); color: white; border-color: var(--status-info);">Potential</span>
                                                break;
                                            case Sentinel.Models.ExposureStatus.RuledOut:
                                                <span class="chip" style="background: var(--signal-dk); color: white; border-color: var(--signal-dk);">Ruled Out</span>
                                                break;
                                            default:
                                                <span class="chip" style="background: var(--graphite); color: white; border-color: var(--graphite);">Unknown</span>
                                                break;
                                        }
                                    </td>
                                    <td class="text-end">
                                        <button type="button" class="btn btn-sm btn-link p-0 me-2" style="color: var(--signal-dk);" onclick="openEditExposure('@exposure.Id')" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <form method="post" asp-page-handler="DeleteExposure" asp-route-id="@Model.Case.Id" asp-route-exposureId="@exposure.Id" class="d-inline" onsubmit="return confirm('Delete this transmission?');">
                                            <button type="submit" class="btn btn-sm btn-link p-0" style="color: var(--status-outbreak);" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    </div>
                }
                else
                {
                    <div style="text-align: center; padding: 3rem; color: var(--hairline);">
                        <i class="bi bi-arrow-up-circle" style="font-size: 3rem; display: block; margin-bottom: 1rem;"></i>
                        <div style="color: var(--graphite);">No transmissions recorded for this case.</div>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-sentinel-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn-sentinel-primary" onclick="openAddExposure(); $('#viewAllTransmissionsModal').modal('hide');">
                    <i class="bi bi-plus-circle me-1"></i>Add New Exposure
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // Global function to handle exposure type visibility
    function updateExposureTypeVisibility() {
        var exposureTypeSelect = document.getElementById('modalExposureTypeSelect');
        if (!exposureTypeSelect) return;

        var type = exposureTypeSelect.value;

        // Get all sections
        var eventSection = document.getElementById('modalEventSection');
        var locationSection = document.getElementById('modalLocationSection');
        var contactSection = document.getElementById('modalContactSection');
        var travelSection = document.getElementById('modalTravelSection');

        // Hide all sections first
        if (eventSection) eventSection.style.display = 'none';
        if (locationSection) locationSection.style.display = 'none';
        if (contactSection) contactSection.style.display = 'none';
        if (travelSection) travelSection.style.display = 'none';

        // Show the correct section based on type
        switch(type) {
            case '1': // Event
                if (eventSection) eventSection.style.display = 'block';
                break;
            case '2': // Location
                if (locationSection) locationSection.style.display = 'block';
                break;
            case '3': // Contact
                if (contactSection) contactSection.style.display = 'block';
                break;
            case '4': // Travel
                if (travelSection) travelSection.style.display = 'block';
                break;
            case '5': // LocallyAcquired
                // No specific section
                break;
        }
    }

    function openAddExposure() {
        // Open in new window - use AddExposure page (not Exposures/Add)
        window.open('/Cases/AddExposure?caseId=@Model.Case.Id', '_blank', 'width=900,height=800,scrollbars=yes,resizable=yes');
    }

    function openAddLabResult() {
        window.open('/Cases/AddLabResult?caseId=@Model.Case.Id', '_blank', 'width=1000,height=900,scrollbars=yes,resizable=yes');
    }

    window.viewLabResult = function(labResultId) {
        window.open('/Cases/ViewLabResult?labResultId=' + labResultId, '_blank', 'width=1000,height=800,scrollbars=yes,resizable=yes');
    }

    function openEditExposure(exposureId) {
        window.open('/Cases/EditExposure?id=' + exposureId + '&caseId=@Model.Case.Id', '_blank', 'width=1000,height=800,scrollbars=yes,resizable=yes');
    }

    function openAddTask() {
        window.open('@Url.Page("/Cases/AddTask", new { caseId = Model.Case.Id })', '_blank', 'width=900,height=800,scrollbars=yes,resizable=yes');
    }

    function openCompleteTaskModal(taskId, taskName) {
        // Implementation for completing tasks without surveys
        alert('Complete task: ' + taskName);
    }

    function showCallHistory(taskId) {
        // Implementation for showing call history
        alert('Show call history for task: ' + taskId);
    }

    $(document).ready(function() {
    // Attach event listener to exposure type dropdown
    var exposureTypeSelect = document.getElementById('modalExposureTypeSelect');
    if (exposureTypeSelect) {
        exposureTypeSelect.addEventListener('change', updateExposureTypeVisibility);
    }

            // Initialize Select2 for Events
            $('.select2-modal-event').select2({
                dropdownParent: $('#addExposureModal'),
                theme: 'bootstrap-5',
                placeholder: 'Type to search for event...',
                allowClear: true,
                minimumInputLength: 2,
                ajax: {
                    url: '/api/events/search',
                    dataType: 'json',
                    delay: 250,
                    data: function(params) {
                        return { term: params.term };
                    },
                    processResults: function(data) {
                        return {
                            results: data.map(function(item) {
                                return {
                                    id: item.id,
                                    text: item.name + (item.location ? ' (' + item.location + ')' : '')
                                };
                            })
                        };
                    }
                }
            });

            // Initialize Select2 for Locations
            $('.select2-modal-location').select2({
                dropdownParent: $('#addExposureModal'),
                theme: 'bootstrap-5',
                placeholder: 'Type to search for location...',
                allowClear: true,
                minimumInputLength: 2,
                ajax: {
                    url: '/api/locations/search',
                    dataType: 'json',
                    delay: 250,
                    data: function(params) {
                        return { term: params.term };
                    },
                    processResults: function(data) {
                        return {
                            results: data.map(function(item) {
                                return {
                                    id: item.id,
                                    text: item.name + (item.address ? ' - ' + item.address : '')
                                };
                            })
                        };
                    }
                }
            });

            // Initialize Select2 for Cases
            $('.select2-modal-case').select2({
                dropdownParent: $('#addExposureModal'),
                theme: 'bootstrap-5',
                placeholder: 'Type to search for case...',
                allowClear: true,
                minimumInputLength: 2,
                ajax: {
                    url: '/api/cases/search',
                    dataType: 'json',
                    delay: 250,
                    data: function(params) {
                        return {
                            term: params.term,
                            excludeCaseId: '@Model.Case.Id'
                        };
                    },
                    processResults: function(data) {
                        return {
                            results: data.map(function(item) {
                                return {
                                    id: item.caseId,
                                    text: item.friendlyId + ' - ' + item.patientName
                                };
                            })
                        };
                    }
                }
            });

            // Initialize Select2 for Countries
            $('.select2-modal-country').select2({
                dropdownParent: $('#addExposureModal'),
                theme: 'bootstrap-5',
                placeholder: 'Type to search for country...',
                allowClear: true,
                minimumInputLength: 2,
                ajax: {
                    url: '/api/countries/search',
                    dataType: 'json',
                    delay: 250,
                    data: function(params) {
                        return { term: params.term };
                    },
                    processResults: function(data) {
                        return {
                            results: data.map(function(item) {
                                return {
                                    id: item.code,
                                    text: item.name
                                };
                            })
                        };
                    }
                }
            });
        });

        // ========================================================================
        // COPY ADDRESS FROM PATIENT
        // ========================================================================

        function copyAddressFromPatient() {
            if (!confirm('Copy address and jurisdiction data from the patient record to this case?\n\n?? This will overwrite any existing case address data.')) {
                return;
            }

            const caseId = '@Model.Case.Id';

            // Show loading state
            const btn = event.target.closest('button');
            const originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split spinner-border spinner-border-sm me-1"></i> Copying...';

            fetch(`/Cases/Details?handler=CopyAddressFromPatient&id=${caseId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(response => response.json())
            .then(data => {
                btn.disabled = false;
                btn.innerHTML = originalHtml;

                if (data.success) {
                    if (data.warning) {
                        // Show warning message
                        const alertHtml = `
                            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                <strong>Address Copied with Warnings:</strong><br/>
                                ${data.message}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        `;
                        document.querySelector('.case-details-container').insertAdjacentHTML('afterbegin', alertHtml);
                    } else {
                        // Show success message
                        const alertHtml = `
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <i class="bi bi-check-circle-fill me-2"></i>
                                ${data.message}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        `;
                        document.querySelector('.case-details-container').insertAdjacentHTML('afterbegin', alertHtml);
                    }

                    if (data.reloadPage) {
                        // Reload after 2 seconds to show updated address
                        setTimeout(() => location.reload(), 2000);
                    }
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(error => {
                btn.disabled = false;
                btn.innerHTML = originalHtml;
                alert('Error copying address: ' + error.message);
            });
        }
</script>



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/case-details-custom-fields.js"></script>
}


