@page
@model Sentinel.Pages.Cases.DetailsModel
@using Sentinel.Models
@using Sentinel.Models.Lookups

@{
    ViewData["Title"] = "Case Details";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<style>
    /* Modern Apple Aesthetic - Orange/Amber Theme for Cases */
    .case-details-container {
        width: 100%;
        /* Full width - no max-width constraint */
    }

    /* Header Section */
    .case-header {
        background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
        border-radius: 16px;
        padding: 2rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 2px 8px rgba(245, 158, 11, 0.08);
        border: 1px solid rgba(245, 158, 11, 0.15);
    }

        .case-header h1 {
            font-size: 2rem;
            font-weight: 600;
            color: #2d3748;
            margin-bottom: 0.5rem;
            letter-spacing: -0.5px;
        }

            .case-header h1 i {
                color: #f59e0b;
            }

        .case-header .subtitle {
            color: #718096;
            font-size: 1rem;
            margin-bottom: 0;
        }

    /* Quick Action Buttons */
    .quick-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1rem;
    }

    .quick-action-btn {
        background: white;
        border: 1px solid #fbbf24;
        border-radius: 10px;
        padding: 0.5rem 1rem;
        font-size: 0.875rem;
        font-weight: 600;
        color: #f59e0b;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
    }

        .quick-action-btn:hover {
            background: #fffbeb;
            border-color: #f59e0b;
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(245, 158, 11, 0.15);
            color: #d97706;
        }

        .quick-action-btn i {
            font-size: 1rem;
        }

        .quick-action-btn.primary {
            background: #f59e0b;
            color: white;
            border-color: #f59e0b;
        }

            .quick-action-btn.primary:hover {
                background: #d97706;
                color: white;
                border-color: #d97706;
            }

        .quick-action-btn.success {
            background: #10b981;
            color: white;
            border-color: #10b981;
        }

            .quick-action-btn.success:hover {
                background: #059669;
                color: white;
                border-color: #059669;
            }

    /* Compact Card Design */
    .info-card {
        background: white;
        border-radius: 12px;
        padding: 1.25rem;
        box-shadow: 0 2px 8px rgba(245, 158, 11, 0.06);
        border: 1px solid rgba(245, 158, 11, 0.1);
        margin-bottom: 1rem;
        height: 100%;
    }

        .info-card:hover {
            box-shadow: 0 4px 12px rgba(245, 158, 11, 0.12);
            transform: translateY(-1px);
            transition: all 0.2s ease;
        }

    .info-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid #fef3c7;
    }

    .info-card-title {
        font-size: 1rem;
        font-weight: 600;
        color: #2d3748;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .info-card-title i {
            color: #f59e0b;
        }

    .info-card-action {
        padding: 0.35rem 0.75rem;
        font-size: 0.75rem;
        border-radius: 8px;
        background: #fffbeb;
        border: 1px solid #fbbf24;
        color: #f59e0b;
        font-weight: 600;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

        .info-card-action:hover {
            background: #f59e0b;
            color: white;
            border-color: #f59e0b;
        }

    /* Outbreak/Contact Tracing Event buttons */
    .btn-outline-purple {
        border-color: #7c3aed;
        color: #7c3aed;
        font-weight: 600;
        transition: all 0.2s;
    }

        .btn-outline-purple:hover {
            background: #7c3aed;
            color: white;
            border-color: #7c3aed;
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(124, 58, 237, 0.2);
        }

    .btn-outline-danger {
        font-weight: 600;
        transition: all 0.2s;
    }

        .btn-outline-danger:hover {
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(220, 38, 38, 0.2);
        }

    /* Compact Info Rows */
    .info-row {
        display: grid;
        grid-template-columns: 140px 1fr;
        gap: 0.75rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid #f7fafc;
        font-size: 0.875rem;
    }

        .info-row:last-child {
            border-bottom: none;
        }

    .info-label {
        color: #718096;
        font-weight: 500;
    }

    .info-value {
        color: #2d3748;
        font-weight: 600;
    }

    /* Badges */
    .badge {
        padding: 0.35rem 0.65rem;
        font-size: 0.75rem;
        font-weight: 600;
        border-radius: 6px;
    }

        .badge.badge-grey {
            background: #718096;
            color: white;
        }

        .badge.badge-teal {
            background: #f59e0b;
            color: white;
        }

        .badge.badge-slate {
            background: #64748b;
            color: white;
        }

        .badge.badge-amber {
            background: #f59e0b;
            color: white;
        }

    /* Compact Table */
    .compact-table {
        font-size: 0.875rem;
    }

        .compact-table th {
            background: #f7fafc;
            color: #4a5568;
            font-weight: 600;
            border: none;
            padding: 0.5rem 0.75rem;
        }

        .compact-table td {
            padding: 0.5rem 0.75rem;
            border-bottom: 1px solid #f7fafc;
        }

        .compact-table tr:last-child td {
            border-bottom: none;
        }

    /* Note Item */
    .note-item {
        background: #fffbeb;
        border-left: 3px solid #f59e0b;
        padding: 0.75rem;
        margin-bottom: 0.75rem;
        border-radius: 8px;
        font-size: 0.875rem;
    }

        .note-item .note-header {
            display: flex;
            justify-content: space-between;
            align-items: start;
            margin-bottom: 0.5rem;
        }

        .note-item .note-meta {
            font-size: 0.75rem;
            color: #92400e;
        }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 2rem 1rem;
        color: #718096;
    }

        .empty-state i {
            font-size: 2.5rem;
            color: #cbd5e0;
            margin-bottom: 0.75rem;
        }

        .empty-state p {
            margin: 0.5rem 0;
            font-size: 0.875rem;
        }

    /* Breadcrumb */
    .breadcrumb {
        background: transparent;
        padding: 0;
        margin-bottom: 1rem;
        font-size: 0.875rem;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        color: #cbd5e0;
    }

    .breadcrumb-item a {
        color: #4a5568;
        text-decoration: none;
    }

        .breadcrumb-item a:hover {
            color: #2d3748;
        }

    .breadcrumb-item.active {
        color: #718096;
    }

    /* Responsive Grid - 3 column layout */
    .case-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 1rem;
        grid-auto-rows: auto;
    }

    /* Tablet view - 2 columns */
    @@media (max-width: 1200px) {
        .case-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    /* Mobile view - 1 column */
    @@media (max-width: 768px) {
        .case-grid {
            grid-template-columns: 1fr;
        }
    }

    /* Left column cards - explicit positioning */
    .info-card.case-info-card {
        grid-column: 1;
        grid-row: 1;
    }

    .info-card.patient-info-card {
        grid-column: 1;
        grid-row: 2;
    }

    .info-card.symptoms-card {
        grid-column: 1;
        grid-row: 3;
    }

    /* Wide cards spanning 2 columns (for lab results and tasks) */
    .info-card.wide {
        grid-column: span 2;
    }

    /* Lab Results - positioned at row 1, columns 2-3 */
    .info-card.lab-results-card {
        grid-column: 2 / span 2;
        grid-row: 1;
    }

    /* Exposures - positioned at row 2, column 2 & 3 */
    .info-card.acquisitions-card {
        grid-column: 2;
        grid-row: 2;
    }

    .info-card.transmissions-card {
        grid-column: 3;
        grid-row: 2;
    }

    /* Tasks - positioned at row 3, columns 2-3 (same row as location card in col 1) */
    .info-card.tasks-card {
        grid-column: 2 / span 2;
        grid-row: 3;
    }

    @@media (max-width: 1200px) {
        .info-card.wide {
            grid-column: span 2;
        }

        .info-card.case-info-card,
        .info-card.patient-info-card,
        .info-card.location-card,
        .info-card.symptoms-card,
        .info-card.lab-results-card,
        .info-card.acquisitions-card, .info-card.transmissions-card,
        .info-card.tasks-card,
        .info-card.notes-card {
            grid-column: auto;
            grid-row: auto;
        }
    }

    @@media (max-width: 768px) {
        .info-card.wide {
            grid-column: span 1;
        }

        .info-card.case-info-card,
        .info-card.patient-info-card,
        .info-card.location-card,
        .info-card.symptoms-card,
        .info-card.lab-results-card,
        .info-card.acquisitions-card, .info-card.transmissions-card,
        .info-card.tasks-card,
        .info-card.notes-card {
            grid-column: auto;
            grid-row: auto;
        }
    }

    /* Half-height cards */
    .info-card.half-height {
        max-height: 400px;
    }

        .info-card.half-height .compact-table {
            display: block;
            max-height: 280px;
            overflow-y: auto;
        }

    /* Alerts */
    .alert {
        border-radius: 10px;
        border: none;
        padding: 0.75rem 1rem;
        font-size: 0.875rem;
        margin-bottom: 1rem;
    }

    /* Modal z-index fixes - CRITICAL FOR VIEW LAB MODAL */
    .modal {
        z-index: 1055 !important;
    }

    .modal-backdrop {
        z-index: 1050 !important;
    }

    .modal-dialog {
        z-index: 1056 !important;
        position: relative;
    }

    /* Force modal to display when shown */
    .modal.show {
        display: block !important;
        opacity: 1 !important;
    }

        .modal.show .modal-dialog {
            transform: none !important;
        }

    /* View Lab Result Modal - Force visibility */
    #viewLabResultModal.show {
        display: block !important;
        visibility: visible !important;
    }

    #viewLabResultModal .modal-dialog {
        pointer-events: auto !important;
        opacity: 1 !important;
        transform: translateY(0) !important;
    }

    #viewLabResultModal.show .modal-content {
        visibility: visible !important;
        opacity: 1 !important;
    }

    /* Keyboard navigation enhancements */
    .field-focused {
        background-color: #f8f9ff;
        border-radius: 6px;
        padding: 8px;
        margin: -8px;
        transition: background-color 0.2s;
    }

    kbd {
        background-color: #f4f4f4;
        border: 1px solid #ccc;
        border-radius: 3px;
        box-shadow: 0 1px 0 rgba(0,0,0,0.2);
        color: #333;
        display: inline-block;
        font-family: 'Courier New', monospace;
        font-size: 0.85em;
        line-height: 1;
        padding: 2px 5px;
        white-space: nowrap;
    }

    /* Custom Field Category Accordion */
    .custom-field-category {
        margin-top: 1rem;
        border-top: 1px solid #fef3c7;
        padding-top: 0.75rem;
    }

        .custom-field-category:first-of-type {
            margin-top: 0.5rem;
        }

    .category-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        padding: 0.5rem 0.75rem;
        background: #fffbeb;
        border-radius: 8px;
        margin-bottom: 0.5rem;
        transition: all 0.2s;
        user-select: none;
    }

        .category-header:hover {
            background: #fef3c7;
        }

    .category-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
        font-size: 0.875rem;
        color: #2d3748;
        margin: 0;
    }

    .category-count {
        background: #f59e0b;
        color: white;
        padding: 0.15rem 0.5rem;
        border-radius: 12px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .category-chevron {
        color: #f59e0b;
        transition: transform 0.2s;
        font-size: 1rem;
    }

        .category-chevron.collapsed {
            transform: rotate(-90deg);
        }

    .category-fields {
        max-height: 1000px;
        overflow: hidden;
        transition: max-height 0.3s ease-out, opacity 0.2s;
        opacity: 1;
    }

        .category-fields.collapsed {
            max-height: 0;
            opacity: 0;
        }

    /* Better focus indicators for accessibility */
    #addLabResultModal input:focus,
    #addLabResultModal select:focus,
    #addLabResultModal textarea:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
    }

    .select2-container--default .select2-selection--single:focus {
        border-color: #667eea;
        outline: 0;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
    }

    /* Exposures Modal Enhancements */
    #viewAllExposuresModal .sticky-top {
        position: sticky;
        top: 0;
        z-index: 10;
        background: #f8f9fa;
    }

    #viewAllExposuresModal .table-responsive {
        position: relative;
    }

    #allExposuresTable tbody tr {
        transition: background-color 0.2s ease;
    }

        #allExposuresTable tbody tr:hover {
            background-color: #f8f9fa;
        }

    /* Lab Results Modal Enhancements */
    #viewAllLabResultsModal .sticky-top {
        position: sticky;
        top: 0;
        z-index: 10;
        background: #f8f9fa;
    }

    #viewAllLabResultsModal .table-responsive {
        position: relative;
    }

    #allLabResultsTable tbody tr {
        transition: background-color 0.2s ease;
    }

        #allLabResultsTable tbody tr:hover {
            background-color: #f8f9fa;
        }

    /* Tasks Modal Enhancements */
    #viewAllTasksModal .sticky-top {
        position: sticky;
        top: 0;
        z-index: 10;
        background: #f8f9fa;
    }

    #viewAllTasksModal .table-responsive {
        position: relative;
    }

    #allTasksTable tbody tr {
        transition: background-color 0.2s ease;
    }

        #allTasksTable tbody tr:hover {
            background-color: #f8f9fa;
        }
</style>


<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Cases</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Case.FriendlyId</li>
    </ol>
</nav>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ExposureInfo"] != null)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        <i class="bi bi-info-circle-fill me-2"></i>@TempData["ExposureInfo"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ExposureWarning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ExposureWarning"]
        <a asp-page="/Cases/Exposures/Create" asp-route-caseId="@Model.Case.Id" class="alert-link ms-2">Add exposure now</a>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="case-details-container">
    <!-- Header Section -->
    <div class="case-header">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h1>
                    <i class="bi bi-virus2"></i>
                    Case @Model.Case.FriendlyId
                </h1>
                @if (Model.Case.Patient != null)
                {
                    <p class="subtitle mb-0">
                        <strong>@Model.Case.Patient.GivenName @Model.Case.Patient.FamilyName</strong>
                        @if (Model.Case.Disease != null)
                        {
                            <span class="mx-2">•</span>
                            <span>@Model.Case.Disease.Name</span>
                        }
                        @if (Model.Case.ConfirmationStatus != null)
                        {
                            <span class="mx-2">•</span>
                            <span class="badge badge-teal">@Model.Case.ConfirmationStatus.Name</span>
                        }
                    </p>

                    @* Address and Jurisdictions on second line *@
                    var hasAddress = !string.IsNullOrWhiteSpace(Model.Case.CaseAddressLine) || !string.IsNullOrWhiteSpace(Model.Case.CaseCity);
                    var hasJurisdictions = Model.Case.Jurisdiction1Id.HasValue ||
                                         Model.Case.Jurisdiction2Id.HasValue ||
                                         Model.Case.Jurisdiction3Id.HasValue ||
                                         Model.Case.Jurisdiction4Id.HasValue ||
                                         Model.Case.Jurisdiction5Id.HasValue;
                    <p class="subtitle mb-0 mt-1" style="font-size: 0.875rem;">
                        @if (hasAddress || hasJurisdictions)
                        {
                            @if (hasAddress)
                            {
                                var jurisdictions = new List<string>();
                                foreach (var jurisdictionType in Model.ActiveJurisdictionTypes.OrderBy(jt => jt.DisplayOrder))
                                {
                                    var jurisdiction = jurisdictionType.FieldNumber switch
                                    {
                                        1 => Model.Case.Jurisdiction1,
                                        2 => Model.Case.Jurisdiction2,
                                        3 => Model.Case.Jurisdiction3,
                                        4 => Model.Case.Jurisdiction4,
                                        5 => Model.Case.Jurisdiction5,
                                        _ => null
                                    };

                                    if (jurisdiction != null)
                                    {
                                        var label = !string.IsNullOrEmpty(jurisdictionType.Code) 
                                            ? jurisdictionType.Code 
                                            : jurisdictionType.Name;
                                        jurisdictions.Add($"{label}: {jurisdiction.Name}");
                                    }
                                }

                                <i class="bi bi-geo-alt-fill text-primary me-1"></i>
                                if (!string.IsNullOrWhiteSpace(Model.Case.CaseAddressLine))
                                {
                                    <span>@Model.Case.CaseAddressLine, </span>
                                }
                                if (!string.IsNullOrWhiteSpace(Model.Case.CaseCity))
                                {
                                    <span>@Model.Case.CaseCity</span>
                                }
                                if (Model.Case.CaseState != null)
                                {
                                    <span>, @Model.Case.CaseState.Code</span>
                                }
                                if (!string.IsNullOrWhiteSpace(Model.Case.CasePostalCode))
                                {
                                    <span> @Model.Case.CasePostalCode</span>
                                }

                                if (jurisdictions.Any())
                                {
                                    <span class="mx-2">•</span>
                                    @string.Join(" • ", jurisdictions)
                                }
                            }
                            else
                            {
                                var jurisdictionsOnly = new List<string>();
                                foreach (var jurisdictionType in Model.ActiveJurisdictionTypes.OrderBy(jt => jt.DisplayOrder))
                                {
                                    var jurisdiction = jurisdictionType.FieldNumber switch
                                    {
                                        1 => Model.Case.Jurisdiction1,
                                        2 => Model.Case.Jurisdiction2,
                                        3 => Model.Case.Jurisdiction3,
                                        4 => Model.Case.Jurisdiction4,
                                        5 => Model.Case.Jurisdiction5,
                                        _ => null
                                    };

                                    if (jurisdiction != null)
                                    {
                                        var label = !string.IsNullOrEmpty(jurisdictionType.Code) 
                                            ? jurisdictionType.Code 
                                            : jurisdictionType.Name;
                                        jurisdictionsOnly.Add($"{label}: {jurisdiction.Name}");
                                    }
                                }

                                if (jurisdictionsOnly.Any())
                                {
                                    <i class="bi bi-pin-map text-success me-1"></i>
                                    @string.Join(" • ", jurisdictionsOnly)
                                }
                            }

                            @if (Model.Case.CaseAddressManualOverride)
                            {
                                <span class="mx-2">•</span>
                                <span class="badge bg-info" style="font-size: 0.65rem;" title="Address manually set">Manual Override</span>
                            }
                        }
                        else
                        {
                            <i class="bi bi-geo-alt text-muted me-1"></i>
                            <span class="text-muted">No address or jurisdiction recorded</span>
                            @if (Model.PatientHasDifferentAddress)
                            {
                                <span class="mx-2">•</span>
                                <i class="bi bi-info-circle text-warning me-1" title="Patient has address data"></i>
                                <span class="text-warning">Patient has address available</span>
                            }
                        }
                    </p>
                }
            </div>
            <div class="text-end">
                <a asp-page="./Index" class="quick-action-btn">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="quick-actions">
            <a asp-page="./Edit" asp-route-id="@Model.Case.Id" class="quick-action-btn primary">
                <i class="bi bi-pencil"></i> Edit Case
            </a>
            @if (Model.PatientHasDifferentAddress)
            {
                <button type="button" class="quick-action-btn warning" onclick="copyAddressFromPatient()" title="Copy address and jurisdiction data from patient record">
                    <i class="bi bi-arrow-down-circle"></i> Copy Address from Patient
                    @if (Model.PatientJurisdictionMappingInProgress)
                    {
                        <i class="bi bi-hourglass-split ms-1" title="Jurisdiction mapping in progress"></i>
                    }
                </button>
            }
            <button type="button" class="quick-action-btn success" data-bs-toggle="modal" data-bs-target="#addNoteModal">
                <i class="bi bi-plus-circle"></i> Add Note
            </button>
            <button type="button" class="quick-action-btn success" onclick="openAddLabResult()">
                <i class="bi bi-plus-circle"></i> Add Lab Result
            </button>
            <button type="button" class="quick-action-btn success" onclick="openAddExposure()">
                <i class="bi bi-plus-circle"></i> Add Exposure
            </button>
            <a asp-page="/Cases/Contacts/BulkCreate" asp-route-caseId="@Model.Case.Id" class="quick-action-btn success">
                <i class="bi bi-people-fill"></i> Bulk Create Contacts
            </a>
            <button type="button" class="quick-action-btn success" onclick="openAddTask()">
                <i class="bi bi-plus-circle"></i> Add Task
            </button>
            @if (Model.Case.Patient != null)
            {
                <a asp-page="/Patients/Details" asp-route-id="@Model.Case.PatientId" class="quick-action-btn">
                    <i class="bi bi-person"></i> View Patient
                </a>
            }
            <a asp-page="./AuditHistory" asp-route-id="@Model.Case.Id" class="quick-action-btn">
                <i class="bi bi-clock-history"></i> Audit Log
            </a>
        </div>
    </div>

    <!-- Main Content Grid -->
    <!-- 3-Column Layout: Left = Case/Patient/Symptoms stacked | Right = Lab Results/Tasks/Exposures+Notes -->
    <div class="case-grid">
        <!-- LEFT COLUMN: Case Information -->
        <div class="info-card case-info-card">
            <div class="info-card-header">
                <h3 class="info-card-title">
                    <i class="bi bi-clipboard-data"></i>
                    Case Information
                </h3>
                <a asp-page="./Edit" asp-route-id="@Model.Case.Id" class="info-card-action">
                    <i class="bi bi-pencil"></i> Edit
                </a>
            </div>
            @if (Model.Case.Disease != null)
            {
                <div class="info-row">
                    <div class="info-label">Disease</div>
                    <div class="info-value">
                        <strong>@Model.Case.Disease.Name</strong>
                        <br /><small class="text-muted">@Model.Case.Disease.Code (@Model.Case.Disease.ExportCode)</small>
                    </div>
                </div>
            }
            <div class="info-row">
                <div class="info-label">Confirmation Status</div>
                <div class="info-value">
                    @if (Model.Case.ConfirmationStatus != null)
                    {
                        <span class="badge badge-teal">@Model.Case.ConfirmationStatus.Name</span>
                    }
                    else
                    {
                        <span class="text-muted">Not set</span>
                    }
                </div>
            </div>
            <div class="info-row">
                <div class="info-label">Date of Onset</div>
                <div class="info-value">
                    @if (Model.Case.DateOfOnset.HasValue)
                    {
                        <i class="bi bi-calendar-event me-1 text-primary"></i>
                        @Model.Case.DateOfOnset.Value.ToString("dd MMM yyyy")
                    }
                    else
                    {
                        <span class="text-muted">Not specified</span>
                    }
                </div>
            </div>
            <div class="info-row">
                <div class="info-label">Date of Notification</div>
                <div class="info-value">
                    @if (Model.Case.DateOfNotification.HasValue)
                    {
                        <i class="bi bi-calendar-check me-1 text-success"></i>
                        @Model.Case.DateOfNotification.Value.ToString("dd MMM yyyy")
                    }
                    else
                    {
                        <span class="text-muted">Not specified</span>
                    }
                </div>
            </div>
            @if (Model.Case.ClinicalNotificationDate.HasValue || !string.IsNullOrWhiteSpace(Model.Case.ClinicalNotifierOrganisation) || !string.IsNullOrWhiteSpace(Model.Case.ClinicalNotificationNotes))
            {
                <div class="info-row">
                    <div class="info-label">Clinical Notification Date</div>
                    <div class="info-value">
                        @if (Model.Case.ClinicalNotificationDate.HasValue)
                        {
                            <i class="bi bi-calendar-plus me-1 text-info"></i>
                            @Model.Case.ClinicalNotificationDate.Value.ToString("dd MMM yyyy")
                        }
                        else
                        {
                            <span class="text-muted">Not specified</span>
                        }
                    </div>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Case.ClinicalNotifierOrganisation))
            {
                <div class="info-row">
                    <div class="info-label">Clinical Notifier Organisation</div>
                    <div class="info-value">
                        <i class="bi bi-building me-1 text-info"></i>
                        @Model.Case.ClinicalNotifierOrganisation
                    </div>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Case.ClinicalNotificationNotes))
            {
                <div class="info-row">
                    <div class="info-label">Clinical Notification Notes</div>
                    <div class="info-value">
                        <i class="bi bi-sticky me-1 text-info"></i>
                        @Model.Case.ClinicalNotificationNotes
                    </div>
                </div>
            }
            <div class="info-row">
                <div class="info-label">Hospitalised</div>
                <div class="info-value">
                    @if (Model.Case.Hospitalised.HasValue)
                    {
                        switch (Model.Case.Hospitalised.Value)
                        {
                            case Sentinel.Models.YesNoUnknown.Yes:
                                <span class="badge bg-danger">Yes</span>
                                break;
                            case Sentinel.Models.YesNoUnknown.No:
                                <span class="badge bg-success">No</span>
                                break;
                            case Sentinel.Models.YesNoUnknown.Unknown:
                                <span class="badge bg-secondary">Unknown</span>
                                break;
                        }
                    }
                    else
                    {
                        <span class="text-muted">Not specified</span>
                    }
                </div>
            </div>
            @if (Model.Case.Hospitalised == Sentinel.Models.YesNoUnknown.Yes)
            {
                if (Model.Case.Hospital != null)
                {
                    <div class="info-row">
                        <div class="info-label">Hospital</div>
                        <div class="info-value">
                            <i class="bi bi-hospital me-1 text-danger"></i>
                            @Model.Case.Hospital.Name
                        </div>
                    </div>
                }
                if (Model.Case.DateOfAdmission.HasValue)
                {
                    <div class="info-row">
                        <div class="info-label">Date of Admission</div>
                        <div class="info-value">
                            <i class="bi bi-calendar-plus me-1 text-danger"></i>
                            @Model.Case.DateOfAdmission.Value.ToString("dd MMM yyyy")
                        </div>
                    </div>
                }
                if (Model.Case.DateOfDischarge.HasValue)
                {
                    <div class="info-row">
                        <div class="info-label">Date of Discharge</div>
                        <div class="info-value">
                            <i class="bi bi-calendar-minus me-1 text-success"></i>
                            @Model.Case.DateOfDischarge.Value.ToString("dd MMM yyyy")
                        </div>
                    </div>
                }
            }
            <div class="info-row">
                <div class="info-label">Died due to disease?</div>
                <div class="info-value">
                    @if (Model.Case.DiedDueToDisease.HasValue)
                    {
                        switch (Model.Case.DiedDueToDisease.Value)
                        {
                            case Sentinel.Models.YesNoUnknown.Yes:
                                <span class="badge bg-dark">Yes</span>
                                break;
                            case Sentinel.Models.YesNoUnknown.No:
                                <span class="badge bg-success">No</span>
                                break;
                            case Sentinel.Models.YesNoUnknown.Unknown:
                                <span class="badge bg-secondary">Unknown</span>
                                break;
                        }
                    }
                    else
                    {
                        <span class="text-muted">Not specified</span>
                    }
                </div>
            </div>

            @* Integrate Custom Fields into Case Information Card *@
            @if (Model.CustomFields.Any())
            {
                var fieldsByCategory = Model.CustomFields
                .OrderBy(f => f.Category ?? "Other")
                .ThenBy(f => f.DisplayOrder)
                .GroupBy(f => f.Category ?? "Additional Details")
                .ToList();

                int categoryIndex = 0;
                foreach (var categoryGroup in fieldsByCategory)
                {
                    var isFirstCategory = categoryIndex == 0;
                    var categoryId = $"category-{categoryIndex}";
                    var fieldsWithValues = categoryGroup.Where(f => Model.CustomFieldValues.ContainsKey(f.Id) || f.ShowOnCaseForm).ToList();

                    if (fieldsWithValues.Any())
                    {
                        <div class="custom-field-category">
                            <div class="category-header" onclick="toggleCategory('@categoryId')">
                                <div class="category-title">
                                    <i class="bi bi-file-text"></i>
                                    <span>@categoryGroup.Key</span>
                                    <span class="category-count">@fieldsWithValues.Count</span>
                                </div>
                                <i class="bi bi-chevron-down category-chevron @(isFirstCategory ? "" : "collapsed")" id="chevron-@categoryId"></i>
                            </div>
                            <div class="category-fields @(isFirstCategory ? "" : "collapsed")" id="@categoryId">
                                @foreach (var field in fieldsWithValues)
                                {
                                    var fieldValue = Model.CustomFieldValues.ContainsKey(field.Id) ? Model.CustomFieldValues[field.Id] : null;

                                    <div class="info-row">
                                        <div class="info-label">
                                            @field.Label
                                            @if (field.IsRequired)
                                            {
                                                <span class="text-danger">*</span>
                                            }
                                        </div>
                                        <div class="info-value">
                                            @switch (field.FieldType)
                                            {
                                                case Sentinel.Models.CustomFieldType.Text:
                                                case Sentinel.Models.CustomFieldType.TextArea:
                                                    if (fieldValue != null && !string.IsNullOrWhiteSpace(fieldValue.ToString()))
                                                    {
                                                        <text>@fieldValue</text>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                    break;

                                                case Sentinel.Models.CustomFieldType.Number:
                                                    if (fieldValue != null)
                                                    {
                                                        <text>@fieldValue</text>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                    break;

                                                case Sentinel.Models.CustomFieldType.Date:
                                                    if (fieldValue != null && DateTime.TryParse(fieldValue.ToString(), out var dateVal))
                                                    {
                                                        <i class="bi bi-calendar me-1"></i>
                                                        <text>@dateVal.ToString("dd MMM yyyy")</text>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                    break;

                                                case Sentinel.Models.CustomFieldType.Checkbox:
                                                    if (fieldValue != null && bool.TryParse(fieldValue.ToString(), out var boolVal))
                                                    {
                                                        if (boolVal)
                                                        {
                                                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Yes</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-secondary"><i class="bi bi-x-circle"></i> No</span>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                    break;

                                                case Sentinel.Models.CustomFieldType.Dropdown:
                                                    if (fieldValue != null && !string.IsNullOrWhiteSpace(fieldValue.ToString()))
                                                    {
                                                        <text>@fieldValue</text>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                    break;

                                                default:
                                                    if (fieldValue != null)
                                                    {
                                                        <text>@fieldValue</text>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                    break;
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                        categoryIndex++;
                    }
                }
            }

        </div>

        <!-- LEFT COLUMN: Patient Information (stacked below Case) -->
        @if (Model.Case.Patient != null)
        {
            <div class="info-card patient-info-card">
                <div class="info-card-header">
                    <h3 class="info-card-title">
                        <i class="bi bi-person-badge"></i>
                        Patient Information
                    </h3>
                    <a asp-page="/Patients/Details" asp-route-id="@Model.Case.PatientId" class="info-card-action">
                        <i class="bi bi-eye"></i> View
                    </a>
                </div>
                <div class="info-row">
                    <div class="info-label">Patient ID</div>
                    <div class="info-value">
                        <a asp-page="/Patients/Details" asp-route-id="@Model.Case.PatientId">
                            @Model.Case.Patient.FriendlyId
                        </a>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-label">Name</div>
                    <div class="info-value">@Model.Case.Patient.GivenName @Model.Case.Patient.FamilyName</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Date of Birth</div>
                    <div class="info-value">
                        @if (Model.Case.Patient.DateOfBirth.HasValue)
                        {
                            var age = DateTime.Now.Year - Model.Case.Patient.DateOfBirth.Value.Year;
                            <span>@Model.Case.Patient.DateOfBirth.Value.ToString("dd MMM yyyy") <small class="text-muted">(@age yrs)</small></span>
                        }
                        else
                        {
                            <span class="text-muted">Not specified</span>
                        }
                    </div>
                </div>
                @if (Model.Case.Patient.DateOfBirth.HasValue && Model.Case.DateOfNotification.HasValue)
                {
                    var dob = Model.Case.Patient.DateOfBirth.Value;
                    var notificationDate = Model.Case.DateOfNotification.Value;
                    var totalMonths = ((notificationDate.Year - dob.Year) * 12) + notificationDate.Month - dob.Month;
                    var years = totalMonths / 12;
                    var months = totalMonths % 12;
                    var weeks = (int)((notificationDate - dob).TotalDays / 7);

                    string ageDisplay;
                    string ageClass = "";

                    if (totalMonths < 4)
                    {
                        ageDisplay = $"{weeks} weeks";
                        ageClass = "text-primary fw-bold";
                    }
                    else if (totalMonths < 24)
                    {
                        ageDisplay = $"{totalMonths} months";
                        ageClass = "text-primary fw-bold";
                    }
                    else if (years < 5)
                    {
                        ageDisplay = months > 0 ? $"{years} years, {months} months" : $"{years} years";
                        ageClass = "text-primary fw-bold";
                    }
                    else
                    {
                        ageDisplay = $"{years} years";
                        if (years < 18) ageClass = "text-info fw-bold";
                        else if (years > 65) ageClass = "text-warning fw-bold";
                    }

                    <div class="info-row">
                        <div class="info-label">Age at Notification</div>
                        <div class="info-value">
                            <i class="bi bi-cake2 me-1"></i>
                            <span class="@ageClass">@ageDisplay</span>
                            @if (years < 18)
                            {
                                <span class="badge bg-info ms-2" style="font-size: 0.65rem;">Child</span>
                            }
                            else if (years > 65)
                            {
                                <span class="badge bg-warning text-dark ms-2" style="font-size: 0.65rem;">Elderly</span>
                            }
                        </div>
                    </div>
                }
                <div class="info-row">
                    <div class="info-label">Gender</div>
                    <div class="info-value">@(Model.Case.Patient.Gender?.Name ?? "-")</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Email</div>
                    <div class="info-value">
                        @if (!string.IsNullOrWhiteSpace(Model.Case.Patient.EmailAddress))
                        {
                            <a href="mailto:@Model.Case.Patient.EmailAddress">
                                <i class="bi bi-envelope me-1"></i>@Model.Case.Patient.EmailAddress
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">Not provided</span>
                        }
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-label">Mobile Phone</div>
                    <div class="info-value">
                        @if (!string.IsNullOrWhiteSpace(Model.Case.Patient.MobilePhone))
                        {
                            <a href="tel:@Model.Case.Patient.MobilePhone">
                                <i class="bi bi-phone me-1"></i>@Model.Case.Patient.MobilePhone
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">Not provided</span>
                        }
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-label">Deceased</div>
                    <div class="info-value">
                        @if (Model.Case.Patient.IsDeceased)
                        {
                            <span class="badge bg-dark">Yes</span>
                            if (Model.Case.Patient.DateOfDeath.HasValue)
                            {
                                <br />

                                <small class="text-muted">@Model.Case.Patient.DateOfDeath.Value.ToString("dd MMM yyyy")</small>
                            }
                        }
                        else
                        {
                            <span class="badge bg-success">No</span>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- LEFT COLUMN: Symptoms (stacked below Patient) -->
        <div class="info-card symptoms-card">
            <div class="info-card-header">
                <h3 class="info-card-title">
                    <i class="bi bi-heart-pulse"></i>
                    Symptoms (@Model.CaseSymptoms.Count)
                </h3>
                <a asp-page="./Edit" asp-route-id="@Model.Case.Id" class="info-card-action">
                    <i class="bi bi-pencil"></i> Edit
                </a>
            </div>
            @if (Model.CaseSymptoms.Any())
            {
                <table class="compact-table w-100">
                    <thead>
                        <tr>
                            <th>Symptom</th>
                            <th>Onset</th>
                            <th>Severity</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var symptom in Model.CaseSymptoms)
                        {
                            <tr>
                                <td>
                                    <strong>@symptom.Symptom?.Name</strong>
                                    @if (symptom.Symptom?.Code == "OTHER" && !string.IsNullOrEmpty(symptom.OtherSymptomText))
                                    {
                                        <br />

                                        <small class="text-muted">(@symptom.OtherSymptomText)</small>
                                    }
                                </td>
                                <td>
                                    @if (symptom.OnsetDate.HasValue)
                                    {
                                        <span>@symptom.OnsetDate.Value.ToString("dd MMM")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(symptom.Severity))
                                    {
                                        var severityClass = symptom.Severity.ToLower() switch
                                        {
                                            "mild" => "bg-success",
                                            "moderate" => "bg-warning",
                                            "severe" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                        <span class="badge @severityClass">@symptom.Severity</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                if (Model.CaseSymptoms.Any(cs => cs.OnsetDate.HasValue))
                {
                    var earliestOnset = Model.CaseSymptoms.Where(cs => cs.OnsetDate.HasValue).Min(cs => cs.OnsetDate!.Value);
                    <div class="alert alert-info mt-3 mb-0" style="padding: 0.5rem 0.75rem; font-size: 0.75rem;">
                        <i class="bi bi-info-circle me-1"></i>
                        <strong>Earliest onset:</strong> @earliestOnset.ToString("dd MMM yyyy")
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-heart-pulse"></i>
                    <p>No symptoms recorded</p>
                    <a asp-page="./Edit" asp-route-id="@Model.Case.Id" class="info-card-action">Add Symptoms</a>
                </div>
            }
        </div>

        <!-- RIGHT SIDE (2 columns): Lab Results - Wide and Half Height -->
        <div class="info-card wide half-height lab-results-card">
            <div class="info-card-header">
                <h3 class="info-card-title">
                    <i class="bi bi-clipboard-pulse"></i>
                    Lab Results (@Model.LabResults.Count)
                </h3>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#viewAllLabResultsModal">
                        <i class="bi bi-list-ul"></i> View All
                    </button>
                    <button type="button" class="info-card-action" onclick="openAddLabResult()">
                        <i class="bi bi-plus-circle"></i> Add
                    </button>
                </div>
            </div>
            @if (Model.LabResults.Any())
            {
                <table class="compact-table w-100">
                    <thead>
                        <tr>
                            <th style="width: 25%;">Test / Specimen</th>
                            <th style="width: 20%;">Tested For</th>
                            <th style="width: 15%;">Result</th>
                            <th style="width: 15%;">Collected</th>
                            <th style="width: 15%;">Reported</th>
                            <th style="width: 10%;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var labResult in Model.LabResults.Take(5))
                        {
                            <tr>
                                <td>
                                    <strong style="font-size: 0.85rem;">@(labResult.TestType?.Name ?? "-")</strong>
                                    <br /><small class="text-muted" style="font-size: 0.75rem;">@(labResult.SpecimenType?.Name ?? "-")</small>
                                    @if (labResult.IsAmended)
                                    {
                                        <br />

                                        <span class="badge bg-warning text-dark" style="font-size: 0.6rem;"><i class="bi bi-pencil-square"></i> Amended</span>
                                    }
                                </td>
                                <td>
                                    @if (labResult.TestedDisease != null)
                                    {
                                        <span style="font-size: 0.8rem;">@labResult.TestedDisease.Name</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (labResult.TestResult != null)
                                    {
                                        var resultClass = labResult.TestResult.Name?.ToLower() switch
                                        {
                                            "positive" => "bg-danger",
                                            "negative" => "bg-success",
                                            "indeterminate" or "equivocal" => "bg-warning",
                                            _ => "bg-secondary"
                                        };
                                        <span class="badge @resultClass" style="font-size: 0.7rem;">@labResult.TestResult.Name</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (labResult.SpecimenCollectionDate.HasValue)
                                    {
                                        <span style="font-size: 0.8rem;">@labResult.SpecimenCollectionDate.Value.ToString("dd MMM yyyy")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (labResult.ResultDate.HasValue)
                                    {
                                        <span style="font-size: 0.8rem;">@labResult.ResultDate.Value.ToString("dd MMM yyyy")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-link p-0" onclick="window.viewLabResult('@labResult.Id')" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                if (Model.LabResults.Count > 5)
                {
                    <div class="text-center mt-2">
                        <small class="text-muted">Showing 5 of @Model.LabResults.Count lab results</small>
                        <button type="button" class="btn btn-sm btn-link p-0 ms-2" data-bs-toggle="modal" data-bs-target="#viewAllLabResultsModal">
                            <i class="bi bi-arrows-angle-expand"></i> View All
                        </button>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-clipboard-pulse"></i>
                    <p>No lab results yet</p>
                    <button type="button" class="info-card-action" onclick="openAddLabResult()">Add Lab Result</button>
                </div>
            }
        </div>

        <!-- RIGHT SIDE: Acquisitions (How THIS case was exposed) -->
        <div class="info-card acquisitions-card">
            <div class="info-card-header">
                <h3 class="info-card-title">
                    <i class="bi bi-arrow-down-circle"></i>
                    Acquisitions (@Model.Acquisitions.Count)
                </h3>
                <div class="d-flex gap-2">
                    @if (Model.Acquisitions.Any(e => e.LocationId.HasValue || e.EventId.HasValue))
                    {
                        var firstExposure = Model.Acquisitions.FirstOrDefault(e => e.LocationId.HasValue || e.EventId.HasValue);
                        <a asp-page="/Outbreaks/CreateFromExposure"
                           asp-route-caseId="@Model.Case.Id"
                           asp-route-exposureId="@firstExposure!.Id"
                           asp-route-locationId="@firstExposure.LocationId"
                           asp-route-eventId="@firstExposure.EventId"
                           class="btn btn-sm btn-outline-purple" title="Create Outbreak from this exposure">
                            <i class="bi bi-diagram-3"></i> Create Outbreak
                        </a>
                    }
                    <button type="button" class="info-card-action" onclick="openAddExposure()">
                        <i class="bi bi-plus-circle"></i> Add
                    </button>
                </div>
            </div>
            @if (Model.Acquisitions.Any())
            {
                <table class="table table-sm table-hover">
                    <thead>
                        <tr>
                            <th style="width: 120px;">Type</th>
                            <th>Source/Location</th>
                            <th style="width: 90px;">Date</th>
                            <th style="width: 100px;">Status</th>
                            <th style="width: 80px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exposure in Model.Acquisitions.OrderByDescending(e => e.ExposureStartDate).Take(5))
                        {
                            <tr>
                                <td>
                                    @switch (exposure.ExposureType)
                                    {
                                        case Sentinel.Models.ExposureType.Event:
                                            <span class="badge badge-teal"><i class="bi bi-calendar-event"></i> Event</span>
                                            break;
                                        case Sentinel.Models.ExposureType.Location:
                                            <span class="badge badge-slate"><i class="bi bi-geo-alt"></i> Location</span>
                                            break;
                                        case Sentinel.Models.ExposureType.Contact:
                                            <span class="badge badge-amber"><i class="bi bi-people"></i> Contact</span>
                                            break;
                                        case Sentinel.Models.ExposureType.Travel:
                                            <span class="badge badge-grey"><i class="bi bi-airplane"></i> Travel</span>
                                            break;
                                        case Sentinel.Models.ExposureType.LocallyAcquired:
                                            <span class="badge badge-teal"><i class="bi bi-house"></i> Locally Acquired</span>
                                            break;
                                        default:
                                            <span class="badge badge-grey">Unknown</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <small>
                                        @* For Contact exposures, show the SOURCE person *@
                                        @if (exposure.ExposureType == Sentinel.Models.ExposureType.Contact && exposure.SourceCase != null)
                                        {
                                            <div>
                                                <strong>
                                                    <i class="bi bi-person"></i>
                                                    <a asp-page="/Cases/Details" asp-route-id="@exposure.SourceCase.Id">
                                                        @if (exposure.SourceCase.Patient != null)
                                                        {
                                                            <text>@exposure.SourceCase.Patient.GivenName @exposure.SourceCase.Patient.FamilyName</text>
                                                        }
                                                        else
                                                        {
                                                            <text>Case @exposure.SourceCase.FriendlyId</text>
                                                        }
                                                    </a>
                                                </strong>
                                            </div>
                                            if (exposure.Location != null)
                                            {
                                                <div class="text-muted">
                                                    <i class="bi bi-geo-alt"></i> At: <a asp-page="/Locations/Details" asp-route-id="@exposure.Location.Id">@exposure.Location.Name</a>
                                                </div>
                                            }
                                            if (exposure.Event != null)
                                            {
                                                <div class="text-muted">
                                                    <i class="bi bi-calendar-event"></i> At: <a asp-page="/Events/Details" asp-route-id="@exposure.Event.Id">@exposure.Event.Name</a>
                                                </div>
                                            }
                                        }
                                        @* For Location/Event exposures without a contact person *@
                                        else if (exposure.Event != null)
                                        {
                                            <a asp-page="/Events/Details" asp-route-id="@exposure.Event.Id">@exposure.Event.Name</a>
                                        }
                                        else if (exposure.Location != null)
                                        {
                                            <a asp-page="/Locations/Details" asp-route-id="@exposure.Location.Id">@exposure.Location.Name</a>
                                        }
                                        @* For Travel exposures, show country *@
                                        else if (exposure.ExposureType == Sentinel.Models.ExposureType.Travel)
                                        {
                                            if (!string.IsNullOrEmpty(exposure.Country))
                                            {
                                                <div><i class="bi bi-airplane"></i> @exposure.Country</div>
                                            }
                                            else if (!string.IsNullOrEmpty(exposure.CountryCode))
                                            {
                                                <div><i class="bi bi-airplane"></i> @exposure.CountryCode</div>
                                            }
                                            else if (!string.IsNullOrEmpty(exposure.FreeTextLocation))
                                            {
                                                <text>@exposure.FreeTextLocation</text>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        }
                                        @* Fallback for other exposure types *@
                                        else if (exposure.ExposureType == Sentinel.Models.ExposureType.LocallyAcquired)
                                        {
                                            if (!string.IsNullOrEmpty(exposure.AddressLine))
                                            {
                                                <text>@exposure.AddressLine, @exposure.City</text>
                                            }
                                            else
                                            {
                                                <text>Patient's Residence</text>
                                            }
                                        }
                                        else if (!string.IsNullOrEmpty(exposure.FreeTextLocation))
                                        {
                                            <text>@exposure.FreeTextLocation</text>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </small>
                                </td>
                                <td><small>@exposure.ExposureStartDate.ToString("dd MMM")</small></td>
                                <td>
                                    @switch (exposure.ExposureStatus)
                                    {
                                        case Sentinel.Models.ExposureStatus.ConfirmedExposure:
                                            <span class="badge bg-danger">Confirmed</span>
                                            break;
                                        case Sentinel.Models.ExposureStatus.UnderInvestigation:
                                            <span class="badge bg-warning">Investigating</span>
                                            break;
                                        case Sentinel.Models.ExposureStatus.PotentialExposure:
                                            <span class="badge bg-info">Potential</span>
                                            break;
                                        case Sentinel.Models.ExposureStatus.RuledOut:
                                            <span class="badge bg-success">Ruled Out</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">Unknown</span>
                                            break;
                                    }
                                </td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-link p-0 text-primary" onclick="openEditExposure('@exposure.Id')" title="Edit Exposure">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <form method="post" asp-page-handler="DeleteExposure" asp-route-id="@Model.Case.Id" asp-route-exposureId="@exposure.Id" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this exposure?');">
                                        <button type="submit" class="btn btn-sm btn-link p-0 text-danger" title="Delete Exposure">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                if (Model.Acquisitions.Count > 5)
                {
                    <div class="text-center mt-2">
                        <small class="text-muted">Showing 5 of @Model.Acquisitions.Count exposures</small>
                        <button type="button" class="btn btn-sm btn-link p-0 ms-2" data-bs-toggle="modal" data-bs-target="#viewAllExposuresModal">
                            <i class="bi bi-arrows-angle-expand"></i> View All
                        </button>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-diagram-3"></i>
                    <p>No exposures recorded</p>
                    <button type="button" class="info-card-action" onclick="openAddExposure()">Add Exposure</button>
                </div>
            }
        </div>

        <!-- RIGHT SIDE: Transmissions (Who THIS case exposed) -->
        <div class="info-card transmissions-card">
            <div class="info-card-header">
                <h3 class="info-card-title">
                    <i class="bi bi-arrow-up-circle"></i>
                    Transmissions (@Model.Transmissions.Count)
                </h3>
                <div class="d-flex gap-1">
                    <a asp-page="/Outbreaks/CreateFromExposure"
                       asp-route-caseId="@Model.Case.Id"
                       class="btn btn-sm btn-outline-danger"
                       title="Create Contact Tracing Event">
                        <i class="bi bi-diagram-3"></i>
                    </a>
                    <a asp-page="/Cases/Contacts/BulkCreate"
                       asp-route-caseId="@Model.Case.Id"
                       class="btn btn-sm btn-outline-primary"
                       title="Bulk Add Contacts">
                        <i class="bi bi-people-fill"></i>
                    </a>
                    @if (Model.Transmissions.Count > 5)
                    {
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#viewAllTransmissionsModal" title="View All">
                            <i class="bi bi-list-ul"></i>
                        </button>
                    }
                    <button type="button" class="btn btn-sm btn-outline-success" onclick="openAddExposure()" title="Add Exposure">
                        <i class="bi bi-plus-circle"></i>
                    </button>
                </div>
            </div>
            @if (Model.Transmissions.Any())
            {
                <table class="table table-sm table-hover">
                    <thead>
                        <tr>
                            <th style="width: 120px;">Type</th>
                            <th>Exposed Person</th>
                            <th style="width: 90px;">Date</th>
                            <th style="width: 100px;">Status</th>
                            <th style="width: 80px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exposure in Model.Transmissions.OrderByDescending(e => e.ExposureStartDate).Take(5))
                        {
                            <tr>
                                <td>
                                    @switch (exposure.ExposureType)
                                    {
                                        case Sentinel.Models.ExposureType.Event:
                                            <span class="badge badge-teal"><i class="bi bi-calendar-event"></i> Event</span>
                                            break;
                                        case Sentinel.Models.ExposureType.Location:
                                            <span class="badge badge-slate"><i class="bi bi-geo-alt"></i> Location</span>
                                            break;
                                        case Sentinel.Models.ExposureType.Contact:
                                            <span class="badge badge-amber"><i class="bi bi-people"></i> Contact</span>
                                            break;
                                        case Sentinel.Models.ExposureType.Travel:
                                            <span class="badge badge-grey"><i class="bi bi-airplane"></i> Travel</span>
                                            break;
                                        case Sentinel.Models.ExposureType.LocallyAcquired:
                                            <span class="badge badge-teal"><i class="bi bi-house"></i> Locally Acquired</span>
                                            break;
                                        default:
                                            <span class="badge badge-grey">Unknown</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <small>
                                        @* For Contact exposures, show the EXPOSED person *@
                                        @if (exposure.ExposureType == Sentinel.Models.ExposureType.Contact && exposure.ExposedCase != null)
                                        {
                                            <div>
                                                <strong>
                                                    <i class="bi bi-person"></i>
                                                    <a asp-page="/Cases/Details" asp-route-id="@exposure.ExposedCase.Id">
                                                        @if (exposure.ExposedCase.Patient != null)
                                                        {
                                                            <text>@exposure.ExposedCase.Patient.GivenName @exposure.ExposedCase.Patient.FamilyName</text>
                                                        }
                                                        else
                                                        {
                                                            <text>Case @exposure.ExposedCase.FriendlyId</text>
                                                        }
                                                    </a>
                                                </strong>
                                            </div>
                                            if (exposure.Location != null)
                                            {
                                                <div class="text-muted">
                                                    <i class="bi bi-geo-alt"></i> At: <a asp-page="/Locations/Details" asp-route-id="@exposure.Location.Id">@exposure.Location?.Name</a>
                                                </div>
                                            }
                                            if (exposure.Event != null)
                                            {
                                                <div class="text-muted">
                                                    <i class="bi bi-calendar-event"></i> At: <a asp-page="/Events/Details" asp-route-id="@exposure.Event.Id">@exposure.Event?.Name</a>
                                                </div>
                                            }
                                        }
                                        @* For Event exposures *@
                                        else if (exposure.ExposureType == Sentinel.Models.ExposureType.Event && exposure.Event != null)
                                        {
                                            <div>
                                                <i class="bi bi-calendar-event"></i>
                                                <a asp-page="/Events/Details" asp-route-id="@exposure.Event.Id">@exposure.Event.Name</a>
                                            </div>
                                            if (exposure.Event.Location != null)
                                            {
                                                <div class="text-muted">
                                                    <i class="bi bi-geo-alt"></i> At: @exposure.Event.Location.Name
                                                </div>
                                            }
                                        }
                                        @* For Location exposures *@
                                        else if (exposure.ExposureType == Sentinel.Models.ExposureType.Location && exposure.Location != null)
                                        {
                                            <div>
                                                <i class="bi bi-geo-alt"></i>
                                                <a asp-page="/Locations/Details" asp-route-id="@exposure.Location.Id">@exposure.Location.Name</a>
                                            </div>
                                        }
                                        @* For Travel exposures *@
                                        else if (exposure.ExposureType == Sentinel.Models.ExposureType.Travel)
                                        {
                                            if (!string.IsNullOrEmpty(exposure.Country))
                                            {
                                                <div><i class="bi bi-airplane"></i> @exposure.Country</div>
                                            }
                                            else if (!string.IsNullOrEmpty(exposure.CountryCode))
                                            {
                                                <div><i class="bi bi-airplane"></i> @exposure.CountryCode</div>
                                            }
                                            else if (!string.IsNullOrEmpty(exposure.FreeTextLocation))
                                            {
                                                <text>@exposure.FreeTextLocation</text>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </small>
                                </td>
                                <td><small>@exposure.ExposureStartDate.ToString("dd MMM")</small></td>
                                <td>
                                    @switch (exposure.ExposureStatus)
                                    {
                                        case Sentinel.Models.ExposureStatus.ConfirmedExposure:
                                            <span class="badge bg-danger">Confirmed</span>
                                            break;
                                        case Sentinel.Models.ExposureStatus.UnderInvestigation:
                                            <span class="badge bg-warning">Investigating</span>
                                            break;
                                        case Sentinel.Models.ExposureStatus.PotentialExposure:
                                            <span class="badge bg-info">Potential</span>
                                            break;
                                        case Sentinel.Models.ExposureStatus.RuledOut:
                                            <span class="badge bg-success">Ruled Out</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">Unknown</span>
                                            break;
                                    }
                                </td>
                                <td class="text-end">
                                    @if (exposure.ExposureType == Sentinel.Models.ExposureType.Location || exposure.ExposureType == Sentinel.Models.ExposureType.Event)
                                    {
                                        <a asp-page="/Cases/Contacts/BulkCreate"
                                           asp-route-caseId="@Model.Case.Id"
                                           asp-route-locationId="@exposure.LocationId"
                                           asp-route-eventId="@exposure.EventId"
                                           asp-route-exposureStartDate="@exposure.ExposureStartDate.ToString("o")"
                                           asp-route-exposureEndDate="@exposure.ExposureEndDate?.ToString("o")"
                                           class="btn btn-sm btn-link p-0 text-info me-1"
                                           title="Bulk Add Contacts for this exposure">
                                            <i class="bi bi-people-fill"></i>
                                        </a>
                                    }
                                    <button type="button" class="btn btn-sm btn-link p-0 text-primary" onclick="openEditExposure('@exposure.Id')" title="Edit Exposure">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <form method="post" asp-page-handler="DeleteExposure" asp-route-id="@Model.Case.Id" asp-route-exposureId="@exposure.Id" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this exposure?');">
                                        <button type="submit" class="btn btn-sm btn-link p-0 text-danger" title="Delete Exposure">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                if (Model.Transmissions.Count > 5)
                {
                    <div class="text-center mt-2">
                        <small class="text-muted">Showing 5 of @Model.Transmissions.Count transmissions</small>
                        <button type="button" class="btn btn-sm btn-link p-0 ms-2" data-bs-toggle="modal" data-bs-target="#viewAllTransmissionsModal">
                            <i class="bi bi-arrows-angle-expand"></i> View All
                        </button>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-diagram-3"></i>
                    <p>No transmissions recorded</p>
                    <small class="text-muted d-block mt-2">
                        <i class="bi bi-lightbulb"></i> Tip: After adding exposures with contacts, use "Create Contact Tracing Event" to manage multiple contacts as a unified investigation
                    </small>
                </div>
            }
        </div>

        <!-- Tasks Section - Wide -->
        <div class="info-card wide tasks-card">
            <div class="info-card-header">
                <h3 class="info-card-title">
                    <i class="bi bi-list-check"></i>
                    Tasks (@Model.Tasks.Count)
                </h3>
                <div class="d-flex gap-2">
                    @if (Model.Tasks.Count > 5)
                    {
                        <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#viewAllTasksModal">
                            <i class="bi bi-list-ul"></i> View All
                        </button>
                    }
                    <button type="button" class="info-card-action" onclick="openAddTask()">
                        <i class="bi bi-plus-circle"></i> Add
                    </button>
                </div>
            </div>
            @if (Model.Tasks.Any())
            {
                <table class="table table-sm table-hover">
                    <thead>
                        <tr>
                            <th>Task</th>
                            <th>Assigned To</th>
                            <th>Survey</th>
                            <th>Priority</th>
                            <th>Due</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in Model.Tasks.OrderBy(t => t.DueDate ?? DateTime.MaxValue).Take(5))
                        {
                            <tr>
                                <td>
                                    <strong>@(task.TaskTemplate?.Name ?? task.Title)</strong>
                                    @if (task.TaskType != null)
                                    {
                                        <br />

                                        <small class="text-muted">@task.TaskType.Name</small>
                                    }
                                    @if (task.CallAttempts?.Any() == true)
                                    {
                                        <br />
                                        <span class="badge bg-info" style="font-size: 0.65rem;">
                                            <i class="bi bi-telephone"></i> @task.CallAttempts.Count call(s)
                                        </span>
                                        <button type="button" class="btn btn-sm btn-link p-0 ms-1"
                                                onclick="showCallHistory('@task.Id')"
                                                title="View Call History"
                                                style="font-size: 0.7rem;">
                                            <i class="bi bi-clock-history"></i>
                                        </button>
                                    }
                                </td>
                                <td>
                                    @if (task.AssignedToUser != null)
                                    {
                                        <small>@task.AssignedToUser.UserName</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Unassigned</span>
                                    }
                                </td>
                                <td>
                                    @if (task.TaskTemplate?.SurveyTemplate != null)
                                    {
                                        <small class="text-muted">
                                            <i class="bi bi-clipboard-check"></i>
                                            @task.TaskTemplate.SurveyTemplate.Name
                                        </small>
                                    }
                                    else if (!string.IsNullOrEmpty(task.TaskTemplate?.SurveyDefinitionJson))
                                    {
                                        <small class="text-muted">
                                            <i class="bi bi-clipboard-check"></i>
                                            <text>Custom Survey</text>
                                        </small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var priorityClass = task.Priority switch
                                        {
                                            TaskPriority.Low => "badge-grey",
                                            TaskPriority.Medium => "badge-slate",
                                            TaskPriority.High => "badge-amber",
                                            TaskPriority.Urgent => "bg-danger",
                                            _ => "badge-grey"
                                        };
                                    }
                                    <span class="badge @priorityClass">@task.Priority</span>
                                </td>
                                <td>
                                    @if (task.DueDate.HasValue)
                                    {
                                        <small>@task.DueDate.Value.ToString("dd MMM")</small>
                                        if (task.Status == CaseTaskStatus.Overdue)
                                        {
                                            <br />

                                            <span class="badge bg-danger" style="font-size: 0.65rem;">Overdue</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var statusClass = task.Status switch
                                        {
                                            CaseTaskStatus.Pending => "badge-grey",
                                            CaseTaskStatus.InProgress => "badge-teal",
                                            CaseTaskStatus.Completed => "bg-success",
                                            CaseTaskStatus.Cancelled => "bg-dark",
                                            CaseTaskStatus.Overdue => "bg-danger",
                                            CaseTaskStatus.WaitingForPatient => "badge-amber",
                                            _ => "badge-grey"
                                        };
                                    }
                                    <span class="badge @statusClass">@task.Status</span>
                                </td>
                                <td class="text-end">
                                    @{
                                        var hasSurvey = (task.TaskTemplate?.SurveyTemplateId.HasValue == true) ||
                                        !string.IsNullOrEmpty(task.TaskTemplate?.SurveyDefinitionJson);
                                        var isCompletedWithSurvey = task.Status == CaseTaskStatus.Completed && hasSurvey && !string.IsNullOrEmpty(task.SurveyResponseJson);
                                    }

                                    @if (isCompletedWithSurvey)
                                    {
                                        <a asp-page="/Tasks/ViewSurveyResult" asp-route-id="@task.Id" class="btn btn-sm btn-link p-0 me-1" title="View Survey Results">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    }
                                    else if (task.Status != CaseTaskStatus.Completed && task.Status != CaseTaskStatus.Cancelled)
                                    {
                                        if (hasSurvey)
                                        {
                                            <a asp-page="/Tasks/CompleteSurvey" asp-route-id="@task.Id" class="btn btn-sm btn-link p-0 me-1" title="Complete Survey">
                                                <i class="bi bi-clipboard-check"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-link p-0 me-1" onclick="openCompleteTaskModal('@task.Id', '@task.TaskTemplate?.Name')" title="Complete">
                                                <i class="bi bi-check-circle"></i>
                                            </button>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                if (Model.Tasks.Count > 5)
                {
                    <div class="text-center mt-2">
                        <small class="text-muted">Showing 5 of @Model.Tasks.Count tasks</small>
                        <button type="button" class="btn btn-sm btn-link p-0 ms-2" data-bs-toggle="modal" data-bs-target="#viewAllTasksModal">
                            <i class="bi bi-arrows-angle-expand"></i> View All
                        </button>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-list-check"></i>
                    <p>No tasks yet</p>
                    <button type="button" class="info-card-action" onclick="openAddTask()">Add Task</button>
                </div>
            }
        </div>
    </div>

    <!-- Notes Card -->
    <div class="info-card notes-card">
        <div class="info-card-header">
            <h3 class="info-card-title">
                <i class="bi bi-chat-left-text"></i>
                Notes (@Model.Notes.Count)
            </h3>
            <button type="button" class="info-card-action" data-bs-toggle="modal" data-bs-target="#addNoteModal">
                <i class="bi bi-plus-circle me-1"></i>Add
            </button>
        </div>

        @if (Model.Notes.Any())
        {
            <div class="scroll-container">
                @foreach (var note in Model.Notes.OrderByDescending(n => n.CreatedAt).Take(3))
                {
                    <div class="note-item">
                        <div class="note-header">
                            <strong>@note.Subject</strong>
                            <div class="note-meta">
                                @note.CreatedAt.ToString("dd MMM yyyy HH:mm") by @note.CreatedBy
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(note.Content))
                        {
                            <p class="mb-1">@note.Content</p>
                        }
                        @if (!string.IsNullOrEmpty(note.AttachmentFileName))
                        {
                            <div class="mt-1">
                                <a href="@note.AttachmentPath" class="btn btn-sm btn-outline-secondary" target="_blank">
                                    <i class="bi bi-paperclip"></i> @note.AttachmentFileName
                                </a>
                            </div>
                        }
                        <div class="text-end mt-2">
                            <form method="post" asp-page-handler="DeleteNote" asp-route-id="@Model.Case.Id" asp-route-noteId="@note.Id"
                                  onsubmit="return confirm('Are you sure you want to delete this note?');" style="display: inline;">
                                <button type="submit" class="btn btn-sm btn-link text-danger p-0">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>

            if (Model.Notes.Count > 3)
            {
                <div class="text-center mt-2">
                    <small class="text-muted">Showing 3 of @Model.Notes.Count notes</small>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-chat-left-text"></i>
                <p>No notes yet</p>
                <button type="button" class="info-card-action" data-bs-toggle="modal" data-bs-target="#addNoteModal">Add Note</button>
            </div>
        }
    </div>
</div>

<!-- Add Note Modal -->
<div class="modal fade" id="addNoteModal" tabindex="-1" aria-labelledby="addNoteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addNoteModalLabel">
                    <i class="bi bi-chat-left-text me-2"></i>Add Note
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="AddNote" asp-route-id="@Model.Case.Id" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Subject <span class="required">*</span></label>
                        <input type="text" name="NewNote.Subject" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Content</label>
                        <textarea name="NewNote.Content" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Attachment</label>
                        <input type="file" name="Attachment" class="form-control" />
                        <small class="form-text text-muted">Optional file attachment (PDF, Word, Excel, Image)</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Add Note
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- View All Tasks Modal -->
<div class="modal fade" id="viewAllTasksModal" tabindex="-1" aria-labelledby="viewAllTasksModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewAllTasksModalLabel">
                    <i class="bi bi-list-check me-2"></i>All Tasks (@Model.Tasks.Count)
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @if (Model.Tasks.Any())
                {
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Task</th>
                                <th>Assigned To</th>
                                <th>Survey</th>
                                <th>Priority</th>
                                <th>Due</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var task in Model.Tasks.OrderBy(t => t.DueDate ?? DateTime.MaxValue))
                            {
                                <tr>
                                    <td>
                                        <strong>@(task.TaskTemplate?.Name ?? task.Title)</strong>
                                        @if (task.TaskType != null)
                                        {
                                            <br />

                                            <small class="text-muted">@task.TaskType.Name</small>
                                        }
                                    </td>
                                    <td>
                                        @if (task.AssignedToUser != null)
                                        {
                                            @task.AssignedToUser.UserName
                                        }
                                        else
                                        {
                                            <span class="text-muted">Unassigned</span>
                                        }
                                    </td>
                                    <td>
                                        @if (task.TaskTemplate?.SurveyTemplate != null)
                                        {
                                            <i class="bi bi-clipboard-check"></i>
                                            @task.TaskTemplate.SurveyTemplate.Name
                                        }
                                        else if (!string.IsNullOrEmpty(task.TaskTemplate?.SurveyDefinitionJson))
                                        {
                                            <i class="bi bi-clipboard-check"></i>
                                            <text>Custom Survey</text>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @{
                                            var priorityClass = task.Priority switch
                                            {
                                                TaskPriority.Low => "badge-grey",
                                                TaskPriority.Medium => "badge-slate",
                                                TaskPriority.High => "badge-amber",
                                                TaskPriority.Urgent => "bg-danger",
                                                _ => "badge-grey"
                                            };
                                        }
                                        <span class="badge @priorityClass">@task.Priority</span>
                                    </td>
                                    <td>
                                        @if (task.DueDate.HasValue)
                                        {
                                            @task.DueDate.Value.ToString("dd MMM yyyy")
                                            if (task.Status == CaseTaskStatus.Overdue)
                                            {
                                                <br />

                                                <span class="badge bg-danger" style="font-size: 0.65rem;">Overdue</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @{
                                            var statusClass = task.Status switch
                                            {
                                                CaseTaskStatus.Pending => "badge-grey",
                                                CaseTaskStatus.InProgress => "badge-teal",
                                                CaseTaskStatus.Completed => "bg-success",
                                                CaseTaskStatus.Cancelled => "bg-dark",
                                                CaseTaskStatus.Overdue => "bg-danger",
                                                CaseTaskStatus.WaitingForPatient => "badge-amber",
                                                _ => "badge-grey"
                                            };
                                        }
                                        <span class="badge @statusClass">@task.Status</span>
                                    </td>
                                    <td class="text-end">
                                        @{
                                            var hasSurvey = (task.TaskTemplate?.SurveyTemplateId.HasValue == true) ||
                                            !string.IsNullOrEmpty(task.TaskTemplate?.SurveyDefinitionJson);
                                            var isCompletedWithSurvey = task.Status == CaseTaskStatus.Completed && hasSurvey && !string.IsNullOrEmpty(task.SurveyResponseJson);
                                        }

                                        @if (isCompletedWithSurvey)
                                        {
                                            <a asp-page="/Tasks/ViewSurveyResult" asp-route-id="@task.Id" class="btn btn-sm btn-link p-0 me-1" title="View Survey Results">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        }
                                        else if (task.Status != CaseTaskStatus.Completed && task.Status != CaseTaskStatus.Cancelled)
                                        {
                                            if (hasSurvey)
                                            {
                                                <a asp-page="/Tasks/CompleteSurvey" asp-route-id="@task.Id" class="btn btn-sm btn-link p-0 me-1" title="Complete Survey">
                                                    <i class="bi bi-clipboard-check"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-sm btn-link p-0 me-1" onclick="openCompleteTaskModal('@task.Id', '@task.TaskTemplate?.Name')" title="Complete">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        No tasks have been created for this case.
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="openAddTask(); $('#viewAllTasksModal').modal('hide');">
                    <i class="bi bi-plus-circle me-1"></i>Add New Task
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Add Exposure Modal -->
<div class="modal fade" id="addExposureModal" tabindex="-1" aria-labelledby="addExposureModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addExposureModalLabel">
                    <i class="bi bi-diagram-3 me-2"></i>Add Exposure
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="AddExposure">
                <div class="modal-body">
                    <input type="hidden" name="CaseId" value="@Model.Case.Id" />

                    <div class="alert alert-info mb-3">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Case:</strong> @Model.Case.FriendlyId - @Model.Case.Patient?.GivenName @Model.Case.Patient?.FamilyName
                    </div>

                    <!-- Exposure Direction Toggle -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            <i class="bi bi-arrow-left-right me-1"></i>Exposure Direction <span class="text-danger">*</span>
                        </label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check" name="ExposureDirection" id="modalDirectionAcquisition" value="Acquisition" checked />
                            <label class="btn btn-outline-primary" for="modalDirectionAcquisition">
                                <i class="bi bi-arrow-down-circle me-1"></i>
                                <strong>Acquisition</strong> <small class="d-block text-muted">This case got exposed</small>
                            </label>

                            <input type="radio" class="btn-check" name="ExposureDirection" id="modalDirectionTransmission" value="Transmission" />
                            <label class="btn btn-outline-danger" for="modalDirectionTransmission">
                                <i class="bi bi-arrow-up-circle me-1"></i>
                                <strong>Transmission</strong> <small class="d-block text-muted">This case exposed others</small>
                            </label>
                        </div>
                        <small class="form-text text-muted">
                            ?? <strong>Acquisition:</strong> Track where patient got infected | <strong>Transmission:</strong> Contact tracing from this case
                        </small>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">
                                Exposure Type <span class="text-danger">*</span>
                            </label>
                            <select name="ExposureType" class="form-select" id="modalExposureTypeSelect" required>
                                <option value="">Select Type</option>
                                <option value="@((int)ExposureType.Event)">Event</option>
                                <option value="@((int)ExposureType.Location)">Location</option>
                                <option value="@((int)ExposureType.Contact)">Contact (Person-to-Person)</option>
                                <option value="@((int)ExposureType.Travel)">Travel</option>
                                <option value="@((int)ExposureType.LocallyAcquired)">Locally Acquired</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">
                                Status <span class="text-danger">*</span>
                            </label>
                            <select name="ExposureStatus" class="form-select">
                                <option value="@((int)ExposureStatus.PotentialExposure)">Potential Exposure</option>
                                <option value="@((int)ExposureStatus.UnderInvestigation)">Under Investigation</option>
                                <option value="@((int)ExposureStatus.ConfirmedExposure)">Confirmed Exposure</option>
                                <option value="@((int)ExposureStatus.RuledOut)">Ruled Out</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mt-2">
                        <div class="col-md-6">
                            <label class="form-label">
                                Start Date <span class="text-danger">*</span>
                            </label>
                            <input name="ExposureStartDate" type="datetime-local" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">
                                End Date
                            </label>
                            <input name="ExposureEndDate" type="datetime-local" class="form-control" />
                        </div>
                    </div>

                    <!-- Type-Specific Sections -->
                    <div id="modalEventSection" class="mt-3" style="display: none;">
                        <label class="form-label">
                            Event <span class="text-danger">*</span>
                        </label>
                        <select name="EventId" class="form-select select2-modal-event">
                            <option value="">Type to search for event...</option>
                        </select>
                    </div>

                    <div id="modalLocationSection" class="mt-3" style="display: none;">
                        <label class="form-label">
                            Location <span class="text-danger">*</span>
                        </label>
                        <select name="LocationId" class="form-select select2-modal-location">
                            <option value="">Type to search for location...</option>
                        </select>
                    </div>

                    <div id="modalContactSection" class="mt-3" style="display: none;">
                        <label class="form-label">
                            Source Case (Person who transmitted)
                        </label>
                        <select name="SourceCaseId" class="form-select select2-modal-case">
                            <option value="">Type to search for case...</option>
                        </select>
                        <small class="form-text text-muted">Search for the person who may have transmitted disease to this case</small>
                    </div>

                    <div id="modalTravelSection" class="mt-3" style="display: none;">
                        <label class="form-label">
                            Country <span class="text-danger">*</span>
                        </label>
                        <select name="CountryCode" class="form-select select2-modal-country">
                            <option value="">Type to search for country...</option>
                        </select>
                    </div>

                    <div class="mt-3">
                        <label class="form-label">Description</label>
                        <textarea name="Description" class="form-control" rows="3" placeholder="Additional details about this exposure..."></textarea>
                    </div>

                    <div class="mt-3">
                        <div class="form-check">
                            <input name="IsReportingExposure" class="form-check-input" type="checkbox" />
                            <label class="form-check-label">
                                Primary Reporting Exposure
                            </label>
                            <small class="form-text text-muted d-block">
                                <i class="bi bi-info-circle me-1"></i>
                                Mark this as the main exposure for reporting purposes
                            </small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i>Save Exposure
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- View All Transmissions Modal -->
<div class="modal fade" id="viewAllTransmissionsModal" tabindex="-1" aria-labelledby="viewAllTransmissionsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewAllTransmissionsModalLabel">
                    <i class="bi bi-arrow-up-circle me-2"></i>All Transmissions (@Model.Transmissions.Count)
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @if (Model.Transmissions.Any())
                {
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>Exposed Person</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var exposure in Model.Transmissions.OrderByDescending(e => e.ExposureStartDate))
                            {
                                <tr>
                                    <td>
                                        @switch (exposure.ExposureType)
                                        {
                                            case Sentinel.Models.ExposureType.Event:
                                                <span class="badge badge-teal"><i class="bi bi-calendar-event"></i> Event</span>
                                                break;
                                            case Sentinel.Models.ExposureType.Location:
                                                <span class="badge badge-slate"><i class="bi bi-geo-alt"></i> Location</span>
                                                break;
                                            case Sentinel.Models.ExposureType.Contact:
                                                <span class="badge badge-amber"><i class="bi bi-people"></i> Contact</span>
                                                break;
                                            case Sentinel.Models.ExposureType.Travel:
                                                <span class="badge badge-grey"><i class="bi bi-airplane"></i> Travel</span>
                                                break;
                                            case Sentinel.Models.ExposureType.LocallyAcquired:
                                                <span class="badge badge-teal"><i class="bi bi-house"></i> Locally Acquired</span>
                                                break;
                                            default:
                                                <span class="badge badge-grey">Unknown</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (exposure.ExposureType == Sentinel.Models.ExposureType.Contact && exposure.ExposedCase != null)
                                        {
                                            <div>
                                                <strong>
                                                    <a asp-page="/Cases/Details" asp-route-id="@exposure.ExposedCase.Id">
                                                        @if (exposure.ExposedCase.Patient != null)
                                                        {
                                                            <text>@exposure.ExposedCase.Patient.GivenName @exposure.ExposedCase.Patient.FamilyName</text>
                                                        }
                                                        else
                                                        {
                                                            <text>Case @exposure.ExposedCase.FriendlyId</text>
                                                        }
                                                    </a>
                                                </strong>
                                            </div>
                                            @if (exposure.Location != null)
                                            {
                                                <div class="text-muted small">
                                                    <i class="bi bi-geo-alt"></i> At: <a asp-page="/Locations/Details" asp-route-id="@exposure.Location.Id">@exposure.Location.Name</a>
                                                </div>
                                            }
                                            @if (exposure.Event != null)
                                            {
                                                <div class="text-muted small">
                                                    <i class="bi bi-calendar-event"></i> At: <a asp-page="/Events/Details" asp-route-id="@exposure.Event.Id">@exposure.Event.Name</a>
                                                </div>
                                            }
                                        }
                                        @* For Event exposures *@
                                        else if (exposure.ExposureType == Sentinel.Models.ExposureType.Event && exposure.Event != null)
                                        {
                                            <div>
                                                <i class="bi bi-calendar-event"></i>
                                                <a asp-page="/Events/Details" asp-route-id="@exposure.Event.Id">@exposure.Event.Name</a>
                                            </div>
                                            @if (exposure.Event.Location != null)
                                            {
                                                <div class="text-muted small">
                                                    <i class="bi bi-geo-alt"></i> At: @exposure.Event.Location.Name
                                                </div>
                                            }
                                        }
                                        @* For Location exposures *@
                                        else if (exposure.ExposureType == Sentinel.Models.ExposureType.Location && exposure.Location != null)
                                        {
                                            <div>
                                                <i class="bi bi-geo-alt"></i>
                                                <a asp-page="/Locations/Details" asp-route-id="@exposure.Location.Id">@exposure.Location.Name</a>
                                            </div>
                                        }
                                        @* For Travel exposures *@
                                        else if (exposure.ExposureType == Sentinel.Models.ExposureType.Travel)
                                        {
                                            @if (!string.IsNullOrEmpty(exposure.Country))
                                            {
                                                <div><i class="bi bi-airplane"></i> @exposure.Country</div>
                                            }
                                            else if (!string.IsNullOrEmpty(exposure.CountryCode))
                                            {
                                                <div><i class="bi bi-airplane"></i> @exposure.CountryCode</div>
                                            }
                                            else if (!string.IsNullOrEmpty(exposure.FreeTextLocation))
                                            {
                                                <text>@exposure.FreeTextLocation</text>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>@exposure.ExposureStartDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @switch (exposure.ExposureStatus)
                                        {
                                            case Sentinel.Models.ExposureStatus.ConfirmedExposure:
                                                <span class="badge bg-danger">Confirmed</span>
                                                break;
                                            case Sentinel.Models.ExposureStatus.UnderInvestigation:
                                                <span class="badge bg-warning">Investigating</span>
                                                break;
                                            case Sentinel.Models.ExposureStatus.PotentialExposure:
                                                <span class="badge bg-info">Potential</span>
                                                break;
                                            case Sentinel.Models.ExposureStatus.RuledOut:
                                                <span class="badge bg-success">Ruled Out</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">Unknown</span>
                                                break;
                                        }
                                    </td>
                                    <td class="text-end">
                                        <button type="button" class="btn btn-sm btn-link p-0 text-primary me-2" onclick="openEditExposure('@exposure.Id')" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <form method="post" asp-page-handler="DeleteExposure" asp-route-id="@Model.Case.Id" asp-route-exposureId="@exposure.Id" class="d-inline" onsubmit="return confirm('Delete this transmission?');">
                                            <button type="submit" class="btn btn-sm btn-link p-0 text-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        No transmissions recorded for this case.
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="openAddExposure(); $('#viewAllTransmissionsModal').modal('hide');">
                    <i class="bi bi-plus-circle me-1"></i>Add New Exposure
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // Global function to handle exposure type visibility
    function updateExposureTypeVisibility() {
        var exposureTypeSelect = document.getElementById('modalExposureTypeSelect');
        if (!exposureTypeSelect) return;

        var type = exposureTypeSelect.value;

        // Get all sections
        var eventSection = document.getElementById('modalEventSection');
        var locationSection = document.getElementById('modalLocationSection');
        var contactSection = document.getElementById('modalContactSection');
        var travelSection = document.getElementById('modalTravelSection');

        // Hide all sections first
        if (eventSection) eventSection.style.display = 'none';
        if (locationSection) locationSection.style.display = 'none';
        if (contactSection) contactSection.style.display = 'none';
        if (travelSection) travelSection.style.display = 'none';

        // Show the correct section based on type
        switch(type) {
            case '1': // Event
                if (eventSection) eventSection.style.display = 'block';
                break;
            case '2': // Location
                if (locationSection) locationSection.style.display = 'block';
                break;
            case '3': // Contact
                if (contactSection) contactSection.style.display = 'block';
                break;
            case '4': // Travel
                if (travelSection) travelSection.style.display = 'block';
                break;
            case '5': // LocallyAcquired
                // No specific section
                break;
        }
    }

    function openAddExposure() {
        // Open in new window - use AddExposure page (not Exposures/Add)
        window.open('/Cases/AddExposure?caseId=@Model.Case.Id', '_blank', 'width=900,height=800,scrollbars=yes,resizable=yes');
    }

    function openAddLabResult() {
        window.open('/Cases/AddLabResult?caseId=@Model.Case.Id', '_blank', 'width=1000,height=900,scrollbars=yes,resizable=yes');
    }

    window.viewLabResult = function(labResultId) {
        window.open('/Cases/ViewLabResult?labResultId=' + labResultId, '_blank', 'width=1000,height=800,scrollbars=yes,resizable=yes');
    }

    function openEditExposure(exposureId) {
        window.open('/Cases/EditExposure?id=' + exposureId + '&caseId=@Model.Case.Id', '_blank', 'width=1000,height=800,scrollbars=yes,resizable=yes');
    }

    function openAddTask() {
        window.open('@Url.Page("/Cases/AddTask", new { caseId = Model.Case.Id })', '_blank', 'width=900,height=800,scrollbars=yes,resizable=yes');
    }

    function openCompleteTaskModal(taskId, taskName) {
        // Implementation for completing tasks without surveys
        alert('Complete task: ' + taskName);
    }

    function showCallHistory(taskId) {
        // Implementation for showing call history
        alert('Show call history for task: ' + taskId);
    }

    $(document).ready(function() {
    // Attach event listener to exposure type dropdown
    var exposureTypeSelect = document.getElementById('modalExposureTypeSelect');
    if (exposureTypeSelect) {
        exposureTypeSelect.addEventListener('change', updateExposureTypeVisibility);
    }

            // Initialize Select2 for Events
            $('.select2-modal-event').select2({
                dropdownParent: $('#addExposureModal'),
                theme: 'bootstrap-5',
                placeholder: 'Type to search for event...',
                allowClear: true,
                minimumInputLength: 2,
                ajax: {
                    url: '/api/events/search',
                    dataType: 'json',
                    delay: 250,
                    data: function(params) {
                        return { term: params.term };
                    },
                    processResults: function(data) {
                        return {
                            results: data.map(function(item) {
                                return {
                                    id: item.id,
                                    text: item.name + (item.location ? ' (' + item.location + ')' : '')
                                };
                            })
                        };
                    }
                }
            });

            // Initialize Select2 for Locations
            $('.select2-modal-location').select2({
                dropdownParent: $('#addExposureModal'),
                theme: 'bootstrap-5',
                placeholder: 'Type to search for location...',
                allowClear: true,
                minimumInputLength: 2,
                ajax: {
                    url: '/api/locations/search',
                    dataType: 'json',
                    delay: 250,
                    data: function(params) {
                        return { term: params.term };
                    },
                    processResults: function(data) {
                        return {
                            results: data.map(function(item) {
                                return {
                                    id: item.id,
                                    text: item.name + (item.address ? ' - ' + item.address : '')
                                };
                            })
                        };
                    }
                }
            });

            // Initialize Select2 for Cases
            $('.select2-modal-case').select2({
                dropdownParent: $('#addExposureModal'),
                theme: 'bootstrap-5',
                placeholder: 'Type to search for case...',
                allowClear: true,
                minimumInputLength: 2,
                ajax: {
                    url: '/api/cases/search',
                    dataType: 'json',
                    delay: 250,
                    data: function(params) {
                        return {
                            term: params.term,
                            excludeCaseId: '@Model.Case.Id'
                        };
                    },
                    processResults: function(data) {
                        return {
                            results: data.map(function(item) {
                                return {
                                    id: item.caseId,
                                    text: item.friendlyId + ' - ' + item.patientName
                                };
                            })
                        };
                    }
                }
            });

            // Initialize Select2 for Countries
            $('.select2-modal-country').select2({
                dropdownParent: $('#addExposureModal'),
                theme: 'bootstrap-5',
                placeholder: 'Type to search for country...',
                allowClear: true,
                minimumInputLength: 2,
                ajax: {
                    url: '/api/countries/search',
                    dataType: 'json',
                    delay: 250,
                    data: function(params) {
                        return { term: params.term };
                    },
                    processResults: function(data) {
                        return {
                            results: data.map(function(item) {
                                return {
                                    id: item.code,
                                    text: item.name
                                };
                            })
                        };
                    }
                }
            });
        });

        // ========================================================================
        // COPY ADDRESS FROM PATIENT
        // ========================================================================

        function copyAddressFromPatient() {
            if (!confirm('Copy address and jurisdiction data from the patient record to this case?\n\n?? This will overwrite any existing case address data.')) {
                return;
            }

            const caseId = '@Model.Case.Id';

            // Show loading state
            const btn = event.target.closest('button');
            const originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split spinner-border spinner-border-sm me-1"></i> Copying...';

            fetch(`/Cases/Details?handler=CopyAddressFromPatient&id=${caseId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(response => response.json())
            .then(data => {
                btn.disabled = false;
                btn.innerHTML = originalHtml;

                if (data.success) {
                    if (data.warning) {
                        // Show warning message
                        const alertHtml = `
                            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                <strong>Address Copied with Warnings:</strong><br/>
                                ${data.message}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        `;
                        document.querySelector('.case-details-container').insertAdjacentHTML('afterbegin', alertHtml);
                    } else {
                        // Show success message
                        const alertHtml = `
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <i class="bi bi-check-circle-fill me-2"></i>
                                ${data.message}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        `;
                        document.querySelector('.case-details-container').insertAdjacentHTML('afterbegin', alertHtml);
                    }

                    if (data.reloadPage) {
                        // Reload after 2 seconds to show updated address
                        setTimeout(() => location.reload(), 2000);
                    }
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(error => {
                btn.disabled = false;
                btn.innerHTML = originalHtml;
                alert('Error copying address: ' + error.message);
            });
        }
</script>



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/case-details-custom-fields.js"></script>
}


