@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="error-template">
                <h1 class="display-1 text-danger">500</h1>
                <h2 class="mb-4">Something Went Wrong</h2>
                <div class="error-details mb-4">
                    <p class="lead">We're sorry, but something went wrong on our end.</p>
                    <p>The error has been logged and our team will investigate.</p>
                </div>
                
                @if (Model.ShowRequestId)
                {
                    <div class="alert alert-secondary" role="alert">
                        <strong>Request ID:</strong> <code>@Model.RequestId</code>
                        <br><small class="text-muted">Please provide this ID when contacting support.</small>
                    </div>
                }
                
                <div class="error-actions">
                    <a asp-page="/Index" class="btn btn-primary btn-lg me-2">
                        <i class="bi bi-house-door me-2"></i>Go to Dashboard
                    </a>
                    <button onclick="history.back()" class="btn btn-outline-secondary btn-lg">
                        <i class="bi bi-arrow-left me-2"></i>Go Back
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .error-template {
        padding: 40px 15px;
    }
    .error-template h1 {
        font-size: 8rem;
        font-weight: 700;
        line-height: 1;
    }
</style>

