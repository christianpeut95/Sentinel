@section Scripts {
<script>
    // ========================================================================
    // WORKER PERFORMANCE - CLIENT-SIDE SEARCH & PAGINATION
    // ========================================================================
    var workerAllRows = [];
    var workerFilteredRows = [];
    var workerCurrentPage = 1;

    function initWorkerTable() {
        var tbody = document.getElementById('workerTableBody');
        if (!tbody) return;
        workerAllRows = Array.from(tbody.querySelectorAll('tr'));
        filterWorkerTable();
    }

    function filterWorkerTable() {
        var search = (document.getElementById('workerSearch')?.value || '').toLowerCase();
        var status = (document.getElementById('workerStatusFilter')?.value || '').toLowerCase();

        workerFilteredRows = workerAllRows.filter(function(row) {
            var name = (row.dataset.workerName || '').toLowerCase();
            var rowStatus = (row.dataset.workerStatus || '').toLowerCase();
            var matchSearch = !search || name.includes(search);
            var matchStatus = !status || rowStatus === status;
            return matchSearch && matchStatus;
        });

        renderWorkerPage(1);
    }

    function renderWorkerPage(page) {
        var pageSize = parseInt(document.getElementById('workerPageSize')?.value || 25);
        var totalPages = Math.max(1, Math.ceil(workerFilteredRows.length / pageSize));
        workerCurrentPage = Math.min(Math.max(1, page), totalPages);

        var start = (workerCurrentPage - 1) * pageSize;
        var end = start + pageSize;

        var tbody = document.getElementById('workerTableBody');
        if (!tbody) return;

        // Hide all, show only current page
        workerAllRows.forEach(function(r) { r.style.display = 'none'; });
        workerFilteredRows.forEach(function(r, idx) {
            r.style.display = (idx >= start && idx < end) ? '' : 'none';
        });

        // Update pagination
        var infoEl = document.getElementById('workerPageInfo');
        var paginationEl = document.getElementById('workerPagination');
        var container = document.getElementById('workerPaginationContainer');

        if (infoEl) {
            infoEl.textContent = 'Showing ' + Math.min(end, workerFilteredRows.length) + ' of ' + workerFilteredRows.length + ' workers';
        }

        if (paginationEl) {
            paginationEl.innerHTML = '';
            if (totalPages <= 1) {
                if (container) container.style.display = workerFilteredRows.length > 0 ? '' : 'none';
                return;
            }
            if (container) container.style.display = '';

            var prevLi = document.createElement('li');
            prevLi.className = 'page-item' + (workerCurrentPage === 1 ? ' disabled' : '');
            prevLi.innerHTML = '<a class="page-link" href="#" onclick="renderWorkerPage(' + (workerCurrentPage - 1) + '); return false;">&laquo;</a>';
            paginationEl.appendChild(prevLi);

            var startP = Math.max(1, workerCurrentPage - 2);
            var endP = Math.min(totalPages, workerCurrentPage + 2);
            for (var i = startP; i <= endP; i++) {
                var li = document.createElement('li');
                li.className = 'page-item' + (i === workerCurrentPage ? ' active' : '');
                li.innerHTML = '<a class="page-link" href="#" onclick="renderWorkerPage(' + i + '); return false;">' + i + '</a>';
                paginationEl.appendChild(li);
            }

            var nextLi = document.createElement('li');
            nextLi.className = 'page-item' + (workerCurrentPage === totalPages ? ' disabled' : '');
            nextLi.innerHTML = '<a class="page-link" href="#" onclick="renderWorkerPage(' + (workerCurrentPage + 1) + '); return false;">&raquo;</a>';
            paginationEl.appendChild(nextLi);
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        initWorkerTable();

        var assignModal = document.getElementById('assignModal');
        assignModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var taskId = button.getAttribute('data-task-id');
            document.getElementById('taskIdInput').value = taskId;
        });

        var reassignModal = document.getElementById('reassignModal');
        reassignModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var taskId = button.getAttribute('data-task-id');
            var taskTitle = button.getAttribute('data-task-title');
            var currentWorker = button.getAttribute('data-current-worker');
            
            document.getElementById('reassignTaskIdInput').value = taskId;
            document.getElementById('reassignTaskTitle').textContent = taskTitle;
            document.getElementById('currentWorkerName').textContent = currentWorker;
        });

        var unassignModal = document.getElementById('unassignModal');
        unassignModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var taskId = button.getAttribute('data-task-id');
            var taskTitle = button.getAttribute('data-task-title');
            
            document.getElementById('unassignTaskIdInput').value = taskId;
            document.getElementById('unassignTaskTitle').textContent = taskTitle;
        });
    });
    </script>
}

