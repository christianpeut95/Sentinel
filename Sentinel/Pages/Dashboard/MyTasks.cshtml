@page
@model Sentinel.Pages.Dashboard.MyTasksModel
@using Sentinel.Models

@{
    ViewData["Title"] = "My Tasks";
}
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}

<!-- Apple Page Header -->
<div class="apple-page-header">
    <h1 class="apple-page-title"><i class="bi bi-list-check"></i> My Tasks</h1>
    <div class="text-muted text-callout">Showing @Model.FilteredTasks.Count of @Model.TotalTasks tasks</div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: var(--radius-medium);">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: var(--radius-medium);">
        <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stats Grid -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-list-task"></i></div>
        <div class="stat-value">@Model.TotalTasks</div>
        <div class="stat-label">Total Tasks</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-hourglass-split"></i></div>
        <div class="stat-value">@Model.PendingTasks</div>
        <div class="stat-label">Pending Tasks</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-exclamation-circle"></i></div>
        <div class="stat-value">@Model.OverdueTasks</div>
        <div class="stat-label">Overdue Tasks</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-check-circle-fill"></i></div>
        <div class="stat-value">@Model.CompletedTasks</div>
        <div class="stat-label">Completed This Week</div>
    </div>
</div>

        <!-- Quick Filters -->
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-body">
                    <form method="get" id="filterForm">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-3">
                                <label class="form-label">Status</label>
                                <select name="StatusFilter" class="form-select" asp-for="StatusFilter" onchange="this.form.submit()">
                                    <option value="">All</option>
                                    <option value="Active">Active (Pending + In Progress)</option>
                                    <option value="@CaseTaskStatus.Pending">Pending</option>
                                    <option value="@CaseTaskStatus.InProgress">In Progress</option>
                                    <option value="@CaseTaskStatus.Completed">Completed</option>
                                    <option value="@CaseTaskStatus.Overdue">Overdue</option>
                                    <option value="@CaseTaskStatus.Cancelled">Cancelled</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Priority</label>
                                <select name="PriorityFilter" class="form-select" asp-for="PriorityFilter" onchange="this.form.submit()">
                                    <option value="">All</option>
                                    <option value="@TaskPriority.Urgent">Urgent</option>
                                    <option value="@TaskPriority.High">High</option>
                                    <option value="@TaskPriority.Medium">Medium</option>
                                    <option value="@TaskPriority.Low">Low</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Due Date</label>
                                <select name="DueDateFilter" class="form-select" asp-for="DueDateFilter" onchange="this.form.submit()">
                                    <option value="">All</option>
                                    <option value="Overdue">Overdue</option>
                                    <option value="DueToday">Due Today</option>
                                    <option value="DueSoon">Due Soon (3 days)</option>
                                    <option value="ThisWeek">This Week</option>
                                    <option value="NoDate">No Due Date</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <a asp-page="/Dashboard/MyTasks" class="btn btn-secondary w-100">
                                    <i class="bi bi-x-circle me-1"></i>Clear Filters
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Tasks Table -->
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-list-ul me-2"></i>Tasks
                        @if (!string.IsNullOrEmpty(Model.StatusFilter) || !string.IsNullOrEmpty(Model.PriorityFilter) || !string.IsNullOrEmpty(Model.DueDateFilter))
                        {
                            <span class="badge bg-secondary">Filtered</span>
                        }
                    </h5>
                    <div class="btn-group" role="group">
                        <a asp-page="/Dashboard/MyTasks" asp-route-sortBy="DueDate" asp-route-sortOrder="@(Model.SortBy == "DueDate" && Model.SortOrder == "asc" ? "desc" : "asc")" 
                           class="btn btn-sm @(Model.SortBy == "DueDate" ? "btn-primary" : "btn-outline-primary")">
                            <i class="bi bi-calendar"></i> Due Date
                            @if (Model.SortBy == "DueDate")
                            {
                                <i class="bi bi-chevron-@(Model.SortOrder == "asc" ? "up" : "down")"></i>
                            }
                        </a>
                        <a asp-page="/Dashboard/MyTasks" asp-route-sortBy="Priority" asp-route-sortOrder="@(Model.SortBy == "Priority" && Model.SortOrder == "asc" ? "desc" : "asc")" 
                           class="btn btn-sm @(Model.SortBy == "Priority" ? "btn-primary" : "btn-outline-primary")">
                            <i class="bi bi-flag"></i> Priority
                            @if (Model.SortBy == "Priority")
                            {
                                <i class="bi bi-chevron-@(Model.SortOrder == "asc" ? "up" : "down")"></i>
                            }
                        </a>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (Model.FilteredTasks.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Task</th>
                                        <th>Case</th>
                                        <th>Priority</th>
                                        <th>Due Date</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var task in Model.FilteredTasks)
                                    {
                                        var isOverdue = task.DueDate.HasValue && task.DueDate.Value.Date < DateTime.Today && task.Status != CaseTaskStatus.Completed;
                                        var isDueToday = task.DueDate.HasValue && task.DueDate.Value.Date == DateTime.Today;
                                        
                                        <tr class="@(isOverdue ? "table-danger" : (isDueToday ? "table-warning" : ""))">
                                            <td>
                                                <strong>@task.Title</strong>
                                                @if (!string.IsNullOrEmpty(task.Description))
                                                {
                                                    <br/><small class="text-muted">@task.Description</small>
                                                }
                                                @if (task.TaskTemplate?.TaskType != null)
                                                {
                                                    <br/><span class="badge bg-secondary mt-1">@task.TaskTemplate.TaskType.Name</span>
                                                }
                                                @if (task.CallAttempts?.Any() == true)
                                                {
                                                    var lastAttempt = task.CallAttempts.OrderByDescending(a => a.AttemptedAt).First();
                                                    <br/>
                                                    <small class="text-info mt-1">
                                                        <i class="bi bi-telephone"></i> 
                                                        <strong>@task.CallAttempts.Count</strong> attempt(s)
                                                        • Last: @lastAttempt.AttemptedAt.ToString("dd MMM HH:mm")
                                                    </small>
                                                    <button type="button" class="btn btn-sm btn-link p-0 ms-1" 
                                                            onclick="showCallHistory('@task.Id')" 
                                                            title="View Call History">
                                                        <i class="bi bi-clock-history"></i>
                                                    </button>
                                                }
                                            </td>
                                            <td>
                                                <a asp-page="/Cases/Details" asp-route-id="@task.CaseId" class="text-decoration-none">
                                                    <i class="bi bi-folder me-1"></i>@task.Case?.FriendlyId
                                                </a>
                                                @if (task.Case?.Patient != null)
                                                {
                                                    <br/><small class="text-muted">@task.Case.Patient.GivenName @task.Case.Patient.FamilyName</small>
                                                }
                                            </td>
                                            <td>
                                                @{
                                                    var priorityClass = task.Priority switch
                                                    {
                                                        TaskPriority.Urgent => "bg-danger",
                                                        TaskPriority.High => "bg-warning text-dark",
                                                        TaskPriority.Medium => "bg-secondary",
                                                        TaskPriority.Low => "bg-info",
                                                        _ => "bg-secondary"
                                                    };
                                                }
                                                <span class="badge @priorityClass">@task.Priority</span>
                                            </td>
                                            <td>
                                                @if (task.DueDate.HasValue)
                                                {
                                                    <span>@task.DueDate.Value.ToString("dd MMM yyyy")</span>
                                                    @if (isOverdue)
                                                    {
                                                        <br/><span class="badge bg-danger"><i class="bi bi-exclamation-triangle"></i> Overdue</span>
                                                    }
                                                    else if (isDueToday)
                                                    {
                                                        <br/><span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> Due Today</span>
                                                    }
                                                    else if (task.DueDate.Value.Date < DateTime.Today.AddDays(3))
                                                    {
                                                        <br/><span class="badge bg-info"><i class="bi bi-clock"></i> Due Soon</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No due date</span>
                                                }
                                            </td>
                                            <td>
                                                @{
                                                    var statusClass = task.Status switch
                                                    {
                                                        CaseTaskStatus.Pending => "bg-secondary",
                                                        CaseTaskStatus.InProgress => "bg-primary",
                                                        CaseTaskStatus.Completed => "bg-success",
                                                        CaseTaskStatus.Cancelled => "bg-dark",
                                                        CaseTaskStatus.Overdue => "bg-danger",
                                                        CaseTaskStatus.WaitingForPatient => "bg-warning text-dark",
                                                        _ => "bg-secondary"
                                                    };
                                                }
                                                <span class="badge @statusClass">@task.Status</span>
                                                @if (task.CompletedAt.HasValue)
                                                {
                                                    <br/><small class="text-muted">@task.CompletedAt.Value.ToString("dd MMM yyyy")</small>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    @{
                                                        var hasSurvey = (task.TaskTemplate?.SurveyTemplateId.HasValue == true) || 
                                                                        !string.IsNullOrEmpty(task.TaskTemplate?.SurveyDefinitionJson);
                                                        var isCompletedWithSurvey = task.Status == CaseTaskStatus.Completed && hasSurvey && !string.IsNullOrEmpty(task.SurveyResponseJson);
                                                    }
                                                    
                                                    @if (isCompletedWithSurvey)
                                                    {
                                                        <a asp-page="/Tasks/ViewSurveyResult" asp-route-id="@task.Id" class="btn btn-sm btn-info" title="View Survey Results">
                                                            <i class="bi bi-eye"></i> Results
                                                        </a>
                                                    }
                                                    else if (task.Status == CaseTaskStatus.Pending)
                                                    {
                                                        <button type="button" class="btn btn-sm btn-primary" onclick="startTask('@task.Id')" title="Start Task">
                                                            <i class="bi bi-play-fill"></i>
                                                        </button>
                                                    }
                                                    
                                                    @if (task.Status != CaseTaskStatus.Completed && task.Status != CaseTaskStatus.Cancelled)
                                                    {
                                                        if (hasSurvey)
                                                        {
                                                            <a asp-page="/Tasks/CompleteSurvey" asp-route-id="@task.Id" class="btn btn-sm btn-success" title="Complete Survey">
                                                                <i class="bi bi-clipboard-check"></i> Survey
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <button type="button" class="btn btn-sm btn-success" onclick="completeTask('@task.Id', '@task.Title')" title="Complete">
                                                                <i class="bi bi-check-circle"></i>
                                                            </button>
                                                        }
                                                        <button type="button" class="btn btn-sm btn-info" onclick="logCallAttempt('@task.Id', '@task.Title')" title="Log Call Attempt">
                                                            <i class="bi bi-telephone-plus"></i>
                                                        </button>
                                                        <button type="button" class="btn btn-sm btn-warning" onclick="cancelTask('@task.Id', '@task.Title')" title="Cancel">
                                                            <i class="bi bi-x-circle"></i>
                                                        </button>
                                                    }
                                                    <a asp-page="/Cases/Details" asp-route-id="@task.CaseId" class="btn btn-sm btn-outline-primary" title="View Case">
                                                        <i class="bi bi-arrow-right"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1"></i>
                            <p class="mt-3">
                                @if (string.IsNullOrEmpty(Model.StatusFilter) && string.IsNullOrEmpty(Model.PriorityFilter) && string.IsNullOrEmpty(Model.DueDateFilter))
                                {
                                    <strong>No tasks assigned to you yet.</strong>
                                    <br/>
                                    <span>Tasks will appear here when they are assigned to you.</span>
                                }
                                else
                                {
                                    <strong>No tasks match the selected filters.</strong>
                                    <br/>
                                    <a asp-page="/Dashboard/MyTasks" class="btn btn-primary mt-2">Clear Filters</a>
                                }
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Complete Task Modal -->
<div class="modal fade" id="completeTaskModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="CompleteTask">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-check-circle me-2"></i>Complete Task</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="taskId" id="completeTaskId" />
                    <div class="alert alert-success">
                        <i class="bi bi-info-circle me-2"></i>
                        Mark task as complete: <strong id="completeTaskName"></strong>
                    </div>
                    <div class="mb-3">
                        <label for="completionNotes" class="form-label">Completion Notes (Optional)</label>
                        <textarea name="completionNotes" id="completionNotes" class="form-control" rows="3" 
                                  placeholder="Add any notes about completing this task..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle me-1"></i>Mark Complete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Cancel Task Modal -->
<div class="modal fade" id="cancelTaskModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="CancelTask">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-x-circle me-2"></i>Cancel Task</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="taskId" id="cancelTaskId" />
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Cancel task: <strong id="cancelTaskName"></strong>
                    </div>
                    <div class="mb-3">
                        <label for="cancellationReason" class="form-label">Reason (Optional)</label>
                        <textarea name="cancellationReason" id="cancellationReason" class="form-control" rows="3" 
                                  placeholder="Why is this task being cancelled?"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Back</button>
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-x-circle me-1"></i>Cancel Task
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Start Task Form (Hidden) -->
<form id="startTaskForm" method="post" asp-page-handler="StartTask" style="display:none;">
    <input type="hidden" name="taskId" id="startTaskId" />
</form>

<!-- Call History Modal -->
<div class="modal fade" id="callHistoryModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-clock-history me-2"></i>Call Attempt History</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="callHistoryContent">
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Log Call Attempt Modal -->
<div class="modal fade" id="logCallAttemptModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-telephone-plus me-2"></i>Log Call Attempt</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="logCallTaskId" />
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    Logging call for: <strong id="logCallTaskName"></strong>
                </div>
                <div class="mb-3">
                    <label for="callOutcome" class="form-label">Outcome <span class="text-danger">*</span></label>
                    <select id="callOutcome" class="form-select" required>
                        <option value="">Select outcome...</option>
                        <option value="0">Completed</option>
                        <option value="1">No Answer</option>
                        <option value="2">Busy</option>
                        <option value="3">Voicemail</option>
                        <option value="4">Refused</option>
                        <option value="5">Wrong Number</option>
                        <option value="6">Language Barrier</option>
                        <option value="7">Disconnected</option>
                        <option value="8">Call Back Requested</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label for="callNotes" class="form-label">Notes</label>
                    <textarea id="callNotes" class="form-control" rows="3" 
                              placeholder="Add notes about this call attempt..."></textarea>
                </div>
                <div class="mb-3">
                    <label for="callDuration" class="form-label">Duration (seconds)</label>
                    <input type="number" id="callDuration" class="form-control" min="0" placeholder="Optional" />
                </div>
                <div class="mb-3">
                    <label for="nextCallbackScheduled" class="form-label">Next Call Scheduled</label>
                    <input type="datetime-local" id="nextCallbackScheduled" class="form-control" />
                    <small class="form-text text-muted">Optional - when should we call back?</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveCallAttempt()">
                    <i class="bi bi-save me-1"></i>Save Call Attempt
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function completeTask(taskId, taskName) {
        $('#completeTaskId').val(taskId);
        $('#completeTaskName').text(taskName);
        $('#completionNotes').val('');
        $('#completeTaskModal').modal('show');
    }

    function cancelTask(taskId, taskName) {
        $('#cancelTaskId').val(taskId);
        $('#cancelTaskName').text(taskName);
        $('#cancellationReason').val('');
        $('#cancelTaskModal').modal('show');
    }

    function startTask(taskId) {
        $('#startTaskId').val(taskId);
        $('#startTaskForm').submit();
    }

    // Log call attempt
    function logCallAttempt(taskId, taskName) {
        $('#logCallTaskId').val(taskId);
        $('#logCallTaskName').text(taskName);
        $('#callOutcome').val('');
        $('#callNotes').val('');
        $('#callDuration').val('');
        $('#nextCallbackScheduled').val('');
        $('#logCallAttemptModal').modal('show');
    }

    // Save call attempt
    async function saveCallAttempt() {
        const taskId = $('#logCallTaskId').val();
        const outcome = $('#callOutcome').val();
        const notes = $('#callNotes').val();
        const duration = $('#callDuration').val();
        const nextCallback = $('#nextCallbackScheduled').val();

        if (!outcome) {
            alert('Please select an outcome');
            return;
        }

        try {
            const response = await fetch('/api/InterviewQueue/log-call-attempt', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() || ''
                },
                body: JSON.stringify({
                    taskId: taskId,
                    outcome: parseInt(outcome),
                    notes: notes || null,
                    durationSeconds: duration ? parseInt(duration) : null,
                    nextCallbackScheduled: nextCallback || null
                })
            });

            if (response.ok) {
                $('#logCallAttemptModal').modal('hide');
                // Reload page to show updated call count
                location.reload();
            } else {
                alert('Failed to save call attempt. Please try again.');
            }
        } catch (error) {            alert('An error occurred while saving the call attempt.');
        }
    }

    // Show call history modal
    async function showCallHistory(taskId) {
        $('#callHistoryModal').modal('show');
        $('#callHistoryContent').html('<div class="text-center py-4"><div class="spinner-border text-primary"></div></div>');

        try {
            const response = await fetch(`/api/InterviewQueue/call-attempts/${taskId}`);
            
            if (!response.ok) {
                throw new Error(`HTTP ${response.status}`);
            }
            
            const data = await response.json();

            if (data && data.length > 0) {
                let html = '<div class="list-group">';
                data.forEach(attempt => {
                    const attemptDate = new Date(attempt.attemptedAt);
                    
                    // Map enum value to display name
                    let outcomeText = 'Unknown';
                    let outcomeClass = 'secondary';
                    switch(attempt.outcome) {
                        case 0: outcomeText = 'Completed'; outcomeClass = 'success'; break;
                        case 1: outcomeText = 'No Answer'; outcomeClass = 'warning'; break;
                        case 2: outcomeText = 'Busy'; outcomeClass = 'info'; break;
                        case 3: outcomeText = 'Voicemail'; outcomeClass = 'secondary'; break;
                        case 4: outcomeText = 'Refused'; outcomeClass = 'danger'; break;
                        case 5: outcomeText = 'Wrong Number'; outcomeClass = 'warning'; break;
                        case 6: outcomeText = 'Language Barrier'; outcomeClass = 'info'; break;
                        case 7: outcomeText = 'Disconnected'; outcomeClass = 'secondary'; break;
                        case 8: outcomeText = 'Call Back Requested'; outcomeClass = 'primary'; break;
                    }
                    
                    const userName = attempt.attemptedByUser?.userName || attempt.attemptedByUser?.email || 'Unknown User';
                    
                    html += `
                        <div class="list-group-item">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1">
                                    <span class="badge bg-${outcomeClass}">${outcomeText}</span>
                                    ${userName}
                                </h6>
                                <small>${attemptDate.toLocaleString('en-AU', { 
                                    day: '2-digit', 
                                    month: 'short', 
                                    year: 'numeric',
                                    hour: '2-digit',
                                    minute: '2-digit'
                                })}</small>
                            </div>
                            ${attempt.notes ? `<p class="mb-1">${attempt.notes}</p>` : '<p class="mb-1 text-muted">No notes recorded</p>'}
                            ${attempt.nextCallbackScheduled ? `<small class="text-info"><i class="bi bi-calendar-check"></i> Next call: ${new Date(attempt.nextCallbackScheduled).toLocaleString('en-AU')}</small>` : ''}
                        </div>
                    `;
                });
                html += '</div>';
                $('#callHistoryContent').html(html);
            } else {
                $('#callHistoryContent').html('<div class="alert alert-info">No call attempts recorded for this task.</div>');
            }
        } catch (error) {            $('#callHistoryContent').html('<div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>Failed to load call history. Please try again.</div>');
        }
    }
</script>
}
