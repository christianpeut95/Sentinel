@page
@model Sentinel.Pages.Locations.DetailsModel

@{
    ViewData["Title"] = "Location Details";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Locations</a></li>
        <li class="breadcrumb-item active" aria-current="page">Details</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>
        <i class="bi bi-geo-alt-fill me-2"></i>@Model.Location.Name
        @if (Model.Location.IsHighRisk)
        {
            <span class="badge bg-warning text-dark ms-2">
                <i class="bi bi-exclamation-triangle me-1"></i>High Risk
            </span>
        }
        @if (!Model.Location.IsActive)
        {
            <span class="badge bg-secondary ms-2">Inactive</span>
        }
    </h2>
    <div>
        <a asp-page="./Edit" asp-route-id="@Model.Location.Id" class="btn btn-primary">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-page="./Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light fw-semibold">
                <i class="bi bi-info-circle me-2"></i>Location Information
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Name</dt>
                    <dd class="col-sm-9">@Model.Location.Name</dd>

                    <dt class="col-sm-3">Type</dt>
                    <dd class="col-sm-9">
                        @if (Model.Location.LocationType != null)
                        {
                            <span class="badge bg-secondary">@Model.Location.LocationType.Name</span>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Address</dt>
                    <dd class="col-sm-9">@(Model.Location.Address ?? "-")</dd>

                    @if (Model.Location.Latitude.HasValue && Model.Location.Longitude.HasValue)
                    {
                        <dt class="col-sm-3">Coordinates</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-success">
                                <i class="bi bi-geo-alt me-1"></i>@Model.Location.Latitude, @Model.Location.Longitude
                            </span>
                            @if (Model.Location.LastGeocoded.HasValue)
                            {
                                <br/><small class="text-muted">Geocoded: @Model.Location.LastGeocoded.Value.ToLocalTime().ToString("g")</small>
                            }
                        </dd>
                    }
                    else if (!string.IsNullOrEmpty(Model.Location.GeocodingStatus))
                    {
                        <dt class="col-sm-3">Geocoding</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-@(Model.Location.GeocodingStatus == "Failed" ? "danger" : "warning")">
                                @Model.Location.GeocodingStatus
                            </span>
                        </dd>
                    }

                    <dt class="col-sm-3">Organization</dt>
                    <dd class="col-sm-9">
                        @if (Model.Location.Organization != null)
                        {
                            <text>@Model.Location.Organization.Name</text>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </dd>

                    @if (!string.IsNullOrEmpty(Model.Location.Notes))
                    {
                        <dt class="col-sm-3">Notes</dt>
                        <dd class="col-sm-9">@Model.Location.Notes</dd>
                    }

                    <dt class="col-sm-3">Created</dt>
                    <dd class="col-sm-9">@Model.Location.CreatedDate.ToLocalTime().ToString("g")</dd>

                    @if (Model.Location.LastModified.HasValue)
                    {
                        <dt class="col-sm-3">Last Modified</dt>
                        <dd class="col-sm-9">@Model.Location.LastModified.Value.ToLocalTime().ToString("g")</dd>
                    }
                </dl>
            </div>
        </div>

        @if (Model.Events.Any())
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light fw-semibold">
                    <i class="bi bi-calendar-event me-2"></i>Events at this Location (@Model.Events.Count)
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Event Name</th>
                                    <th>Type</th>
                                    <th>Date</th>
                                    <th>Attendees</th>
                                    <th>Exposures</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var evt in Model.Events)
                                {
                                    <tr>
                                        <td>
                                            <a asp-page="/Events/Details" asp-route-id="@evt.Id">@evt.Name</a>
                                        </td>
                                        <td>
                                            @if (evt.EventType != null)
                                            {
                                                <span class="badge bg-info">@evt.EventType.Name</span>
                                            }
                                        </td>
                                        <td>@evt.StartDateTime.ToLocalTime().ToString("d")</td>
                                        <td>@(evt.EstimatedAttendees?.ToString() ?? "-")</td>
                                        <td>
                                            @if (Model.EventExposureCounts.ContainsKey(evt.Id))
                                            {
                                                <span class="badge bg-warning text-dark">@Model.EventExposureCounts[evt.Id]</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">0</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (Model.DirectExposureCount > 0)
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light fw-semibold">
                    <i class="bi bi-diagram-3 me-2"></i>Direct Exposures (@Model.DirectExposureCount)
                </div>
                <div class="card-body">
                    <p class="mb-0">@Model.DirectExposureCount case(s) have exposure records directly linked to this location (not through events).</p>
                </div>
            </div>
        }
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light fw-semibold">
                <i class="bi bi-bar-chart me-2"></i>Statistics
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-3">
                    <span>Total Events:</span>
                    <strong>@Model.Events.Count</strong>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span>Direct Exposures:</span>
                    <strong>@Model.DirectExposureCount</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span>Total Exposures:</span>
                    <strong>@Model.TotalExposureCount</strong>
                </div>
            </div>
        </div>

        @if (Model.Location.Latitude.HasValue && Model.Location.Longitude.HasValue)
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light fw-semibold">
                    <i class="bi bi-map me-2"></i>Map
                </div>
                <div class="card-body">
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle me-2"></i>
                        Map integration can be added here using Google Maps, OpenStreetMap, or Azure Maps.
                        <br/><br/>
                        <strong>Coordinates:</strong><br/>
                        Lat: @Model.Location.Latitude<br/>
                        Lng: @Model.Location.Longitude
                    </div>
                </div>
            </div>
        }
    </div>
</div>
