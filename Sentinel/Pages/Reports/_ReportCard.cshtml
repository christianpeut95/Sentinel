@model Sentinel.Models.Reporting.ReportDefinition

<div class="col-md-6 col-lg-4 mb-3">
    <div class="card report-card shadow-sm h-100">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <h5 class="card-title mb-0">@Model.Name</h5>
                <div>
                    @if (!string.IsNullOrEmpty(Model.Category))
                    {
                        <span class="badge bg-primary">@Model.Category</span>
                    }
                    @if (Model.IsPublic)
                    {
                        <span class="badge bg-success">
                            <i class="bi bi-globe"></i>
                        </span>
                    }
                </div>
            </div>
            
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p class="card-text text-muted small mb-3">
                    @(Model.Description.Length > 100 ? Model.Description.Substring(0, 100) + "..." : Model.Description)
                </p>
            }

            <div class="d-flex align-items-center text-muted small mb-2">
                <i class="bi bi-database me-1"></i>
                <span class="me-3">@Model.EntityType</span>
                <i class="bi bi-list-columns me-1"></i>
                <span>@Model.Fields.Count fields</span>
            </div>

            @if (Model.Folder != null)
            {
                <div class="mb-2">
                    <span class="badge bg-light text-dark">
                        <i class="bi @(Model.Folder.Icon ?? "bi-folder") me-1"></i>
                        @Model.Folder.Name
                    </span>
                </div>
            }

            <div class="text-muted small mb-3">
                <i class="bi bi-clock me-1"></i>
                Updated @((Model.ModifiedAt ?? Model.CreatedAt).ToString("MMM dd, yyyy"))
            </div>

            @if (Model.RunCount > 0)
            {
                <div class="text-muted small mb-3">
                    <i class="bi bi-play-circle me-1"></i>
                    Run @Model.RunCount time@(Model.RunCount > 1 ? "s" : "")
                </div>
            }

            <div class="d-flex gap-2">
                <a href="/Reports/View/@Model.Id?t=@DateTime.UtcNow.Ticks" class="btn btn-sm btn-primary flex-fill">
                    <i class="bi bi-play-circle me-1"></i> Run
                </a>
                <a href="/Reports/Builder?reportId=@Model.Id" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-pencil"></i>
                </a>
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-three-dots-vertical"></i>
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="/Reports/Builder?reportId=@Model.Id">
                            <i class="bi bi-pencil me-2"></i>Edit
                        </a></li>
                        <li><a class="dropdown-item" href="#" onclick="event.preventDefault(); duplicateReport(@Model.Id)">
                            <i class="bi bi-files me-2"></i>Duplicate
                        </a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="#" onclick="event.preventDefault(); moveToFolder(@Model.Id)">
                            <i class="bi bi-folder me-2"></i>Move to Folder
                        </a></li>
                        @if (Model.Folder != null)
                        {
                            <li><a class="dropdown-item" href="#" onclick="event.preventDefault(); removeFromFolder(@Model.Id)">
                                <i class="bi bi-folder-x me-2"></i>Remove from Folder
                            </a></li>
                        }
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="#" onclick="event.preventDefault(); confirmDelete(@Model.Id, '@Model.Name')">
                            <i class="bi bi-trash me-2"></i>Delete
                        </a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
