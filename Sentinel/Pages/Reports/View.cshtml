@page "{id:int}"
@model Sentinel.Pages.Reports.ViewModel
@{
    ViewData["Title"] = Model.ReportDefinition?.Name ?? "Report";
    ViewData["BodyClass"] = "reports-page";
}
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}

@section Styles {
    <!-- WebDataRocks CSS -->
    <link href="https://cdn.webdatarocks.com/latest/webdatarocks.css" rel="stylesheet" />
    <!-- Full-width styling for Reports -->
    <link href="~/css/reports-fullwidth.css" rel="stylesheet" />
}
<div class="container-fluid py-4">
    @if (Model.ReportDefinition == null)
    {
        <div class="alert alert-danger">Report not found.</div>
    }
    else if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger">
            <strong>Error:</strong> @Model.ErrorMessage
        </div>
    }
    else
    {
        <!-- Header -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h2>
                            <i class="bi bi-file-bar-graph me-2"></i>
                            @Model.ReportDefinition.Name
                        </h2>
                        @if (!string.IsNullOrEmpty(Model.ReportDefinition.Description))
                        {
                            <p class="text-muted mb-0">@Model.ReportDefinition.Description</p>
                        }
                        <div class="mt-2">
                            @if (!string.IsNullOrEmpty(Model.ReportDefinition.Category))
                            {
                                <span class="badge bg-primary me-2">@Model.ReportDefinition.Category</span>
                            }
                            <span class="badge bg-secondary me-2">@Model.ReportDefinition.EntityType</span>
                            <span class="badge bg-info text-dark">@Model.TotalRows rows</span>
                        </div>
                    </div>
                    <div>
                        <button type="button" class="btn btn-outline-secondary me-2" onclick="toggleView()">
                            <i class="bi bi-layout-split me-1"></i>
                            <span id="viewToggleText">Split View</span>
                        </button>
                        <a href="/Reports/Builder?reportId=@Model.ReportDefinition.Id" class="btn btn-outline-primary me-2">
                            <i class="bi bi-pencil me-1"></i> Edit
                        </a>
                        <button type="button" class="btn btn-success" onclick="exportToExcel()">
                            <i class="bi bi-file-earmark-excel me-1"></i> Export
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- View Mode Toggle -->
        <div class="row mb-3">
            <div class="col-12">
                <ul class="nav nav-tabs" id="viewTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="pivot-tab" data-bs-toggle="tab" 
                                data-bs-target="#pivot-view" type="button">
                            <i class="bi bi-grid-3x3-gap me-1"></i> Pivot View
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="table-tab" data-bs-toggle="tab" 
                                data-bs-target="#table-view" type="button">
                            <i class="bi bi-table me-1"></i> Table View
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="split-tab" data-bs-toggle="tab" 
                                data-bs-target="#split-view" type="button">
                            <i class="bi bi-layout-split me-1"></i> Split View
                        </button>
                    </li>
                    @if (!string.IsNullOrEmpty(Model.ReportDefinition?.ChartConfiguration))
                    {
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="chart-tab" data-bs-toggle="tab" 
                                    data-bs-target="#chart-view" type="button">
                                <i class="bi bi-graph-up me-1"></i> Chart
                            </button>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <!-- Tab Content -->
        <div class="tab-content" id="viewTabContent">
            <!-- Pivot View -->
            <div class="tab-pane fade show active" id="pivot-view">
                <div class="card shadow-sm">
                    <div class="card-body p-0">
                        <div id="pivotContainer" style="height: 700px;"></div>
                    </div>
                </div>
            </div>

            <!-- Table View -->
            <div class="tab-pane fade" id="table-view">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        @if (Model.ReportData != null && Model.ReportData.Any())
                                        {
                                            @foreach (var key in Model.ReportData.First().Keys)
                                            {
                                                <th>@key</th>
                                            }
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.ReportData != null)
                                    {
                                        @foreach (var row in Model.ReportData)
                                        {
                                            <tr>
                                                @foreach (var value in row.Values)
                                                {
                                                    <td>@value</td>
                                                }
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Split View -->
            <div class="tab-pane fade" id="split-view">
                <div class="row">
                    <!-- Pivot (left) -->
                    <div class="col-lg-6 mb-3">
                        <div class="card shadow-sm">
                            <div class="card-header bg-light">
                                <h5 class="mb-0">Pivot Analysis</h5>
                            </div>
                            <div class="card-body p-0">
                                <div id="pivotContainerSplit" style="height: 600px;"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Table (right) -->
                    <div class="col-lg-6 mb-3">
                        <div class="card shadow-sm">
                            <div class="card-header bg-light">
                                <h5 class="mb-0">Raw Data</h5>
                            </div>
                            <div class="card-body" style="height: 600px; overflow-y: auto;">
                                <div class="table-responsive">
                                    <table class="table table-sm table-striped">
                                        <thead class="sticky-top bg-white">
                                            <tr>
                                                @if (Model.ReportData != null && Model.ReportData.Any())
                                                {
                                                    @foreach (var key in Model.ReportData.First().Keys)
                                                    {
                                                        <th>@key</th>
                                                    }
                                                }
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model.ReportData != null)
                                            {
                                                @foreach (var row in Model.ReportData)
                                                {
                                                    <tr>
                                                        @foreach (var value in row.Values)
                                                        {
                                                            <td>@value</td>
                                                        }
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.ReportDefinition?.ChartConfiguration))
            {
                <!-- Chart View -->
                <div class="tab-pane fade" id="chart-view">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <canvas id="reportLineChart" style="max-height: 500px;"></canvas>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Report Info -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header">
                        <h5 class="mb-0">Report Details</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <h6>Fields (@Model.ReportDefinition.Fields.Count)</h6>
                                <ul class="list-unstyled">
                                    @foreach (var field in Model.ReportDefinition.Fields)
                                    {
                                        <li>
                                            <i class="bi bi-dot"></i>
                                            @field.DisplayName
                                            <small class="text-muted">(@field.DataType)</small>
                                            @if (field.IsCustomField)
                                            {
                                                <span class="badge bg-success">Custom</span>
                                            }
                                        </li>
                                    }
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <h6>Filters (@Model.ReportDefinition.Filters.Count)</h6>
                                @if (Model.ReportDefinition.Filters.Any())
                                {
                                    <ul class="list-unstyled">
                                        @foreach (var filter in Model.ReportDefinition.Filters)
                                        {
                                            <li>
                                                <i class="bi bi-funnel"></i>
                                                @filter.FieldPath @filter.Operator @filter.Value
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p class="text-muted">No filters applied</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <!-- WebDataRocks -->
    <script src="https://cdn.webdatarocks.com/latest/webdatarocks.js"></script>
    <script src="https://cdn.webdatarocks.com/latest/webdatarocks.toolbar.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    
    <script src="~/js/webdatarocks-helper.js"></script>
    <script>
        const reportData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ReportData));
        const pivotConfig = @Html.Raw(Model.ReportDefinition?.PivotConfiguration ?? "null");
        const chartConfig = @Html.Raw(Model.ReportDefinition?.ChartConfiguration ?? "null");

        let pivot1 = null;
        let pivot2 = null;

        // Wait for WebDataRocks to load
        function initializePivots() {
            if (typeof WebDataRocks === 'undefined') {
                setTimeout(initializePivots, 100);
                return;
            }

            // Prepare report config with FRESH data (replace stale cached dataSource)
            let reportConfig;
            if (pivotConfig) {
                // Use saved pivot configuration but REPLACE dataSource with fresh data
                reportConfig = JSON.parse(JSON.stringify(pivotConfig)); // Deep clone
                reportConfig.dataSource = { data: reportData }; // Inject fresh data            } else {
                // No saved config - use default flat table
                reportConfig = {
                    dataSource: { data: reportData }
                };            }

            // Initialize pivot view
            pivot1 = new WebDataRocks({
                container: "#pivotContainer",
                toolbar: true,
                height: "100%",
                report: reportConfig
            });

            // Initialize split view pivot (same config, separate instance)
            pivot2 = new WebDataRocks({
                container: "#pivotContainerSplit",
                toolbar: false,
                height: "100%",
                report: JSON.parse(JSON.stringify(reportConfig)) // Deep clone to avoid shared state
            });        }

        function exportToExcel() {
            if (pivot1) {
                pivot1.exportTo('excel');
            }
        }

        function toggleView() {
            const splitTab = document.getElementById('split-tab');
            splitTab.click();
        }

        // ===== Chart rendering =====
        function getPeriodKey(date, groupBy) {
            const y = date.getFullYear();
            const m = String(date.getMonth() + 1).padStart(2, '0');
            const d = String(date.getDate()).padStart(2, '0');
            switch (groupBy) {
                case 'day':     return `${y}-${m}-${d}`;
                case 'week': {
                    const week = getISOWeek(date);
                    return `${y}-W${String(week).padStart(2, '0')}`;
                }
                case 'month':   return `${y}-${m}`;
                case 'quarter': return `${y}-Q${Math.ceil((date.getMonth() + 1) / 3)}`;
                case 'year':    return `${y}`;
                default:        return `${y}-${m}`;
            }
        }

        function getISOWeek(date) {
            const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
            const dayNum = d.getUTCDay() || 7;
            d.setUTCDate(d.getUTCDate() + 4 - dayNum);
            const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
            return Math.ceil((((d - yearStart) / 86400000) + 1) / 7);
        }

        function startOfPeriod(date, groupBy) {
            const d = new Date(date);
            switch (groupBy) {
                case 'day':     d.setHours(0,0,0,0); return d;
                case 'week': {
                    const day = d.getDay();
                    d.setDate(d.getDate() - (day === 0 ? 6 : day - 1));
                    d.setHours(0,0,0,0);
                    return d;
                }
                case 'month':   d.setDate(1); d.setHours(0,0,0,0); return d;
                case 'quarter': d.setMonth(Math.floor(d.getMonth() / 3) * 3, 1); d.setHours(0,0,0,0); return d;
                case 'year':    d.setMonth(0, 1); d.setHours(0,0,0,0); return d;
                default:        d.setDate(1); d.setHours(0,0,0,0); return d;
            }
        }

        function nextPeriod(date, groupBy) {
            const d = new Date(date);
            switch (groupBy) {
                case 'day':     d.setDate(d.getDate() + 1); return d;
                case 'week':    d.setDate(d.getDate() + 7); return d;
                case 'month':   d.setMonth(d.getMonth() + 1); return d;
                case 'quarter': d.setMonth(d.getMonth() + 3); return d;
                case 'year':    d.setFullYear(d.getFullYear() + 1); return d;
                default:        d.setMonth(d.getMonth() + 1); return d;
            }
        }

        function buildChartData(data, cfg) {
            const xField = cfg.xAxisField;
            const groupBy = cfg.groupBy || 'month';
            const fillEmpty = cfg.fillEmptyPeriods !== false;

            const counts = {};
            data.forEach(row => {
                const rawVal = row[xField];
                if (rawVal === null || rawVal === undefined || rawVal === '') return;
                const date = new Date(rawVal);
                if (isNaN(date.getTime())) return;
                const key = getPeriodKey(date, groupBy);
                counts[key] = (counts[key] || 0) + 1;
            });

            if (Object.keys(counts).length === 0) return { labels: [], values: [] };

            if (!fillEmpty) {
                const sortedKeys = Object.keys(counts).sort();
                return { labels: sortedKeys, values: sortedKeys.map(k => counts[k]) };
            }

            const allDates = data
                .map(r => r[xField])
                .filter(v => v !== null && v !== undefined && v !== '')
                .map(v => new Date(v))
                .filter(d => !isNaN(d.getTime()));

            let minDate = cfg.startDate ? new Date(cfg.startDate) : new Date(Math.min(...allDates));
            let maxDate = cfg.endDate ? new Date(cfg.endDate) : new Date(Math.max(...allDates));

            const labels = [];
            const values = [];
            let current = startOfPeriod(minDate, groupBy);
            const end = startOfPeriod(maxDate, groupBy);

            while (current <= end) {
                const key = getPeriodKey(current, groupBy);
                labels.push(key);
                values.push(counts[key] || 0);
                current = nextPeriod(current, groupBy);
            }

            return { labels, values };
        }

        function initializeChart() {
            if (!chartConfig || !reportData || reportData.length === 0) return;
            const canvas = document.getElementById('reportLineChart');
            if (!canvas) return;

            const { labels, values } = buildChartData(reportData, chartConfig);
            if (labels.length === 0) return;

            new Chart(canvas, {
                type: 'line',
                data: {
                    labels,
                    datasets: [{
                        label: chartConfig.yAxisLabel || 'Count',
                        data: values,
                        borderColor: 'rgba(13, 110, 253, 1)',
                        backgroundColor: 'rgba(13, 110, 253, 0.1)',
                        borderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        tension: 0.3,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        title: {
                            display: !!(chartConfig.title),
                            text: chartConfig.title || ''
                        },
                        legend: { display: false }
                    },
                    scales: {
                        x: {
                            title: {
                                display: !!(chartConfig.xAxisLabel),
                                text: chartConfig.xAxisLabel || ''
                            },
                            ticks: { maxRotation: 45, minRotation: 0 }
                        },
                        y: {
                            title: {
                                display: !!(chartConfig.yAxisLabel),
                                text: chartConfig.yAxisLabel || ''
                            },
                            beginAtZero: true,
                            ticks: { stepSize: 1, precision: 0 }
                        }
                    }
                }
            });
        }

        // Initialize when page loads
        document.addEventListener('DOMContentLoaded', () => {
            initializePivots();
            initializeChart();
        });
    </script>

    <style>
        .sticky-top {
            position: sticky;
            top: 0;
            z-index: 10;
        }
    </style>
}
