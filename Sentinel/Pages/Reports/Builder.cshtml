@page
@model Sentinel.Pages.Reports.BuilderModel
@{
    ViewData["Title"] = Model.ReportId.HasValue ? "Edit Report" : "Report Builder";
    ViewData["BodyClass"] = "reports-page";
}
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}

@section Styles {
    <link href="https://cdn.webdatarocks.com/latest/webdatarocks.css" rel="stylesheet" />
    <link href="~/css/reports-fullwidth.css" rel="stylesheet" />
    <style nonce="@GetCspNonce()">
        /* Loading overlay */
        #report-loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.95);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(2px);
        }

        #report-loading-overlay.hidden {
            display: none;
        }

        .loading-content {
            text-align: center;
            padding: 40px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        }

        .loading-spinner {
            width: 60px;
            height: 60px;
            border: 4px solid #f3f3f3;
            border-top: 4px solid #0d6efd;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .loading-text {
            font-size: 18px;
            font-weight: 500;
            color: #333;
            margin-bottom: 10px;
        }

        .loading-subtext {
            font-size: 14px;
            color: #666;
        }

        .loading-progress {
            margin-top: 15px;
            font-size: 12px;
            color: #999;
            font-family: monospace;
        }
    </style>
}

<!-- Loading Overlay -->
<div id="report-loading-overlay">
    <div class="loading-content">
        <div class="loading-spinner"></div>
        <div class="loading-text">Loading Report</div>
        <div class="loading-subtext">Restoring filters and collection queries...</div>
        <div class="loading-progress" id="loading-progress"></div>
    </div>
</div>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2><i class="bi bi-graph-up me-2"></i>@ViewData["Title"]</h2>
                <div>
                    <button type="button" class="btn btn-outline-secondary me-2" id="btnPreview">
                        <i class="bi bi-eye me-1"></i> Preview
                    </button>
                    <button type="button" class="btn btn-primary" id="btnSave">
                        <i class="bi bi-save me-1"></i> Save Report
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <!-- Left Panel: Available Fields -->
        <div class="col-xl-3 col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-list-columns me-2"></i>Available Fields</h5>
                </div>
                <div class="card-body p-0">
                    <div class="p-3 border-bottom">
                        <label class="form-label mb-1 small fw-bold">Entity Type:</label>
                        <select class="form-select form-select-sm" id="entityTypeSelector">
                            <optgroup label="Core Entities">
                                <option value="Case" selected="@(Model.EntityType == "Case")">Cases</option>
                                <option value="Contact" selected="@(Model.EntityType == "Contact")">Contacts</option>
                                <option value="Outbreak" selected="@(Model.EntityType == "Outbreak")">Outbreaks</option>
                                <option value="Patient" selected="@(Model.EntityType == "Patient")">Patients</option>
                                <option value="Task" selected="@(Model.EntityType == "Task")">Tasks</option>
                                <option value="Location" selected="@(Model.EntityType == "Location")">Locations</option>
                                <option value="Event" selected="@(Model.EntityType == "Event")">Events</option>
                            </optgroup>
                            <optgroup label="Flattened Views">
                                <option value="CaseContactTasksFlattened" selected="@(Model.EntityType == "CaseContactTasksFlattened")">Case Tasks + Transmission Chains</option>
                                <option value="OutbreakTasksFlattened" selected="@(Model.EntityType == "OutbreakTasksFlattened")">Outbreak Tasks</option>
                                <option value="CaseTimelineAll" selected="@(Model.EntityType == "CaseTimelineAll")">Case Timeline</option>
                                <option value="ContactTracingMindMapNodes" selected="@(Model.EntityType == "ContactTracingMindMapNodes")">Network Nodes</option>
                                <option value="ContactTracingMindMapEdges" selected="@(Model.EntityType == "ContactTracingMindMapEdges")">Network Edges</option>
                                <option value="ContactsListSimple" selected="@(Model.EntityType == "ContactsListSimple")">Contacts List</option>
                            </optgroup>
                        </select>
                        
                        <!-- Load Default Fields Button -->
                        <button type="button" class="btn btn-outline-primary btn-sm w-100 mt-2" id="btnLoadDefaults">
                            <i class="bi bi-magic me-1"></i> Load Default Fields
                        </button>
                    </div>
                    <div class="p-3 border-bottom">
                        <input type="text" class="form-control form-control-sm" id="fieldSearch" placeholder="?? Search fields...">
                    </div>
                    <div id="fieldCategories" class="accordion accordion-flush" style="max-height: calc(100vh - 320px); overflow-y: auto;">
                        @if (Model.AvailableFields != null)
                        {
                            @foreach (var category in Model.AvailableFields)
                            {
                                var categoryId = category.Key.Replace(" ", "");
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@categoryId">
                                            @category.Key
                                            <span class="badge bg-secondary ms-auto me-2">@category.Value.Count</span>
                                        </button>
                                    </h2>
                                    <div id="@categoryId" class="accordion-collapse collapse">
                                        <div class="accordion-body p-0">
                                            @foreach (var field in category.Value)
                                            {
                                                <div class="field-item p-2 border-bottom" 
                                                     draggable="true"
                                                     data-field-path="@field.FieldPath"
                                                     data-display-name="@field.DisplayName"
                                                     data-data-type="@field.DataType"
                                                     data-is-custom="@field.IsCustomField.ToString().ToLower()"
                                                     data-custom-id="@field.CustomFieldDefinitionId">
                                                    <div class="d-flex align-items-start">
                                                        <i class="bi bi-grip-vertical text-muted me-2"></i>
                                                        <div class="flex-grow-1">
                                                            <small class="d-block fw-bold">@field.DisplayName</small>
                                                            <small class="text-muted">
                                                                @field.DataType
                                                                @if (field.IsCustomField)
                                                                {
                                                                    <span class="badge bg-success ms-1">Custom</span>
                                                                }
                                                            </small>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Panel: Report Configuration -->
        <div class="col-xl-9 col-lg-8">
            <!-- Report Settings -->
            <div class="card shadow-sm mb-3">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-gear me-2"></i>Report Settings</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Report Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="reportName" value="@Model.ReportDefinition?.Name" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Category</label>
                            <select class="form-select" id="reportCategory">
                                <option value="">Select category...</option>
                                <option value="Epidemiological">Epidemiological</option>
                                <option value="Laboratory">Laboratory</option>
                                <option value="Outbreak">Outbreak</option>
                                <option value="Surveillance">Surveillance</option>
                                <option value="Custom">Custom</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" id="reportDescription" rows="2">@Model.ReportDefinition?.Description</textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="reportPublic">
                                <label class="form-check-label" for="reportPublic">Share this report with all users</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Selected Fields -->
            <div class="card shadow-sm mb-3">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-check2-square me-2"></i>Selected Fields</h5>
                </div>
                <div class="card-body">
                    <div id="selectedFields" class="list-group">
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-arrow-left-circle fs-1"></i>
                            <p class="mt-2">Drag fields from the left panel to add them to your report</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Filters -->
            <div class="card shadow-sm mb-3">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-funnel me-2"></i>Filters</h5>
                        <div>
                            <button type="button" class="btn btn-sm btn-outline-success me-2" id="btnAddGroup">
                                <i class="bi bi-plus-square me-1"></i> Add Group
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-primary" id="btnAddFilter">
                                <i class="bi bi-plus-circle me-1"></i> Add Filter
                            </button>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div id="filters" class="list-group">
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-funnel fs-1"></i>
                            <p class="mt-2">No filters added yet</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Collection Queries (Related Data) -->
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-info text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-diagram-3 me-2"></i>Collection Queries (Related Data)</h5>
                        <button type="button" class="btn btn-sm btn-light" id="btnAddCollectionQuery">
                            <i class="bi bi-plus-circle me-1"></i> Add Query
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="alert alert-info small mb-3">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Collection Queries let you filter or aggregate related data.</strong><br>
                        Examples: "Has positive PCR result", "Number of exposures > 3", "Sum of lab values", etc.
                    </div>
                    <div id="collectionQueries" class="list-group">
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-diagram-3 fs-1"></i>
                            <p class="mt-2">No collection queries added yet</p>
                            <small class="text-muted">Use collection queries to filter on related data like exposures, tasks, or lab results</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Preview -->
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-table me-2"></i>Preview</h5>
                </div>
                <div class="card-body">
                    <div id="previewContainer" style="min-height: 400px;">
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-eye-slash fs-1"></i>
                            <p class="mt-2">Click "Preview" to see your report</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.webdatarocks.com/latest/webdatarocks.js"></script>
<script src="~/js/webdatarocks-helper.js"></script>
<script src="~/js/report-builder.js"></script>
<script src="~/js/report-builder-collections.js"></script>
<script src="~/js/report-builder-actions.js"></script>

<script>
console.log('[Builder.cshtml] Script section executing...');

// Initialize Report Builder with data from Razor model
document.addEventListener('DOMContentLoaded', () => {
    console.log('[Builder.cshtml] DOMContentLoaded event fired');

    const savedReport = {
        reportId: @(Model.ReportId?.ToString() ?? "null"),
        entityType: '@Model.EntityType',
        fields: @Html.Raw(Model.FieldsJson ?? "[]"),
        filters: @Html.Raw(Model.FiltersJson ?? "[]"),
        collectionQueries: @Html.Raw(Model.CollectionQueriesJson ?? "[]"),
        pivotConfiguration: '@Html.Raw(Model.ReportDefinition?.PivotConfiguration ?? "")'
    };

    console.log('[Builder.cshtml] Saved report data:', savedReport);

    // Store saved pivot config and report ID in ReportBuilder
    ReportBuilder.savedPivotConfiguration = savedReport.pivotConfiguration;
    ReportBuilder.reportId = savedReport.reportId;

    // Store original entity type for change detection
    document.getElementById('entityTypeSelector').dataset.originalValue = savedReport.entityType;
    document.getElementById('entityTypeSelector').dataset.reportId = savedReport.reportId;

    console.log('[Builder.cshtml] About to call ReportBuilder.init()');

    // Initialize ReportBuilder
    ReportBuilder.init(savedReport);

    console.log('[Builder.cshtml] ReportBuilder.init() called successfully');
});
</script>

<style>
.field-item {
    cursor: grab;
    user-select: none;
    transition: background-color 0.2s;
}

.field-item:hover {
    background-color: #f8f9fa;
}

.field-item:active {
    cursor: grabbing;
}

.selected-field-item {
    cursor: move;
    transition: all 0.2s;
}

.selected-field-item.dragging {
    opacity: 0.5;
    background-color: #e7f1ff;
}

.selected-field-item:hover {
    background-color: #f8f9fa;
}

.filter-group {
    background-color: #f8f9fa;
    border-left: 4px solid #0d6efd !important;
}

.filter-group .group-filters {
    min-height: 60px;
}

.filter-group .list-group-item {
    background-color: white;
}
</style>
}