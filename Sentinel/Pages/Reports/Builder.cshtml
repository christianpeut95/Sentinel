@page
@model Sentinel.Pages.Reports.BuilderModel
@{
    ViewData["Title"] = Model.ReportId.HasValue ? "Edit Report" : "Report Builder";
    ViewData["BodyClass"] = "reports-page";
}
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}

@section Styles {
    <link href="https://cdn.webdatarocks.com/latest/webdatarocks.css" rel="stylesheet" />
    <link href="~/css/reports-fullwidth.css" rel="stylesheet" />
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2><i class="bi bi-graph-up me-2"></i>@ViewData["Title"]</h2>
                <div>
                    <button type="button" class="btn btn-outline-secondary me-2" id="btnPreview">
                        <i class="bi bi-eye me-1"></i> Preview
                    </button>
                    <button type="button" class="btn btn-primary" id="btnSave">
                        <i class="bi bi-save me-1"></i> Save Report
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <!-- Left Panel: Available Fields -->
        <div class="col-xl-3 col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-list-columns me-2"></i>Available Fields</h5>
                </div>
                <div class="card-body p-0">
                    <div class="p-3 border-bottom">
                        <label class="form-label mb-1 small fw-bold">Entity Type:</label>
                        <select class="form-select form-select-sm" id="entityTypeSelector">
                            <optgroup label="Core Entities">
                                <option value="Case" selected="@(Model.EntityType == "Case")">Cases</option>
                                <option value="Contact" selected="@(Model.EntityType == "Contact")">Contacts</option>
                                <option value="Outbreak" selected="@(Model.EntityType == "Outbreak")">Outbreaks</option>
                                <option value="Patient" selected="@(Model.EntityType == "Patient")">Patients</option>
                                <option value="Task" selected="@(Model.EntityType == "Task")">Tasks</option>
                                <option value="Location" selected="@(Model.EntityType == "Location")">Locations</option>
                                <option value="Event" selected="@(Model.EntityType == "Event")">Events</option>
                            </optgroup>
                            <optgroup label="Flattened Views">
                                <option value="CaseContactTasksFlattened" selected="@(Model.EntityType == "CaseContactTasksFlattened")">Case Tasks + Transmission Chains</option>
                                <option value="OutbreakTasksFlattened" selected="@(Model.EntityType == "OutbreakTasksFlattened")">Outbreak Tasks</option>
                                <option value="CaseTimelineAll" selected="@(Model.EntityType == "CaseTimelineAll")">Case Timeline</option>
                                <option value="ContactTracingMindMapNodes" selected="@(Model.EntityType == "ContactTracingMindMapNodes")">Network Nodes</option>
                                <option value="ContactTracingMindMapEdges" selected="@(Model.EntityType == "ContactTracingMindMapEdges")">Network Edges</option>
                                <option value="ContactsListSimple" selected="@(Model.EntityType == "ContactsListSimple")">Contacts List</option>
                            </optgroup>
                        </select>
                        
                        <!-- Load Default Fields Button -->
                        <button type="button" class="btn btn-outline-primary btn-sm w-100 mt-2" id="btnLoadDefaults">
                            <i class="bi bi-magic me-1"></i> Load Default Fields
                        </button>
                    </div>
                    <div class="p-3 border-bottom">
                        <input type="text" class="form-control form-control-sm" id="fieldSearch" placeholder="?? Search fields...">
                    </div>
                    <div id="fieldCategories" class="accordion accordion-flush" style="max-height: calc(100vh - 320px); overflow-y: auto;">
                        @if (Model.AvailableFields != null)
                        {
                            @foreach (var category in Model.AvailableFields)
                            {
                                var categoryId = category.Key.Replace(" ", "");
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@categoryId">
                                            @category.Key
                                            <span class="badge bg-secondary ms-auto me-2">@category.Value.Count</span>
                                        </button>
                                    </h2>
                                    <div id="@categoryId" class="accordion-collapse collapse">
                                        <div class="accordion-body p-0">
                                            @foreach (var field in category.Value)
                                            {
                                                <div class="field-item p-2 border-bottom" 
                                                     draggable="true"
                                                     data-field-path="@field.FieldPath"
                                                     data-display-name="@field.DisplayName"
                                                     data-data-type="@field.DataType"
                                                     data-is-custom="@field.IsCustomField.ToString().ToLower()"
                                                     data-custom-id="@field.CustomFieldDefinitionId">
                                                    <div class="d-flex align-items-start">
                                                        <i class="bi bi-grip-vertical text-muted me-2"></i>
                                                        <div class="flex-grow-1">
                                                            <small class="d-block fw-bold">@field.DisplayName</small>
                                                            <small class="text-muted">
                                                                @field.DataType
                                                                @if (field.IsCustomField)
                                                                {
                                                                    <span class="badge bg-success ms-1">Custom</span>
                                                                }
                                                            </small>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Panel: Report Configuration -->
        <div class="col-xl-9 col-lg-8">
            <!-- Report Settings -->
            <div class="card shadow-sm mb-3">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-gear me-2"></i>Report Settings</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Report Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="reportName" value="@Model.ReportDefinition?.Name" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Category</label>
                            <select class="form-select" id="reportCategory">
                                <option value="">Select category...</option>
                                <option value="Epidemiological">Epidemiological</option>
                                <option value="Laboratory">Laboratory</option>
                                <option value="Outbreak">Outbreak</option>
                                <option value="Surveillance">Surveillance</option>
                                <option value="Custom">Custom</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" id="reportDescription" rows="2">@Model.ReportDefinition?.Description</textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="reportPublic">
                                <label class="form-check-label" for="reportPublic">Share this report with all users</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Selected Fields -->
            <div class="card shadow-sm mb-3">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-check2-square me-2"></i>Selected Fields</h5>
                </div>
                <div class="card-body">
                    <div id="selectedFields" class="list-group">
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-arrow-left-circle fs-1"></i>
                            <p class="mt-2">Drag fields from the left panel to add them to your report</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Filters -->
            <div class="card shadow-sm mb-3">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-funnel me-2"></i>Filters</h5>
                        <div>
                            <button type="button" class="btn btn-sm btn-outline-success me-2" id="btnAddGroup">
                                <i class="bi bi-plus-square me-1"></i> Add Group
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-primary" id="btnAddFilter">
                                <i class="bi bi-plus-circle me-1"></i> Add Filter
                            </button>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div id="filters" class="list-group">
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-funnel fs-1"></i>
                            <p class="mt-2">No filters added yet</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Collection Queries (Related Data) -->
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-info text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-diagram-3 me-2"></i>Collection Queries (Related Data)</h5>
                        <button type="button" class="btn btn-sm btn-light" id="btnAddCollectionQuery">
                            <i class="bi bi-plus-circle me-1"></i> Add Query
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="alert alert-info small mb-3">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Collection Queries let you filter or aggregate related data.</strong><br>
                        Examples: "Has positive PCR result", "Number of exposures > 3", "Sum of lab values", etc.
                    </div>
                    <div id="collectionQueries" class="list-group">
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-diagram-3 fs-1"></i>
                            <p class="mt-2">No collection queries added yet</p>
                            <small class="text-muted">Use collection queries to filter on related data like exposures, tasks, or lab results</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Preview -->
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-table me-2"></i>Preview</h5>
                </div>
                <div class="card-body">
                    <div id="previewContainer" style="min-height: 400px;">
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-eye-slash fs-1"></i>
                            <p class="mt-2">Click "Preview" to see your report</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.webdatarocks.com/latest/webdatarocks.js"></script>
<script src="~/js/webdatarocks-helper.js"></script>

<script>
// Report Builder - Clean Version
const ReportBuilder = {
    selectedFields: [],
    filters: [],
    filterGroups: [],
    nextFilterId: 1,
    nextGroupId: 1,
    
    init() {        this.setupDragDrop();
        this.setupEventListeners();
        this.setupFieldSearch();
        this.loadSavedReport();    },
    
    loadSavedReport() {
        // Load saved fields if editing an existing report
        @if (Model.ReportDefinition != null)
        {
            @:// Load saved fields
            foreach (var field in Model.ReportDefinition.Fields.OrderBy(f => f.DisplayOrder))
            {
                @:this.selectedFields.push({
                @:    fieldPath: '@field.FieldPath',
                @:    displayName: '@field.DisplayName',
                @:    dataType: '@field.DataType',
                @:    isCustom: @field.IsCustomField.ToString().ToLower(),
                @:    customId: @(field.CustomFieldDefinitionId?.ToString() ?? "null")
                @:});
            }
            @:this.renderSelectedFields();
            
            @:// Load saved filters
            var filterIndex = 0;
            foreach (var filter in Model.ReportDefinition.Filters.OrderBy(f => f.DisplayOrder))
            {
                var filterGroupId = filter.GroupId?.ToString() ?? "null";
                var filterValue = filter.Value?.Replace("'", "\\'") ?? "";
                @:this.addFilter();
                @:setTimeout(() => {
                @:    const filterElements = document.querySelectorAll('#filters .list-group-item');
                @:    const filterEl = filterElements[filterElements.length - 1];
                @:    if (filterEl) {
                @:        const fieldSelect = filterEl.querySelector('.filter-field');
                @:        if (fieldSelect) fieldSelect.value = '@filter.FieldPath';
                @:        fieldSelect?.dispatchEvent(new Event('change'));
                @:        const operatorSelect = filterEl.querySelector('.filter-operator');
                @:        if (operatorSelect) operatorSelect.value = '@filter.Operator';
                @:        operatorSelect?.dispatchEvent(new Event('change'));
                @:        const valueInput = filterEl.querySelector('.filter-value');
                @:        if (valueInput) valueInput.value = '@Html.Raw(filterValue)';
                if (filterGroupId != "null")
                {
                    @:        filterEl.dataset.groupId = '@filterGroupId';
                }
                @:    }
                @:}, @((filterIndex + 1) * 100));
                filterIndex++;
            }
        }
        
        // Load saved collection queries if editing an existing report
        const collectionQueriesJson = '@Html.Raw(Model.CollectionQueriesJson ?? "")';
        if (collectionQueriesJson) {
            try {
                const savedQueries = JSON.parse(collectionQueriesJson);                // Restore each collection query
                savedQueries.forEach(query => {
                    this.restoreCollectionQuery(query);
                });
            } catch (e) {            }
        }
    },
    
    async restoreCollectionQuery(query) {
        // Add the query UI element
        const queryId = this.collectionQueryNextId++;
        const newQuery = {
            id: queryId,
            collectionName: query.collectionName,
            operation: query.operation,
            displayAsColumn: query.displayAsColumn,
            columnName: query.columnName,
            comparator: query.comparator,
            value: query.value,
            subFilters: [],
            collectionSubFields: []
        };
        
        this.collectionQueries.push(newQuery);
        
        // Add the query card to the DOM
        const container = document.getElementById('collectionQueries');
        if (container.children.length === 1 && container.children[0].querySelector('.text-center')) {
            container.innerHTML = '';
        }
        
        // Create the query card HTML
        container.insertAdjacentHTML('beforeend', this.getCollectionQueryHtml(newQuery));
        
        // Fetch sub-fields for this collection
        await this.updateCollectionFields(queryId);
        
        // Restore sub-filters after fields are loaded
        if (query.subFilters && query.subFilters.length > 0) {
            // Wait a bit for the fields to be available
            setTimeout(() => {
                query.subFilters.forEach(subFilter => {
                    this.restoreCollectionSubFilter(queryId, subFilter);
                });
            }, 100);
        }
        
        // Set the operation (this will show/hide comparator as needed)
        document.getElementById(`operation-${queryId}`).value = query.operation;
        this.updateCollectionOperator(queryId);
        
        // Restore display as column state
        if (query.displayAsColumn) {
            document.getElementById(`display-as-column-${queryId}`).checked = true;
            document.getElementById(`column-name-${queryId}`).value = query.columnName || '';
            this.toggleDisplayMode(queryId);
        }
        
        // Restore comparator values if not display mode
        if (!query.displayAsColumn && query.comparator) {
            document.getElementById(`comparator-${queryId}`).value = query.comparator;
            document.getElementById(`value-${queryId}`).value = query.value || '';
        }
    },
    
    restoreCollectionSubFilter(queryId, subFilter) {
        const query = this.collectionQueries.find(q => q.id === queryId);
        if (!query) return;
        
        const subFilterId = Date.now() + Math.random();
        query.subFilters.push(subFilterId);
        
        const container = document.getElementById(`subfilters-${queryId}`);
        if (!container) return;
        
        // Remove placeholder if exists
        if (container.querySelector('.text-muted')) {
            container.innerHTML = '';
        }
        
        const fields = query.collectionSubFields;
        const fieldOptions = fields.map(fieldName => {
            const displayName = this.formatFieldName(fieldName);
            const selected = fieldName === subFilter.field ? 'selected' : '';
            return `<option value="${fieldName}" ${selected}>${displayName}</option>`;
        }).join('');
        
        const operatorOptions = [
            { value: 'Equals', label: 'Equals' },
            { value: 'NotEquals', label: 'Not Equals' },
            { value: 'Contains', label: 'Contains' },
            { value: 'StartsWith', label: 'Starts With' },
            { value: 'EndsWith', label: 'Ends With' },
            { value: 'GreaterThan', label: 'Greater Than' },
            { value: 'LessThan', label: 'Less Than' }
        ].map(op => {
            const selected = op.value === subFilter.operator ? 'selected' : '';
            return `<option value="${op.value}" ${selected}>${op.label}</option>`;
        }).join('');
        
        container.insertAdjacentHTML('beforeend', `
            <div class="card mb-2" id="subfilter-${queryId}-${subFilterId}">
                <div class="card-body p-2">
                    <div class="row g-2 align-items-center">
                        <div class="col-md-4">
                            <select class="form-select form-select-sm subfilter-field">
                                ${fieldOptions}
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select class="form-select form-select-sm subfilter-operator">
                                ${operatorOptions}
                            </select>
                        </div>
                        <div class="col-md-4">
                            <input type="text" class="form-control form-control-sm subfilter-value" 
                                   placeholder="Value" value="${subFilter.value || ''}">
                        </div>
                        <div class="col-md-1">
                            <button type="button" class="btn btn-sm btn-outline-danger" 
                                    onclick="ReportBuilder.removeCollectionSubFilter(${queryId}, ${subFilterId})">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        `);
    },
    
    
    setupDragDrop() {
        // Make available fields draggable
        document.querySelectorAll('.field-item').forEach(item => {
            item.addEventListener('dragstart', (e) => {
                const fieldData = {
                    fieldPath: item.dataset.fieldPath,
                    displayName: item.dataset.displayName,
                    dataType: item.dataset.dataType,
                    isCustom: item.dataset.isCustom === 'true',
                    customId: item.dataset.customId || null
                };
                e.dataTransfer.setData('application/json', JSON.stringify(fieldData));
                e.dataTransfer.setData('drag-type', 'add-field');
                e.dataTransfer.effectAllowed = 'copy';
            });
        });
        
        // Setup drop zone for adding fields
        const dropZone = document.getElementById('selectedFields');
        
        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            const dragType = e.dataTransfer.types.includes('drag-type') ? 'add-field' : 'reorder';
            e.dataTransfer.dropEffect = dragType === 'add-field' ? 'copy' : 'move';
        });
        
        dropZone.addEventListener('drop', (e) => {            // Check if this is an add-field operation (has JSON data)
            const jsonData = e.dataTransfer.getData('application/json');
            const dragType = e.dataTransfer.types.includes('drag-type') ? e.dataTransfer.getData('drag-type') : null;            // Only process if it's an add-field operation (not a reorder)
            if (jsonData && dragType === 'add-field') {                e.preventDefault();
                e.stopPropagation();
                const fieldData = JSON.parse(jsonData);
                this.addField(fieldData);
            } else {            }
        });
    },
    
    setupEventListeners() {
        document.getElementById('btnPreview').addEventListener('click', () => this.preview());
        document.getElementById('btnSave').addEventListener('click', () => this.save());
        document.getElementById('btnAddFilter').addEventListener('click', () => this.addFilter());
        document.getElementById('btnAddGroup').addEventListener('click', () => this.addFilterGroup());
        document.getElementById('btnAddCollectionQuery').addEventListener('click', () => this.addCollectionQuery());
        document.getElementById('btnLoadDefaults').addEventListener('click', () => this.loadDefaultFields());
        
        // Entity type selector - prevent changes when editing existing report
        document.getElementById('entityTypeSelector').addEventListener('change', (e) => {
            const reportId = @(Model.ReportId?.ToString() ?? "null");
            
            if (reportId) {
                // Editing existing report - warn user
                if (!confirm('Changing the entity type will clear all fields, filters, and collection queries. Are you sure?')) {
                    // Revert to original value
                    e.target.value = '@Model.EntityType';
                    return;
                }
            }
            
            // Reload page with new entity type
            if (reportId) {
                // Create new report with new entity type
                window.location.href = '?entityType=' + e.target.value;
            } else {
                // Just reload with new entity type
                window.location.href = '?entityType=' + e.target.value;
            }
        });
    },
    
    setupFieldSearch() {
        document.getElementById('fieldSearch').addEventListener('input', (e) => {
            const search = e.target.value.toLowerCase();
            document.querySelectorAll('.field-item').forEach(item => {
                const text = item.textContent.toLowerCase();
                item.style.display = text.includes(search) ? '' : 'none';
            });
        });
    },
    
    addField(field) {        if (this.selectedFields.some(f => f.fieldPath === field.fieldPath)) {
            alert('Field already added');
            return;
        }
        
        this.selectedFields.push(field);        this.renderSelectedFields();
    },
    
    removeField(fieldPath) {
        this.selectedFields = this.selectedFields.filter(f => f.fieldPath !== fieldPath);
        this.renderSelectedFields();
    },
    
    renderSelectedFields() {
        const container = document.getElementById('selectedFields');
        
        if (this.selectedFields.length === 0) {
            container.innerHTML = `
                <div class="text-center text-muted py-4">
                    <i class="bi bi-arrow-left-circle fs-1"></i>
                    <p class="mt-2">Drag fields from the left panel to add them to your report</p>
                </div>
            `;
            return;
        }
        
        container.innerHTML = this.selectedFields.map((field, index) => `
            <div class="list-group-item selected-field-item" draggable="true" data-index="${index}" data-field-path="${field.fieldPath}">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center flex-grow-1">
                        <i class="bi bi-grip-vertical text-muted me-2" style="cursor: move;"></i>
                        <div>
                            <strong>${field.displayName}</strong>
                            ${field.isCustom ? '<span class="badge bg-success ms-2">Custom</span>' : ''}
                            <br><small class="text-muted">${field.fieldPath} (${field.dataType})</small>
                        </div>
                    </div>
                    <button class="btn btn-sm btn-outline-danger" onclick="ReportBuilder.removeField('${field.fieldPath}')">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            </div>
        `).join('');
        
        // Setup reordering after rendering
        this.setupFieldReordering();
    },
    
    setupFieldReordering() {
        const items = document.querySelectorAll('.selected-field-item');
        let draggedItem = null;
        let draggedIndex = null;
        
        items.forEach(item => {
            item.addEventListener('dragstart', (e) => {
                draggedItem = item;
                draggedIndex = parseInt(item.dataset.index);
                item.classList.add('dragging');
                e.dataTransfer.effectAllowed = 'move';
                e.dataTransfer.setData('drag-type', 'reorder');
                e.dataTransfer.setData('text/plain', ''); // For compatibility
            });
            
            item.addEventListener('dragend', (e) => {
                item.classList.remove('dragging');
                draggedItem = null;
                draggedIndex = null;
            });
            
            item.addEventListener('dragover', (e) => {
                // Only handle reorder operations
                if (draggedItem && draggedItem !== item) {
                    e.preventDefault();
                    e.dataTransfer.dropEffect = 'move';
                    
                    const container = item.parentElement;
                    const mouseY = e.clientY;
                    const itemRect = item.getBoundingClientRect();
                    const itemMiddle = itemRect.top + itemRect.height / 2;
                    
                    if (mouseY < itemMiddle) {
                        container.insertBefore(draggedItem, item);
                    } else {
                        container.insertBefore(draggedItem, item.nextSibling);
                    }
                }
            });
            
            item.addEventListener('drop', (e) => {
                // Only handle if this is a reorder operation
                if (draggedItem) {
                    e.preventDefault();
                    e.stopPropagation();
                    
                    // Get current order from DOM
                    const items = document.querySelectorAll('.selected-field-item');
                    const newOrder = [];
                    items.forEach(item => {
                        const fieldPath = item.dataset.fieldPath;
                        const field = this.selectedFields.find(f => f.fieldPath === fieldPath);
                        if (field) newOrder.push(field);
                    });
                    
                    this.selectedFields = newOrder;
                }
            });
        });
    },
    
    addFilter() {
        const filterId = this.nextFilterId++;
        const container = document.getElementById('filters');
        
        if (this.selectedFields.length === 0) {
            alert('Please add fields first');
            return;
        }
        
        if (container.querySelector('.text-center')) {
            container.innerHTML = '';
        }
        
        const filterHtml = `
            <div class="list-group-item" id="filter-${filterId}">
                <div class="row g-2">
                    <div class="col-md-4">
                        <select class="form-select form-select-sm filter-field" data-filter-id="${filterId}">
                            <option value="">Select field...</option>
                            ${this.selectedFields.map(f => `<option value="${f.fieldPath}" data-type="${f.dataType}">${f.displayName}</option>`).join('')}
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select form-select-sm filter-operator" id="operator-${filterId}">
                            <option value="Equals">Equals</option>
                            <option value="Contains">Contains</option>
                            <option value="GreaterThan">Greater Than</option>
                            <option value="LessThan">Less Than</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <input type="text" class="form-control form-control-sm filter-value" id="value-${filterId}" placeholder="Value">
                    </div>
                    <div class="col-md-1">
                        <button class="btn btn-sm btn-outline-danger" onclick="ReportBuilder.removeFilter(${filterId})">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                </div>
            </div>
        `;
        
        container.insertAdjacentHTML('beforeend', filterHtml);
        
        // Add smart filter event listener (does NOT affect drag-drop)
        this.setupSmartFilter(filterId);
    },
    
    setupSmartFilter(filterId) {
        const fieldSelect = document.querySelector(`.filter-field[data-filter-id="${filterId}"]`);
        const operatorSelect = document.getElementById(`operator-${filterId}`);
        const valueInput = document.getElementById(`value-${filterId}`);
        
        if (!fieldSelect || !operatorSelect || !valueInput) return;
        
        fieldSelect.addEventListener('change', (e) => {
            const selectedOption = e.target.options[e.target.selectedIndex];
            const dataType = selectedOption.dataset.type || 'String';
            
            // Update operators based on data type
            this.updateOperators(operatorSelect, dataType);
            
            // Update input type based on data type and operator
            this.updateValueInput(valueInput, dataType, operatorSelect.value);
        });
        
        // Also listen to operator changes to update input type
        operatorSelect.addEventListener('change', (e) => {
            const selectedOption = fieldSelect.options[fieldSelect.selectedIndex];
            const dataType = selectedOption.dataset.type || 'String';
            this.updateValueInput(valueInput, dataType, e.target.value);
        });
    },
    
    updateOperators(selectElement, dataType) {
        const operatorsByType = {
            'String': [
                { value: 'Equals', label: 'Equals' },
                { value: 'NotEquals', label: 'Not Equals' },
                { value: 'Contains', label: 'Contains' },
                { value: 'NotContains', label: 'Does Not Contain' },
                { value: 'StartsWith', label: 'Starts With' },
                { value: 'EndsWith', label: 'Ends With' },
                { value: 'IsNull', label: 'Is Null' },
                { value: 'IsNotNull', label: 'Is Not Null' },
                { value: 'IsEmpty', label: 'Is Empty' },
                { value: 'IsNotEmpty', label: 'Is Not Empty' }
            ],
            'Int32': [
                { value: 'Equals', label: 'Equals' },
                { value: 'NotEquals', label: 'Not Equals' },
                { value: 'GreaterThan', label: 'Greater Than (>)' },
                { value: 'LessThan', label: 'Less Than (<)' },
                { value: 'GreaterThanOrEqual', label: 'Greater Than or Equal (=)' },
                { value: 'LessThanOrEqual', label: 'Less Than or Equal (=)' },
                { value: 'Between', label: 'Between' },
                { value: 'IsNull', label: 'Is Null' },
                { value: 'IsNotNull', label: 'Is Not Null' }
            ],
            'Decimal': [
                { value: 'Equals', label: 'Equals' },
                { value: 'NotEquals', label: 'Not Equals' },
                { value: 'GreaterThan', label: 'Greater Than (>)' },
                { value: 'LessThan', label: 'Less Than (<)' },
                { value: 'GreaterThanOrEqual', label: 'Greater Than or Equal (=)' },
                { value: 'LessThanOrEqual', label: 'Less Than or Equal (=)' },
                { value: 'Between', label: 'Between' },
                { value: 'IsNull', label: 'Is Null' },
                { value: 'IsNotNull', label: 'Is Not Null' }
            ],
            'DateTime': [
                { value: 'Equals', label: 'On Date' },
                { value: 'NotEquals', label: 'Not On Date' },
                { value: 'GreaterThan', label: 'After' },
                { value: 'LessThan', label: 'Before' },
                { value: 'GreaterThanOrEqual', label: 'On or After' },
                { value: 'LessThanOrEqual', label: 'On or Before' },
                { value: 'Between', label: 'Between Dates' },
                { value: 'IsNull', label: 'Is Null' },
                { value: 'IsNotNull', label: 'Is Not Null' },
                { value: 'InLast', label: 'In Last X Days' },
                { value: 'InNext', label: 'In Next X Days' }
            ],
            'Boolean': [
                { value: 'Equals', label: 'Is' },
                { value: 'IsNull', label: 'Is Null' },
                { value: 'IsNotNull', label: 'Is Not Null' }
            ]
        };
        
        const normalizedType = dataType.includes('Int') || dataType.includes('Number') ? 'Int32' :
                               dataType.includes('Decimal') || dataType.includes('Double') ? 'Decimal' :
                               dataType.includes('Date') ? 'DateTime' :
                               dataType.includes('Bool') ? 'Boolean' : 'String';
        
        const operators = operatorsByType[normalizedType] || operatorsByType['String'];
        
        selectElement.innerHTML = operators.map(op => 
            `<option value="${op.value}">${op.label}</option>`
        ).join('');
    },
    
    updateValueInput(inputElement, dataType, operator) {
        const parentCol = inputElement.closest('.col-md-4');
        if (!parentCol) return;
        
        // Handle special operators that need multiple inputs or different input types
        if (operator === 'Between') {
            // Create two input fields for "Between"
            const inputType = dataType.includes('Date') ? 'date' : 'number';
            parentCol.innerHTML = `
                <input type="${inputType}" class="form-control form-control-sm filter-value mb-1" 
                       placeholder="From" style="width: 100%;">
                <input type="${inputType}" class="form-control form-control-sm filter-value-end" 
                       placeholder="To" style="width: 100%;">
            `;
            return;
        }
        
        if (operator === 'InLast' || operator === 'InNext') {
            // Create number input for days
            parentCol.innerHTML = `
                <input type="number" class="form-control form-control-sm filter-value" 
                       placeholder="Number of days" min="1" style="width: 100%;">
            `;
            return;
        }
        
        if (operator === 'IsNull' || operator === 'IsNotNull' || operator === 'IsEmpty' || operator === 'IsNotEmpty') {
            // No input needed for these operators
            parentCol.innerHTML = `
                <input type="text" class="form-control form-control-sm filter-value" 
                       placeholder="(no value needed)" disabled style="width: 100%;">
            `;
            return;
        }
        
        // Standard single input
        const normalizedType = dataType.includes('Date') ? 'date' :
                               dataType.includes('Int') || dataType.includes('Number') ? 'number' :
                               dataType.includes('Bool') ? 'checkbox' : 'text';
        
        if (normalizedType === 'checkbox') {
            parentCol.innerHTML = `
                <div class="form-check mt-2">
                    <input type="checkbox" class="form-check-input filter-value" id="value-${inputElement.id}">
                    <label class="form-check-label" for="value-${inputElement.id}">True</label>
                </div>
            `;
        } else if (normalizedType === 'date') {
            parentCol.innerHTML = `
                <input type="date" class="form-control form-control-sm filter-value" 
                       placeholder="Select date" style="width: 100%;">
            `;
        } else if (normalizedType === 'number') {
            parentCol.innerHTML = `
                <input type="number" class="form-control form-control-sm filter-value" 
                       placeholder="Enter number" step="any" style="width: 100%;">
            `;
        } else {
            parentCol.innerHTML = `
                <input type="text" class="form-control form-control-sm filter-value" 
                       placeholder="Enter value" style="width: 100%;">
            `;
        }
    },
    
    removeFilter(filterId) {
        document.getElementById(`filter-${filterId}`)?.remove();
        const container = document.getElementById('filters');
        if (container.children.length === 0) {
            container.innerHTML = `
                <div class="text-center text-muted py-4">
                    <i class="bi bi-funnel fs-1"></i>
                    <p class="mt-2">No filters added yet</p>
                </div>
            `;
        }
    },
    
    addFilterGroup() {
        const groupId = this.nextGroupId++;
        const groupHtml = `
            <div class="filter-group mb-3 p-3 border border-primary rounded" id="group-${groupId}" data-group-id="${groupId}">
