@page "{id:int}"
@using Sentinel.Models
@model Sentinel.Pages.Outbreaks.CaseDefinitionsModel
@{
    ViewData["Title"] = "Case Definitions - " + Model.Outbreak.Name;
    
    // Pre-calculate history lists to avoid nested code blocks
    var confirmedHistory = Model.Definitions.Where(d => d.Classification == CaseClassification.Confirmed && !d.IsActive).ToList();
    var probableHistory = Model.Definitions.Where(d => d.Classification == CaseClassification.Probable && !d.IsActive).ToList();
    var suspectHistory = Model.Definitions.Where(d => d.Classification == CaseClassification.Suspect && !d.IsActive).ToList();
    var notacaseHistory = Model.Definitions.Where(d => d.Classification == CaseClassification.NotACase && !d.IsActive).ToList();
}
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="Index">Outbreaks</a></li>
        <li class="breadcrumb-item"><a asp-page="Details" asp-route-id="@Model.Outbreak.Id">@Model.Outbreak.Name</a></li>
        <li class="breadcrumb-item active" aria-current="page">Case Definitions</li>
    </ol>
</nav>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="mb-4">
    <h2><i class="bi bi-clipboard2-check me-2"></i>Case Definitions</h2>
    <p class="text-muted">Define criteria for classifying cases in <strong>@Model.Outbreak.Name</strong></p>
</div>

<!-- Active Definitions Overview -->
<div class="row g-3 mb-4">
    <!-- Confirmed -->
    <div class="col-lg-6">
        <div class="card border-danger h-100">
            <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-check-circle-fill me-2"></i>Confirmed Case</h6>
                <button type="button" class="btn btn-sm btn-light" onclick="openDefinitionModal(@((int)CaseClassification.Confirmed), null)">
                    <i class="bi bi-plus"></i> Create
                </button>
            </div>
            <div class="card-body">
                @if (Model.ConfirmedDefinition != null)
                {
                    <h6>@Model.ConfirmedDefinition.DefinitionName <small class="text-muted">(v@Model.ConfirmedDefinition.Version)</small></h6>
                    @if (!string.IsNullOrEmpty(Model.ConfirmedDefinition.DefinitionText))
                    {
                        <p class="mb-0">@Model.ConfirmedDefinition.DefinitionText</p>
                    }
                    <div class="mt-3">
                        <button type="button" class="btn btn-sm btn-outline-primary" 
                                onclick="openDefinitionModal(@((int)CaseClassification.Confirmed), @Model.ConfirmedDefinition.Id)">
                            <i class="bi bi-pencil"></i> Edit
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#confirmedHistory">
                            <i class="bi bi-clock-history"></i> History
                        </button>
                    </div>
                    
                    @if (confirmedHistory.Any())
                    {
                        <div class="collapse mt-3" id="confirmedHistory">
                            <h6 class="text-muted">Previous Versions</h6>
                            <ul class="list-group list-group-sm">
                                @foreach (var def in confirmedHistory)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <small><strong>v@def.Version:</strong> @def.DefinitionName</small>
                                            <br>
                                            <small class="text-muted">Effective: @def.EffectiveDate.ToString("MMM d, yyyy")</small>
                                        </div>
                                        <form method="post" asp-page-handler="ActivateDefinition" asp-route-id="@Model.Outbreak.Id" asp-route-definitionId="@def.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Reactivate">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>
                                        </form>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted mb-0">No confirmed case definition set.</p>
                    <button type="button" class="btn btn-sm btn-danger mt-2" onclick="openDefinitionModal(@((int)CaseClassification.Confirmed), null)">
                        <i class="bi bi-plus-circle"></i> Create Definition
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- Probable -->
    <div class="col-lg-6">
        <div class="card border-warning h-100">
            <div class="card-header bg-warning d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-exclamation-circle-fill me-2"></i>Probable Case</h6>
                <button type="button" class="btn btn-sm btn-light" onclick="openDefinitionModal(@((int)CaseClassification.Probable), null)">
                    <i class="bi bi-plus"></i> Create
                </button>
            </div>
            <div class="card-body">
                @if (Model.ProbableDefinition != null)
                {
                    <h6>@Model.ProbableDefinition.DefinitionName <small class="text-muted">(v@Model.ProbableDefinition.Version)</small></h6>
                    @if (!string.IsNullOrEmpty(Model.ProbableDefinition.DefinitionText))
                    {
                        <p class="mb-0">@Model.ProbableDefinition.DefinitionText</p>
                    }
                    <div class="mt-3">
                        <button type="button" class="btn btn-sm btn-outline-primary" 
                                onclick="openDefinitionModal(@((int)CaseClassification.Probable), @Model.ProbableDefinition.Id)">
                            <i class="bi bi-pencil"></i> Edit
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#probableHistory">
                            <i class="bi bi-clock-history"></i> History
                        </button>
                    </div>
                    
                    @if (probableHistory.Any())
                    {
                        <div class="collapse mt-3" id="probableHistory">
                            <h6 class="text-muted">Previous Versions</h6>
                            <ul class="list-group list-group-sm">
                                @foreach (var def in probableHistory)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <small><strong>v@def.Version:</strong> @def.DefinitionName</small>
                                            <br>
                                            <small class="text-muted">Effective: @def.EffectiveDate.ToString("MMM d, yyyy")</small>
                                        </div>
                                        <form method="post" asp-page-handler="ActivateDefinition" asp-route-id="@Model.Outbreak.Id" asp-route-definitionId="@def.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Reactivate">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>
                                        </form>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted mb-0">No probable case definition set.</p>
                    <button type="button" class="btn btn-sm btn-warning mt-2" onclick="openDefinitionModal(@((int)CaseClassification.Probable), null)">
                        <i class="bi bi-plus-circle"></i> Create Definition
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- Suspect -->
    <div class="col-lg-6">
        <div class="card border-secondary h-100">
            <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-question-circle-fill me-2"></i>Suspect Case</h6>
                <button type="button" class="btn btn-sm btn-light" onclick="openDefinitionModal(@((int)CaseClassification.Suspect), null)">
                    <i class="bi bi-plus"></i> Create
                </button>
            </div>
            <div class="card-body">
                @if (Model.SuspectDefinition != null)
                {
                    <h6>@Model.SuspectDefinition.DefinitionName <small class="text-muted">(v@Model.SuspectDefinition.Version)</small></h6>
                    @if (!string.IsNullOrEmpty(Model.SuspectDefinition.DefinitionText))
                    {
                        <p class="mb-0">@Model.SuspectDefinition.DefinitionText</p>
                    }
                    <div class="mt-3">
                        <button type="button" class="btn btn-sm btn-outline-primary" 
                                onclick="openDefinitionModal(@((int)CaseClassification.Suspect), @Model.SuspectDefinition.Id)">
                            <i class="bi bi-pencil"></i> Edit
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#suspectHistory">
                            <i class="bi bi-clock-history"></i> History
                        </button>
                    </div>
                    
                    @if (suspectHistory.Any())
                    {
                        <div class="collapse mt-3" id="suspectHistory">
                            <h6 class="text-muted">Previous Versions</h6>
                            <ul class="list-group list-group-sm">
                                @foreach (var def in suspectHistory)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <small><strong>v@def.Version:</strong> @def.DefinitionName</small>
                                            <br>
                                            <small class="text-muted">Effective: @def.EffectiveDate.ToString("MMM d, yyyy")</small>
                                        </div>
                                        <form method="post" asp-page-handler="ActivateDefinition" asp-route-id="@Model.Outbreak.Id" asp-route-definitionId="@def.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Reactivate">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>
                                        </form>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted mb-0">No suspect case definition set.</p>
                    <button type="button" class="btn btn-sm btn-secondary mt-2" onclick="openDefinitionModal(@((int)CaseClassification.Suspect), null)">
                        <i class="bi bi-plus-circle"></i> Create Definition
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- Not a Case -->
    <div class="col-lg-6">
        <div class="card border-light h-100">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-x-circle-fill me-2"></i>Not a Case</h6>
                <button type="button" class="btn btn-sm btn-secondary" onclick="openDefinitionModal(@((int)CaseClassification.NotACase), null)">
                    <i class="bi bi-plus"></i> Create
                </button>
            </div>
            <div class="card-body">
                @if (Model.NotACaseDefinition != null)
                {
                    <h6>@Model.NotACaseDefinition.DefinitionName <small class="text-muted">(v@Model.NotACaseDefinition.Version)</small></h6>
                    @if (!string.IsNullOrEmpty(Model.NotACaseDefinition.DefinitionText))
                    {
                        <p class="mb-0">@Model.NotACaseDefinition.DefinitionText</p>
                    }
                    <div class="mt-3">
                        <button type="button" class="btn btn-sm btn-outline-primary" 
                                onclick="openDefinitionModal(@((int)CaseClassification.NotACase), @Model.NotACaseDefinition.Id)">
                            <i class="bi bi-pencil"></i> Edit
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#notacaseHistory">
                            <i class="bi bi-clock-history"></i> History
                        </button>
                    </div>
                    
                    @if (notacaseHistory.Any())
                    {
                        <div class="collapse mt-3" id="notacaseHistory">
                            <h6 class="text-muted">Previous Versions</h6>
                            <ul class="list-group list-group-sm">
                                @foreach (var def in notacaseHistory)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <small><strong>v@def.Version:</strong> @def.DefinitionName</small>
                                            <br>
                                            <small class="text-muted">Effective: @def.EffectiveDate.ToString("MMM d, yyyy")</small>
                                        </div>
                                        <form method="post" asp-page-handler="ActivateDefinition" asp-route-id="@Model.Outbreak.Id" asp-route-definitionId="@def.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Reactivate">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>
                                        </form>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted mb-0">No exclusion criteria defined.</p>
                    <button type="button" class="btn btn-sm btn-secondary mt-2" onclick="openDefinitionModal(@((int)CaseClassification.NotACase), null)">
                        <i class="bi bi-plus-circle"></i> Create Definition
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-page="Details" asp-route-id="@Model.Outbreak.Id" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Outbreak
    </a>
</div>

<!-- Case Definition Modal -->
<div class="modal fade" id="definitionModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" asp-page-handler="SaveDefinition" asp-route-id="@Model.Outbreak.Id" id="definitionForm">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Case Definition</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="EditingDefinitionId" id="editingDefinitionId">
                    <input type="hidden" name="Definition.Classification" id="definitionClassification">
                    
                    <div class="mb-3">
                        <label class="form-label">Definition Name <span class="text-danger">*</span></label>
                        <input type="text" name="Definition.DefinitionName" class="form-control" id="definitionName" required 
                               placeholder="e.g., Gastroenteritis Outbreak Definition">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Definition Text</label>
                        <textarea name="Definition.DefinitionText" class="form-control" id="definitionText" rows="5" 
                                  placeholder="Describe the criteria for this classification..."></textarea>
                        <small class="text-muted">Provide a clear description of what constitutes this classification.</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Specific Criteria (Optional)</label>
                        <div id="criteriaBuilder" class="border rounded p-3 bg-light">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="mb-0">Criteria Rules</h6>
                                <button type="button" class="btn btn-sm btn-success" onclick="openAddCriterionModal()">
                                    <i class="bi bi-plus-circle"></i> Add Criterion
                                </button>
                            </div>
                            <div id="criteriaList" class="mb-2">
                                <p class="text-muted mb-0"><em>No criteria defined yet. Click "Add Criterion" to start.</em></p>
                            </div>
                        </div>
                        <textarea name="Definition.CriteriaJson" class="form-control d-none" id="criteriaJson" rows="4"></textarea>
                        <small class="text-muted">Define specific measurable criteria for classification (optional).</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Notes</label>
                        <textarea name="Definition.Notes" class="form-control" id="definitionNotes" rows="2" 
                                  placeholder="Additional notes or references..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i>Save Definition
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Criterion Modal -->
<div class="modal fade" id="addCriterionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Criterion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Custom Field <span class="text-danger">*</span></label>
                    <select class="form-select" id="criterionCustomField" required>
                        <option value="">-- Select a custom field --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Operator <span class="text-danger">*</span></label>
                    <select class="form-select" id="criterionOperator" required>
                        <option value="1">Equals</option>
                        <option value="2">Not Equals</option>
                        <option value="3">Contains</option>
                        <option value="4">Does Not Contain</option>
                        <option value="5">Greater Than</option>
                        <option value="6">Less Than</option>
                        <option value="7">Between</option>
                        <option value="8">In List</option>
                        <option value="9">Is Present</option>
                        <option value="10">Is Absent</option>
                    </select>
                </div>

                <div id="criterionInputContainer" class="mb-3">
                    <label class="form-label">Value <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="criterionInput" placeholder="Enter value..." required>
                </div>

                <div class="mb-3">
                    <label class="form-label">Logic Operator</label>
                    <select class="form-select" id="criterionLogicOperator">
                        <option value="AND">AND</option>
                        <option value="OR">OR</option>
                    </select>
                    <small class="text-muted">How this criterion combines with others</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="addCriterion()">
                    <i class="bi bi-plus-circle"></i> Add Criterion
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script nonce="@GetCspNonce()">
        // Serialize only the needed properties to avoid circular reference
        const definitions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.Definitions.Select(d => new {
                d.Id,
                d.Classification,
                d.DefinitionName,
                d.DefinitionText,
                d.CriteriaJson,
                d.Notes,
                d.Version
            })
        ));

        let currentCriteria = [];
        let customFieldsCache = [];

        // Load custom fields on page load
        document.addEventListener('DOMContentLoaded', async function() {
            await loadCustomFields();
        });

        async function loadCustomFields() {
            try {
                const response = await fetch('/api/CustomFields/ForCaseDefinitions');
                if (!response.ok) throw new Error('Failed to load custom fields');
                customFieldsCache = await response.json();
            } catch (error) {
                console.error('Error loading custom fields:', error);
            }
        }

        function openDefinitionModal(classification, definitionId) {
            const modal = new bootstrap.Modal(document.getElementById('definitionModal'));
            const classificationNames = {
                1: 'Confirmed',
                2: 'Probable',
                3: 'Suspect',
                4: 'Not a Case'
            };

            const form = document.getElementById('definitionForm');
            form.reset();
            currentCriteria = [];

            document.getElementById('modalTitle').textContent = 
                (definitionId ? 'Edit ' : 'Create ') + classificationNames[classification] + ' Case Definition';
            document.getElementById('definitionClassification').value = classification;
            document.getElementById('editingDefinitionId').value = definitionId || '';

            // Load existing definition data if editing
            if (definitionId) {
                const definition = definitions.find(d => d.Id === definitionId);
                if (definition) {
                    document.getElementById('definitionName').value = definition.DefinitionName || '';
                    document.getElementById('definitionText').value = definition.DefinitionText || '';
                    document.getElementById('definitionNotes').value = definition.Notes || '';

                    // Parse existing criteria
                    if (definition.CriteriaJson && definition.CriteriaJson !== '{}') {
                        try {
                            const parsedCriteria = JSON.parse(definition.CriteriaJson);
                            if (parsedCriteria.criteria && Array.isArray(parsedCriteria.criteria)) {
                                currentCriteria = parsedCriteria.criteria;
                                updateCriteriaDisplay();
                            }
                        } catch (e) {
                            console.error('Error parsing criteria JSON:', e);
                        }
                    }
                }
            }

            updateCriteriaDisplay();
            modal.show();
        }

        async function openAddCriterionModal() {
            const modal = new bootstrap.Modal(document.getElementById('addCriterionModal'));

            // Populate custom fields dropdown
            const select = document.getElementById('criterionCustomField');
            select.innerHTML = '<option value="">-- Select a custom field --</option>';

            customFieldsCache.forEach(field => {
                const option = document.createElement('option');
                option.value = field.id;
                option.textContent = `${field.label} (${field.fieldType})`;
                option.dataset.fieldType = field.fieldType;
                option.dataset.hasLookup = field.hasLookupTable;
                select.appendChild(option);
            });

            // Reset form
            document.getElementById('criterionCustomField').value = '';
            document.getElementById('criterionOperator').value = '1';
            document.getElementById('criterionInput').value = '';
            document.getElementById('criterionLogicOperator').value = 'AND';

            modal.show();
        }

        // Handle custom field selection change
        document.getElementById('criterionCustomField')?.addEventListener('change', async function() {
            const customFieldId = this.value;
            if (!customFieldId) return;

            const selectedOption = this.options[this.selectedIndex];
            const fieldType = selectedOption.dataset.fieldType;
            const hasLookup = selectedOption.dataset.hasLookup === 'true';

            if (hasLookup) {
                await loadCustomFieldWithLookup(customFieldId);
            } else {
                showRegularInput(fieldType);
            }

            updateOperatorOptions(fieldType, hasLookup);
        });

        async function loadCustomFieldWithLookup(customFieldId) {
            try {
                const response = await fetch(`/api/CustomFields/${customFieldId}`);
                if (!response.ok) throw new Error('Failed to load custom field details');

                const customField = await response.json();
                const inputContainer = document.getElementById('criterionInputContainer');

                if (customField.hasLookupTable && customField.lookupValues) {
                    inputContainer.innerHTML = `
                        <label class="form-label">Select Value <span class="text-danger">*</span></label>
                        <select class="form-select" id="criterionInput" required>
                            <option value="">-- Select ${customField.label} --</option>
                            ${customField.lookupValues.map(v => `
                                <option value="${v.id}">${v.displayText}</option>
                            `).join('')}
                        </select>
                    `;
                } else {
                    showRegularInput(customField.fieldType);
                }
            } catch (error) {
                console.error('Error loading custom field:', error);
                alert('Failed to load custom field details');
            }
        }

        function showRegularInput(fieldType) {
            const inputContainer = document.getElementById('criterionInputContainer');
            let inputHtml = '';

            switch (fieldType) {
                case 'Number':
                    inputHtml = `
                        <label class="form-label">Value <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" id="criterionInput" placeholder="Enter number..." required>
                    `;
                    break;
                case 'Date':
                    inputHtml = `
                        <label class="form-label">Date <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" id="criterionInput" required>
                    `;
                    break;
                case 'Boolean':
                    inputHtml = `
                        <label class="form-label">Value <span class="text-danger">*</span></label>
                        <select class="form-select" id="criterionInput" required>
                            <option value="">-- Select --</option>
                            <option value="true">Yes</option>
                            <option value="false">No</option>
                        </select>
                    `;
                    break;
                default: // Text
                    inputHtml = `
                        <label class="form-label">Value <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="criterionInput" placeholder="Enter value..." required>
                    `;
                    break;
            }

            inputContainer.innerHTML = inputHtml;
        }

        function updateOperatorOptions(fieldType, hasLookup) {
            const operatorSelect = document.getElementById('criterionOperator');

            if (hasLookup) {
                operatorSelect.innerHTML = `
                    <option value="1">Equals</option>
                    <option value="2">Not Equals</option>
                    <option value="8">In List</option>
                    <option value="9">Is Present</option>
                    <option value="10">Is Absent</option>
                `;
            } else if (fieldType === 'Number' || fieldType === 'Date') {
                operatorSelect.innerHTML = `
                    <option value="1">Equals</option>
                    <option value="2">Not Equals</option>
                    <option value="5">Greater Than</option>
                    <option value="6">Less Than</option>
                    <option value="7">Between</option>
                    <option value="9">Is Present</option>
                    <option value="10">Is Absent</option>
                `;
            } else if (fieldType === 'Boolean') {
                operatorSelect.innerHTML = `
                    <option value="1">Equals</option>
                    <option value="2">Not Equals</option>
                    <option value="9">Is Present</option>
                    <option value="10">Is Absent</option>
                `;
            } else {
                operatorSelect.innerHTML = `
                    <option value="1">Equals</option>
                    <option value="2">Not Equals</option>
                    <option value="3">Contains</option>
                    <option value="4">Does Not Contain</option>
                    <option value="9">Is Present</option>
                    <option value="10">Is Absent</option>
                `;
            }
        }

        function addCriterion() {
            const customFieldId = document.getElementById('criterionCustomField').value;
            const operator = parseInt(document.getElementById('criterionOperator').value);
            const input = document.getElementById('criterionInput').value;
            const logicOperator = document.getElementById('criterionLogicOperator').value;

            if (!customFieldId) {
                alert('Please select a custom field');
                return;
            }

            if (!operator) {
                alert('Please select an operator');
                return;
            }

            // Input not required for "Is Present" or "Is Absent" operators
            if (operator !== 9 && operator !== 10 && !input) {
                alert('Please provide a value');
                return;
            }

            const selectedField = customFieldsCache.find(f => f.id == customFieldId);
            if (!selectedField) {
                alert('Invalid custom field selected');
                return;
            }

            const criterion = {
                type: 'CustomField',
                customFieldId: parseInt(customFieldId),
                customFieldLabel: selectedField.label,
                operator: operator,
                operatorText: getOperatorText(operator),
                input: input || '',
                logicOperator: currentCriteria.length === 0 ? null : logicOperator
            };

            currentCriteria.push(criterion);
            updateCriteriaDisplay();

            // Close modal
            bootstrap.Modal.getInstance(document.getElementById('addCriterionModal')).hide();
        }

        function getOperatorText(operator) {
            const operators = {
                1: 'Equals',
                2: 'Not Equals',
                3: 'Contains',
                4: 'Does Not Contain',
                5: 'Greater Than',
                6: 'Less Than',
                7: 'Between',
                8: 'In List',
                9: 'Is Present',
                10: 'Is Absent'
            };
            return operators[operator] || 'Unknown';
        }

        function updateCriteriaDisplay() {
            const criteriaList = document.getElementById('criteriaList');

            if (currentCriteria.length === 0) {
                criteriaList.innerHTML = '<p class="text-muted mb-0"><em>No criteria defined yet. Click "Add Criterion" to start.</em></p>';
            } else {
                criteriaList.innerHTML = currentCriteria.map((criterion, index) => `
                    <div class="card mb-2">
                        <div class="card-body py-2">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    ${criterion.logicOperator ? `<span class="badge bg-secondary me-2">${criterion.logicOperator}</span>` : ''}
                                    <strong>${criterion.customFieldLabel}</strong>
                                    <span class="text-muted">${criterion.operatorText}</span>
                                    ${criterion.input ? `<strong>${criterion.input}</strong>` : ''}
                                </div>
                                <button type="button" class="btn btn-sm btn-danger" onclick="removeCriterion(${index})">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                `).join('');
            }

            // Update hidden JSON field
            const criteriaJson = currentCriteria.length > 0 ? JSON.stringify({ criteria: currentCriteria }) : '{}';
            document.getElementById('criteriaJson').value = criteriaJson;
        }

        function removeCriterion(index) {
            currentCriteria.splice(index, 1);
            // Update logic operators - first criterion should have null
            if (currentCriteria.length > 0) {
                currentCriteria[0].logicOperator = null;
            }
            updateCriteriaDisplay();
        }
    </script>
}


