@page
@using Sentinel.Models
@model Sentinel.Pages.Outbreaks.ClassifyCasesModel
@{
    ViewData["Title"] = "Classify Cases - " + Model.Outbreak.Name;
}
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="Index">Outbreaks</a></li>
        <li class="breadcrumb-item"><a asp-page="Details" asp-route-id="@Model.Outbreak.Id">@Model.Outbreak.Name</a></li>
        <li class="breadcrumb-item active" aria-current="page">Classify Cases</li>
    </ol>
</nav>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="mb-4">
    <h2><i class="bi bi-clipboard-check me-2"></i>Classify Outbreak Cases</h2>
    <p class="text-muted">Review and classify cases based on the outbreak case definition</p>
</div>

<div class="row">
    <div class="col-lg-9">
        @if (Model.ActiveDefinition != null)
        {
            <div class="alert alert-info mb-4">
                <div class="d-flex align-items-start">
                    <i class="bi bi-info-circle fs-4 me-3"></i>
                    <div>
                        <h6 class="mb-1">Active Case Definition (Version @Model.ActiveDefinition.Version)</h6>
                        <p class="mb-2">@Model.ActiveDefinition.DefinitionName</p>
                        @if (!string.IsNullOrEmpty(Model.ActiveDefinition.DefinitionText))
                        {
                            <div class="small">
                                <strong>Definition:</strong>
                                <div>@Html.Raw(Model.ActiveDefinition.DefinitionText.Replace("\n", "<br>"))</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-warning mb-4">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>No Active Case Definition</strong> - Create a case definition to guide classification.
            </div>
        }

        <!-- Unclassified Cases -->
        @if (Model.UnclassifiedCases.Any())
        {
            <div class="card border-warning mb-4">
                <div class="card-header bg-warning bg-opacity-10">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-question-circle text-warning me-2"></i>
                            Unclassified Cases (@Model.UnclassifiedCases.Count)
                        </h5>
                        <div class="btn-group btn-group-sm">
                            <button type="button" class="btn btn-outline-warning" onclick="selectAllUnclassified()">
                                <i class="bi bi-check-all"></i> Select All
                            </button>
                            <button type="button" class="btn btn-warning" id="bulkClassifyBtn" disabled data-bs-toggle="modal" data-bs-target="#bulkClassifyModal">
                                <i class="bi bi-lightning"></i> Bulk Classify
                            </button>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th width="40"><input type="checkbox" id="selectAllCheckbox" onchange="toggleAllUnclassified(this)"></th>
                                    <th>Case ID</th>
                                    <th>Patient</th>
                                    <th>Disease</th>
                                    <th>Onset Date</th>
                                    <th>Linked</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var oc in Model.UnclassifiedCases)
                                {
                                    <tr>
                                        <td><input type="checkbox" class="unclassified-checkbox" value="@oc.Id" onchange="updateBulkButton()"></td>
                                        <td>
                                            <a asp-page="/Cases/Details" asp-route-id="@oc.Case.Id" target="_blank">
                                                @oc.Case.FriendlyId
                                                <i class="bi bi-box-arrow-up-right small"></i>
                                            </a>
                                        </td>
                                        <td>
                                            @if (oc.Case.Patient != null)
                                            {
                                                <div>@oc.Case.Patient.GivenName @oc.Case.Patient.FamilyName</div>
                                            }
                                        </td>
                                        <td>@oc.Case.Disease?.Name</td>
                                        <td>
                                            @if (oc.Case.DateOfOnset.HasValue)
                                            {
                                                @oc.Case.DateOfOnset.Value.ToString("MMM d, yyyy")
                                            }
                                        </td>
                                        <td>
                                            <small class="text-muted">@oc.LinkedDate.ToString("MMM d")</small>
                                        </td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-primary" 
                                                    onclick="showClassifyModal(@oc.Id, '@oc.Case.Patient?.GivenName @oc.Case.Patient?.FamilyName', '@oc.Case.FriendlyId')">
                                                <i class="bi bi-clipboard-check"></i> Classify
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle me-2"></i>All cases have been classified!
            </div>
        }

        <!-- Classified Cases -->
        @if (Model.ClassifiedCases.Any())
        {
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="bi bi-check-circle-fill text-success me-2"></i>
                        Classified Cases (@Model.ClassifiedCases.Count)
                    </h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Case ID</th>
                                    <th>Patient</th>
                                    <th>Classification</th>
                                    <th>Disease</th>
                                    <th>Onset Date</th>
                                    <th>Classified</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var oc in Model.ClassifiedCases)
                                {
                                    <tr>
                                        <td>
                                            <a asp-page="/Cases/Details" asp-route-id="@oc.Case.Id" target="_blank">
                                                @oc.Case.FriendlyId
                                                <i class="bi bi-box-arrow-up-right small"></i>
                                            </a>
                                        </td>
                                        <td>
                                            @if (oc.Case.Patient != null)
                                            {
                                                <div>@oc.Case.Patient.GivenName @oc.Case.Patient.FamilyName</div>
                                            }
                                        </td>
                                        <td>
                                            @if (oc.Classification.HasValue)
                                            {
                                                switch (oc.Classification.Value)
                                                {
                                                    case CaseClassification.Confirmed:
                                                        <span class="badge bg-danger">Confirmed</span>
                                                        break;
                                                    case CaseClassification.Probable:
                                                        <span class="badge bg-warning text-dark">Probable</span>
                                                        break;
                                                    case CaseClassification.Suspect:
                                                        <span class="badge bg-secondary">Suspect</span>
                                                        break;
                                                    case CaseClassification.NotACase:
                                                        <span class="badge bg-light text-dark">Not a Case</span>
                                                        break;
                                                }
                                            }
                                        </td>
                                        <td>@oc.Case.Disease?.Name</td>
                                        <td>
                                            @if (oc.Case.DateOfOnset.HasValue)
                                            {
                                                @oc.Case.DateOfOnset.Value.ToString("MMM d, yyyy")
                                            }
                                        </td>
                                        <td>
                                            <small class="text-muted">
                                                @if (oc.ClassificationDate.HasValue)
                                                {
                                                    @oc.ClassificationDate.Value.ToString("MMM d, yyyy")
                                                }
                                            </small>
                                        </td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-outline-primary" 
                                                    onclick="showClassifyModal(@oc.Id, '@oc.Case.Patient?.GivenName @oc.Case.Patient?.FamilyName', '@oc.Case.FriendlyId')">
                                                <i class="bi bi-pencil"></i> Reclassify
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="col-lg-3">
        <div class="card bg-light mb-3">
            <div class="card-body">
                <h6 class="card-title"><i class="bi bi-info-circle me-2"></i>Classification Guide</h6>
                <div class="small">
                    <p class="mb-2"><span class="badge bg-danger">Confirmed</span></p>
                    <p class="small mb-3">Meets laboratory confirmation criteria</p>
                    
                    <p class="mb-2"><span class="badge bg-warning text-dark">Probable</span></p>
                    <p class="small mb-3">Meets clinical criteria, lacks lab confirmation</p>
                    
                    <p class="mb-2"><span class="badge bg-secondary">Suspect</span></p>
                    <p class="small mb-3">Under investigation, awaiting information</p>
                    
                    <p class="mb-2"><span class="badge bg-light text-dark border">Not a Case</span></p>
                    <p class="small mb-0">Does not meet case definition</p>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h6 class="card-title">Summary</h6>
                <div class="d-flex justify-content-between mb-2">
                    <span>Unclassified:</span>
                    <strong class="text-warning">@Model.UnclassifiedCases.Count</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Confirmed:</span>
                    <strong class="text-danger">@Model.ClassifiedCases.Count(c => c.Classification == CaseClassification.Confirmed)</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Probable:</span>
                    <strong class="text-warning">@Model.ClassifiedCases.Count(c => c.Classification == CaseClassification.Probable)</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Suspect:</span>
                    <strong>@Model.ClassifiedCases.Count(c => c.Classification == CaseClassification.Suspect)</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span>Not a Case:</span>
                    <strong>@Model.ClassifiedCases.Count(c => c.Classification == CaseClassification.NotACase)</strong>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <a asp-page="Details" asp-route-id="@Model.Outbreak.Id" class="btn btn-secondary w-100">
                <i class="bi bi-arrow-left me-1"></i>Back to Outbreak
            </a>
        </div>
    </div>
</div>

<!-- Classify Single Case Modal -->
<div class="modal fade" id="classifyModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Classify" asp-route-id="@Model.Outbreak.Id">
                <div class="modal-header">
                    <h5 class="modal-title">Classify Case</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="outbreakCaseId" id="classifyOutbreakCaseId">
                    
                    <div class="mb-3">
                        <strong>Case:</strong> <span id="classifyCaseId"></span><br>
                        <strong>Patient:</strong> <span id="classifyPatientName"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Classification <span class="text-danger">*</span></label>
                        <select name="classification" class="form-select" required>
                            <option value="">-- Select Classification --</option>
                            <option value="@CaseClassification.Confirmed">Confirmed</option>
                            <option value="@CaseClassification.Probable">Probable</option>
                            <option value="@CaseClassification.Suspect">Suspect</option>
                            <option value="@CaseClassification.NotACase">Not a Case</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Notes</label>
                        <textarea name="notes" class="form-control" rows="3" placeholder="Reason for classification..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Classify
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Bulk Classify Modal -->
<div class="modal fade" id="bulkClassifyModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="BulkClassify" asp-route-id="@Model.Outbreak.Id" id="bulkClassifyForm">
                <div class="modal-header">
                    <h5 class="modal-title">Bulk Classify Cases</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Classify <strong><span id="bulkSelectedCount">0</span> selected cases</strong> as:</p>

                    <div class="mb-3">
                        <label class="form-label">Classification <span class="text-danger">*</span></label>
                        <select name="classification" class="form-select" required>
                            <option value="">-- Select Classification --</option>
                            <option value="@CaseClassification.Confirmed">Confirmed</option>
                            <option value="@CaseClassification.Probable">Probable</option>
                            <option value="@CaseClassification.Suspect">Suspect</option>
                            <option value="@CaseClassification.NotACase">Not a Case</option>
                        </select>
                    </div>

                    <div class="alert alert-warning small">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        This will apply the same classification to all selected cases.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-lightning-fill me-1"></i>Bulk Classify
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showClassifyModal(outbreakCaseId, patientName, caseId) {
            document.getElementById('classifyOutbreakCaseId').value = outbreakCaseId;
            document.getElementById('classifyPatientName').textContent = patientName;
            document.getElementById('classifyCaseId').textContent = caseId;
            new bootstrap.Modal(document.getElementById('classifyModal')).show();
        }

        function toggleAllUnclassified(checkbox) {
            document.querySelectorAll('.unclassified-checkbox').forEach(cb => {
                cb.checked = checkbox.checked;
            });
            updateBulkButton();
        }

        function selectAllUnclassified() {
            document.querySelectorAll('.unclassified-checkbox').forEach(cb => {
                cb.checked = true;
            });
            document.getElementById('selectAllCheckbox').checked = true;
            updateBulkButton();
        }

        function updateBulkButton() {
            const selected = document.querySelectorAll('.unclassified-checkbox:checked');
            const bulkBtn = document.getElementById('bulkClassifyBtn');
            const count = selected.length;
            
            bulkBtn.disabled = count === 0;
            document.getElementById('bulkSelectedCount').textContent = count;
            
            // Clear previous hidden inputs
            const form = document.getElementById('bulkClassifyForm');
            form.querySelectorAll('input[name="selectedCaseIds"]').forEach(input => input.remove());
            
            // Add new hidden inputs for selected IDs
            selected.forEach(checkbox => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'selectedCaseIds';
                input.value = checkbox.value;
                form.appendChild(input);
            });
        }
    </script>
}
