                        <h6 class="text-muted mb-1">Duration</h6>
                        <h2 class="mb-0">@Model.Statistics.DaysSinceStart</h2>
                        <small class="text-muted">Days since start</small>
                    </div>
                    <div class="bg-secondary bg-opacity-10 p-3 rounded">
                        <i class="bi bi-calendar3 fs-3 text-secondary"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Outbreak Context -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="bi bi-info-circle me-2"></i>Outbreak Context</h6>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <strong>Disease:</strong><br>
                    @if (Model.Outbreak.PrimaryDisease != null)
                    {
                        <span class="badge bg-warning text-dark">@Model.Outbreak.PrimaryDisease.Name</span>
                    }
                    else
                    {
                        <span class="text-muted">Not specified</span>
                    }
                </div>
                
                @if (Model.Outbreak.PrimaryLocation != null)
                {
                    <div class="mb-3">
                        <strong><i class="bi bi-geo-alt me-1"></i>Primary Location:</strong><br>
                        <a asp-page="/Locations/Details" asp-route-id="@Model.Outbreak.PrimaryLocation.Id" class="text-decoration-none">
                            @Model.Outbreak.PrimaryLocation.Name
                        </a>
                    </div>
                }
                
                @if (Model.Outbreak.PrimaryEvent != null)
                {
                    <div class="mb-3">
                        <strong><i class="bi bi-calendar-event me-1"></i>Primary Event:</strong><br>
                        <a asp-page="/Events/Details" asp-route-id="@Model.Outbreak.PrimaryEvent.Id" class="text-decoration-none">
                            @Model.Outbreak.PrimaryEvent.Name
                        </a>
                    </div>
                }
                
                <div class="mb-3">
                    <strong>Lead Investigator:</strong><br>
                    @if (Model.Outbreak.LeadInvestigator != null)
                    {
                        <span>@Model.Outbreak.LeadInvestigator.UserName</span>
                    }
                    else
                    {
                        <span class="text-muted">Not assigned</span>
                    }
                </div>
                
                <div>
                    <a asp-page="ClassifyCases" asp-route-id="@Model.Outbreak.Id" class="btn btn-sm btn-primary w-100">
                        <i class="bi bi-clipboard-check me-1"></i>Classify Cases
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header bg-light">
                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-people-fill me-2"></i>Investigation Team (@Model.TeamMembers.Count)</h6>
                    <a asp-page="ManageTeam" asp-route-id="@Model.Outbreak.Id" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-gear"></i>
                    </a>
                </div>
            </div>
            <div class="card-body">
                @if (Model.TeamMembers.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead>
