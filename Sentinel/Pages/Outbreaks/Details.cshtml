                    <div class="mb-3">
                        <label class="form-label">Justification <span class="text-danger">*</span></label>
                        <textarea name="justification" class="form-control" rows="4" required 
                                  placeholder="Document evidence and criteria met for outbreak confirmation..."></textarea>
                        <small class="text-muted">Describe case counts, epidemiological links, attack rates, or other evidence supporting outbreak confirmation.</small>
