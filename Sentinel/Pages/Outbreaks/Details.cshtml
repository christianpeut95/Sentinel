@page
@using Sentinel.Models
@model Sentinel.Pages.Outbreaks.DetailsModel
@{
    ViewData["Title"] = Model.Outbreak.Name;
}
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="Index">Outbreaks</a></li>
        @if (Model.IsChildOutbreak)
        {
            <li class="breadcrumb-item"><a asp-page="Details" asp-route-id="@Model.Outbreak.ParentOutbreakId">@Model.Outbreak.ParentOutbreak?.Name</a></li>
        }
        <li class="breadcrumb-item active" aria-current="page">@Model.Outbreak.Name</li>
    </ol>
</nav>

@* Show parent outbreak banner if this is a child *@
@if (Model.IsChildOutbreak)
{
    <div class="alert alert-info mb-4">
        <i class="bi bi-diagram-3 me-2"></i>
        <strong>Sub-Investigation</strong><br/>
        <small>This is a sub-investigation under: <a asp-page="Details" asp-route-id="@Model.Outbreak.ParentOutbreakId" class="alert-link">@Model.Outbreak.ParentOutbreak?.Name</a></small>
    </div>
}


@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="mb-1">
            @if (Model.IsContactTracingMode)
            {
                <i class="bi bi-people text-primary me-2"></i>
            }
            else
            {
                <i class="bi bi-exclamation-triangle text-danger me-2"></i>
            }
            @Model.Outbreak.Name
        </h2>
        <div class="d-flex align-items-center gap-3">
            @switch (Model.Outbreak.Status)
            {
                case OutbreakStatus.Active:
                    <span class="badge bg-danger fs-6">Active Investigation</span>
                    break;
                case OutbreakStatus.Monitoring:
                    <span class="badge bg-warning fs-6">Under Monitoring</span>
                    break;
                case OutbreakStatus.Resolved:
                    <span class="badge bg-success fs-6">Resolved</span>
                    break;
                case OutbreakStatus.Closed:
                    <span class="badge bg-secondary fs-6">Closed</span>
                    break;
            }
            
            @* Confirmation Status Badge *@
            @if (Model.Outbreak.ConfirmationStatus != null)
            {
                @switch (Model.Outbreak.ConfirmationStatus.Name)
                {
                    case "Under Investigation":
                        <span class="badge bg-info fs-6"><i class="bi bi-search me-1"></i>Contact Tracing Investigation</span>
                        break;
                    case "Suspected":
                        <span class="badge bg-warning fs-6"><i class="bi bi-exclamation-circle me-1"></i>Suspected Outbreak</span>
                        break;
                    case "Confirmed":
                        <span class="badge bg-danger fs-6"><i class="bi bi-exclamation-triangle me-1"></i>Confirmed Outbreak</span>
                        break;
                    case "Probable":
                        <span class="badge bg-warning fs-6"><i class="bi bi-exclamation-triangle me-1"></i>Probable Outbreak</span>
                        break;
                    case "Not a Case":
                        <span class="badge bg-secondary fs-6"><i class="bi bi-x-circle me-1"></i>Not an Outbreak</span>
                        break;
                    default:
                        <span class="badge bg-secondary fs-6">@Model.Outbreak.ConfirmationStatus.Name</span>
                        break;
                }
            }
            
            <span class="text-muted">Started @Model.Outbreak.StartDate.ToString("MMMM d, yyyy")</span>
            @if (Model.Outbreak.EndDate.HasValue)
            {
                <span class="text-muted">• Ended @Model.Outbreak.EndDate.Value.ToString("MMMM d, yyyy")</span>
            }
        </div>
        @if (!string.IsNullOrEmpty(Model.Outbreak.Description))
        {
            <p class="text-muted mt-2 mb-0">@Model.Outbreak.Description</p>
        }
    </div>
    <div class="d-flex gap-2">
        @* Primary Quick Actions - Most frequently used *@
        <a asp-page="LinkCases" asp-route-id="@Model.Outbreak.Id" class="btn btn-success" title="Link Case/Contact">
            <i class="bi bi-link me-1"></i>Link Case/Contact
        </a>
        <a asp-page="CreateChild" asp-route-parentId="@Model.Outbreak.Id" class="btn btn-info" title="Create Sub-Investigation">
            <i class="bi bi-plus-circle me-1"></i>Sub-Investigation
        </a>
        @if (!Model.IsContactTracingMode)
        {
            <a asp-page="LineList" asp-route-id="@Model.Outbreak.Id" class="btn btn-outline-primary" title="Line List">
                <i class="bi bi-table me-1"></i>Line List
            </a>
        }
        
        @* Edit and More Actions Dropdown *@
        <div class="btn-group">
            <a asp-page="Edit" asp-route-id="@Model.Outbreak.Id" class="btn btn-primary">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                <span class="visually-hidden">More Actions</span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" asp-page="Tasks" asp-route-id="@Model.Outbreak.Id">
                    <i class="bi bi-check2-square me-2"></i>Task Dashboard
                </a></li>
                @if (!Model.IsContactTracingMode)
                {
                    <li><a class="dropdown-item" asp-page="ClassifyCases" asp-route-id="@Model.Outbreak.Id">
                        <i class="bi bi-clipboard-check me-2"></i>Classify Cases
                    </a></li>
                    <li><a class="dropdown-item" asp-page="CaseDefinitions" asp-route-id="@Model.Outbreak.Id">
                        <i class="bi bi-clipboard2-check me-2"></i>Case Definitions
                    </a></li>
                    <li><hr class="dropdown-divider"></li>
                }
                <li><a class="dropdown-item" asp-page="ManageTeam" asp-route-id="@Model.Outbreak.Id">
                    <i class="bi bi-person-plus me-2"></i>Manage Team
                </a></li>
                @* Upgrade/Confirmation Actions *@
                @if (Model.Outbreak.ConfirmationStatus?.Name == "Under Investigation")
                {
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-warning" href="#" data-bs-toggle="modal" data-bs-target="#upgradeToSuspectedModal">
                        <i class="bi bi-arrow-up-circle me-2"></i>Upgrade to Suspected Outbreak
                    </a></li>
                }
                @if (Model.Outbreak.ConfirmationStatus?.Name == "Suspected" || Model.Outbreak.ConfirmationStatus?.Name == "Probable")
                {
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="#" data-bs-toggle="modal" data-bs-target="#confirmOutbreakModal">
                        <i class="bi bi-check-circle me-2"></i>Confirm as Outbreak
                    </a></li>
                }
            </ul>
        </div>
    </div>
</div>

@* View Toggle for Parent/Aggregated *@
@if (Model.HasChildren)
{
    <div class="card mb-3 bg-light">
        <div class="card-body py-2">
            <div class="d-flex justify-content-between align-items-center">
                <span class="small text-muted">
                    <i class="bi bi-diagram-3 me-1"></i>
                    This outbreak has @Model.ChildOutbreaks.Count sub-investigation(s) @(Model.ShowAllDescendants ? "(all descendants)" : "(direct children)")
                </span>
                <div class="btn-group btn-group-sm">
                    <a asp-page="Details" asp-route-id="@Model.Outbreak.Id" asp-route-showAggregated="false" 
                       class="btn @(!Model.ShowAggregated ? "btn-primary" : "btn-outline-secondary")">
                        <i class="bi bi-funnel me-1"></i>Parent Only
                    </a>
                    <a asp-page="Details" asp-route-id="@Model.Outbreak.Id" asp-route-showAggregated="true" 
                       class="btn @(Model.ShowAggregated ? "btn-primary" : "btn-outline-secondary")">
                        <i class="bi bi-collection me-1"></i>Aggregated View
                    </a>
                </div>
            </div>
        </div>
    </div>
}



<!-- Statistics Cards -->

<div class="row g-3 mb-4">
    <!-- Classification Statistics -->
    <div class="col-md-3">
        <div class="card border-danger h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-2">
                    <div class="flex-grow-1">
                        <h6 class="text-muted small mb-0">Confirmed</h6>
                        <h3 class="mb-0 text-danger">@Model.Statistics.ConfirmedCases</h3>
                    </div>
                    <div class="bg-danger bg-opacity-10 rounded-circle p-3">
                        <i class="bi bi-check-circle-fill text-danger fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-warning h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-2">
                    <div class="flex-grow-1">
                        <h6 class="text-muted small mb-0">Probable</h6>
                        <h3 class="mb-0 text-warning">@Model.Statistics.ProbableCases</h3>
                    </div>
                    <div class="bg-warning bg-opacity-10 rounded-circle p-3">
                        <i class="bi bi-exclamation-circle-fill text-warning fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-secondary h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-2">
                    <div class="flex-grow-1">
                        <h6 class="text-muted small mb-0">Suspect</h6>
                        <h3 class="mb-0 text-secondary">@Model.Statistics.SuspectCases</h3>
                    </div>
                    <div class="bg-secondary bg-opacity-10 rounded-circle p-3">
                        <i class="bi bi-question-circle-fill text-secondary fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-info h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-2">
                    <div class="flex-grow-1">
                        <h6 class="text-muted small mb-0">Contacts</h6>
                        <h3 class="mb-0 text-info">@Model.Statistics.TotalContacts</h3>
                    </div>
                    <div class="bg-info bg-opacity-10 rounded-circle p-3">
                        <i class="bi bi-people-fill text-info fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Child Outbreaks Section - Collapsible *@
@if (Model.HasChildren)
{
    <div class="card mb-4">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3 flex-grow-1">
                <button class="btn btn-sm btn-link text-decoration-none p-0" type="button" data-bs-toggle="collapse" data-bs-target="#subInvestigationsCollapse" aria-expanded="true" aria-controls="subInvestigationsCollapse">
                    <h5 class="mb-0">
                        <i class="bi bi-diagram-3 me-2"></i>Sub-Investigations
                        <span class="badge bg-primary ms-2">@Model.ChildOutbreaks.Count</span>
                        <i class="bi bi-chevron-down collapse-icon ms-2"></i>
                    </h5>
                </button>
                <div class="btn-group btn-group-sm">
                    <a asp-page="Details" asp-route-id="@Model.Outbreak.Id" 
                       asp-route-showAggregated="@Model.ShowAggregated"
                       asp-route-showAllDescendants="false" 
                       class="btn @(!Model.ShowAllDescendants ? "btn-sm btn-outline-primary active" : "btn-sm btn-outline-secondary")">
                        Direct Only
                    </a>
                    <a asp-page="Details" asp-route-id="@Model.Outbreak.Id" 
                       asp-route-showAggregated="@Model.ShowAggregated"
                       asp-route-showAllDescendants="true" 
                       class="btn @(Model.ShowAllDescendants ? "btn-sm btn-outline-primary active" : "btn-sm btn-outline-secondary")">
                        All Descendants
                    </a>
                </div>
            </div>
            <a asp-page="CreateChild" asp-route-parentId="@Model.Outbreak.Id" class="btn btn-sm btn-success">
                <i class="bi bi-plus-circle me-1"></i>Create
            </a>
        </div>
        <div class="collapse show" id="subInvestigationsCollapse">
            <div class="card-body">
            <div class="row g-3">
                @foreach (var child in Model.ChildOutbreaks)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 border-primary">
                            <div class="card-header bg-primary bg-opacity-10">
                                <h6 class="mb-0">
                                    @if (child.PrimaryLocation != null)
                                    {
                                        <i class="bi bi-geo-alt me-1"></i>
                                    }
                                    else if (child.PrimaryEvent != null)
                                    {
                                        <i class="bi bi-calendar-event me-1"></i>
                                    }
                                    @child.Name
                                </h6>
                                @if (child.ParentOutbreak != null && Model.ShowAllDescendants)
                                {
                                    <small class="text-muted d-block">
                                        <i class="bi bi-arrow-return-right me-1"></i>Under: @child.ParentOutbreak.Name
                                    </small>
                                }
                            </div>

                            <div class="card-body">
                                <div class="mb-2">
                                    <small class="text-muted">Lead:</small>
                                    <div>@(child.LeadInvestigator?.UserName ?? "Unassigned")</div>
                                </div>
                                <div class="mb-2">
                                    <small class="text-muted">Status:</small>
                                    <div>
                                        <span class="badge @(child.Status == OutbreakStatus.Active ? "bg-danger" : child.Status == OutbreakStatus.Monitoring ? "bg-warning" : "bg-success")">
                                            @child.Status
                                        </span>
                                        @if (child.ConfirmationStatus != null)
                                        {
                                            <span class="badge bg-info">@child.ConfirmationStatus.Name</span>
                                        }
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <small class="text-muted">Venue:</small>
                                    <div>@(child.PrimaryLocation?.Name ?? child.PrimaryEvent?.Name ?? "Not specified")</div>
                                </div>
                                <div>
                                    <small class="text-muted">Started:</small>
                                    <div>@child.StartDate.ToString("MMM dd, yyyy")</div>
                                </div>
                            </div>
                            <div class="card-footer">
                                <a asp-page="Details" asp-route-id="@child.Id" class="btn btn-sm btn-primary w-100">
                                    <i class="bi bi-eye me-1"></i>View Details
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
            </div>
        </div>
    </div>
}

<!-- Demographics and Epidemic Curve -->

<div class="row g-3 mb-4">
    <!-- Demographics Card -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-person-lines-fill me-2"></i>Demographics</h5>
            </div>
            <div class="card-body">
                <h6 class="mb-3">Age Distribution</h6>
                @if (Model.Statistics.MedianAge.HasValue)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small text-muted">Median Age</span>
                            <strong>@Model.Statistics.MedianAge.Value.ToString("F1") years</strong>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="small text-muted">Age Range</span>
                            <strong>@Model.Statistics.MinAge - @Model.Statistics.MaxAge years</strong>
                        </div>
                    </div>
                }
                else
                {
                    <p class="text-muted small">No age data available</p>
                }
                
                <hr>
                
                <h6 class="mb-3">Sex Distribution</h6>
                <div class="mb-2">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="small">Male</span>
                        <span class="badge bg-primary">@Model.Statistics.MaleCount</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-primary" role="progressbar" 
                             style="width: @(Model.Statistics.TotalCases > 0 ? (Model.Statistics.MaleCount * 100.0 / Model.Statistics.TotalCases).ToString("F0") : "0")%">
                        </div>
                    </div>
                </div>
                
                <div class="mb-2">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="small">Female</span>
                        <span class="badge" style="background-color: #e91e63;">@Model.Statistics.FemaleCount</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar" role="progressbar" 
                             style="width: @(Model.Statistics.TotalCases > 0 ? (Model.Statistics.FemaleCount * 100.0 / Model.Statistics.TotalCases).ToString("F0") : "0")%; background-color: #e91e63;">
                        </div>
                    </div>
                </div>
                
                @if (Model.Statistics.OtherSexCount > 0)
                {
                    <div class="mb-2">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="small">Other</span>
                            <span class="badge bg-secondary">@Model.Statistics.OtherSexCount</span>
                        </div>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-secondary" role="progressbar" 
                                 style="width: @(Model.Statistics.TotalCases > 0 ? (Model.Statistics.OtherSexCount * 100.0 / Model.Statistics.TotalCases).ToString("F0") : "0")%">
                            </div>
                        </div>
                    </div>
                }
                
                @if (Model.Statistics.UnknownSexCount > 0)
                {
                    <div class="mb-2">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="small">Unknown</span>
                            <span class="badge bg-light text-dark border">@Model.Statistics.UnknownSexCount</span>
                        </div>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-light border" role="progressbar" 
                                 style="width: @(Model.Statistics.TotalCases > 0 ? (Model.Statistics.UnknownSexCount * 100.0 / Model.Statistics.TotalCases).ToString("F0") : "0")%">
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
    
    <!-- Epidemic Curve -->
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>Epidemic Curve</h5>
                <small class="text-muted">Cases by date of onset (or notification if not available)</small>
            </div>
            <div class="card-body">
                <canvas id="epidemicCurve" style="max-height: 300px;"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Original Statistics Cards for Reference -->
<div class="row g-3 mb-4">
    <div class="col-lg-3 col-md-6">
        <div class="card border-danger">
            <div class="card-body">
