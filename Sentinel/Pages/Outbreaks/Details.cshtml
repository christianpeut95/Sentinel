                        <small class="text-muted">
                            @Model.Statistics.ConfirmedCases Confirmed • 
                            @Model.Statistics.ProbableCases Probable • 
                            @Model.Statistics.SuspectCases Suspect
                        </small>
                    </div>
                    <div class="bg-danger bg-opacity-10 p-3 rounded">
                        <i class="bi bi-virus fs-3 text-danger"></i>
                    </div>
