<!-- Add Timeline Event Modal -->
<div class="modal fade" id="addTimelineEventModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-clock-history me-2"></i>Add Timeline Event</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="AddTimelineEvent" asp-route-id="@Model.Outbreak.Id">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Event Title <span class="text-danger">*</span></label>
                        <input type="text" name="title" class="form-control" required maxlength="200"
                               placeholder="Brief description of the event..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="description" class="form-control" rows="3" maxlength="1000"
                                  placeholder="Additional details (optional)..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Event Date & Time <span class="text-danger">*</span></label>
                        <input type="datetime-local" name="eventDate" class="form-control" required 
                               value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Event Type</label>
                        <select name="eventType" class="form-select">
                            <option value="0">General Note</option>
                            <option value="1">Outbreak Declared</option>
                            <option value="2">Case Added</option>
                            <option value="3">Contact Added</option>
                            <option value="4">Definition Updated</option>
                            <option value="5">Team Member Added</option>
                            <option value="6">Status Changed</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Add Event</button>
                </div>
            </form>
        </div>
    </div>
</div>

