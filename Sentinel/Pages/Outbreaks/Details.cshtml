        <div class="card border-info">
            <div class="card-header bg-info bg-opacity-10 d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-people me-2 text-info"></i>Contacts Under Monitoring</h5>
                <div class="btn-group btn-group-sm">
                    <a asp-page="LinkCases" asp-route-id="@Model.Outbreak.Id" class="btn btn-outline-info">
                        <i class="bi bi-plus-circle me-1"></i>Link Contact
                    </a>
                    <button type="button" class="btn btn-outline-info" onclick="selectAllContacts()">
                        <i class="bi bi-check-all me-1"></i>Select All
                    </button>
                    <button type="button" class="btn btn-info" id="bulkActionsContactsBtn" disabled onclick="bulkActionsContacts()">
                        <i class="bi bi-lightning me-1"></i>Bulk Actions
                    </button>
                </div>
            </div>
            <div class="card-body">
                @if (Model.Contacts.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th width="40"><input type="checkbox" id="selectAllContactsCheckbox" onchange="toggleAllContacts(this)"></th>
                                    <th>Contact</th>
                                    <th>Disease</th>
                                    <th>Notification Date</th>
                                    <th>Linked Date</th>
                                    <th>Linked By</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var outbreakCase in Model.Contacts)
                                {
                                    <tr>
                                        <td><input type="checkbox" class="contact-checkbox" value="@outbreakCase.Case.Id"></td>
                                        <td>
                                            <a asp-page="/Cases/Details" asp-route-id="@outbreakCase.Case.Id">
                                                @outbreakCase.Case.Patient?.GivenName @outbreakCase.Case.Patient?.FamilyName
                                            </a>
                                            <br>
                                            <small class="text-muted">@outbreakCase.Case.FriendlyId</small>
                                        </td>
                                        <td>@outbreakCase.Case.Disease?.Name</td>
                                        <td>
                                            @if (outbreakCase.Case.DateOfNotification.HasValue)
                                            {
                                                @outbreakCase.Case.DateOfNotification.Value.ToString("MMM d, yyyy")
                                            }
                                        </td>
                                        <td>
                                            <small>@outbreakCase.LinkedDate.ToString("MMM d, yyyy")</small>
                                        </td>
                                        <td>
                                            <small class="text-muted">@outbreakCase.LinkMethod.ToString().Replace("_", " ")</small>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <a asp-page="/Cases/Details" asp-route-id="@outbreakCase.Case.Id" class="btn btn-sm btn-outline-primary" title="View Contact">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <button type="button" class="btn btn-sm btn-outline-danger" 
                                                        onclick="unlinkCase(@outbreakCase.Id, '@outbreakCase.Case.Patient?.GivenName @outbreakCase.Case.Patient?.FamilyName')" 
                                                        title="Unlink">
                                                    <i class="bi bi-link-45deg"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-inbox display-1 text-muted"></i>
                        <p class="text-muted mt-3">No contacts linked to this outbreak yet.</p>
                        <a asp-page="LinkCases" asp-route-id="@Model.Outbreak.Id" class="btn btn-info">
                            <i class="bi bi-plus-circle me-1"></i>Link First Contact
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Timeline Tab -->
    <div class="tab-pane fade" id="timeline" role="tabpanel" aria-labelledby="timeline-tab">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Investigation Timeline</h5>
                <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addTimelineEventModal">
                    <i class="bi bi-plus-circle me-1"></i>Add Event
                </button>
            </div>
            <div class="card-body">
                @if (Model.Timeline.Any())
                {
                    <div class="timeline">
                        @foreach (var item in Model.Timeline)
                        {
                            <div class="timeline-item mb-3">
                                <div class="d-flex">
                                    <div class="timeline-marker">
                                        @switch (item.EventType)
                                        {
                                            case TimelineEventType.OutbreakDeclared:
                                                <i class="bi bi-flag-fill text-danger"></i>
                                                break;
                                            case TimelineEventType.CaseAdded:
                                            case TimelineEventType.ContactAdded:
                                                <i class="bi bi-person-plus-fill text-primary"></i>
                                                break;
                                            case TimelineEventType.DefinitionUpdated:
                                                <i class="bi bi-file-earmark-text text-warning"></i>
                                                break;
                                            case TimelineEventType.TeamMemberAdded:
                                                <i class="bi bi-people-fill text-success"></i>
                                                break;
                                            default:
                                                <i class="bi bi-circle-fill text-secondary"></i>
                                                break;
                                        }
                                    </div>
                                    <div class="flex-grow-1 ms-3">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <strong>@item.Title</strong>
                                                @if (!string.IsNullOrEmpty(item.Description))
                                                {
                                                    <p class="text-muted mb-0">@item.Description</p>
                                                }
                                            </div>
                                            <small class="text-muted">@item.EventDate.ToString("MMM d, yyyy h:mm tt")</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted text-center">No timeline events yet.</p>
                }
            </div>
        </div>
    </div>

</div>

@section Styles {
    <style>
        .timeline {
            position: relative;
            padding-left: 30px;
        }
        
        .timeline::before {
            content: '';
            position: absolute;
            left: 15px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: #dee2e6;
        }
        
        .timeline-marker {
            position: absolute;
            left: -30px;
            width: 30px;
            height: 30px;
            background: white;
            border: 2px solid #dee2e6;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.875rem;
        }
        
        /* Sub-investigations collapse animation */
        .collapse-icon {
            transition: transform 0.3s ease;
        }
        
        [aria-expanded="false"] .collapse-icon {
            transform: rotate(-90deg);
        }
        
        [aria-expanded="true"] .collapse-icon {
            transform: rotate(0deg);
        }
    </style>
}

@section Scripts {
    <script>
        function toggleAllCases(checkbox) {
            document.querySelectorAll('.case-checkbox').forEach(cb => cb.checked = checkbox.checked);
            updateBulkActionButtons();
        }
        
        function toggleAllContacts(checkbox) {
            document.querySelectorAll('.contact-checkbox').forEach(cb => cb.checked = checkbox.checked);
            updateBulkActionButtons();
        }
        
        function updateBulkActionButtons() {
            const casesSelected = document.querySelectorAll('.case-checkbox:checked').length;
            const contactsSelected = document.querySelectorAll('.contact-checkbox:checked').length;
            
            document.getElementById('bulkActionsCasesBtn').disabled = casesSelected === 0;
            document.getElementById('bulkActionsContactsBtn').disabled = contactsSelected === 0;
        }
        
        function bulkActionsCases() {
            const selectedIds = Array.from(document.querySelectorAll('.case-checkbox:checked'))
                .map(cb => cb.value)
                .join(',');
            
            if (selectedIds) {
                window.location.href = `/Outbreaks/BulkActions?id=@Model.Outbreak.Id&caseIds=${selectedIds}`;
            }
        }
        
        function bulkActionsContacts() {
            const selectedIds = Array.from(document.querySelectorAll('.contact-checkbox:checked'))
                .map(cb => cb.value)
                .join(',');
            
            if (selectedIds) {
                window.location.href = `/Outbreaks/BulkActions?id=@Model.Outbreak.Id&caseIds=${selectedIds}`;
            }
        }
        
        // Update on individual checkbox change
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.case-checkbox, .contact-checkbox').forEach(cb => {
                cb.addEventListener('change', updateBulkActionButtons);
            });
        });
        
        function unlinkCase(outbreakCaseId, patientName) {
            if (confirm(`Are you sure you want to unlink ${patientName} from this outbreak?`)) {
                const reason = prompt('Reason for unlinking:');
                if (reason) {
                    // Submit form to unlink
                    const form = document.createElement('form');
                    form.method = 'POST';
                    form.action = '?handler=UnlinkCase&id=@Model.Outbreak.Id';
                    
                    const idInput = document.createElement('input');
                    idInput.type = 'hidden';
                    idInput.name = 'outbreakCaseId';
                    idInput.value = outbreakCaseId;
                    form.appendChild(idInput);
                    
                    const reasonInput = document.createElement('input');
                    reasonInput.type = 'hidden';
                    reasonInput.name = 'reason';
                    reasonInput.value = reason;
                    form.appendChild(reasonInput);
                    
                    document.body.appendChild(form);
                    form.submit();
                }
            }
        }
        
        // Handle collapse icon animation
        document.addEventListener('DOMContentLoaded', function() {
            const collapseElement = document.getElementById('subInvestigationsCollapse');
            if (collapseElement) {
                const collapseButton = document.querySelector('[data-bs-target=\"#subInvestigationsCollapse\"]');
                
                collapseElement.addEventListener('show.bs.collapse', function() {
                    if (collapseButton) {
                        collapseButton.setAttribute('aria-expanded', 'true');
                    }
                });
                
                collapseElement.addEventListener('hide.bs.collapse', function() {
                    if (collapseButton) {
                        collapseButton.setAttribute('aria-expanded', 'false');
                    }
                });
            }
        });
        
        
        // Epidemic Curve Chart
        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('epidemicCurve');
            if (!ctx) return;
            
            const epiData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Statistics.EpiCurveData));
            
            const dates = epiData.map(d => new Date(d.Date));
            const confirmedData = epiData.map(d => d.ConfirmedCount);
            const probableData = epiData.map(d => d.ProbableCount);
            const suspectData = epiData.map(d => d.SuspectCount);
            const unclassifiedData = epiData.map(d => d.UnclassifiedCount);
            
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: dates.map(d => d.toLocaleDateString()),
                    datasets: [
                        {
                            label: 'Confirmed',
                            data: confirmedData,
                            backgroundColor: 'rgba(220, 53, 69, 0.8)',
                            borderColor: 'rgb(220, 53, 69)',
                            borderWidth: 1
                        },
                        {
                            label: 'Probable',
                            data: probableData,
                            backgroundColor: 'rgba(255, 193, 7, 0.8)',
                            borderColor: 'rgb(255, 193, 7)',
                            borderWidth: 1
                        },
                        {
                            label: 'Suspect',
                            data: suspectData,
                            backgroundColor: 'rgba(108, 117, 125, 0.8)',
                            borderColor: 'rgb(108, 117, 125)',
                            borderWidth: 1
                        },
                        {
                            label: 'Unclassified',
                            data: unclassifiedData,
                            backgroundColor: 'rgba(206, 212, 218, 0.8)',
                            borderColor: 'rgb(206, 212, 218)',
                            borderWidth: 1
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            stacked: true,
                            title: {
                                display: true,
                                text: 'Date'
                            }
                        },
                        y: {
                            stacked: true,
                            beginAtZero: true,
                            ticks: {
                                stepSize: 1
                            },
                            title: {
                                display: true,
                                text: 'Number of Cases'
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: false
                        },
                        title: {
                            display: false
                        }
                    }
                }
            });
        });
    </script>
}

<!-- Upgrade to Suspected Outbreak Modal -->
<div class="modal fade" id="upgradeToSuspectedModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title"><i class="bi bi-arrow-up-circle me-2"></i>Upgrade to Suspected Outbreak</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="UpgradeToSuspected" asp-route-id="@Model.Outbreak.Id">
                <div class="modal-body">
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Upgrade Investigation Status</strong>
                        <p class="mb-0 mt-2">This will change the classification from "Contact Tracing Investigation" to "Suspected Outbreak". This action indicates that patterns suggest a potential outbreak situation.</p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Reason for Upgrade</label>
                        <textarea name="reason" class="form-control" rows="3" required 
                                  placeholder="Document why this investigation is being upgraded (e.g., multiple linked cases, pattern emerging...)"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning"><i class="bi bi-arrow-up-circle me-1"></i>Upgrade to Suspected</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Confirm as Outbreak Modal -->
<div class="modal fade" id="confirmOutbreakModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Confirm as Outbreak</h5>
