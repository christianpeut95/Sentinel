<div class="tab-content" id="outbreakTabsContent">
    <!-- Cases Tab -->
    <div class="tab-pane fade show active" id="cases" role="tabpanel" aria-labelledby="cases-tab">
        <div class="card border-danger">
            <div class="card-header bg-danger bg-opacity-10 d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-virus me-2 text-danger"></i>Outbreak Cases</h5>
                <div class="btn-group btn-group-sm">
                    <a asp-page="LinkCases" asp-route-id="@Model.Outbreak.Id" class="btn btn-outline-danger">
                        <i class="bi bi-plus-circle me-1"></i>Link Case
                    </a>
                    <button type="button" class="btn btn-outline-danger" onclick="selectAllCases()">
                        <i class="bi bi-check-all me-1"></i>Select All
                    </button>
                    <button type="button" class="btn btn-danger" id="bulkActionsCasesBtn" disabled onclick="bulkActionsCases()">
                        <i class="bi bi-lightning me-1"></i>Bulk Actions
                    </button>
                </div>
            </div>
            <div class="card-body">
                @if (Model.Cases.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th width="40"><input type="checkbox" id="selectAllCasesCheckbox" onchange="toggleAllCases(this)"></th>
                                    <th>Patient</th>
                                    <th>Classification</th>
                                    <th>Disease</th>
                                    <th>Onset Date</th>
                                    <th>Linked Date</th>
                                    <th>Linked By</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var outbreakCase in Model.Cases)
                                {
                                    <tr>
                                        <td><input type="checkbox" class="case-checkbox" value="@outbreakCase.Case.Id"></td>
                                        <td>
                                            <a asp-page="/Cases/Details" asp-route-id="@outbreakCase.Case.Id">
                                                @outbreakCase.Case.Patient?.GivenName @outbreakCase.Case.Patient?.FamilyName
                                            </a>
                                            <br>
                                            <small class="text-muted">@outbreakCase.Case.FriendlyId</small>
                                        </td>
                                        <td>
                                            @if (outbreakCase.Classification.HasValue)
                                            {
                                                switch (outbreakCase.Classification.Value)
                                                {
                                                    case CaseClassification.Confirmed:
                                                        <span class="badge bg-danger">Confirmed</span>
                                                        break;
                                                    case CaseClassification.Probable:
                                                        <span class="badge bg-warning text-dark">Probable</span>
                                                        break;
                                                    case CaseClassification.Suspect:
                                                        <span class="badge bg-secondary">Suspect</span>
                                                        break;
                                                    case CaseClassification.NotACase:
                                                        <span class="badge bg-light text-dark">Not a Case</span>
                                                        break;
                                                }
                                            }
                                        </td>
                                        <td>@outbreakCase.Case.Disease?.Name</td>
                                        <td>
                                            @if (outbreakCase.Case.DateOfOnset.HasValue)
                                            {
                                                @outbreakCase.Case.DateOfOnset.Value.ToString("MMM d, yyyy")
                                            }
                                        </td>
                                        <td>
                                            <small>@outbreakCase.LinkedDate.ToString("MMM d, yyyy")</small>
                                        </td>
                                        <td>
                                            <small class="text-muted">@outbreakCase.LinkMethod.ToString().Replace("_", " ")</small>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <a asp-page="/Cases/Details" asp-route-id="@outbreakCase.Case.Id" class="btn btn-sm btn-outline-primary" title="View Case">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <button type="button" class="btn btn-sm btn-outline-danger" 
                                                        onclick="unlinkCase(@outbreakCase.Id, '@outbreakCase.Case.Patient?.GivenName @outbreakCase.Case.Patient?.FamilyName')" 
                                                        title="Unlink">
                                                    <i class="bi bi-link-45deg"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-inbox display-1 text-muted"></i>
                        <p class="text-muted mt-3">No cases linked to this outbreak yet.</p>
                        <a asp-page="LinkCases" asp-route-id="@Model.Outbreak.Id" class="btn btn-danger">
                            <i class="bi bi-plus-circle me-1"></i>Link First Case
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Contacts Tab -->
