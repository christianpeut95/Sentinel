            </div>
        </div>
    </div>
    
    <div class="col-lg-3 col-md-6">
        <div class="card border-info">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="text-muted mb-1">Contacts</h6>
                        <h2 class="mb-0">@Model.Statistics.TotalContacts</h2>
                        <small class="text-muted">Under monitoring</small>
                    </div>
                    <div class="bg-info bg-opacity-10 p-3 rounded">
                        <i class="bi bi-people fs-3 text-info"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-3 col-md-6">
        <div class="card border-primary">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="text-muted mb-1">Investigation Team</h6>
                        <h2 class="mb-0">@Model.Statistics.TeamMemberCount</h2>
                        <small class="text-muted">Active members</small>
                    </div>
                    <div class="bg-primary bg-opacity-10 p-3 rounded">
                        <i class="bi bi-people-fill fs-3 text-primary"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-3 col-md-6">
        <div class="card border-secondary">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
