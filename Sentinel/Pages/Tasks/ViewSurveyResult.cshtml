@page "{id:guid}"
@model Sentinel.Pages.Tasks.ViewSurveyResultModel

@{
    ViewData["Title"] = "View Survey Result";
}

<style nonce="@GetCspNonce()">
    /* Breadcrumb styling */
    .breadcrumb {
        background: transparent
        padding: 0
        margin-bottom: 1rem
        font-size: 0.875rem
    }

    .breadcrumb-item + .breadcrumb-item::before {
        color: #cbd5e0
    }

    .breadcrumb-item a {
        color: #4a5568
        text-decoration: none
    }

    .breadcrumb-item a:hover {
        color: #2d3748
    }

    .breadcrumb-item.active {
        color: #718096
    }

    .survey-container {
        max-width: 1200px
        margin: 0 auto
        padding: 1.5rem
    }

    .survey-header {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%)
        border-radius: 16px
        padding: 2rem
        margin-bottom: 1.5rem
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04)
        border: 1px solid rgba(0, 0, 0, 0.06)
    }

    .survey-header h1 {
        font-size: 1.75rem
        font-weight: 600
        color: #2d3748
        margin-bottom: 0.5rem
        letter-spacing: -0.5px
    }

    .survey-meta {
        display: grid
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr))
        gap: 1.5rem
        margin-top: 1rem
        padding-top: 1rem
        border-top: 1px solid rgba(0, 0, 0, 0.08)
    }

    .meta-item {
        display: flex
        flex-direction: column
    }

    .meta-label {
        font-size: 0.75rem
        color: #718096
        font-weight: 600
        text-transform: uppercase
        letter-spacing: 0.5px
        margin-bottom: 0.25rem
    }

    .meta-value {
        font-size: 0.95rem
        color: #2d3748
        font-weight: 600
    }

    .badge-completed {
        background: #d1fae5
        color: #065f46
        padding: 0.375rem 0.875rem
        border-radius: 9999px
        font-size: 0.75rem
        font-weight: 600
        display: inline-block
        margin-left: 0.5rem
    }

    .survey-card {
        background: white
        border-radius: 12px
        padding: 2rem
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04)
        border: 1px solid rgba(0, 0, 0, 0.08)
        margin-bottom: 1.5rem
    }

    .action-buttons {
        display: flex
        gap: 1rem
        margin-top: 2rem
        padding-top: 1.5rem
        border-top: 1px solid rgba(0, 0, 0, 0.08)
    }

    .btn-back {
        background: white
        color: #4a5568
        border: 1.5px solid #e2e8f0
        padding: 0.75rem 1.5rem
        border-radius: 10px
        font-weight: 600
        font-size: 0.875rem
        transition: all 0.2s
        text-decoration: none
        display: inline-flex
        align-items: center
        gap: 0.5rem
    }

    .btn-back:hover {
        background: #f7fafc
        border-color: #cbd5e0
        color: #2d3748
        transform: translateY(-1px)
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05)
    }

    /* SurveyJS Display Mode Styling */
    #surveyResultContainer .sv-root-modern {
        background: transparent
        box-shadow: none
    }

    #surveyResultContainer .sv-container-modern {
        padding: 0
    }

    #surveyResultContainer .sv-body {
        padding: 0
    }

    /* Read-only styling enhancements */
    #surveyResultContainer input,
    #surveyResultContainer textarea,
    #surveyResultContainer select {
        background-color: #f7fafc !important
        cursor: default !important
    }

    #surveyResultContainer .sv-question {
        opacity: 1 !important
    }

    .readonly-banner {
        background: #e0f2fe
        border-left: 4px solid #0284c7
        border-radius: 8px
        padding: 1rem 1.25rem
        margin-bottom: 1.5rem
        display: flex
        align-items: center
        gap: 0.75rem
    }

    .readonly-banner i {
        color: #0284c7
        font-size: 1.25rem
    }

    .readonly-banner p {
        margin: 0
        color: #075985
        font-size: 0.875rem
        font-weight: 500
    }

    /* Display mode navigation styling */
    #surveyResultContainer .sv-btn {
        opacity: 1 !important
    }

    #surveyResultContainer .sv-footer {
        margin-top: 2rem
        padding-top: 1.5rem
        border-top: 1px solid rgba(0, 0, 0, 0.08)
    }

    #surveyResultContainer .sv-progress {
        margin-bottom: 1.5rem
    }

    #surveyResultContainer .sv-progress__text {
        font-weight: 600
        color: #2d3748
    }
</style>

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Cases/Details" asp-route-id="@Model.Task.CaseId">Case Details</a></li>
        <li class="breadcrumb-item active" aria-current="page">View Survey Result</li>
    </ol>
</nav>

<div class="survey-container">
    <!-- Header -->
    <div class="survey-header">
        <h1>
            <i class="bi bi-file-earmark-text"></i>
            @Model.Task.Title
            <span class="badge-completed">
                <i class="bi bi-check-circle-fill"></i> Completed
            </span>
        </h1>

        <div class="survey-meta">
            <div class="meta-item">
                <span class="meta-label">Case</span>
                <span class="meta-value">
                    <a asp-page="/Cases/Details" asp-route-id="@Model.Task.CaseId" class="text-decoration-none">
                        @Model.Task.Case?.Patient?.GivenName @Model.Task.Case?.Patient?.FamilyName - @Model.Task.Case?.Disease?.Name
                    </a>
                </span>
            </div>

            <div class="meta-item">
                <span class="meta-label">Task Type</span>
                <span class="meta-value">@Model.Task.TaskType?.Name</span>
            </div>

            <div class="meta-item">
                <span class="meta-label">Assigned To</span>
                <span class="meta-value">
                    @if (Model.Task.AssignedToUser != null)
                    {
                        @(Model.Task.AssignedToUser.FirstName + " " + Model.Task.AssignedToUser.LastName)
                    }
                    else
                    {
                        <text>Unassigned</text>
                    }
                </span>
            </div>

            <div class="meta-item">
                <span class="meta-label">Completed By</span>
                <span class="meta-value">
                    @if (Model.Task.CompletedByUser != null)
                    {
                        @(Model.Task.CompletedByUser.FirstName + " " + Model.Task.CompletedByUser.LastName)
                    }
                    else
                    {
                        <text>Unknown</text>
                    }
                </span>
            </div>

            <div class="meta-item">
                <span class="meta-label">Completed At</span>
                <span class="meta-value">
                    @if (Model.Task.CompletedAt.HasValue)
                    {
                        @Model.Task.CompletedAt.Value.ToString("MMM dd, yyyy h:mm tt")
                    }
                    else
                    {
                        <text>N/A</text>
                    }
                </span>
            </div>
        </div>
    </div>

    <!-- Read-only banner -->
    <div class="readonly-banner">
        <i class="bi bi-eye"></i>
        <p>This is a read-only view of the completed survey. Responses cannot be modified.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.Task.CompletionNotes))
    {
        <div class="survey-card">
            <h5 class="mb-3" style="color: #2d3748; font-weight: 600;">
                <i class="bi bi-sticky"></i> Completion Notes
            </h5>
            <p style="color: #4a5568; white-space: pre-wrap;">@Model.Task.CompletionNotes</p>
        </div>
    }

    <!-- Survey Display Container -->
    <div class="survey-card">
        <div id="surveyResultContainer"></div>
    </div>

    <!-- Action Buttons -->
    <div class="action-buttons">
        <a asp-page="/Cases/Details" asp-route-id="@Model.Task.CaseId" class="btn-back">
            <i class="bi bi-arrow-left"></i>
            Back to Case
        </a>
    </div>
</div>

@section Scripts {
    <script nonce="@GetCspNonce()">
        (function() {
            try {                // Parse JSON data
                const surveyDefinition = @Html.Raw(Model.SurveyDefinitionJson ?? "{}")
                const surveyResponse = @Html.Raw(Model.SurveyResponseJson ?? "{}");                // Validate data
                if (!surveyDefinition || typeof surveyDefinition !== 'object') {                    throw new Error('Invalid survey definition')
                }

                if (!surveyResponse || typeof surveyResponse !== 'object') {                    throw new Error('Invalid survey response')
                }

                // Check Survey is available
                if (typeof Survey === 'undefined') {                    throw new Error('Survey library not loaded')
                }

                // Create survey model
                const survey = new Survey.Model(surveyDefinition)
                // Set to display mode (read-only)
                survey.mode = "display"
                // Load the saved responses
                survey.data = surveyResponse
                // ENABLE navigation buttons for multi-page surveys in display mode
                // This allows users to navigate through all pages to view responses
                survey.showNavigationButtons = true
                survey.showCompletedPage = false
                // Show progress bar to indicate multiple pages
                survey.showProgressBar = "top"
                survey.progressBarType = "pages";                // Render the survey - same as CompleteSurvey page
                const surveyContainer = document.getElementById("surveyResultContainer")
                if (!surveyContainer) {                    throw new Error('Survey container not found')
                }                survey.render(surveyContainer);                );            } catch (error) {                const container = document.getElementById('surveyResultContainer')
                if (container) {
                    container.innerHTML = 
                        '<div class="alert alert-danger">' +
                        '<i class="bi bi-exclamation-triangle me-2"></i>' +
                        '<strong>Error:</strong> ' + (error.message || 'Error loading survey results. Please contact support.') +
                        '</div>'
                }
            }
        })()
    </script>
}

@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}
