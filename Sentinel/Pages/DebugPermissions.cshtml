@page
@model Sentinel.Pages.DebugPermissionsModel

@{
    ViewData["Title"] = "Debug Permissions";
}

<div class="container mt-4">
    <h2>Debug Permissions</h2>
    
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="card mb-3">
            <div class="card-header bg-info text-white">
                <h5>User Information</h5>
            </div>
            <div class="card-body">
                <p><strong>User ID:</strong> @Model.UserId</p>
                <p><strong>User Name:</strong> @Model.UserName</p>
                <p><strong>Roles:</strong> @string.Join(", ", User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role).Select(c => c.Value))</p>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <h5>Specific Permission Checks</h5>
            </div>
            <div class="card-body">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Permission</th>
                            <th>Has Permission?</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var check in Model.SpecificChecks)
                        {
                            <tr>
                                <td>@check.Key</td>
                                <td>
                                    @if (check.Value)
                                    {
                                        <span class="badge bg-success">? YES</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">? NO</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header bg-success text-white">
                <h5>All User Permissions (@Model.UserPermissions.Count)</h5>
            </div>
            <div class="card-body">
                @if (Model.UserPermissions.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Module</th>
                                <th>Action</th>
                                <th>Name</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var perm in Model.UserPermissions.OrderBy(p => p.Module).ThenBy(p => p.Action))
                            {
                                <tr>
                                    <td>@perm.Module</td>
                                    <td>@perm.Action</td>
                                    <td><code>@perm.Name</code></td>
                                    <td>@perm.Description</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-warning">
                        <strong>No permissions found!</strong> This user has no permissions assigned.
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <strong>Not authenticated.</strong> Please <a asp-area="Identity" asp-page="/Account/Login">log in</a> to see your permissions.
        </div>
    }
</div>
