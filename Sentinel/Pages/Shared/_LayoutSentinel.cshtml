@using Microsoft.AspNetCore.Identity
@using Sentinel.Models
@inject UserManager<ApplicationUser> UserManager
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@*
  Sentinel Design System Layout v0.2
  Watchful. Modern. Quiet.
*@
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sentinel</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="~/Icons/sentinel-icon.svg" />
    <link rel="alternate icon" href="~/Icons/sentinel-favicon.ico" />

    <!-- Bootstrap + Icons (for compatibility) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />

    <!-- Sentinel Design System -->
    <link rel="stylesheet" href="~/css/sentinel-design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <link href="/_content/AntDesign/css/ant-design-blazor.css" rel="stylesheet" />
    
    <!-- jQuery UI for autocomplete -->
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css" />
    
    <!-- Select2 for enhanced dropdowns -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    
    <!-- SurveyJS for survey rendering -->
    <link href="https://unpkg.com/survey-core@1.12.4/defaultV2.min.css" rel="stylesheet" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <div class="sentinel-layout">
        <!-- Mobile Toggle -->
        <button class="sidebar-toggle" onclick="toggleSidebar()">
            <i class="bi bi-list"></i>
        </button>

        <!-- Sidebar Navigation -->
        <aside class="sentinel-sidebar" id="sentinelSidebar">
            <!-- Brand -->
            <div class="brand">
                <div class="brand-icon">
                    <!-- Sentinel Logo SVG -->
                    <svg viewBox="0 0 80 80" width="40" height="40">
                        <rect width="80" height="80" rx="10" fill="#0C2A20"/>
                        <g fill="none" stroke="#3DD598" stroke-width="1.5">
                            <circle cx="40" cy="40" r="12"/>
                            <circle cx="40" cy="40" r="20" opacity="0.55"/>
                            <circle cx="40" cy="40" r="28" opacity="0.25"/>
                        </g>
                        <circle cx="40" cy="40" r="5" fill="#3DD598"/>
                    </svg>
                </div>
                <span class="brand-name">Sentinel</span>
            </div>

            <!-- Workbench Section -->
            <div class="nav-section">
                <div class="nav-section-title">Workbench</div>
                <a href="/" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")">
                    <span>Dashboard</span>
                </a>
                <a href="/Cases/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Cases") == true ? "active" : "")">
                    <span>Cases</span>
                    <span class="nav-count">→</span>
                </a>
                <a href="/Patients/Search" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Patients") == true ? "active" : "")">
                    <span>Patients</span>
                    <span class="nav-count">→</span>
                </a>
                <a href="/Contacts/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Contacts") == true ? "active" : "")">
                    <span>Contacts</span>
                    <span class="nav-count">→</span>
                </a>
                <a href="/Events/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Events") == true ? "active" : "")">
                    <span>Events</span>
                    <span class="nav-count">→</span>
                </a>
                <a href="/Locations/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Locations") == true ? "active" : "")">
                    <span>Locations</span>
                    <span class="nav-count">→</span>
                </a>
                <a href="/Organizations/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Organizations") == true ? "active" : "")">
                    <span>Organizations</span>
                    <span class="nav-count">→</span>
                </a>
            </div>

            <!-- Outbreaks Section -->
            <div class="nav-section">
                <div class="nav-section-title">Outbreaks</div>
                <a href="/Outbreaks/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Outbreaks") == true ? "active" : "")">
                    <span>Active</span>
                    <span class="nav-count">→</span>
                </a>
            </div>

            <!-- Data Section -->
            <div class="nav-section">
                <div class="nav-section-title">Data</div>
                <a href="/Reports/Builder" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Reports") == true ? "active" : "")">
                    <span>Reports</span>
                    <span class="nav-count">→</span>
                </a>
                <a href="/DataInbox/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("DataInbox") == true ? "active" : "")">
                    <span>Data Inbox</span>
                    <span class="nav-count">→</span>
                </a>
            </div>

            <!-- Settings Section -->
            <div class="nav-section">
                <div class="nav-section-title">System</div>
                <a href="/Settings/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Settings") == true ? "active" : "")">
                    <span>Settings</span>
                    <span class="nav-count">→</span>
                </a>
                <a href="/Settings/About" class="nav-link">
                    <span>About</span>
                    <span class="nav-count">→</span>
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="sentinel-main">
            <!-- Header -->
            <header class="sentinel-header">
                <div>
                    <h1 class="page-title">@ViewData["Title"]</h1>
                    @if (ViewData["Subtitle"] != null)
                    {
                        <div class="page-meta">@ViewData["Subtitle"]</div>
                    }
                </div>
                <div class="header-spacer"></div>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="dropdown">
                        <button class="btn-sentinel-secondary dropdown-toggle" type="button" id="userMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="display: flex; align-items: center; gap: var(--spacing-2);">
                            <i class="bi bi-person-circle"></i>
                            <span>@User.Identity.Name.Split('@')[0]</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenuDropdown" style="border: 1px solid var(--hairline); border-radius: var(--radius-md); box-shadow: var(--shadow-lg); min-width: 200px;">
                            <li>
                                <div class="dropdown-header" style="font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--graphite); padding: var(--spacing-2) var(--spacing-4);">
                                    @User.Identity.Name
                                </div>
                            </li>
                            <li><hr class="dropdown-divider" style="border-color: var(--hairline); margin: var(--spacing-2) 0;"></li>
                            <li>
                                <a class="dropdown-item" href="/Settings/Index" style="padding: var(--spacing-2) var(--spacing-4); color: var(--forest); font-size: 14px; transition: background var(--transition-normal);">
                                    <i class="bi bi-gear me-2"></i>Settings
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/Settings/About" style="padding: var(--spacing-2) var(--spacing-4); color: var(--forest); font-size: 14px; transition: background var(--transition-normal);">
                                    <i class="bi bi-info-circle me-2"></i>About
                                </a>
                            </li>
                            <li><hr class="dropdown-divider" style="border-color: var(--hairline); margin: var(--spacing-2) 0;"></li>
                            <li>
                                <form method="post" action="/Identity/Account/Logout" style="margin: 0;">
                                    <button type="submit" class="dropdown-item" style="padding: var(--spacing-2) var(--spacing-4); color: var(--status-outbreak); font-size: 14px; width: 100%; text-align: left; background: none; border: none; cursor: pointer; transition: background var(--transition-normal);">
                                        <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
            </header>

            <!-- Page Content -->
            <div class="sentinel-container">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="/_content/AntDesign/js/ant-design-blazor.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Apple Navigation Script -->
    <script src="~/js/apple-navigation.js" asp-append-version="true"></script>

    <!-- Autocomplete Utility -->
    <script src="~/js/autocomplete.js" asp-append-version="true"></script>

    <!-- Geocoding Service -->
    <script src="~/js/geocoding.js" asp-append-version="true"></script>
    <script>
        SentinelGeocoding.init({
            provider: '@(Configuration["Geocoding:Provider"] ?? "nominatim")',
            apiKey: '@(Configuration["Geocoding:ApiKey"] ?? "")',
            email: '@(Configuration["Geocoding:Email"] ?? "")',
            defaultCountry: '@(Configuration["Organization:CountryCode"] ?? "AU")'
        });
    </script>

    <script>
        // Sidebar toggle for mobile
        function toggleSidebar() {
            document.getElementById('sentinelSidebar').classList.toggle('open');
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
