    <!-- jQuery (required for jQuery UI) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            var layout = document.getElementById('layoutWrapper');
            var toggle = document.getElementById('sidebarToggle');
            var overlay = document.getElementById('layoutOverlay');
            var sidebar = document.getElementById('siteSidebar');

            // Toggles collapsed state for desktop/tablet
            function toggleSidebarCollapsed() {
                var isCollapsed = layout.classList.contains('sidebar-collapsed');
                if (isCollapsed) {
                    layout.classList.remove('sidebar-collapsed');
                    toggle.setAttribute('aria-expanded', 'true');
                } else {
                    layout.classList.add('sidebar-collapsed');
                    toggle.setAttribute('aria-expanded', 'false');
                }
            }

            // Mobile show/hide
            function showMobileSidebar() {
                sidebar.classList.add('show-mobile');
                overlay.classList.add('show');
                overlay.setAttribute('aria-hidden', 'false');
            }

            function hideMobileSidebar() {
                sidebar.classList.remove('show-mobile');
                overlay.classList.remove('show');
                overlay.setAttribute('aria-hidden', 'true');
            }

            // Toggle behavior adapts by viewport width
            toggle.addEventListener('click', function () {
                if (window.matchMedia('(max-width: 767.98px)').matches) {
                    // mobile: open/close overlay sidebar
                    if (sidebar.classList.contains('show-mobile')) {
                        hideMobileSidebar();
                    } else {
                        showMobileSidebar();
                    }
                } else {
                    // desktop: collapse/expand
                    toggleSidebarCollapsed();
                }
            });

            // clicking overlay hides mobile sidebar
            overlay.addEventListener('click', function () {
                hideMobileSidebar();
            });

            // preserve collapsed state across reloads (optional)
            (function restoreState() {
                try {
                    var stored = localStorage.getItem('sidebarCollapsed');
                    if (stored === 'true' && window.matchMedia('(min-width: 768px)').matches) {
                        layout.classList.add('sidebar-collapsed');
                        toggle.setAttribute('aria-expanded', 'false');
                    }
                } catch (e) { /* ignore */ }
            })();

            // save state when window changes (desktop collapse only)
            window.addEventListener('beforeunload', function () {
                try {
                    localStorage.setItem('sidebarCollapsed', layout.classList.contains('sidebar-collapsed'));
                } catch (e) { /* ignore */ }
            });

            // Close mobile sidebar on navigation (progressive enhancement)
            document.querySelectorAll('.sidebar .nav-link').forEach(function (link) {
                link.addEventListener('click', function () {
                    if (window.matchMedia('(max-width: 767.98px)').matches) {
                        hideMobileSidebar();
                    }
                });
            });
        })();
    </script>
    
    <!-- Select2 for enhanced dropdowns -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <!-- SurveyJS for survey rendering -->
    <script src="https://unpkg.com/survey-core@1.12.4/survey.core.min.js"></script>
    <script src="https://unpkg.com/survey-js-ui@1.12.4/survey-js-ui.min.js"></script>
    
    <!-- Chart.js for epidemic curves and visualizations -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    
    <script>
        // Register custom date functions for SurveyJS
        if (typeof Survey !== 'undefined' && Survey.FunctionFactory && Survey.FunctionFactory.Instance) {
            console.log('Registering SurveyJS custom functions...');
            
            // today() - returns current date as YYYY-MM-DD
            Survey.FunctionFactory.Instance.register("today", function() {
                const today = new Date();
                return today.toISOString().split('T')[0];
            });

            // currentDate() - alias for today()
            Survey.FunctionFactory.Instance.register("currentDate", function() {
                const today = new Date();
                return today.toISOString().split('T')[0];
            });

            // age(birthDate) - calculate age from birth date
            Survey.FunctionFactory.Instance.register("age", function(params) {
                if (params.length < 1 || !params[0]) return null;
                const birthDate = new Date(params[0]);
                if (isNaN(birthDate.getTime())) return null;
                
                const today = new Date();
                let age = today.getFullYear() - birthDate.getFullYear();
                const monthDiff = today.getMonth() - birthDate.getMonth();
                
                if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) {
                    age--;
                }
                
                return age;
            });

            // addDays(date, days) - add days to a date
            Survey.FunctionFactory.Instance.register("addDays", function(params) {
                if (params.length < 2) return null;
                const dateStr = params[0];
                const daysToAdd = parseInt(params[1]);
                
                if (!dateStr || isNaN(daysToAdd)) return null;
                
                const date = new Date(dateStr);
                if (isNaN(date.getTime())) return null;
                
                date.setDate(date.getDate() + daysToAdd);
                return date.toISOString().split('T')[0];
            });

            // dateDiff(date1, date2) - calculate difference in days
            Survey.FunctionFactory.Instance.register("dateDiff", function(params) {
                if (params.length < 2) return null;
                const date1Str = params[0];
                const date2Str = params[1];
                
                if (!date1Str || !date2Str) return null;
                
                const date1 = new Date(date1Str);
                const date2 = new Date(date2Str);
                
                if (isNaN(date1.getTime()) || isNaN(date2.getTime())) return null;
                
                const diffTime = Math.abs(date2 - date1);
                const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                return diffDays;
            });
            
            console.log('SurveyJS custom functions registered successfully');
        } else {
            console.warn('SurveyJS not loaded - custom functions not registered');
        }
    </script>

