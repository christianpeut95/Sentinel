@page "/tools/test-data-generator"
@model Sentinel.Pages.Tools.TestDataGeneratorModel
@{
    ViewData["Title"] = "Test Data Generator";
}
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}

<div class="apple-container">
    <div class="apple-header">
        <h1><i class="bi bi-diagram-3"></i> Test Data Generator</h1>
        <p class="subtitle">Generate realistic test data for development and testing</p>
    </div>

    <!-- Tab Navigation -->
    <ul class="nav nav-tabs mb-4" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="patients-tab" data-bs-toggle="tab" data-bs-target="#patients-panel" type="button" role="tab">
                <i class="bi bi-people me-2"></i>Patients
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="cases-tab" data-bs-toggle="tab" data-bs-target="#cases-panel" type="button" role="tab">
                <i class="bi bi-file-medical me-2"></i>Historical Cases
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <!-- PATIENTS TAB -->
        <div class="tab-pane fade show active" id="patients-panel" role="tabpanel">
            <div class="apple-card">
                <div class="card-header">
                    <h2><i class="bi bi-person-plus"></i> Patient Data Generation</h2>
                </div>
                <div class="card-body">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                <strong>About this tool:</strong> Generates realistic patient data using Australian names, Adelaide addresses, 
                proper phone numbers, and email addresses. Can optionally geocode addresses and assign jurisdictions.
            </div>

            <form method="post">
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="PatientCount" class="form-label">Number of Patients</label>
                        <input asp-for="PatientCount" class="form-control form-control-lg" min="1" max="500" />
                        <small class="text-muted">Recommended: 10-100 patients</small>
                        <span asp-validation-for="PatientCount" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Options</label>
                        <div class="form-check form-switch">
                            <input asp-for="UseGeocoding" class="form-check-input" type="checkbox" id="geocodingSwitch">
                            <label class="form-check-label" for="geocodingSwitch">
                                <strong>Enable Geocoding & Jurisdiction Assignment</strong>
                                <br />
                                <small class="text-muted">Geocodes addresses and assigns jurisdictions (slower but more realistic)</small>
                            </label>
                        </div>
                    </div>
                </div>

                @if (Model.Result != null)
                {
                    <div class="alert @(Model.Result.HasErrors ? "alert-warning" : "alert-success") mb-4">
                        <h5 class="alert-heading">
                            @if (Model.Result.HasErrors)
                            {
                                <i class="bi bi-exclamation-triangle me-2"></i>
                                <text>Generation Completed with Warnings</text>
                            }
                            else
                            {
                                <i class="bi bi-check-circle me-2"></i>
                                <text>Generation Successful!</text>
                            }
                        </h5>
                        
                        <div class="row g-3 mt-2">
                            <div class="col-md-3">
                                <div class="stat-card">
                                    <div class="stat-value">@Model.Result.PatientsCreated</div>
                                    <div class="stat-label">Patients Created</div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="stat-card">
                                    <div class="stat-value">@Model.Result.Errors.Count</div>
                                    <div class="stat-label">Errors</div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="stat-card">
                                    <div class="stat-value">@Model.Result.Duration.TotalSeconds.ToString("F1")s</div>
                                    <div class="stat-label">Duration</div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="stat-card">
                                    <div class="stat-value">@((Model.Result.PatientsCreated / Math.Max(Model.Result.Duration.TotalSeconds, 0.1)).ToString("F1"))/s</div>
                                    <div class="stat-label">Rate</div>
                                </div>
                            </div>
                        </div>

                        @if (Model.Result.HasErrors)
                        {
                            <details class="mt-3">
                                <summary class="btn btn-sm btn-outline-warning">View @Model.Result.Errors.Count Error(s)</summary>
                                <div class="mt-2 p-3 bg-light rounded">
                                    @foreach (var error in Model.Result.Errors)
                                    {
                                        <div class="text-danger small">• @error</div>
                                    }
                                </div>
                            </details>
                        }

                        <div class="mt-3">
                            <a href="/patients" class="btn btn-success">
                                <i class="bi bi-people me-2"></i>View Patients
                            </a>
                        </div>
                    </div>
                }

                <div class="d-flex gap-2">
                    <button type="submit" asp-page-handler="Generate" class="btn btn-primary btn-lg">
                        <i class="bi bi-play-fill me-2"></i>
                        Generate @Model.PatientCount Patient@(Model.PatientCount != 1 ? "s" : "")
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Configuration Summary -->
    <div class="apple-card mt-4">
        <div class="card-header">
            <h3><i class="bi bi-gear"></i> Configuration</h3>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <h5>Data Sources</h5>
                    <ul class="list-unstyled">
                        <li><i class="bi bi-check-circle text-success me-2"></i>70 Australian first names</li>
                        <li><i class="bi bi-check-circle text-success me-2"></i>70 Australian last names</li>
                        <li><i class="bi bi-check-circle text-success me-2"></i>43 Adelaide suburbs</li>
                        <li><i class="bi bi-check-circle text-success me-2"></i>Australian phone formats (04XX & 08)</li>
                        <li><i class="bi bi-check-circle text-success me-2"></i>Realistic email addresses</li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <h5>Features</h5>
                    <ul class="list-unstyled">
                        <li><i class="bi bi-check-circle text-success me-2"></i>Random ages (0-100 years)</li>
                        <li><i class="bi bi-check-circle text-success me-2"></i>Adelaide postcodes (5000-5999)</li>
                        <li><i class="bi bi-check-circle text-success me-2"></i>Optional geocoding integration</li>
                        <li><i class="bi bi-check-circle text-success me-2"></i>Automatic jurisdiction assignment</li>
                        <li><i class="bi bi-check-circle text-success me-2"></i>Batch processing (saves every 10)</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions for Patients -->
    <div class="row g-3 mt-4">
        <div class="col-md-4">
            <form method="post" asp-page-handler="Quick">
                <input type="hidden" name="count" value="10" />
                <button type="submit" class="quick-action-card w-100">
                    <div class="icon"><i class="bi bi-lightning"></i></div>
                    <h4>Quick Test</h4>
                    <p>10 patients, no geocoding</p>
                    <small class="text-muted">~5 seconds</small>
                </button>
            </form>
        </div>
        <div class="col-md-4">
            <form method="post" asp-page-handler="Quick">
                <input type="hidden" name="count" value="50" />
                <button type="submit" class="quick-action-card w-100">
                    <div class="icon"><i class="bi bi-people"></i></div>
                    <h4>Standard Set</h4>
                    <p>50 patients, with geocoding</p>
                    <small class="text-muted">~2 minutes</small>
                </button>
            </form>
        </div>
        <div class="col-md-4">
            <form method="post" asp-page-handler="Quick">
                <input type="hidden" name="count" value="100" />
                <button type="submit" class="quick-action-card w-100">
                    <div class="icon"><i class="bi bi-database"></i></div>
                    <h4>Full Dataset</h4>
                    <p>100 patients, with geocoding</p>
                    <small class="text-muted">~4 minutes</small>
                </button>
            </form>
        </div>
    </div>
</div>

        <!-- CASES TAB -->
        <div class="tab-pane fade" id="cases-panel" role="tabpanel">
            <div class="apple-card">
                <div class="card-header">
                    <h2><i class="bi bi-file-medical"></i> Historical Case Data Generation</h2>
                </div>
                <div class="card-body">
                    @if (TempData["CaseSuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle me-2"></i>
                            @TempData["CaseSuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>About this tool:</strong> Generates historical case data across multiple years for year-over-year reporting and analysis. 
                        Includes realistic dates, confirmation statuses, hospitalizations, and custom field data.
                    </div>

                    <form method="post" asp-page-handler="GenerateCases">
                        <div class="row g-3 mb-4">
                            <div class="col-md-3">
                                <label asp-for="StartYear" class="form-label fw-bold">Start Year</label>
                                <input asp-for="StartYear" class="form-control form-control-lg" min="2015" max="2030" type="number" />
                                <span asp-validation-for="StartYear" class="text-danger"></span>
                            </div>

                            <div class="col-md-3">
                                <label asp-for="EndYear" class="form-label fw-bold">End Year</label>
                                <input asp-for="EndYear" class="form-control form-control-lg" min="2015" max="2030" type="number" />
                                <span asp-validation-for="EndYear" class="text-danger"></span>
                            </div>

                            <div class="col-md-3">
                                <label asp-for="CasesPerYear" class="form-label fw-bold">Cases Per Year</label>
                                <input asp-for="CasesPerYear" class="form-control form-control-lg" min="10" max="500" type="number" />
                                <small class="text-muted d-block">10-200 recommended</small>
                                <span asp-validation-for="CasesPerYear" class="text-danger"></span>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label fw-bold">Target Diseases</label>
                                <select asp-for="SelectedDiseaseIds" asp-items="Model.AvailableDiseases" class="form-select form-control-lg" multiple>
                                </select>
                                <small class="text-muted d-block">Leave blank for all diseases</small>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-12">
                                <label class="form-label fw-bold">Generation Options</label>
                                
                                <div class="form-check form-switch mb-2">
                                    <input asp-for="IncludeCustomFields" class="form-check-input" type="checkbox" id="customFieldsSwitch">
                                    <label class="form-check-label" for="customFieldsSwitch">
                                        <strong>Include Custom Field Data</strong>
                                        <br />
                                        <small class="text-muted">Populates disease-specific custom fields with realistic test values</small>
                                    </label>
                                </div>

                                <div class="form-check form-switch mb-2">
                                    <input asp-for="IncludeLabResults" class="form-check-input" type="checkbox" id="labResultsSwitch">
                                    <label class="form-check-label" for="labResultsSwitch">
                                        <strong>Generate Lab Results</strong>
                                        <br />
                                        <small class="text-muted">Creates lab results for ~60% of cases</small>
                                    </label>
                                </div>

                                <div class="form-check form-switch">
                                    <input asp-for="UseSeasonalPatterns" class="form-check-input" type="checkbox" id="seasonalSwitch">
                                    <label class="form-check-label" for="seasonalSwitch">
                                        <strong>Use Seasonal Patterns</strong>
                                        <br />
                                        <small class="text-muted">Distributes cases realistically (e.g., flu in winter, gastro in summer)</small>
                                    </label>
                                </div>
                            </div>
                        </div>

                        @if (Model.CaseResult != null)
                        {
                            <div class="alert @(Model.CaseResult.HasErrors ? "alert-warning" : "alert-success") mb-4">
                                <h5 class="alert-heading">
                                    @if (Model.CaseResult.HasErrors)
                                    {
                                        <i class="bi bi-exclamation-triangle me-2"></i>
                                        <text>Generation Completed with Warnings</text>
                                    }
                                    else
                                    {
                                        <i class="bi bi-check-circle me-2"></i>
                                        <text>Generation Successful!</text>
                                    }
                                </h5>
                                
                                <div class="row g-3 mt-2">
                                    <div class="col-md-2">
                                        <div class="stat-card">
                                            <div class="stat-value">@Model.CaseResult.CasesCreated</div>
                                            <div class="stat-label">Cases</div>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="stat-card">
                                            <div class="stat-value">@Model.CaseResult.LabResultsCreated</div>
                                            <div class="stat-label">Lab Results</div>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="stat-card">
                                            <div class="stat-value">@Model.CaseResult.CustomFieldsCreated</div>
                                            <div class="stat-label">Custom Fields</div>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="stat-card">
                                            <div class="stat-value">@Model.CaseResult.Errors.Count</div>
                                            <div class="stat-label">Errors</div>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="stat-card">
                                            <div class="stat-value">@Model.CaseResult.Duration.TotalSeconds.ToString("F1")s</div>
                                            <div class="stat-label">Duration</div>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="stat-card">
                                            <div class="stat-value">@((Model.CaseResult.CasesCreated / Math.Max(Model.CaseResult.Duration.TotalSeconds, 0.1)).ToString("F1"))/s</div>
                                            <div class="stat-label">Rate</div>
                                        </div>
                                    </div>
                                </div>

                                @if (Model.CaseResult.HasErrors)
                                {
                                    <details class="mt-3">
                                        <summary class="btn btn-sm btn-outline-warning">View @Model.CaseResult.Errors.Count Error(s)</summary>
                                        <div class="mt-2 p-3 bg-light rounded">
                                            @foreach (var error in Model.CaseResult.Errors)
                                            {
                                                <div class="text-danger small">• @error</div>
                                            }
                                        </div>
                                    </details>
                                }

                                <div class="mt-3">
                                    <a href="/cases" class="btn btn-success">
                                        <i class="bi bi-file-medical me-2"></i>View Cases
                                    </a>
                                </div>
                            </div>
                        }

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-calendar-range me-2"></i>
                                Generate Historical Cases
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Quick Presets for Cases -->
            <div class="row g-3 mt-4">
                <div class="col-md-4">
                    <form method="post" asp-page-handler="QuickCases">
                        <input type="hidden" name="preset" value="test" />
                        <button type="submit" class="quick-action-card w-100">
                            <div class="icon"><i class="bi bi-clipboard-data"></i></div>
                            <h4>Test Dataset</h4>
                            <p>2024-2025, 50 cases/year</p>
                            <small class="text-muted">All diseases, with custom fields</small>
                        </button>
                    </form>
                </div>
                <div class="col-md-4">
                    <form method="post" asp-page-handler="QuickCases">
                        <input type="hidden" name="preset" value="comparison" />
                        <button type="submit" class="quick-action-card w-100">
                            <div class="icon"><i class="bi bi-bar-chart-line"></i></div>
                            <h4>5-Year Comparison</h4>
                            <p>2020-2024, 100 cases/year</p>
                            <small class="text-muted">For year-over-year analysis</small>
                        </button>
                    </form>
                </div>
                <div class="col-md-4">
                    <form method="post" asp-page-handler="QuickCases">
                        <input type="hidden" name="preset" value="full" />
                        <button type="submit" class="quick-action-card w-100">
                            <div class="icon"><i class="bi bi-calendar3-range"></i></div>
                            <h4>Full Historical</h4>
                            <p>2019-2025, 150 cases/year</p>
                            <small class="text-muted">Complete test dataset</small>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- System Status (outside tabs) -->
    <div class="apple-card mt-4">
        <div class="card-header">
            <h3><i class="bi bi-activity"></i> System Status</h3>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="stat-value">@Model.CurrentPatientCount</div>
                        <div class="stat-label">Patients in Database</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="stat-value">@Model.CurrentCaseCount</div>
                        <div class="stat-label">Cases in Database</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="stat-value">@Model.ActiveDiseaseCount</div>
                        <div class="stat-label">Active Diseases</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .stat-card {
        text-align: center;
        padding: 1rem;
        background: rgba(0, 123, 255, 0.05);
        border-radius: 8px;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: bold;
        color: #007bff;
    }

    .stat-label {
        font-size: 0.875rem;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .quick-action-card {
        cursor: pointer;
        padding: 2rem;
        background: white;
        border: 2px solid #e9ecef;
        border-radius: 12px;
        text-align: center;
        transition: all 0.3s ease;
        display: block;
        text-decoration: none;
        color: inherit;
    }

    .quick-action-card:hover {
        border-color: #007bff;
        transform: translateY(-4px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.1);
    }

    .quick-action-card .icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .quick-action-card h4 {
        margin-bottom: 0.5rem;
        color: #212529;
    }

    .quick-action-card p {
        margin-bottom: 0.5rem;
        color: #6c757d;
    }

    details summary {
        cursor: pointer;
        user-select: none;
    }

    details summary::-webkit-details-marker {
        display: none;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
