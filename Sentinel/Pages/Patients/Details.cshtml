@page
@model Sentinel.Pages.Patients.DetailsModel
@using Sentinel.Models
@using Sentinel.Models.Lookups

@{
    ViewData["Title"] = $"{Model.Patient.GivenName} {Model.Patient.FamilyName}";
    ViewData["Subtitle"] = $"Patient ID: {Model.Patient.FriendlyId}";

    // Calculate age
    int? age = null;
    if (Model.Patient.DateOfBirth.HasValue)
    {
        var today = DateTime.UtcNow;
        age = today.Year - Model.Patient.DateOfBirth.Value.Year;
        if (Model.Patient.DateOfBirth.Value.Date > today.AddYears(-age.Value)) age--;
    }
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="background: var(--signal-lt); border: 1px solid var(--signal); color: var(--forest);">
        <i class="bi bi-check-circle-fill me-2" style="color: var(--signal-dk);"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="background: #FBE2D8; border: 1px solid #F2BBA4; color: #7A2A15;">
        <i class="bi bi-exclamation-triangle-fill me-2" style="color: var(--status-outbreak);"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Page Header -->
<div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--spacing-6); flex-wrap: wrap; gap: var(--spacing-4);">
    <div>
        <h1 style="font-family: var(--f-sans); font-weight: 600; font-size: 28px; letter-spacing: -0.02em; color: var(--forest); margin: 0; display: flex; align-items: center; gap: var(--spacing-2);">
            <i class="bi bi-person-badge" style="color: var(--signal-dk);"></i>
            @Model.Patient.GivenName @Model.Patient.FamilyName
        </h1>
        <div style="margin-top: var(--spacing-2); display: flex; align-items: center; gap: var(--spacing-3);">
            <span class="friendly-id" style="font-family: var(--f-mono); font-weight: 600; color: var(--signal-dk); background: var(--signal-lt); padding: 4px 8px; border-radius: var(--radius-sm); font-size: 11px; border: 1px solid var(--signal);">
                @Model.Patient.FriendlyId
            </span>
            @if (Model.Patient.IsDeceased)
            {
                <span class="chip-clear" style="background: var(--graphite); color: var(--chalk);">
                    <span class="dot" style="background: var(--chalk);"></span>
                    Deceased
                </span>
            }
        </div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        @if (User.HasClaim(c => c.Type == "Permission" && c.Value == "Case.Create"))
        {
            <a asp-page="/Cases/Create" asp-route-patientId="@Model.Patient.Id" class="btn-sentinel-primary">
                <i class="bi bi-virus"></i> Create Case
            </a>
        }
        <a asp-page="./Edit" asp-route-id="@Model.Patient.Id" class="btn-sentinel-primary">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <button type="button" class="btn-sentinel-secondary" data-bs-toggle="modal" data-bs-target="#addNoteModal">
            <i class="bi bi-plus-circle"></i> Add Note
        </button>
        <div class="dropdown">
            <button class="btn-sentinel-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-three-dots"></i> More
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" asp-page="./AuditHistory" asp-route-id="@Model.Patient.Id">
                    <i class="bi bi-clock-history me-2"></i>Audit History
                </a></li>
                <li><a class="dropdown-item" asp-page="./SelectMerge" asp-route-patientId="@Model.Patient.Id">
                    <i class="bi bi-arrows-collapse me-2"></i>Merge Patient
                </a></li>
                @if (User.HasClaim(c => c.Type == "Permission" && c.Value == "Patient.Delete"))
                {
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" asp-page="./Delete" asp-route-id="@Model.Patient.Id">
                        <i class="bi bi-trash me-2"></i>Delete
                    </a></li>
                }
            </ul>
        </div>
        <a asp-page="./Index" class="btn-sentinel-secondary">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>
        <div class="row">
                <div class="col-md-6 mb-4">
                    <div class="sentinel-card">
                        <div class="sentinel-card-header">
                            <h3 class="sentinel-card-title">
                                <i class="bi bi-person"></i>Demographics
                            </h3>
                        </div>
                        <div class="sentinel-card-body">
                            <div class="row mb-3">
                                <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">Patient ID</div>
                                <div class="col-sm-7" style="font-weight: 500;">
                                    @if (!string.IsNullOrWhiteSpace(Model.Patient.FriendlyId))
                                    {
                                        <span class="friendly-id" style="font-family: var(--f-mono); font-weight: 600; color: var(--signal-dk); background: var(--signal-lt); padding: 4px 8px; border-radius: var(--radius-sm); font-size: 11px; border: 1px solid var(--signal);">
                                            @Model.Patient.FriendlyId
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="color: var(--graphite);">—</span>
                                    }
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">First Name</div>
                                <div class="col-sm-7" style="font-weight: 500; color: var(--forest);">@Model.Patient.GivenName</div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">Last Name</div>
                                <div class="col-sm-7" style="font-weight: 500; color: var(--forest);">@Model.Patient.FamilyName</div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">Date of Birth</div>
                                <div class="col-sm-7" style="font-weight: 500;">
                                    @(Model.Patient.DateOfBirth?.ToString("dd MMM yyyy") ?? "—")
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">Age</div>
                                <div class="col-sm-7" style="font-weight: 500;">
                                    @if (age.HasValue)
                                    {
                                        <span class="chip-info">
                                            <span class="dot"></span>
                                            @age years
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="color: var(--graphite);">—</span>
                                    }
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">@Html.DisplayNameFor(m => m.Patient.SexAtBirthId)</div>
                        <div class="col-sm-7" style="font-weight: 500;">@(Model.Patient.SexAtBirth?.Name ?? "—")</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">@Html.DisplayNameFor(m => m.Patient.GenderId)</div>
                        <div class="col-sm-7" style="font-weight: 500;">@(Model.Patient.Gender?.Name ?? "—")</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">Country of Birth</div>
                        <div class="col-sm-7" style="font-weight: 500;">@(Model.Patient.CountryOfBirth?.Name ?? "—")</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">Language Spoken at Home</div>
                        <div class="col-sm-7" style="font-weight: 500;">@(Model.Patient.LanguageSpokenAtHome?.Name ?? "—")</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">Ancestry</div>
                        <div class="col-sm-7" style="font-weight: 500;">@(Model.Patient.Ancestry?.Name ?? "—")</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">@Html.DisplayNameFor(m => m.Patient.AtsiStatusId)</div>
                        <div class="col-sm-7" style="font-weight: 500;">@(Model.Patient.AtsiStatus?.Name ?? "—")</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">@Html.DisplayNameFor(m => m.Patient.OccupationId)</div>
                        <div class="col-sm-7" style="font-weight: 500;">@(Model.Patient.Occupation?.Name ?? "—")</div>
                    </div>

                    <hr style="border-color: var(--hairline);" />

                    <div class="row mb-3">
                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">Deceased</div>
                        <div class="col-sm-7" style="font-weight: 500;">
                            @if (Model.Patient.IsDeceased)
                            {
                                <span class="chip-clear" style="background: var(--graphite); color: var(--chalk);">
                                    <span class="dot" style="background: var(--chalk);"></span>
                                    Yes
                                </span>
                                @if (Model.Patient.DateOfDeath.HasValue)
                                {
                                    <br /><small style="color: var(--graphite); font-size: 11px;">@Model.Patient.DateOfDeath.Value.ToString("dd MMM yyyy")</small>
                                }
                            }
                            else
                            {
                                <span class="chip-info">
                                    <span class="dot"></span>
                                    No
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="sentinel-card" style="margin-bottom: var(--spacing-4);">
                <div class="sentinel-card-header">
                    <h3 class="sentinel-card-title">
                        <i class="bi bi-telephone"></i>Contact Information
                    </h3>
                </div>
                <div class="sentinel-card-body">
                    <div class="row mb-3">
                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">@Html.DisplayNameFor(m => m.Patient.HomePhone)</div>
                        <div class="col-sm-7" style="font-weight: 500;">
                            @if (!string.IsNullOrWhiteSpace(Model.Patient.HomePhone))
                            {
                                <a href="tel:@Model.Patient.HomePhone" style="color: var(--signal-dk); text-decoration: none;">
                                    <i class="bi bi-telephone"></i> @Model.Patient.HomePhone
                                </a>
                            }
                            else
                            {
                                <span style="color: var(--graphite);">—</span>
                            }
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">@Html.DisplayNameFor(m => m.Patient.MobilePhone)</div>
                        <div class="col-sm-7" style="font-weight: 500;">
                            @if (!string.IsNullOrWhiteSpace(Model.Patient.MobilePhone))
                            {
                                <a href="tel:@Model.Patient.MobilePhone" style="color: var(--signal-dk); text-decoration: none;">
                                    <i class="bi bi-phone"></i> @Model.Patient.MobilePhone
                                </a>
                            }
                            else
                            {
                                <span style="color: var(--graphite);">—</span>
                            }
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">@Html.DisplayNameFor(m => m.Patient.EmailAddress)</div>
                        <div class="col-sm-7" style="font-weight: 500;">
                            @if (!string.IsNullOrWhiteSpace(Model.Patient.EmailAddress))
                            {
                                <a href="mailto:@Model.Patient.EmailAddress" style="color: var(--signal-dk); text-decoration: none;">
                                    <i class="bi bi-envelope"></i> @Model.Patient.EmailAddress
                                </a>
                            }
                            else
                            {
                                <span style="color: var(--graphite);">—</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="sentinel-card">
                <div class="sentinel-card-header">
                    <h3 class="sentinel-card-title">
                        <i class="bi bi-geo-alt"></i>Address
                    </h3>
                </div>
                <div class="sentinel-card-body">
                    <div class="row mb-3">
                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">Address</div>
                        <div class="col-sm-7" style="font-weight: 500;">@(Model.Patient.AddressLine ?? "—")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">Suburb</div>
                        <div class="col-sm-7" style="font-weight: 500;">@(Model.Patient.City ?? "—")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">State</div>
                        <div class="col-sm-7" style="font-weight: 500;">@(Model.Patient.State?.Name ?? "—")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">Postcode</div>
                        <div class="col-sm-7" style="font-weight: 500;">@(Model.Patient.PostalCode ?? "—")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">Geocoded</div>
                        <div class="col-sm-7" style="font-weight: 500;">
                            @if (Model.Patient.Latitude.HasValue && Model.Patient.Longitude.HasValue)
                            {
                                <span class="chip-info">
                                    <span class="dot"></span>
                                    <i class="bi bi-geo-alt-fill"></i> Yes
                                </span>
                            }
                            else
                            {
                                <span class="chip-clear">
                                    <span class="dot"></span>
                                    <i class="bi bi-geo"></i> No
                                </span>
                            }
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">Coordinates</div>
                        <div class="col-sm-7" style="font-weight: 500;">
                            @if (Model.Patient.Latitude.HasValue && Model.Patient.Longitude.HasValue)
                            {
                                <small style="color: var(--graphite); font-family: var(--f-mono); font-size: 11px;">@($"{Model.Patient.Latitude.Value:F5}, {Model.Patient.Longitude.Value:F5}")</small>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Jurisdictions Card -->
            @if (Model.ActiveJurisdictionTypes.Any() && 
                (Model.Patient.Jurisdiction1Id.HasValue || 
                 Model.Patient.Jurisdiction2Id.HasValue || 
                 Model.Patient.Jurisdiction3Id.HasValue || 
                 Model.Patient.Jurisdiction4Id.HasValue || 
                 Model.Patient.Jurisdiction5Id.HasValue))
            {
                <div class="sentinel-card" style="margin-top: var(--spacing-4);">
                    <div class="sentinel-card-header">
                        <h3 class="sentinel-card-title">
                            <i class="bi bi-pin-map"></i>
                            Geographic Jurisdictions
                        </h3>
                    </div>
                    <div class="sentinel-card-body">
                        @foreach (var jurisdictionType in Model.ActiveJurisdictionTypes.OrderBy(jt => jt.DisplayOrder))
                        {
                            var jurisdiction = jurisdictionType.FieldNumber switch
                            {
                                1 => Model.Patient.Jurisdiction1,
                                2 => Model.Patient.Jurisdiction2,
                                3 => Model.Patient.Jurisdiction3,
                                4 => Model.Patient.Jurisdiction4,
                                5 => Model.Patient.Jurisdiction5,
                                _ => null
                            };

                            if (jurisdiction != null)
                            {
                                <div class="row mb-3">
                                    <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">
                                        @jurisdictionType.Name
                                        @if (!string.IsNullOrEmpty(jurisdictionType.Code))
                                        {
                                            <small style="color: var(--graphite);">(@jurisdictionType.Code)</small>
                                        }
                                    </div>
                                    <div class="col-sm-7" style="font-weight: 500;">
                                        @jurisdiction.Name
                                        @if (!string.IsNullOrEmpty(jurisdiction.Code))
                                        {
                                            <span class="chip-info" style="margin-left: var(--spacing-2);">@jurisdiction.Code</span>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    @if (Model.CustomFields.Any())
    {
        @foreach (var category in Model.FieldsByCategory)
        {
            <div class="row" style="margin-top: var(--spacing-4);">
                <div class="col-12">
                    <div class="sentinel-card">
                        <div class="sentinel-card-header">
                            <h3 class="sentinel-card-title">
                                <i class="bi bi-clipboard-data"></i>
                                @category.Key
                            </h3>
                        </div>
                        <div class="sentinel-card-body">
                            @foreach (var field in category.Value.OrderBy(f => f.DisplayOrder))
                            {
                                var hasValue = Model.CustomFieldValues.TryGetValue(field.Id, out var value) && !string.IsNullOrWhiteSpace(value);
                                var displayValue = hasValue ? value : "-";

                                @if (field.FieldType == CustomFieldType.Checkbox)
                                {
                                    <div class="row mb-3">
                                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">@field.Label</div>
                                        <div class="col-sm-7" style="font-weight: 500;">
                                            @if (displayValue == "True")
                                            {
                                                <i class="bi bi-check-square-fill" style="color: var(--signal-dk);"></i>
                                                <span>Yes</span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-square" style="color: var(--graphite);"></i>
                                                <span style="color: var(--graphite);">No</span>
                                            }
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="row mb-3">
                                        <div class="col-sm-5 text-mono" style="color: var(--graphite); font-size: 12px;">@field.Label</div>
                                        <div class="col-sm-7" style="font-weight: 500;">
                                            @if (field.FieldType == CustomFieldType.Email && hasValue)
                                            {
                                                <a href="mailto:@displayValue"><i class="bi bi-envelope"></i> @displayValue</a>
                                            }
                                            else if (field.FieldType == CustomFieldType.Phone && hasValue)
                                            {
                                                <a href="tel:@displayValue"><i class="bi bi-telephone"></i> @displayValue</a>
                                            }
                                            else if (field.FieldType == CustomFieldType.Date && hasValue && DateTime.TryParse(displayValue, out var dateValue))
                                            {
                                                @dateValue.ToString("dd MMM yyyy")
                                            }
                                            else
                                            {
                                                @displayValue
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    <!-- Patient Notes Section -->
    <div class="sentinel-card" style="margin-top: var(--spacing-5);">
        <div class="sentinel-card-header" style="display: flex; justify-content: space-between; align-items: center;">
            <h3 class="sentinel-card-title" style="margin: 0;">
                <i class="bi bi-chat-left-text"></i>
                Patient Notes
            </h3>
            <span class="chip-info">@Model.PatientNotes.Count</span>
        </div>
        <div class="sentinel-card-body">
            @if (Model.PatientNotes.Any())
            {
                @foreach (var note in Model.PatientNotes)
                {
                    <div class="note-item">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                @if (note.Type == "SMS")
                                {
                                    <span class="chip-info" style="margin-right: var(--spacing-2);"><i class="bi bi-chat-dots"></i> SMS</span>
                                }
                                else if (note.Type == "Phone Call")
                                {
                                    <span class="chip-clear" style="margin-right: var(--spacing-2); background: var(--signal-dk); color: var(--chalk);"><i class="bi bi-telephone"></i> Phone Call</span>
                                }
                                else if (note.Type == "Email")
                                {
                                    <span class="chip-info" style="margin-right: var(--spacing-2);"><i class="bi bi-envelope"></i> Email</span>
                                }
                                else
                                {
                                    <span class="chip-clear" style="margin-right: var(--spacing-2);"><i class="bi bi-chat-left-text"></i> Note</span>
                                }
                                @if (!string.IsNullOrEmpty(note.Subject))
                                {
                                    <strong>@note.Subject</strong>
                                }
                            </div>
                            <div class="d-flex align-items-center">
                                <small style="color: var(--graphite); margin-right: var(--spacing-2);">@note.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</small>
                                <form method="post" asp-page-handler="DeleteNote" asp-route-id="@Model.Patient.Id" asp-route-noteId="@note.Id" class="d-inline">
                                    <button type="submit" class="btn-sentinel-secondary" style="padding: 4px 8px; font-size: 12px; background: var(--status-outbreak); border-color: var(--status-outbreak); color: var(--chalk);" 
                                            onclick="return confirm('Are you sure you want to delete this note? This action cannot be undone.');"
                                            title="Delete note">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                        <p class="mb-2">@note.Content</p>
                        <small class="text-muted">
                            <i class="bi bi-person me-1"></i>@(note.CreatedBy ?? "Unknown")
                            @if (!string.IsNullOrEmpty(note.Recipient))
                            {
                                <span class="ms-2"><i class="bi bi-arrow-right"></i> @note.Recipient</span>
                            }
                        </small>
                        @if (!string.IsNullOrEmpty(note.AttachmentFileName))
                        {
                            <div class="mt-2">
                                <a href="@note.AttachmentPath" target="_blank" class="btn-sentinel-secondary" style="padding: 4px 10px; font-size: 12px;">
                                    <i class="bi bi-paperclip"></i> @note.AttachmentFileName
                                </a>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-chat-left-text display-1 opacity-25"></i>
                    <p class="mt-3">No notes yet. Click "Add Note" to create the first one.</p>
                </div>
            }
        </div>
    </div>

    <!-- Case Communication Notes Section -->
    @if (Model.CaseCommunicationNotes.Any())
    {
        <div class="sentinel-card" style="margin-top: var(--spacing-5);">
            <div class="sentinel-card-header" style="display: flex; justify-content: space-between; align-items: center;">
                <h3 class="sentinel-card-title" style="margin: 0;">
                    <i class="bi bi-telephone-forward"></i>
                    Case Communications
                </h3>
                <span class="chip-info">@Model.CaseCommunicationNotes.Count</span>
            </div>
            <div class="sentinel-card-body">
                <p style="color: var(--graphite); margin-bottom: var(--spacing-3); font-size: 13px;">Phone calls, emails, and SMS messages from cases related to this patient.</p>
                @foreach (var note in Model.CaseCommunicationNotes)
                {
                    <div class="note-item" style="border-left-color: #17a2b8;">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                @if (note.Type == "SMS")
                                {
                                    <span class="chip-info" style="margin-right: var(--spacing-2);"><i class="bi bi-chat-dots"></i> SMS</span>
                                }
                                else if (note.Type == "Phone Call")
                                {
                                    <span class="chip-clear" style="margin-right: var(--spacing-2); background: var(--signal-dk); color: var(--chalk);"><i class="bi bi-telephone"></i> Phone Call</span>
                                }
                                else if (note.Type == "Email")
                                {
                                    <span class="chip-info" style="margin-right: var(--spacing-2);"><i class="bi bi-envelope"></i> Email</span>
                                }
                                @if (!string.IsNullOrEmpty(note.Subject))
                                {
                                    <strong>@note.Subject</strong>
                                }
                                @if (note.Case != null)
                                {
                                    <a asp-page="/Cases/Details" asp-route-id="@note.CaseId" class="chip-clear" style="margin-left: var(--spacing-2); text-decoration: none; background: var(--bone);">
                                        <i class="bi bi-virus2"></i> @note.Case.FriendlyId
                                    </a>
                                }
                            </div>
                            <div class="d-flex align-items-center">
                                <small style="color: var(--graphite); margin-right: var(--spacing-2);">@note.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</small>
                                <form method="post" asp-page-handler="DeleteCaseNote" asp-route-id="@Model.Patient.Id" asp-route-noteId="@note.Id" class="d-inline">
                                    <button type="submit" class="btn-sentinel-secondary" style="padding: 4px 8px; font-size: 12px; background: var(--status-outbreak); border-color: var(--status-outbreak); color: var(--chalk);" 
                                            onclick="return confirm('Are you sure you want to delete this case communication note? This action cannot be undone.');"
                                            title="Delete note">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                        <p class="mb-2">@note.Content</p>
                        <small class="text-muted">
                            <i class="bi bi-person me-1"></i>@(note.CreatedBy ?? "Unknown")
                            @if (!string.IsNullOrEmpty(note.Recipient))
                            {
                                <span class="ms-2"><i class="bi bi-arrow-right"></i> @note.Recipient</span>
                            }
                        </small>
                        @if (!string.IsNullOrEmpty(note.AttachmentFileName))
                        {
                            <div class="mt-2">
                                <a href="@note.AttachmentPath" target="_blank" class="btn-sentinel-secondary" style="padding: 4px 10px; font-size: 12px;">
                                    <i class="bi bi-paperclip"></i> @note.AttachmentFileName
                                </a>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    <!-- Cases Section -->
    <div class="sentinel-card" style="margin-top: var(--spacing-5);">
        <div class="sentinel-card-header" style="display: flex; justify-content: space-between; align-items: center;">
            <h3 class="sentinel-card-title" style="margin: 0;">
                <i class="bi bi-virus"></i>
                Cases
            </h3>
            <span class="chip-info">@Model.Cases.Count</span>
        </div>
        <div class="sentinel-card-body">
            @if (Model.Cases.Any())
            {
                <div class="table-responsive">
                    <table class="patient-table">
                        <thead>
                            <tr>
                                <th>Case ID</th>
                                <th>Type</th>
                                <th>Disease</th>
                                <th>Date of Onset</th>
                                <th>Date of Notification</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var caseItem in Model.Cases)
                            {
                                <tr>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(caseItem.FriendlyId))
                                        {
                                            <span class="chip-clear" style="background: var(--graphite); color: var(--chalk);">@caseItem.FriendlyId</span>
                                        }
                                        else
                                        {
                                            <span style="color: var(--graphite);">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (caseItem.Type == CaseType.Case)
                                        {
                                            <span class="chip-outbreak"><i class="bi bi-virus2"></i> Case</span>
                                        }
                                        else
                                        {
                                            <span class="chip-watch"><i class="bi bi-people"></i> Contact</span>
                                        }
                                    </td>
                                    <td>@(caseItem.Disease?.Name ?? "-")</td>
                                    <td>@(caseItem.DateOfOnset?.ToString("dd MMM yyyy") ?? "-")</td>
                                    <td>@(caseItem.DateOfNotification?.ToString("dd MMM yyyy") ?? "-")</td>
                                    <td>@(caseItem.ConfirmationStatus?.Name ?? "-")</td>
                                    <td>
                                        <a asp-page="/Cases/Details" asp-route-id="@caseItem.Id" class="btn-sentinel-secondary" style="padding: 4px 10px; font-size: 12px;">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-virus display-1 opacity-25"></i>
                    <p class="mt-3">No cases found for this patient.</p>
                    @if (User.HasClaim(c => c.Type == "Permission" && c.Value == "Case.Create"))
                    {
                        <a asp-page="/Cases/Create" asp-route-patientId="@Model.Patient.Id" class="btn-sentinel-primary" style="margin-top: var(--spacing-2);">
                            <i class="bi bi-plus-circle"></i> Create First Case
                        </a>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Metadata -->
    <div class="sentinel-card" style="margin-top: var(--spacing-5);">
        <div class="sentinel-card-header">
            <h3 class="sentinel-card-title">
                <i class="bi bi-info-circle"></i>
                Record Information
            </h3>
        </div>
        <div class="sentinel-card-body">
            <div class="row">
                <div class="col-md-6 mb-2">
                    <small class="text-mono" style="color: var(--graphite); font-size: 11px;">Created:</small>
                    <div style="font-weight: 500;">@Model.Patient.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>
                </div>
                <div class="col-md-6 mb-2">
                    <small class="text-mono" style="color: var(--graphite); font-size: 11px;">Created By:</small>
                    <div style="font-weight: 500;">
                        @if (Model.Patient.CreatedByUser != null)
                        {
                            <span>@Model.Patient.CreatedByUser.UserName</span>
                        }
                        else
                        {
                            <span class="text-muted">Unknown</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Note Modal -->
<div class="modal fade" id="addNoteModal" tabindex="-1" aria-labelledby="addNoteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" asp-page-handler="AddNote" asp-route-id="@Model.Patient.Id" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title" id="addNoteModalLabel"><i class="bi bi-plus-circle me-2"></i>Add Note/Communication</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="NewNote.Type" class="form-label">Type <span class="text-danger">*</span></label>
                                <select asp-for="NewNote.Type" class="form-select" required id="noteTypeSelect">
                                    <option value="Note">Note</option>
                                    <option value="SMS">SMS</option>
                                    <option value="Phone Call">Phone Call</option>
                                    <option value="Email">Email</option>
                                </select>
                                <span asp-validation-for="NewNote.Type" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6" id="recipientField" style="display: none;">
                            <div class="mb-3">
                                <label asp-for="NewNote.Recipient" class="form-label">Recipient</label>
                                <input asp-for="NewNote.Recipient" class="form-control" placeholder="Contact name or number/email" />
                                <span asp-validation-for="NewNote.Recipient" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewNote.Subject" class="form-label">Subject</label>
                        <input asp-for="NewNote.Subject" class="form-control" placeholder="Brief summary" />
                        <span asp-validation-for="NewNote.Subject" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewNote.Content" class="form-label">Content <span class="text-danger">*</span></label>
                        <textarea asp-for="NewNote.Content" class="form-control" rows="5" required></textarea>
                        <span asp-validation-for="NewNote.Content" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Attachment" class="form-label">Attachment (optional)</label>
                        <input asp-for="Attachment" type="file" class="form-control" />
                        <small class="text-muted">Upload a file related to this note (e.g., document, image)</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i>Save Note</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Show/hide recipient field based on note type
        document.getElementById('noteTypeSelect').addEventListener('change', function() {
            var recipientField = document.getElementById('recipientField');
            var communicationTypes = ['SMS', 'Phone Call', 'Email'];
            
            if (communicationTypes.includes(this.value)) {
                recipientField.style.display = 'block';
            } else {
                recipientField.style.display = 'none';
            }
        });

        // Reset form when modal is closed
        document.getElementById('addNoteModal').addEventListener('hidden.bs.modal', function () {
            this.querySelector('form').reset();
            document.getElementById('recipientField').style.display = 'none';
        });
    </script>
}

