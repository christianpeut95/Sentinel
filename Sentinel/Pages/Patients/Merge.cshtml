@page
@model Sentinel.Pages.Patients.MergeModel
@{
    ViewData["Title"] = "Merge Patients";
    ViewData["Subtitle"] = "Review and select which values to keep for each field";
}

<!-- Page Header -->
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-6);">
    <div>
        <h1 style="font-family: var(--f-sans); font-weight: 600; font-size: 28px; letter-spacing: -0.02em; color: var(--status-outbreak); margin: 0; display: flex; align-items: center; gap: var(--spacing-2);">
            <i class="bi bi-arrow-left-right" style="color: var(--status-outbreak);"></i>
            Merge Patients
        </h1>
        <p style="color: var(--graphite); margin-top: var(--spacing-2); font-size: 14px;">
            Patient @Model.SourceId will be deleted and merged into Patient @Model.TargetId.
        </p>
    </div>
</div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div style="background: #FFE6E6; border: 1px solid #FF9999; border-radius: var(--radius-md); padding: var(--spacing-4); margin-bottom: var(--spacing-5); color: var(--status-outbreak);">
            <i class="bi bi-exclamation-triangle-fill" style="margin-right: var(--spacing-2);"></i>
            @Model.ErrorMessage
        </div>
    }

    @if (Model.Comparison != null)
    {
        <form method="post">
            <input type="hidden" asp-for="SourceId" />
            <input type="hidden" asp-for="TargetId" />

            <div style="background: #E6F3FF; border: 1px solid #99CCFF; border-radius: var(--radius-md); padding: var(--spacing-4); margin-bottom: var(--spacing-5); color: #004080;">
                <i class="bi bi-info-circle" style="margin-right: var(--spacing-2);"></i>
                <strong>Tip:</strong> Click on a value to select it. The selected value will be kept in the merged patient record.
            </div>

            <!-- Standard Fields -->
            <div class="sentinel-card" style="margin-bottom: var(--spacing-5);">
                <div class="sentinel-card-header">
                    <h3 class="sentinel-card-title">
                        <i class="bi bi-clipboard-data"></i>
                        Standard Fields
                    </h3>
                </div>
                <div class="sentinel-card-body">
                    <table class="patient-table" style="border: 1px solid var(--hairline);">
                        <thead>
                            <tr>
                                <th style="width: 20%; font-family: var(--f-mono); font-size: 12px; color: var(--graphite);">Field</th>
                                <th style="width: 40%; background: #FFE6E6; border-left: 3px solid var(--status-outbreak);">
                                    <i class="bi bi-exclamation-circle"></i> Source Patient (@Model.SourceId) - Will be Deleted
                                </th>
                                <th style="width: 40%; background: #E6F7ED; border-left: 3px solid var(--signal-dk);">
                                    <i class="bi bi-check-circle"></i> Target Patient (@Model.TargetId) - Will be Kept
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @await Html.PartialAsync("_MergeFieldRow", new { 
                                FieldName = "GivenName", 
                                Label = "First Name", 
                                SourceValue = Model.Comparison.SourcePatient.GivenName,
                                TargetValue = Model.Comparison.TargetPatient.GivenName
                            })
                            
                            @await Html.PartialAsync("_MergeFieldRow", new { 
                                FieldName = "FamilyName", 
                                Label = "Last Name", 
                                SourceValue = Model.Comparison.SourcePatient.FamilyName,
                                TargetValue = Model.Comparison.TargetPatient.FamilyName
                            })
                            
                            @await Html.PartialAsync("_MergeFieldRow", new { 
                                FieldName = "DateOfBirth", 
                                Label = "Date of Birth", 
                                SourceValue = Model.Comparison.SourcePatient.DateOfBirth?.ToString("yyyy-MM-dd"),
                                TargetValue = Model.Comparison.TargetPatient.DateOfBirth?.ToString("yyyy-MM-dd")
                            })
                            
                            @await Html.PartialAsync("_MergeFieldRow", new { 
                                FieldName = "SexAtBirthId", 
                                Label = "Sex at Birth", 
                                SourceValue = Model.Comparison.SourcePatient.SexAtBirth?.Name,
                                TargetValue = Model.Comparison.TargetPatient.SexAtBirth?.Name
                            })
                            
                            @await Html.PartialAsync("_MergeFieldRow", new { 
                                FieldName = "GenderId", 
                                Label = "Gender", 
                                SourceValue = Model.Comparison.SourcePatient.Gender?.Name,
                                TargetValue = Model.Comparison.TargetPatient.Gender?.Name
                            })
                            
                            @await Html.PartialAsync("_MergeFieldRow", new { 
                                FieldName = "HomePhone", 
                                Label = "Home Phone", 
                                SourceValue = Model.Comparison.SourcePatient.HomePhone,
                                TargetValue = Model.Comparison.TargetPatient.HomePhone
                            })
                            
                            @await Html.PartialAsync("_MergeFieldRow", new { 
                                FieldName = "MobilePhone", 
                                Label = "Mobile Phone", 
                                SourceValue = Model.Comparison.SourcePatient.MobilePhone,
                                TargetValue = Model.Comparison.TargetPatient.MobilePhone
                            })
                            
                            @await Html.PartialAsync("_MergeFieldRow", new { 
                                FieldName = "EmailAddress", 
                                Label = "Email Address", 
                                SourceValue = Model.Comparison.SourcePatient.EmailAddress,
                                TargetValue = Model.Comparison.TargetPatient.EmailAddress
                            })
                            
                            @await Html.PartialAsync("_MergeFieldRow", new { 
                                FieldName = "AddressLine", 
                                Label = "Address", 
                                SourceValue = Model.Comparison.SourcePatient.AddressLine,
                                TargetValue = Model.Comparison.TargetPatient.AddressLine
                            })
                            
                            @await Html.PartialAsync("_MergeFieldRow", new { 
                                FieldName = "City", 
                                Label = "Suburb", 
                                SourceValue = Model.Comparison.SourcePatient.City,
                                TargetValue = Model.Comparison.TargetPatient.City
                            })
                            
                            @await Html.PartialAsync("_MergeFieldRow", new { 
                                FieldName = "State", 
                                Label = "State", 
                                SourceValue = Model.Comparison.SourcePatient.State,
                                TargetValue = Model.Comparison.TargetPatient.State
                            })
                            
                            @await Html.PartialAsync("_MergeFieldRow", new { 
                                FieldName = "PostalCode", 
                                Label = "Postcode", 
                                SourceValue = Model.Comparison.SourcePatient.PostalCode,
                                TargetValue = Model.Comparison.TargetPatient.PostalCode
                            })
                            
                            @await Html.PartialAsync("_MergeFieldRow", new { 
                                FieldName = "CountryOfBirthId", 
                                Label = "Country of Birth", 
                                SourceValue = Model.Comparison.SourcePatient.CountryOfBirth?.Name,
                                TargetValue = Model.Comparison.TargetPatient.CountryOfBirth?.Name
                            })
                            
                            @await Html.PartialAsync("_MergeFieldRow", new { 
                                FieldName = "LanguageSpokenAtHomeId", 
                                Label = "Language Spoken at Home", 
                                SourceValue = Model.Comparison.SourcePatient.LanguageSpokenAtHome?.Name,
                                TargetValue = Model.Comparison.TargetPatient.LanguageSpokenAtHome?.Name
                            })
                            
                            @await Html.PartialAsync("_MergeFieldRow", new { 
                                FieldName = "AncestryId", 
                                Label = "Ancestry", 
                                SourceValue = Model.Comparison.SourcePatient.Ancestry?.Name,
                                TargetValue = Model.Comparison.TargetPatient.Ancestry?.Name
                            })
                            
                            @await Html.PartialAsync("_MergeFieldRow", new { 
                                FieldName = "AtsiStatusId", 
                                Label = "ATSI Status", 
                                SourceValue = Model.Comparison.SourcePatient.AtsiStatus?.Name,
                                TargetValue = Model.Comparison.TargetPatient.AtsiStatus?.Name
                            })
                            
                            @await Html.PartialAsync("_MergeFieldRow", new { 
                                FieldName = "OccupationId", 
                                Label = "Occupation", 
                                SourceValue = Model.Comparison.SourcePatient.Occupation?.Name,
                                TargetValue = Model.Comparison.TargetPatient.Occupation?.Name
                            })
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Custom Fields -->
            @if (Model.Comparison.SourceCustomFields.Any() || Model.Comparison.TargetCustomFields.Any())
            {
                <div class="sentinel-card" style="margin-bottom: var(--spacing-5);">
                    <div class="sentinel-card-header">
                        <h3 class="sentinel-card-title">
                            <i class="bi bi-sliders"></i>
                            Custom Fields
                        </h3>
                    </div>
                    <div class="sentinel-card-body">
                        <table class="patient-table" style="border: 1px solid var(--hairline);">
                            <thead>
                                <tr>
                                    <th style="width: 20%; font-family: var(--f-mono); font-size: 12px; color: var(--graphite);">Field</th>
                                    <th style="width: 40%; background: #FFE6E6; border-left: 3px solid var(--status-outbreak);">
                                        Source Patient (@Model.SourceId)
                                    </th>
                                    <th style="width: 40%; background: #E6F7ED; border-left: 3px solid var(--signal-dk);">
                                        Target Patient (@Model.TargetId)
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var allFieldIds = Model.Comparison.SourceCustomFields.Keys
                                        .Union(Model.Comparison.TargetCustomFields.Keys)
                                        .Distinct();
                                }
                                @foreach (var fieldId in allFieldIds)
                                {
                                    var sourceField = Model.Comparison.SourceCustomFields.GetValueOrDefault(fieldId);
                                    var targetField = Model.Comparison.TargetCustomFields.GetValueOrDefault(fieldId);
                                    var label = sourceField?.Label ?? targetField?.Label ?? "Unknown";
                                    
                                    <tr>
                                        <td><strong>@label</strong></td>
                                        <td>
                                            <label class="merge-option">
                                                <input type="radio" 
                                                       name="SelectedCustomFieldValues[@int.Parse(fieldId)]" 
                                                       value="source:@fieldId" 
                                                       checked="@(sourceField?.DisplayValue != null)" />
                                                <span class="value-display">
                                                    @(sourceField?.DisplayValue ?? "(empty)")
                                                </span>
                                            </label>
                                        </td>
                                        <td>
                                            <label class="merge-option">
                                                <input type="radio" 
                                                       name="SelectedCustomFieldValues[@int.Parse(fieldId)]" 
                                                       value="target:@fieldId"
                                                       checked="@(sourceField?.DisplayValue == null && targetField?.DisplayValue != null)" />
                                                <span class="value-display">
                                                    @(targetField?.DisplayValue ?? "(empty)")
                                                </span>
                                            </label>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <!-- Summary -->
            <div class="sentinel-card" style="margin-bottom: var(--spacing-5);">
                <div class="sentinel-card-header">
                    <h3 class="sentinel-card-title">
                        <i class="bi bi-info-circle"></i>
                        Additional Information
                    </h3>
                </div>
                <div class="sentinel-card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p style="font-weight: 500;"><strong>Source Patient Audit Logs:</strong> @Model.Comparison.SourceAuditLogCount</p>
                            <p style="color: var(--graphite); font-size: 13px;">All audit logs will be preserved and linked to the target patient.</p>
                        </div>
                        <div class="col-md-6">
                            <p style="font-weight: 500;"><strong>Target Patient Audit Logs:</strong> @Model.Comparison.TargetAuditLogCount</p>
                        </div>
                    </div>
                </div>
            </div>

                    <!-- Actions -->
                    <div class="row">
                        <div class="col-md-12">
                            <button type="submit" class="btn-sentinel-primary" style="background: var(--status-outbreak); border-color: var(--status-outbreak); padding: 12px 24px; font-size: 16px;" onclick="return confirm('Are you sure you want to merge these patients? This action cannot be undone.');">
                                <i class="bi bi-check-circle"></i> Confirm Merge
                            </button>
                            <a asp-page="./SelectMerge" class="btn-sentinel-secondary" style="padding: 12px 24px; font-size: 16px; margin-left: var(--spacing-2);">
                                <i class="bi bi-arrow-left"></i> Back
                            </a>
                            <a asp-page="./Index" class="btn-sentinel-secondary" style="padding: 12px 24px; font-size: 16px; margin-left: var(--spacing-2);">
                                Cancel
                            </a>
                        </div>
                    </div>
                </form>
            }
@section Scripts {
    <style>
        .merge-option {
            display: block;
            padding: 10px;
            cursor: pointer;
            border-radius: 4px;
            transition: background-color 0.2s;
        }

        .merge-option:hover {
            background-color: #f8f9fa;
        }

        .merge-option input[type="radio"]:checked + .value-display {
            font-weight: bold;
            color: #0d6efd;
        }

        .value-display {
            margin-left: 8px;
        }

        td {
            vertical-align: middle !important;
        }
    </style>
}
