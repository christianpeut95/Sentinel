@page
@model Sentinel.Pages.Patients.SearchModel

@{
    ViewData["Title"] = "Advanced Patient Search";
    ViewData["Subtitle"] = "Search across all patient records with advanced filtering";
}

<!-- Page Header -->
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-6);">
    <div>
        <h1 style="font-family: var(--f-sans); font-weight: 600; font-size: 28px; letter-spacing: -0.02em; color: var(--forest); margin: 0; display: flex; align-items: center; gap: var(--spacing-2);">
            <i class="bi bi-search" style="color: var(--signal-dk);"></i>
            Advanced Patient Search
        </h1>
    </div>
    <a asp-page="./Index" class="btn-sentinel-secondary">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</div>

<!-- Search Criteria Card -->
<div class="sentinel-card" style="margin-bottom: var(--spacing-5);">
    <div class="sentinel-card-header">
        <h3 class="sentinel-card-title">
            <i class="bi bi-funnel"></i>
            Search Criteria
        </h3>
    </div>
    <div class="sentinel-card-body">
        <form method="get">
            <!-- Essential Fields -->
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="GivenName" class="sentinel-label">First Name</label>
                    <input asp-for="GivenName" class="sentinel-input" placeholder="First name" />
                </div>
                <div class="col-md-3">
                    <label asp-for="FamilyName" class="sentinel-label">Last Name</label>
                    <input asp-for="FamilyName" class="sentinel-input" placeholder="Last name" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Phone" class="sentinel-label">Phone</label>
                    <input asp-for="Phone" class="sentinel-input" placeholder="Phone number" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Email" class="sentinel-label">Email</label>
                    <input asp-for="Email" class="sentinel-input" type="email" placeholder="Email" />
                </div>
            </div>

            <div class="row g-3 mt-2">
                <div class="col-md-3">
                    <label asp-for="DateOfBirthFrom" class="sentinel-label">DOB From</label>
                    <input asp-for="DateOfBirthFrom" class="sentinel-input" type="date" />
                </div>
                <div class="col-md-3">
                    <label asp-for="DateOfBirthTo" class="sentinel-label">DOB To</label>
                    <input asp-for="DateOfBirthTo" class="sentinel-input" type="date" />
                </div>
                <div class="col-md-3">
                    <label asp-for="City" class="sentinel-label">Suburb</label>
                    <input asp-for="City" class="sentinel-input" placeholder="Suburb" />
                </div>
                <div class="col-md-3">
                    <label asp-for="PostalCode" class="sentinel-label">Postcode</label>
                    <input asp-for="PostalCode" class="sentinel-input" placeholder="Postcode" />
                </div>
            </div>

            <!-- Collapsible Additional Filters -->
            <div style="margin-top: var(--spacing-4);">
                <button type="button" class="btn-sentinel-secondary" style="padding: 8px 14px; font-size: 13px;" data-bs-toggle="collapse" data-bs-target="#additionalFilters" aria-expanded="false" aria-controls="additionalFilters">
                    <i class="bi bi-plus-circle"></i> More Filters
                </button>
            </div>

            <div class="collapse" style="margin-top: var(--spacing-4);" id="additionalFilters">
                <div style="background: var(--bone); border: 1px solid var(--hairline); border-radius: var(--radius-md); padding: var(--spacing-4);">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label asp-for="SexAtBirthId" class="sentinel-label">Sex at Birth</label>
                            <select asp-for="SexAtBirthId" class="sentinel-input" asp-items="Model.SexAtBirths">
                                <option value="">-- All --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="GenderId" class="sentinel-label">Gender</label>
                            <select asp-for="GenderId" class="sentinel-input" asp-items="Model.Genders">
                                <option value="">-- All --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="State" class="sentinel-label">State</label>
                            <input asp-for="State" class="sentinel-input" placeholder="State" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="CountryOfBirthId" class="sentinel-label">Country of Birth</label>
                            <select asp-for="CountryOfBirthId" class="sentinel-input" asp-items="Model.Countries">
                                <option value="">-- All --</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mt-2">
                        <div class="col-md-3">
                            <label asp-for="LanguageSpokenAtHomeId" class="sentinel-label">Language</label>
                            <select asp-for="LanguageSpokenAtHomeId" class="sentinel-input" asp-items="Model.Languages">
                                <option value="">-- All --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="AncestryId" class="sentinel-label">Ethnicity</label>
                            <select asp-for="AncestryId" class="sentinel-input" asp-items="Model.Ethnicities">
                                <option value="">-- All --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="AtsiStatusId" class="sentinel-label">ATSI Status</label>
                            <select asp-for="AtsiStatusId" class="sentinel-input" asp-items="Model.AtsiStatuses">
                                <option value="">-- All --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="OccupationId" class="sentinel-label">Occupation</label>
                            <select asp-for="OccupationId" class="sentinel-input" asp-items="Model.Occupations">
                                <option value="">-- All --</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mt-2">
                        <div class="col-md-3">
                            <label asp-for="CreatedFrom" class="sentinel-label">Created From</label>
                            <input asp-for="CreatedFrom" class="sentinel-input" type="date" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="CreatedTo" class="sentinel-label">Created To</label>
                            <input asp-for="CreatedTo" class="sentinel-input" type="date" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2" style="margin-top: var(--spacing-4);">
                <button type="submit" class="btn-sentinel-primary">
                    <i class="bi bi-search"></i> Search
                </button>
                <button type="submit" asp-page-handler="Clear" class="btn-sentinel-secondary">
                    <i class="bi bi-x-circle"></i> Clear
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.HasSearched)
{
    <!-- Search Results Card -->
    <div class="sentinel-card">
        <div class="sentinel-card-header">
            <h3 class="sentinel-card-title">
                <i class="bi bi-list-check"></i>
                Search Results
                <span class="chip-info" style="margin-left: var(--spacing-2);">@Model.TotalResults patient(s)</span>
            </h3>
        </div>
        <div class="sentinel-card-body">
            @if (Model.TotalResults == 0)
            {
                <div style="background: #E6F3FF; border: 1px solid #99CCFF; border-radius: var(--radius-md); padding: var(--spacing-4); color: #004080;">
                    <i class="bi bi-info-circle" style="margin-right: var(--spacing-2);"></i>
                    No patients found matching your search criteria. Try adjusting your filters.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="patient-table" style="margin-bottom: 0;">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Date of Birth</th>
                                <th>Age</th>
                                <th>Sex</th>
                                <th>Phone</th>
                                <th>Email</th>
                                <th>Suburb</th>
                                <th>State</th>
                                <th>Created</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var patient in Model.SearchResults)
                            {
                                var age = patient.DateOfBirth.HasValue
                                    ? (int)Math.Floor((DateTime.UtcNow - patient.DateOfBirth.Value).TotalDays / 365.2425)
                                    : (int?)null;
                                <tr>
                                    <td>
                                        <strong>@patient.GivenName @patient.FamilyName</strong>
                                    </td>
                                    <td>@(patient.DateOfBirth?.ToString("dd MMM yyyy") ?? "-")</td>
                                    <td>@(age?.ToString() ?? "-")</td>
                                    <td>@(patient.SexAtBirth?.Name ?? "-")</td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(patient.MobilePhone))
                                        {
                                            <span title="Mobile">@patient.MobilePhone</span>
                                        }
                                        else if (!string.IsNullOrWhiteSpace(patient.HomePhone))
                                        {
                                            <span title="Home">@patient.HomePhone</span>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(patient.EmailAddress))
                                        {
                                            <small>@patient.EmailAddress</small>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td>@(patient.City ?? "-")</td>
                                    <td>@(patient.State?.Code ?? "-")</td>
                                    <td><small class="text-muted">@patient.CreatedAt.ToString("dd MMM yyyy")</small></td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-page="./Details" asp-route-id="@patient.Id" class="btn-sentinel-secondary" style="padding: 4px 10px; font-size: 12px;" title="View details">
                                                <i class="bi bi-eye"></i> View
                                            </a>
                                            <a asp-page="./Edit" asp-route-id="@patient.Id" class="btn-sentinel-secondary" style="padding: 4px 10px; font-size: 12px;" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.TotalResults > 50)
                {
                    <div style="background: #FFF4E6; border: 1px solid #FFD699; border-radius: var(--radius-md); padding: var(--spacing-4); margin-top: var(--spacing-4); margin-bottom: 0; color: #804000;">
                        <i class="bi bi-exclamation-triangle" style="margin-right: var(--spacing-2);"></i>
                        <strong>Large result set:</strong> @Model.TotalResults patients found. Consider refining your search criteria for faster results.
                    </div>
                }
            }
        </div>
    </div>
}
else
{
    <div style="background: #E6F3FF; border: 1px solid #99CCFF; border-radius: var(--radius-md); padding: var(--spacing-4); color: #004080;">
        <i class="bi bi-info-circle" style="margin-right: var(--spacing-2);"></i>
        Enter search criteria above and click <strong>Search</strong> to find patients.
    </div>
}

@section Scripts {
    <script>
        // Auto-focus the first input field
        document.addEventListener('DOMContentLoaded', function() {
            const firstInput = document.querySelector('input[type="text"]');
            if (firstInput) {
                firstInput.focus();
            }
        });
    </script>
}
