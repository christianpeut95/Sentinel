@page
@model Sentinel.Pages.Patients.SearchModel

@{
    ViewData["Title"] = "Advanced Patient Search";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Patients</a></li>
        <li class="breadcrumb-item active" aria-current="page">Advanced Search</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-search me-2"></i>Advanced Patient Search</h2>
    <a asp-page="./Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-funnel me-2"></i>Search Criteria</h5>
    </div>
    <div class="card-body">
        <form method="get">
            <!-- Essential Fields -->
            <div class="row g-2">
                <div class="col-md-3">
                    <label asp-for="GivenName" class="form-label fw-bold">First Name</label>
                    <input asp-for="GivenName" class="form-control form-control-sm" placeholder="First name" />
                </div>
                <div class="col-md-3">
                    <label asp-for="FamilyName" class="form-label fw-bold">Last Name</label>
                    <input asp-for="FamilyName" class="form-control form-control-sm" placeholder="Last name" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Phone" class="form-label fw-bold">Phone</label>
                    <input asp-for="Phone" class="form-control form-control-sm" placeholder="Phone number" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Email" class="form-label fw-bold">Email</label>
                    <input asp-for="Email" class="form-control form-control-sm" type="email" placeholder="Email" />
                </div>
            </div>

            <div class="row g-2 mt-2">
                <div class="col-md-3">
                    <label asp-for="DateOfBirthFrom" class="form-label fw-bold">DOB From</label>
                    <input asp-for="DateOfBirthFrom" class="form-control form-control-sm" type="date" />
                </div>
                <div class="col-md-3">
                    <label asp-for="DateOfBirthTo" class="form-label fw-bold">DOB To</label>
                    <input asp-for="DateOfBirthTo" class="form-control form-control-sm" type="date" />
                </div>
                <div class="col-md-3">
                    <label asp-for="City" class="form-label fw-bold">Suburb</label>
                    <input asp-for="City" class="form-control form-control-sm" placeholder="Suburb" />
                </div>
                <div class="col-md-3">
                    <label asp-for="PostalCode" class="form-label fw-bold">Postcode</label>
                    <input asp-for="PostalCode" class="form-control form-control-sm" placeholder="Postcode" />
                </div>
            </div>

            <!-- Collapsible Additional Filters -->
            <div class="mt-3">
                <a class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" href="#additionalFilters" role="button" aria-expanded="false" aria-controls="additionalFilters">
                    <i class="bi bi-plus-circle me-1"></i>More Filters
                </a>
            </div>

            <div class="collapse mt-3" id="additionalFilters">
                <div class="card card-body bg-light">
                    <div class="row g-2">
                        <div class="col-md-3">
                            <label asp-for="SexAtBirthId" class="form-label fw-bold">Sex at Birth</label>
                            <select asp-for="SexAtBirthId" class="form-select form-select-sm" asp-items="Model.SexAtBirths">
                                <option value="">-- All --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="GenderId" class="form-label fw-bold">Gender</label>
                            <select asp-for="GenderId" class="form-select form-select-sm" asp-items="Model.Genders">
                                <option value="">-- All --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="State" class="form-label fw-bold">State</label>
                            <input asp-for="State" class="form-control form-control-sm" placeholder="State" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="CountryOfBirthId" class="form-label fw-bold">Country of Birth</label>
                            <select asp-for="CountryOfBirthId" class="form-select form-select-sm" asp-items="Model.Countries">
                                <option value="">-- All --</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-2 mt-2">
                        <div class="col-md-3">
                            <label asp-for="LanguageSpokenAtHomeId" class="form-label fw-bold">Language</label>
                            <select asp-for="LanguageSpokenAtHomeId" class="form-select form-select-sm" asp-items="Model.Languages">
                                <option value="">-- All --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="AncestryId" class="form-label fw-bold">Ethnicity</label>
                            <select asp-for="AncestryId" class="form-select form-select-sm" asp-items="Model.Ethnicities">
                                <option value="">-- All --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="AtsiStatusId" class="form-label fw-bold">ATSI Status</label>
                            <select asp-for="AtsiStatusId" class="form-select form-select-sm" asp-items="Model.AtsiStatuses">
                                <option value="">-- All --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="OccupationId" class="form-label fw-bold">Occupation</label>
                            <select asp-for="OccupationId" class="form-select form-select-sm" asp-items="Model.Occupations">
                                <option value="">-- All --</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-2 mt-2">
                        <div class="col-md-3">
                            <label asp-for="CreatedFrom" class="form-label fw-bold">Created From</label>
                            <input asp-for="CreatedFrom" class="form-control form-control-sm" type="date" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="CreatedTo" class="form-label fw-bold">Created To</label>
                            <input asp-for="CreatedTo" class="form-control form-control-sm" type="date" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-search me-1"></i>Search
                </button>
                <button type="submit" asp-page-handler="Clear" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-x-circle me-1"></i>Clear
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.HasSearched)
{
    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0">
                <i class="bi bi-list-check me-2"></i>Search Results
                <span class="badge bg-primary ms-2">@Model.TotalResults patient(s) found</span>
            </h5>
        </div>
        <div class="card-body">
            @if (Model.TotalResults == 0)
            {
                <div class="alert alert-info mb-0">
                    <i class="bi bi-info-circle me-2"></i>
                    No patients found matching your search criteria. Try adjusting your filters.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Date of Birth</th>
                                <th>Age</th>
                                <th>Sex</th>
                                <th>Phone</th>
                                <th>Email</th>
                                <th>Suburb</th>
                                <th>State</th>
                                <th>Created</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var patient in Model.SearchResults)
                            {
                                var age = patient.DateOfBirth.HasValue
                                    ? (int)Math.Floor((DateTime.UtcNow - patient.DateOfBirth.Value).TotalDays / 365.2425)
                                    : (int?)null;
                                <tr>
                                    <td>
                                        <strong>@patient.GivenName @patient.FamilyName</strong>
                                    </td>
                                    <td>@(patient.DateOfBirth?.ToString("dd MMM yyyy") ?? "-")</td>
                                    <td>@(age?.ToString() ?? "-")</td>
                                    <td>@(patient.SexAtBirth?.Name ?? "-")</td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(patient.MobilePhone))
                                        {
                                            <span title="Mobile">@patient.MobilePhone</span>
                                        }
                                        else if (!string.IsNullOrWhiteSpace(patient.HomePhone))
                                        {
                                            <span title="Home">@patient.HomePhone</span>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(patient.EmailAddress))
                                        {
                                            <small>@patient.EmailAddress</small>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td>@(patient.City ?? "-")</td>
                                    <td>@(patient.State?.Code ?? "-")</td>
                                    <td><small class="text-muted">@patient.CreatedAt.ToString("dd MMM yyyy")</small></td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-page="./Details" asp-route-id="@patient.Id" class="btn btn-outline-primary" title="View details">
                                                <i class="bi bi-eye"></i> View
                                            </a>
                                            <a asp-page="./Edit" asp-route-id="@patient.Id" class="btn btn-outline-secondary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.TotalResults > 50)
                {
                    <div class="alert alert-warning mt-3 mb-0">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Large result set:</strong> @Model.TotalResults patients found. Consider refining your search criteria for faster results.
                    </div>
                }
            }
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        Enter search criteria above and click <strong>Search</strong> to find patients.
    </div>
}

@section Scripts {
    <script>
        // Auto-focus the first input field
        document.addEventListener('DOMContentLoaded', function() {
            const firstInput = document.querySelector('input[type="text"]');
            if (firstInput) {
                firstInput.focus();
            }
        });
    </script>
}
