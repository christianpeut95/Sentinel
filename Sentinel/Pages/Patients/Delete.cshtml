@page
@model Sentinel.Pages.Patients.DeleteModel

@{
    ViewData["Title"] = "Delete Patient";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index">Patients</a></li>
        <li class="breadcrumb-item active" aria-current="page">Delete</li>
    </ol>
</nav>

<h2><i class="bi bi-trash me-2 text-danger"></i>Delete Patient</h2>

<div class="alert alert-warning mt-3">
    <i class="bi bi-exclamation-triangle me-2"></i>
    <strong>Warning:</strong> Are you sure you want to delete this patient?
</div>

<div class="card shadow-sm">
    <div class="card-header bg-light">
        <strong>Patient Information</strong>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Patient.GivenName)</dt>
            <dd class="col-sm-9">@Model.Patient.GivenName</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Patient.FamilyName)</dt>
            <dd class="col-sm-9">@Model.Patient.FamilyName</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Patient.DateOfBirth)</dt>
            <dd class="col-sm-9">@(Model.Patient.DateOfBirth?.ToString("dd MMM yyyy") ?? "-")</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Patient.SexAtBirthId)</dt>
            <dd class="col-sm-9">@(Model.Patient.SexAtBirth?.Name ?? "-")</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Patient.GenderId)</dt>
            <dd class="col-sm-9">@(Model.Patient.Gender?.Name ?? "-")</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Patient.CountryOfBirth)</dt>
            <dd class="col-sm-9">@(Model.Patient.CountryOfBirth?.Name ?? "-")</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Patient.LanguageSpokenAtHome)</dt>
            <dd class="col-sm-9">@(Model.Patient.LanguageSpokenAtHome?.Name ?? "-")</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Patient.Ancestry)</dt>
            <dd class="col-sm-9">@(Model.Patient.Ancestry?.Name ?? "-")</dd>

            <dt class="col-sm-3">Address</dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrWhiteSpace(Model.Patient.AddressLine))
                {
                    <text>@Model.Patient.AddressLine<br /></text>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Patient.City))
                {
                    <text>@Model.Patient.City </text>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Patient.State))
                {
                    <text>@Model.Patient.State </text>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Patient.PostalCode))
                {
                    <text>@Model.Patient.PostalCode</text>
                }
                @if (string.IsNullOrWhiteSpace(Model.Patient.AddressLine) && string.IsNullOrWhiteSpace(Model.Patient.City))
                {
                    <text>-</text>
                }
            </dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Patient.CreatedAt)</dt>
            <dd class="col-sm-9">@Model.Patient.CreatedAt.ToString("dd MMM yyyy HH:mm")</dd>
        </dl>
    </div>
</div>

<form method="post" class="mt-3">
    <input type="hidden" asp-for="Patient.Id" />
    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete Patient</button>
    <a asp-page="./Index" class="btn btn-outline-secondary ms-2"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
</form>
