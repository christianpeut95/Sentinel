@page
@model Sentinel.Pages.Patients.DeleteModel

@{
    ViewData["Title"] = "Delete Patient";
    ViewData["Subtitle"] = $"Confirm deletion of {Model.Patient.GivenName} {Model.Patient.FamilyName}";
}

<!-- Page Header -->
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-6);">
    <div>
        <h1 style="font-family: var(--f-sans); font-weight: 600; font-size: 28px; letter-spacing: -0.02em; color: var(--status-outbreak); margin: 0; display: flex; align-items: center; gap: var(--spacing-2);">
            <i class="bi bi-trash"></i>
            Delete Patient
        </h1>
    </div>
</div>

<!-- Warning Alert -->
<div style="background: #FBE2D8; border: 1px solid #F2BBA4; border-radius: var(--radius-md); padding: var(--spacing-4); margin-bottom: var(--spacing-5); color: #7A2A15;">
    <div style="display: flex; align-items: center; gap: var(--spacing-2);">
        <i class="bi bi-exclamation-triangle-fill" style="font-size: 20px; color: var(--status-outbreak);"></i>
        <div>
            <strong>Warning:</strong> Are you sure you want to delete this patient? This action cannot be undone.
        </div>
    </div>
</div>

<!-- Patient Information Card -->
<div class="sentinel-card" style="margin-bottom: var(--spacing-5);">
    <div class="sentinel-card-header">
        <h3 class="sentinel-card-title">
            <i class="bi bi-person"></i>
            Patient Information
        </h3>
    </div>
    <div class="sentinel-card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 text-mono" style="color: var(--graphite); font-size: 12px;">@Html.DisplayNameFor(model => model.Patient.GivenName)</dt>
            <dd class="col-sm-9" style="font-weight: 500; color: var(--forest);">@Model.Patient.GivenName</dd>

            <dt class="col-sm-3 text-mono" style="color: var(--graphite); font-size: 12px;">@Html.DisplayNameFor(model => model.Patient.FamilyName)</dt>
            <dd class="col-sm-9" style="font-weight: 500; color: var(--forest);">@Model.Patient.FamilyName</dd>

            <dt class="col-sm-3 text-mono" style="color: var(--graphite); font-size: 12px;">@Html.DisplayNameFor(model => model.Patient.DateOfBirth)</dt>
            <dd class="col-sm-9" style="font-weight: 500;">@(Model.Patient.DateOfBirth?.ToString("dd MMM yyyy") ?? "—")</dd>

            <dt class="col-sm-3 text-mono" style="color: var(--graphite); font-size: 12px;">@Html.DisplayNameFor(model => model.Patient.SexAtBirthId)</dt>
            <dd class="col-sm-9" style="font-weight: 500;">@(Model.Patient.SexAtBirth?.Name ?? "—")</dd>

            <dt class="col-sm-3 text-mono" style="color: var(--graphite); font-size: 12px;">@Html.DisplayNameFor(model => model.Patient.GenderId)</dt>
            <dd class="col-sm-9" style="font-weight: 500;">@(Model.Patient.Gender?.Name ?? "—")</dd>

            <dt class="col-sm-3 text-mono" style="color: var(--graphite); font-size: 12px;">@Html.DisplayNameFor(model => model.Patient.CountryOfBirth)</dt>
            <dd class="col-sm-9" style="font-weight: 500;">@(Model.Patient.CountryOfBirth?.Name ?? "—")</dd>

            <dt class="col-sm-3 text-mono" style="color: var(--graphite); font-size: 12px;">@Html.DisplayNameFor(model => model.Patient.LanguageSpokenAtHome)</dt>
            <dd class="col-sm-9" style="font-weight: 500;">@(Model.Patient.LanguageSpokenAtHome?.Name ?? "—")</dd>

            <dt class="col-sm-3 text-mono" style="color: var(--graphite); font-size: 12px;">@Html.DisplayNameFor(model => model.Patient.Ancestry)</dt>
            <dd class="col-sm-9" style="font-weight: 500;">@(Model.Patient.Ancestry?.Name ?? "—")</dd>

            <dt class="col-sm-3 text-mono" style="color: var(--graphite); font-size: 12px;">Address</dt>
            <dd class="col-sm-9" style="font-weight: 500;">
                @if (!string.IsNullOrWhiteSpace(Model.Patient.AddressLine))
                {
                    <text>@Model.Patient.AddressLine<br /></text>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Patient.City))
                {
                    <text>@Model.Patient.City </text>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Patient.State?.Code))
                {
                    <text>@Model.Patient.State </text>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Patient.PostalCode))
                {
                    <text>@Model.Patient.PostalCode</text>
                }
                @if (string.IsNullOrWhiteSpace(Model.Patient.AddressLine) && string.IsNullOrWhiteSpace(Model.Patient.City))
                {
                    <text>—</text>
                }
            </dd>

            <dt class="col-sm-3 text-mono" style="color: var(--graphite); font-size: 12px;">@Html.DisplayNameFor(model => model.Patient.CreatedAt)</dt>
            <dd class="col-sm-9 text-mono" style="font-weight: 500; font-size: 12px;">@Model.Patient.CreatedAt.ToString("dd MMM yyyy HH:mm")</dd>
        </dl>
    </div>
</div>

<!-- Actions -->
<form method="post">
    <input type="hidden" asp-for="Patient.Id" />
    <button type="submit" class="btn-sentinel-primary" style="background: var(--status-outbreak); border-color: var(--status-outbreak);">
        <i class="bi bi-trash"></i> Delete Patient
    </button>
    <a asp-page="./Index" class="btn-sentinel-secondary ms-2">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</form>
