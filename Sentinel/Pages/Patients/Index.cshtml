@page
@model Sentinel.Pages.Patients.IndexModel
@using Sentinel.Models

@{
    ViewData["Title"] = "Patients";
    ViewData["Subtitle"] = "All registered patients in the surveillance system";
}
@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}

<style>
    /* Patients Page - Sentinel Theme */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: var(--spacing-4);
        margin-bottom: var(--spacing-6);
    }

    .stat-card {
        background: var(--chalk);
        border: 1px solid var(--hairline);
        border-radius: var(--radius-md);
        padding: var(--spacing-4);
        border-left: 3px solid var(--signal-dk);
    }

    .stat-value {
        font-size: 28px;
        font-weight: 600;
        color: var(--signal-dk);
        margin-bottom: var(--spacing-1);
        font-family: var(--f-mono);
    }

    .stat-label {
        font-size: 12px;
        color: var(--graphite);
        font-family: var(--f-mono);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .patient-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .patient-table thead {
        background: var(--signal-lt);
    }

    .patient-table th {
        padding: var(--spacing-3);
        text-align: left;
        font-weight: 600;
        font-size: 11px;
        color: var(--forest);
        border-bottom: 2px solid var(--signal-dk);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-family: var(--f-mono);
    }

    .patient-table td {
        padding: var(--spacing-3);
        border-bottom: 1px solid var(--hairline);
        vertical-align: middle;
    }

    .patient-table tbody tr {
        transition: background var(--transition-normal);
        cursor: pointer;
    }

    .patient-table tbody tr:hover {
        background: var(--signal-lt);
    }

    .patient-table tbody tr:last-child td {
        border-bottom: none;
    }

    .friendly-id {
        font-family: var(--f-mono);
        font-weight: 600;
        color: var(--signal-dk);
        background: var(--signal-lt);
        padding: 4px 8px;
        border-radius: var(--radius-sm);
        font-size: 11px;
        display: inline-block;
        border: 1px solid var(--signal);
    }

    .gender-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 8px;
        border-radius: var(--radius-sm);
        font-size: 11px;
        font-weight: 500;
    }

    .gender-badge.male {
        background: rgba(59, 130, 246, 0.1);
        color: #3b82f6;
    }

    .gender-badge.female {
        background: rgba(236, 72, 153, 0.1);
        color: #ec4899;
    }

    .gender-badge.other {
        background: rgba(139, 92, 246, 0.1);
        color: #8b5cf6;
    }

    .btn-icon-sm {
        width: 28px;
        height: 28px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--hairline);
        background: var(--chalk);
        color: var(--graphite);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all var(--transition-normal);
        text-decoration: none;
        margin-right: 4px;
        font-size: 12px;
    }

    .btn-icon-sm:hover {
        background: var(--signal-lt);
        border-color: var(--signal-dk);
        color: var(--signal-dk);
        transform: translateY(-1px);
    }

    .sortable-header {
        cursor: pointer;
        user-select: none;
        transition: color var(--transition-normal);
        display: flex;
        align-items: center;
        gap: 4px;
        text-decoration: none;
        color: inherit;
    }

    .sortable-header:hover {
        color: var(--signal-dk) !important;
    }

    .sort-icon {
        font-size: 10px;
        color: var(--hairline);
        transition: color var(--transition-normal);
    }

    .sortable-header:hover .sort-icon {
        color: var(--signal-dk);
    }

    .sort-icon.active {
        color: var(--signal-dk);
    }

    .pagination-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--spacing-4);
        border-top: 1px solid var(--hairline);
        background: var(--signal-lt);
    }

    .pagination-info {
        font-size: 12px;
        color: var(--graphite);
        font-family: var(--f-mono);
    }

    .pagination {
        display: flex;
        gap: 4px;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .pagination .page-item {
        margin: 0;
    }

    .pagination .page-link {
        padding: 6px 12px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--hairline);
        background: var(--chalk);
        color: var(--forest);
        text-decoration: none;
        font-size: 12px;
        font-weight: 500;
        transition: all var(--transition-normal);
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 32px;
    }

    .pagination .page-link:hover {
        background: var(--signal-lt);
        border-color: var(--signal-dk);
        color: var(--signal-dk);
    }

    .pagination .page-item.active .page-link {
        background: var(--signal-dk);
        color: var(--chalk);
        border-color: var(--signal-dk);
    }

    .pagination .page-item.disabled .page-link {
        background: var(--bone);
        color: var(--hairline);
        border-color: var(--hairline);
        cursor: not-allowed;
    }

    .patient-link {
        color: var(--forest);
        text-decoration: none;
        font-weight: 500;
    }

    .patient-link:hover {
        color: var(--signal-dk);
        text-decoration: underline;
    }

    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .pagination-bar {
            flex-direction: column;
            gap: var(--spacing-3);
            align-items: flex-start;
        }
    }
</style>

        <!-- Page Header -->
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-6);">
            <div>
                <h1 style="font-family: var(--f-sans); font-weight: 600; font-size: 28px; letter-spacing: -0.02em; color: var(--forest); margin: 0; display: flex; align-items: center; gap: var(--spacing-2);">
                    <i class="bi bi-person-circle" style="color: var(--signal-dk);"></i>
                    Patients
                </h1>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-page="Search" class="btn-sentinel-secondary">
                    <i class="bi bi-search"></i>
                    Advanced Search
                </a>
                <a asp-page="Create" class="btn-sentinel-primary">
                    <i class="bi bi-plus-circle"></i>
                    Add New Patient
                </a>
            </div>
        </div>

<!-- Quick Search -->
<div class="sentinel-card" style="margin-bottom: var(--spacing-5);">
    <div class="sentinel-card-header">
        <h2 class="sentinel-card-title">
            <i class="bi bi-funnel"></i>
            Quick Search & Filters
        </h2>
    </div>
    <div style="padding: var(--spacing-4);">
        <form method="get" class="row g-3">
            <div class="col-md-6">
                <div class="sentinel-form-group">
                    <label class="sentinel-label">Search</label>
                    <input type="text" class="sentinel-input" name="SearchTerm" value="@Model.SearchTerm" 
                           placeholder="Search by name, patient ID, or city..." />
                </div>
            </div>
            <div class="col-md-4">
                <div class="sentinel-form-group">
                    <label class="sentinel-label">Filter By</label>
                    <select class="sentinel-input" name="FilterBy">
                        <option value="" selected="@(string.IsNullOrEmpty(Model.FilterBy))">All Patients</option>
                        <option value="Recent" selected="@(Model.FilterBy == "Recent")">Recent (7 days)</option>
                        <option value="Today" selected="@(Model.FilterBy == "Today")">Today</option>
                        <option value="ThisMonth" selected="@(Model.FilterBy == "ThisMonth")">This Month</option>
                        <option value="Geocoded" selected="@(Model.FilterBy == "Geocoded")">Geocoded</option>
                        <option value="NotGeocoded" selected="@(Model.FilterBy == "NotGeocoded")">Not Geocoded</option>
                        <option value="Deceased" selected="@(Model.FilterBy == "Deceased")">Deceased</option>
                    </select>
                </div>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <div class="sentinel-form-group" style="width: 100%;">
                    <button type="submit" class="btn-sentinel-primary w-100">
                        <i class="bi bi-search"></i> Apply
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Stats Bar -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-value">@Model.TotalCount</div>
        <div class="stat-label">Total Patients</div>
    </div>
    <div class="stat-card">
        <div class="stat-value">@Model.Patients.Count(p => p.Gender?.Name == "Male")</div>
        <div class="stat-label">Male (Page)</div>
    </div>
    <div class="stat-card">
        <div class="stat-value">@Model.Patients.Count(p => p.Gender?.Name == "Female")</div>
        <div class="stat-label">Female (Page)</div>
    </div>
    <div class="stat-card">
        <div class="stat-value">@Model.Patients.Count(p => p.IsDeceased)</div>
        <div class="stat-label">Deceased (Page)</div>
    </div>
</div>

@if (Model.TotalCount == 0)
{
    <div class="sentinel-card" style="text-align: center; padding: var(--spacing-10);">
        <i class="bi bi-person-circle" style="font-size: 48px; color: var(--signal); opacity: 0.3;"></i>
        <h3 style="margin-top: var(--spacing-4); font-weight: 600; color: var(--forest);">No Patients Yet</h3>
        <p style="color: var(--graphite); margin-bottom: var(--spacing-5);">Add your first patient to the surveillance system.</p>
        <a asp-page="Create" class="btn-sentinel-primary">
            <i class="bi bi-plus-circle"></i>
            Add First Patient
        </a>
    </div>
}
else
{
    <div class="sentinel-card">
        <div class="sentinel-card-header">
            <h2 class="sentinel-card-title">
                <i class="bi bi-list-ul"></i>
                All Patients (@Model.TotalCount total, showing @Model.Patients.Count())
            </h2>
        </div>
        <div class="table-responsive">
            <table class="patient-table">
                <thead>
                    <tr>
                        <th style="width: 90px;">
                            <a href="@Model.GetSortUrl("FriendlyId")" class="sortable-header">
                                Patient ID
                                <i class="bi @Model.GetSortIcon("FriendlyId") sort-icon @(Model.SortBy == "FriendlyId" ? "active" : "")"></i>
                            </a>
                        </th>
                        <th>
                            <a href="@Model.GetSortUrl("Name")" class="sortable-header">
                                Name
                                <i class="bi @Model.GetSortIcon("Name") sort-icon @(Model.SortBy == "Name" ? "active" : "")"></i>
                            </a>
                        </th>
                        <th style="width: 100px;">
                            <a href="@Model.GetSortUrl("DateOfBirth")" class="sortable-header">
                                DOB
                                <i class="bi @Model.GetSortIcon("DateOfBirth") sort-icon @(Model.SortBy == "DateOfBirth" ? "active" : "")"></i>
                            </a>
                        </th>
                        <th style="width: 50px;">Age</th>
                        <th style="width: 70px;">
                            <a href="@Model.GetSortUrl("Gender")" class="sortable-header">
                                Gender
                                <i class="bi @Model.GetSortIcon("Gender") sort-icon @(Model.SortBy == "Gender" ? "active" : "")"></i>
                            </a>
                        </th>
                        <th style="width: 120px;">Suburb</th>
                        <th style="width: 110px;">Phone</th>
                        <th style="width: 150px;">Email</th>
                        <th style="text-align: center; width: 70px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var patient in Model.Patients)
                    {
                        var age = patient.DateOfBirth.HasValue ? 
                            (DateTime.Today.Year - patient.DateOfBirth.Value.Year - 
                            (DateTime.Today < patient.DateOfBirth.Value.AddYears(DateTime.Today.Year - patient.DateOfBirth.Value.Year) ? 1 : 0)) 
                            : (int?)null;

                        <tr onclick="window.location.href='@Url.Page("./Details", new { id = patient.Id })'">
                            <td>
                                <span class="friendly-id">@patient.FriendlyId</span>
                            </td>
                            <td>
                                <a asp-page="./Details" asp-route-id="@patient.Id" class="patient-link" onclick="event.stopPropagation()">
                                    @patient.FamilyName, @patient.GivenName
                                </a>
                            </td>
                            <td>@(patient.DateOfBirth?.ToString("dd MMM yyyy") ?? "—")</td>
                            <td>@(age?.ToString() ?? "—")</td>
                            <td>
                                @if (patient.Gender != null)
                                {
                                    var genderClass = patient.Gender.Name.ToLower();
                                    <span class="gender-badge @genderClass">
                                        @if (patient.Gender.Name == "Male")
                                        {
                                            <i class="bi bi-gender-male"></i>
                                        }
                                        else if (patient.Gender.Name == "Female")
                                        {
                                            <i class="bi bi-gender-female"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-gender-ambiguous"></i>
                                        }
                                        @patient.Gender.Name
                                    </span>
                                }
                                else
                                {
                                    <span style="color: var(--graphite); font-style: italic;">—</span>
                                }
                            </td>
                            <td>@(patient.City ?? "—")</td>
                            <td>@(patient.MobilePhone ?? patient.HomePhone ?? "—")</td>
                            <td style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 150px;" title="@patient.EmailAddress">
                                @(patient.EmailAddress ?? "—")
                            </td>
                            <td style="text-align: center;" onclick="event.stopPropagation()">
                                <a asp-page="./Details" asp-route-id="@patient.Id" class="btn-icon-sm" title="View Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-page="./Edit" asp-route-id="@patient.Id" class="btn-icon-sm" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="pagination-bar">
                <div class="pagination-info">
                    Showing @((Model.CurrentPage - 1) * Model.PageSize + 1) - @(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount)) of @Model.TotalCount patients
                </div>
                <ul class="pagination">
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="?CurrentPage=1&SortBy=@Model.SortBy&SortOrder=@Model.SortOrder">
                            <i class="bi bi-chevron-double-left"></i>
                        </a>
                    </li>
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="?CurrentPage=@(Model.CurrentPage - 1)&SortBy=@Model.SortBy&SortOrder=@Model.SortOrder">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="?CurrentPage=@i&SortBy=@Model.SortBy&SortOrder=@Model.SortOrder">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="?CurrentPage=@(Model.CurrentPage + 1)&SortBy=@Model.SortBy&SortOrder=@Model.SortOrder">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="?CurrentPage=@Model.TotalPages&SortBy=@Model.SortBy&SortOrder=@Model.SortOrder">
                            <i class="bi bi-chevron-double-right"></i>
                        </a>
                    </li>
                </ul>
            </div>
        }
    </div>
}
