<script nonce="@GetCspNonce()">
// Use centralized geocoding service for place search
$(document).ready(function() {
    var placeInput = document.getElementById('placeSearchInput');
    var placeDropdown = document.getElementById('placeDropdown');

    if (!placeInput || !placeDropdown) {
        return;
    }

    // Check if SentinelGeocoding is defined
    if (typeof SentinelGeocoding === 'undefined') {
        console.error('SentinelGeocoding is not defined. Make sure geocoding.js is loaded.');
        placeInput.placeholder = 'Address search unavailable - geocoding not initialized';
        placeInput.disabled = true;
        return;
    }

    // Only initialize if Google provider is configured
    if (!SentinelGeocoding.shouldUseGoogleMaps()) {
        console.log('Place search disabled - using', SentinelGeocoding.getConfig()?.provider || 'nominatim');
        placeInput.placeholder = 'Place search requires Google Maps (currently using ' + (SentinelGeocoding.getConfig()?.provider || 'Nominatim') + ')';
        placeInput.disabled = true;
        return;
    }
        
    SentinelGeocoding.loadGoogleMaps(function() {
        var service = new google.maps.places.AutocompleteService();
        var detailsService = new google.maps.places.PlacesService(document.createElement('div'));
        var sessionToken = new google.maps.places.AutocompleteSessionToken();
        var items = [];
        var focused = -1;
        var config = SentinelGeocoding.getConfig();
            
        function debounce(fn, ms) { var t; return function () { var args = arguments; clearTimeout(t); t = setTimeout(function () { fn.apply(null, args); }, ms); }; }

        function clearDropdown() {
            placeDropdown.innerHTML = '';
            placeDropdown.classList.remove('show');
            placeInput.setAttribute('aria-expanded', 'false');
            items = [];
            focused = -1;
        }

        function buildItem(pred, idx) {
            var btn = document.createElement('button');
            btn.type = 'button';
                btn.className = 'dropdown-item'
                btn.setAttribute('role', 'option')
                btn.dataset.index = String(idx)
                var icon = document.createElement('i')
                icon.className = 'bi bi-geo-alt-fill me-2 text-primary'
                var text = document.createElement('span')
                text.innerText = pred.description || ''
                btn.appendChild(icon)
                btn.appendChild(text)
                btn.addEventListener('click', function () { selectItem(idx); })
                return btn
            }

            function renderResults(preds) {
                placeDropdown.innerHTML = ''
                if (!preds || preds.length === 0) { clearDropdown(); return; }
                preds.forEach(function (p, i) { placeDropdown.appendChild(buildItem(p, i)); })
                placeDropdown.classList.add('show')
                placeInput.setAttribute('aria-expanded', 'true')
                items = Array.from(placeDropdown.querySelectorAll('[role="option"]'))
                focused = -1
                window.__lastPlaceResults = preds
            }

            function focusItem(i) {
                if (focused >= 0 && items[focused]) items[focused].classList.remove('active')
                focused = i
                if (focused >= 0 && items[focused]) { items[focused].classList.add('active'); items[focused].scrollIntoView({ block: 'nearest' }); }
            }

            function selectItem(i) {
                var sel = items[i];
                if (!sel) return;
                var idx = Number(sel.dataset.index);
                var pred = window.__lastPlaceResults && window.__lastPlaceResults[idx];
                if (!pred) {
                    console.error('No prediction found for index:', idx);
                    return;
                }
                
                console.log('Fetching place details for:', pred.description, 'PlaceID:', pred.place_id);
                
                try {
                    detailsService.getDetails({ 
                        placeId: pred.place_id, 
                        fields: ['name', 'formatted_address', 'address_components', 'geometry'], 
                        sessionToken: sessionToken 
                    }, function (result, status) {
                        console.log('Place details response:', status, result);
                        
                        if (status !== google.maps.places.PlacesServiceStatus.OK || !result) {
                            console.error('Place details error:', status);
                            
                            // Fallback: At least fill the address field with the prediction description
                            var addressInput = document.getElementById('addressInput');
                            if (addressInput && pred.description) {
                                addressInput.value = pred.description;
                                showWarningMessage('Address filled from search, but coordinates unavailable. Please verify address details.');
                            } else {
                                alert('Unable to get place details. Status: ' + status + '\n\nPlease check:\n1. Places API is enabled in Google Cloud Console\n2. Billing is set up\n3. API key has Places API permissions');
                            }
                            clearDropdown();
                            return;
                        }
                        var comps = {};
                        (result.address_components || []).forEach(function (c) {
                            (c.types || []).forEach(function (t) {
                                if (!comps[t]) comps[t] = c.long_name;
                            });
                        });
                        var street = [comps['street_number'], comps['route']].filter(Boolean).join(' ');
                        var city = comps['locality'] || comps['postal_town'] || comps['sublocality'] || comps['administrative_area_level_2'] || '';
                        var state = comps['administrative_area_level_1'] || '';
                        var postal = comps['postal_code'] || '';
                        // Fill all address fields
                        var addressInput = document.getElementById('addressInput');
                        if (addressInput) addressInput.value = street || result.formatted_address || pred.description || '';
                        var cityEl = document.getElementById('Patient_City');
                        var stateEl = document.getElementById('Patient_State');
                        var postalEl = document.getElementById('Patient_PostalCode');
                        if (cityEl) cityEl.value = city;
                        if (stateEl) stateEl.value = state;
                        if (postalEl) postalEl.value = postal;
                        // Fill coordinates
                        var latEl = document.getElementById('Patient_Latitude');
                        var lonEl = document.getElementById('Patient_Longitude');
                        if (latEl && lonEl && result.geometry && result.geometry.location) {
                            latEl.value = result.geometry.location.lat();
                            lonEl.value = result.geometry.location.lng();
                            // Auto-detect jurisdictions
                            detectJurisdictions(latEl.value, lonEl.value);
                        }

                        clearDropdown();
                        placeInput.value = ''; // Clear search after selection
                            
                        // Show success message
                        showSuccessMessage(result.name || 'Address');
                        sessionToken = new google.maps.places.AutocompleteSessionToken();
                    });
                } catch (error) {
                    console.error('Error calling getDetails:', error);
                    alert('Error fetching place details: ' + error.message);
                    clearDropdown();
                }
            }

            function detectJurisdictions(lat, lon) {
                fetch('/Patients/Create?handler=DetectJurisdictions', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({ latitude: parseFloat(lat), longitude: parseFloat(lon) })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success && data.jurisdictions && data.jurisdictions.length > 0) {
                        // Auto-populate jurisdiction fields (both hidden ID and visible text input)
                        data.jurisdictions.forEach(function(j) {
                            var searchFieldId = 'jurisdictionSearch' + j.fieldNumber;
                            var hiddenFieldId = 'Jurisdiction' + j.fieldNumber + 'Id';
                            var searchEl = document.getElementById(searchFieldId);
                            var hiddenEl = document.getElementById(hiddenFieldId);
                            if (searchEl && hiddenEl) {
                                searchEl.value = j.jurisdictionName;
                                hiddenEl.value = j.jurisdictionId;
                                searchEl.style.backgroundColor = '#d4edda'; // Light green highlight
                                setTimeout(function() { searchEl.style.backgroundColor = ''; }, 2000);
                            }
                        });
                        // Show success message
                        var successMsg = document.createElement('div');
                        successMsg.className = 'alert alert-success alert-dismissible fade show mt-2';
                        successMsg.innerHTML = '<i class="bi bi-check-circle me-2"></i>Auto-detected ' + data.jurisdictions.length + ' jurisdiction(s) from address';
                        document.querySelector('.card-header:has(i.bi-pin-map)')?.parentElement.querySelector('.card-body').prepend(successMsg);
                        setTimeout(function() { successMsg.remove(); }, 5000);
                    }
                })
                .catch(error => {
                    console.error('Error detecting jurisdictions:', error);
                });
            }

            function showSuccessMessage(placeName) {
                if (document.getElementById('placeSuccess')) {
                    document.getElementById('placeSuccess').remove();
                }
                var successDiv = document.createElement('div');
                successDiv.id = 'placeSuccess';
                successDiv.className = 'alert alert-success alert-dismissible fade show mt-2';
                successDiv.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i><strong>Selected:</strong> ' + placeName + ' - All address fields filled!';
                placeInput.parentElement.appendChild(successDiv);
                setTimeout(function() {
                    successDiv.style.opacity = '0';
                    successDiv.style.transition = 'opacity 0.5s';
                    setTimeout(function() { if (successDiv.parentElement) successDiv.remove(); }, 500);
                }, 3000);
            }
            
            function showWarningMessage(message) {
                if (document.getElementById('placeWarning')) {
                    document.getElementById('placeWarning').remove();
                }
                var warningDiv = document.createElement('div');
                warningDiv.id = 'placeWarning';
                warningDiv.className = 'alert alert-warning alert-dismissible fade show mt-2';
                warningDiv.innerHTML = '<i class="bi bi-exclamation-triangle-fill me-2"></i>' + message;
                placeInput.parentElement.appendChild(warningDiv);
                setTimeout(function() {
                    warningDiv.style.opacity = '0';
                    warningDiv.style.transition = 'opacity 0.5s';
                    setTimeout(function() { if (warningDiv.parentElement) warningDiv.remove(); }, 500);
                }, 5000);
            }

            function fetchSuggestions(q) {
                if (!q) { clearDropdown(); return; }
                    
                var request = { 
                    input: q, 
                    sessionToken: sessionToken 
                }
                // Add country bias for localization
                if (config.defaultCountry) {
                    request.componentRestrictions = { country: config.defaultCountry };
                }
                    
                service.getPlacePredictions(request, function (predictions, status) {
                    if (status !== google.maps.places.PlacesServiceStatus.OK || !predictions) {
                        clearDropdown();
                        return;
                    }
                    renderResults(predictions.slice(0, 8));
                });
            }

            placeInput.addEventListener('input', debounce(function (e) { fetchSuggestions(e.target.value); }, 300));
            placeInput.addEventListener('keydown', function (e) {
                if (!placeDropdown.classList.contains('show')) return;
                if (e.key === 'ArrowDown') { e.preventDefault(); focusItem(Math.min(items.length - 1, focused + 1)); }
                else if (e.key === 'ArrowUp') { e.preventDefault(); focusItem(Math.max(0, focused - 1)); }
                else if (e.key === 'Enter') { e.preventDefault(); if (focused >= 0) selectItem(focused); }
                else if (e.key === 'Escape') { clearDropdown(); }
            });
            document.addEventListener('click', function (ev) { 
                if (!ev.target) return; 
                if (ev.target === placeInput || placeDropdown.contains(ev.target)) return; 
                clearDropdown(); 
            });
            placeInput.addEventListener('blur', function () { 
                setTimeout(function () { 
                    if (document.activeElement && !placeDropdown.contains(document.activeElement)) clearDropdown(); 
                }, 150); 
            });
            
            console.log('Place search initialized with Google Maps');
        });
    });
</script>

<script nonce="@GetCspNonce()">
    // Occupation autocomplete
    $(document).ready(function () {
        if (typeof $.fn.autocomplete === 'undefined') {
            return;
        }

        var $searchInput = $('#occupationSearch')
        var $hiddenInput = $('#occupationId')
        // Load existing occupation name if editing
        @if (Model.Patient?.OccupationId != null)
        {
            <text>
            var existingOccupationId = @Model.Patient.OccupationId
            var existingOccupationName = '@(Model.Patient.Occupation?.Name ?? "")'
            if (existingOccupationName) {
                $searchInput.val(existingOccupationName)
            }
            </text>
        }

        $searchInput.autocomplete({
            source: function (request, response) {                $.ajax({
                    url: '/Api/OccupationSearch',
                    method: 'GET',
                    data: { term: request.term },
                    dataType: 'json',
                    success: function (data) {                        if (!data || data.length === 0) {                        }
                        response($.map(data, function (item) {
                            return {
                                label: item.label + ' (' + item.code + ')',
                                value: item.label,
                                id: item.id,
                                code: item.code,
                                majorGroup: item.majorGroup
                            }
                        }))
                    },
                    error: function (xhr, status, error) {                        response([])
                    }
                })
            },
            minLength: 2,
            select: function (event, ui) {
                $hiddenInput.val(ui.item.id)
                $searchInput.val(ui.item.value)
                return false
            },
            focus: function (event, ui) {
                $searchInput.val(ui.item.value)
                return false
            }
        }).autocomplete("instance")._renderItem = function (ul, item) {
            return $("<li>")
                .append("<div><strong>" + item.value + "</strong><br/><small class='text-muted'>" + item.code + (item.majorGroup ? " - " + item.majorGroup : "") + "</small></div>")
                .appendTo(ul)
        }
        // Clear hidden field when search input is cleared
            $searchInput.on('input', function () {
                if ($(this).val() === '') {
                    $hiddenInput.val('')
                }
            });        // Jurisdiction autocomplete initialization
        $('.jurisdiction-autocomplete').each(function() {
            var $searchInput = $(this)
            var fieldNumber = $searchInput.data('field-number')
            var jurisdictionTypeId = $searchInput.data('jurisdiction-type-id')
            var $hiddenInput = $('#Jurisdiction' + fieldNumber + 'Id');            $searchInput.autocomplete({
                source: function(request, response) {
                    $.ajax({
                        url: '/api/jurisdictions/search',
                        type: 'GET',
                        dataType: 'json',
                        data: {
                            term: request.term,
                            typeId: jurisdictionTypeId
                        },
                        success: function(data) {                            response($.map(data, function(item) {
                                return {
                                    label: item.name + (item.code ? ' (' + item.code + ')' : ''),
                                    value: item.name,
                                    id: item.id
                                }
                            }))
                        },
                        error: function(xhr, status, error) {                            response([])
                        }
                    })
                },
                minLength: 2,
                select: function(event, ui) {
                    $hiddenInput.val(ui.item.id)
                    $searchInput.val(ui.item.value);                    return false
                },
                focus: function(event, ui) {
                    $searchInput.val(ui.item.value)
                    return false
                }
            }).autocomplete("instance")._renderItem = function(ul, item) {
                return $("<li>")
                    .append("<div>" + item.label + "</div>")
                    .appendTo(ul)
            }
            // Clear hidden field when search input is cleared
            $searchInput.on('input', function() {
                if ($(this).val() === '') {
                    $hiddenInput.val('')
                }
            })
        });            // Deceased field toggle
            $('#isDeceasedSelect').on('change', function() {
                var isDeceased = $(this).val() === 'true'
                if (isDeceased) {
                    $('#dateOfDeathField').slideDown()
                } else {
                    $('#dateOfDeathField').slideUp()
                    $('#dateOfDeath').val('')
                }
            })
            // Initialize deceased field display on page load
            if ($('#isDeceasedSelect').val() === 'true') {
                $('#dateOfDeathField').show()
            }

            // Date of death validation
            $('#dateOfDeath').on('change', function() {
                var dateOfBirth = $('#Patient_DateOfBirth').val()
                var dateOfDeath = $(this).val()
                if (dateOfBirth && dateOfDeath && dateOfDeath < dateOfBirth) {
                    alert('Date of death cannot be before date of birth.')
                    $(this).val('')
                }
            })
        })
    </script>
    
    <style nonce="@GetCspNonce()">
        /* jQuery UI Autocomplete styling fix */
        .ui-autocomplete {
            position: absolute
            top: 100%
            left: 0
            z-index: 1000
            display: none
            float: left
            min-width: 160px
            padding: 5px 0
            margin: 2px 0 0
            list-style: none
            font-size: 14px
            background-color: #ffffff
            border: 1px solid #cccccc
            border-radius: 4px
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.175)
            background-clip: padding-box
            max-height: 300px
            overflow-y: auto
        }

        .ui-autocomplete .ui-menu-item {
            padding: 0
            margin: 0
        }

        .ui-autocomplete .ui-menu-item > div {
            padding: 10px 15px
            cursor: pointer
            line-height: 1.42857143
            color: #333333
            border: none
        }

        .ui-autocomplete .ui-menu-item > div:hover,
        .ui-autocomplete .ui-state-focus {
            background-color: #f5f5f5
            color: #262626
        }

        .ui-autocomplete .ui-menu-item > div strong {
            font-weight: 600
            color: #0d6efd
        }

        .ui-autocomplete .ui-menu-item .text-muted {
            color: #6c757d
            font-size: 0.875rem
        }

        .ui-helper-hidden-accessible {
            position: absolute
            clip: rect(1px 1px 1px 1px)
            clip: rect(1px, 1px, 1px, 1px)
        }
    </style>

    @if (Model.Mode == "popup" && Model.ReturnContext == "exposure")
    {
        <script nonce="@GetCspNonce()">
            // Patient Search for Popup Mode            $(document).ready(function() {                var searchTimeout
                var $searchInput = $('#patientSearchInput')
                var $searchResults = $('#patientSearchResults')
                var $searchEmpty = $('#patientSearchEmpty')
                var $resultsList = $('#patientResultsList');                $searchInput.on('input', function() {
                    .val())
                    clearTimeout(searchTimeout)
                    var term = $(this).val().trim()
                    if (term.length < 2) {
                        $searchResults.hide()
                        $searchEmpty.hide()
                        return
                    }

                    searchTimeout = setTimeout(function() {
                        searchPatients(term)
                    }, 300)
                })
                function searchPatients(term) {                    $.ajax({
                        url: '/api/patients/search',
                        method: 'GET',
                        data: { query: term }, // Controller uses 'query' parameter
                        success: function(data) {                            if (data && data.length > 0) {
                                displayPatients(data)
                                $searchResults.show()
                                $searchEmpty.hide()
                            } else {
                                $searchResults.hide()
                                $searchEmpty.show()
                            }
                        },
                        error: function(xhr, status, error) {                            $searchResults.hide()
                            $searchEmpty.hide()
                        }
                    })
                }

                function displayPatients(patients) {
                    $resultsList.empty()
                    patients.forEach(function(patient) {
                        // Controller returns different format
                        var dob = patient.dateOfBirth ? new Date(patient.dateOfBirth).toLocaleDateString() : 'Unknown'
                        var age = calculateAge(patient.dateOfBirth)
                        var $item = $('<div>')
                            .css({
                                padding: '12px',
                                marginBottom: '8px',
                                background: 'rgba(0, 122, 255, 0.05)',
                                borderRadius: '6px',
                                border: '1px solid var(--color-divider)',
                                cursor: 'pointer',
                                transition: 'all 0.2s'
                            })
                            .hover(
                                function() { $(this).css('background', 'rgba(0, 122, 255, 0.1)'); },
                                function() { $(this).css('background', 'rgba(0, 122, 255, 0.05)'); }
                            )
                            .html(`
                                <div style="display: flex; justify-content: space-between; align-items: start;">
                                    <div>
                                        <strong style="font-size: 15px;">${patient.name}</strong>
                                        <br/>
                                        <small style="color: var(--color-secondary);">
                                            ID: ${patient.friendlyId} | DOB: ${dob}${age ? ' (' + age + ')' : ''}
                                        </small>
                                    </div>
                                    <button type="button" class="btn-apple btn-apple-primary" style="font-size: 13px;">
                                        <i class="bi bi-link-45deg me-1"></i>Use This Patient
                                    </button>
                                </div>
                            `)
                            .on('click', function() {
                                linkExistingPatient(patient.id, patient.name.split(' ')[0], patient.name.split(' ').slice(1).join(' '))
                            })
                        $resultsList.append($item)
                    })
                }

                function calculateAge(dateOfBirth) {
                    if (!dateOfBirth) return ''
                    var today = new Date()
                    var birthDate = new Date(dateOfBirth)
                    var age = today.getFullYear() - birthDate.getFullYear()
                    var m = today.getMonth() - birthDate.getMonth()
                    if (m < 0 || (m === 0 && today.getDate() < birthDate.getDate())) {
                        age--
                    }
                    return age + ' years'
                }

                function linkExistingPatient(patientId, givenName, familyName) {
                    if (!confirm(`Link existing patient: ${givenName} ${familyName}?`)) {
                        return
                    }                    // Post to the handler
                    $.ajax({
                        url: '?handler=LinkExistingPatient',
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                        },
                        data: { 
                            patientId: patientId,
                            diseaseId: '@Model.DiseaseId'
                        },
                        success: function(response) {                            // The response is HTML with script to close window and notify parent
                            var tempDiv = document.createElement('div')
                            tempDiv.innerHTML = response
                            var scripts = tempDiv.getElementsByTagName('script')
                            for (var i = 0; i < scripts.length; i++) {
                                eval(scripts[i].innerHTML)
                            }
                        },
                        error: function(xhr, status, error) {                            alert('Error linking patient: ' + xhr.responseText)
                        }
                    })
                }
            })
        </script>
    }
}

@functions {
    public string GetCspNonce()
    {
        if (HttpContext?.Items?.TryGetValue("csp-nonce", out var nonce) == true && nonce is string nonceStr)
        {
            return nonceStr;
        }
        return string.Empty;
    }
}
